    (Map.values maps.stock_plan_pool_adjustments)

stockPlanPoolAdjustmentHistoryIndex : CapTableMaps -> Update (Map Text [StockPlanPoolAdjustmentOcfData])
stockPlanPoolAdjustmentHistoryIndex maps =
