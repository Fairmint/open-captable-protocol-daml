validateSourceSecurityBalances : CapTableMaps -> Update ()
validateSourceSecurityBalances maps = do
  stockReductions <- stockReductionEventsBySecurityId maps
  warrantReductions <- warrantReductionEventsBySecurityId maps
  equityCompensationReductions <- equityCompensationReductionEventsBySecurityId maps
  splitEvents <- splitEventsByStockClassId maps
  validateReductionSecurityReferences "Stock" maps.stock_issuances_by_security_id stockReductions
  validateReductionSecurityReferences "Warrant" maps.warrant_issuances_by_security_id warrantReductions
  validateReductionSecurityReferences "Equity compensation" maps.equity_compensation_issuances_by_security_id equityCompensationReductions
  mapA_
    (\issuanceCid -> do
      issuance <- fetch issuanceCid
      let reductions = fromOptional [] (Map.lookup issuance.issuance_data.security_id stockReductions)
          splits = filter
            (splitUnambiguouslyFollowsIssuance issuance.issuance_data.date)
            (fromOptional [] (Map.lookup issuance.issuance_data.stock_class_id splitEvents))
      validateSourceSecurityBalance issuance.issuance_data.security_id issuance.issuance_data.quantity (reductions ++ splits))
    (Map.values maps.stock_issuances)
  mapA_
    (\issuanceCid -> do
      issuance <- fetch issuanceCid
      case issuance.issuance_data.quantity of
        Some quantity ->
          validateSourceSecurityBalance
            issuance.issuance_data.security_id
            quantity
            (fromOptional [] (Map.lookup issuance.issuance_data.security_id warrantReductions))
        None -> pure ())
    (Map.values maps.warrant_issuances)
  mapA_
    (\issuanceCid -> do
      issuance <- fetch issuanceCid
      let reductions = fromOptional [] (Map.lookup issuance.issuance_data.security_id equityCompensationReductions)
          splits = case issuance.issuance_data.stock_class_id of
            Some stockClassId -> filter
              (splitUnambiguouslyFollowsIssuance issuance.issuance_data.date)
              (fromOptional [] (Map.lookup stockClassId splitEvents))
            None -> []
      validateSourceSecurityBalance issuance.issuance_data.security_id issuance.issuance_data.quantity (reductions ++ splits))
    (Map.values maps.equity_compensation_issuances)

