convertibleConversionOutputQuantity :
  CapTableMaps ->
  ConvertibleIssuanceOcfData ->
  ConvertibleConversionOcfData ->
  OcfConvertibleConversionRight ->
  Update (Optional Decimal)
convertibleConversionOutputQuantity maps issuanceData conversionData conversionRight = do
  case (conversionData.balance_security_id, conversionData.quantity_converted) of
    (Some _, None) ->
      assertMsg
        ("Partial convertible conversion requires quantity_converted: " <> conversionData.id)
        False
    _ -> pure ()
  case conversionData.quantity_converted of
    Some outputQuantity -> do
      assertMsg
        ("Convertible conversion output quantity must be positive for " <> conversionData.id)
        (outputQuantity > 0.0)
      case conversionRight.conversion_mechanism of
        OcfConvMechFixedAmount fixedAmount -> do
          expectedOutputQuantity <- case conversionData.balance_security_id of
            Some balanceSecurityId -> case Map.lookup balanceSecurityId maps.convertible_issuances_by_security_id of
              Some balanceIssuanceCid -> do
                balanceIssuance <- fetch balanceIssuanceCid
                let sourceAmount = issuanceData.investment_amount.amount
                    balanceAmount = balanceIssuance.issuance_data.investment_amount.amount
                assertMsg
                  ("Partial fixed convertible conversion requires a positive source principal for " <> conversionData.id)
                  (sourceAmount > 0.0)
                assertMsg
                  ("Partial fixed convertible conversion balance must be positive and below the source principal for " <> conversionData.id)
                  (balanceAmount > 0.0 && balanceAmount < sourceAmount)
                pure (fixedAmount.converts_to_quantity * (sourceAmount - balanceAmount) / sourceAmount)
              None -> do
                assertMsg ("Convertible conversion balance security not found: " <> balanceSecurityId) False
                pure fixedAmount.converts_to_quantity
            None -> pure fixedAmount.converts_to_quantity
          assertMsg
            ("Fixed convertible conversion output quantity mismatch for " <> conversionData.id <> ": expected " <> show expectedOutputQuantity <> ", found " <> show outputQuantity)
            (outputQuantity == expectedOutputQuantity)
        _ -> pure ()
      pure (Some outputQuantity)
    None -> case conversionRight.conversion_mechanism of
      OcfConvMechFixedAmount fixedAmount ->
        pure (Some fixedAmount.converts_to_quantity)
      _ -> pure None

convertibleConversionExpectedResult :
  CapTableMaps ->
  ConvertibleIssuanceOcfData ->
  ConvertibleConversionOcfData ->
  Update (Optional Text, Optional Decimal)
convertibleConversionExpectedResult maps issuanceData conversionData =
  case convertibleConversionTrigger issuanceData conversionData.trigger_id of
    Some trigger -> do
      quantityOpt <- convertibleConversionOutputQuantity maps issuanceData conversionData trigger.conversion_right
      pure (trigger.conversion_right.converts_to_stock_class_id, quantityOpt)
    None -> do
      assertMsg
        ("Convertible conversion trigger not found: " <> conversionData.trigger_id)
        False
      pure (None, None)

