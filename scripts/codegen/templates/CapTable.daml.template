  foldl
    (\latest candidate ->
      if candidate.date <= asOf
        then case latest of
          Some current ->
            if stockClassAuthorizedAdjustmentTakesPrecedence candidate current
              then Some candidate
              else latest
          None -> Some candidate
        else latest)
    None
