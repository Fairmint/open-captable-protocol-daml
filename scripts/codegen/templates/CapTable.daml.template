-- | A Financing issuance ID must identify exactly one supported issuance family.
-- Counting matches rejects both missing IDs and ambiguous cross-family collisions.
financingIssuanceMatchCount : CapTableMaps -> Text -> Int
financingIssuanceMatchCount maps issuanceId =
  (if isSome (Map.lookup issuanceId maps.convertible_issuances) then 1 else 0)
    + (if isSome (Map.lookup issuanceId maps.equity_compensation_issuances) then 1 else 0)
    + (if isSome (Map.lookup issuanceId maps.stock_issuances) then 1 else 0)
    + (if isSome (Map.lookup issuanceId maps.warrant_issuances) then 1 else 0)

validateFinancingIssuanceReferences : CapTableMaps -> Update ()
validateFinancingIssuanceReferences maps =
  mapA_
    (\financingCid -> do
      financing <- fetch financingCid
      mapA_
        (\issuanceId -> do
          let matchCount = financingIssuanceMatchCount maps issuanceId
          assertMsg
            ("Financing " <> financing.financing_data.id <> " issuance reference must match exactly one issuance object: " <> issuanceId <> " (matches " <> show matchCount <> ")")
            (matchCount == 1))
        financing.financing_data.issuance_ids)
    (Map.values (fromOptional Map.empty maps.financings))

securityBalanceEventSortKey : SecurityBalanceEvent -> (Date, Int, Text)
securityBalanceEventSortKey event = case event of
  -- OCF event dates are day-precision; for equal days, apply multipliers before reductions.
  SecurityBalanceMultiplier with event_date; event_id -> (ocfDate event_date, 0, event_id)
  SecurityBalanceReduction with event_date; event_id -> (ocfDate event_date, 1, event_id)

securityBalanceEventDate : SecurityBalanceEvent -> Time
securityBalanceEventDate event = case event of
  SecurityBalanceReduction with event_date -> event_date
  SecurityBalanceMultiplier with event_date -> event_date

-- OCF dates have day precision and provide no intra-day ordering. Only apply
-- splits that unambiguously occurred after an issuance; treating a same-day
-- split as earlier can double-scale a post-split issuance. Same-day splits are
-- treated as ambiguous and excluded.
splitUnambiguouslyFollowsIssuance : Time -> SecurityBalanceEvent -> Bool
splitUnambiguouslyFollowsIssuance issuanceDate event =
  ocfDate (securityBalanceEventDate event) > ocfDate issuanceDate

addSecurityBalanceEvent : Text -> SecurityBalanceEvent -> Map Text [SecurityBalanceEvent] -> Map Text [SecurityBalanceEvent]
addSecurityBalanceEvent key event index =
  Map.insert key (event :: fromOptional [] (Map.lookup key index)) index

applySecurityBalanceEvent : Text -> Decimal -> SecurityBalanceEvent -> Update Decimal
applySecurityBalanceEvent securityId current event = case event of
  SecurityBalanceReduction with event_id; quantity -> do
    assertMsg
      ("Security reduction quantity must be non-negative for " <> securityId <> " at " <> event_id)
      (quantity >= 0.0)
    let next = current - quantity
    assertMsg
      ("Security balance cannot be negative for " <> securityId <> " at " <> event_id <>
        ": reducing " <> show quantity <> " from " <> show current <> " leaves " <> show next)
      (next >= 0.0)
    pure next
  SecurityBalanceMultiplier with event_id; numerator; denominator -> do
    assertMsg
      ("Security balance multiplier must be positive for " <> securityId <> " at " <> event_id)
      (numerator > 0.0 && denominator > 0.0)
    pure (current * numerator / denominator)

