stockPlanPoolAdjustmentTakesPrecedence :
  StockPlanPoolAdjustmentOcfData ->
  StockPlanPoolAdjustmentOcfData ->
  Bool
stockPlanPoolAdjustmentTakesPrecedence candidate current =
