            Some current ->
              if stockPlanPoolAdjustmentTakesPrecedence adjustment.adjustment_data current
                then Map.insert stockPlanId adjustment.adjustment_data index
                else index
            None -> Map.insert stockPlanId adjustment.adjustment_data index
      pure nextIndex)
