        else pure events)
    []
    (Map.values maps.stock_cancellations)

  repurchaseEvents <- foldlA
    (\events repurchaseCid -> do
      repurchase <- fetch repurchaseCid
      if repurchase.repurchase_data.security_id == issuanceData.security_id
