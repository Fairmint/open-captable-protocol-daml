          (stockClassShareEventOnOrAfter issuanceData.date)
          (fromOptional [] (Map.lookup issuanceData.stock_class_id eventIndex.stock_class_split_events_by_stock_class_id))
  in (StockClassShareDelta with
      event_date = issuanceData.date
      event_priority = 0
      quantity_delta = issuanceData.quantity)
