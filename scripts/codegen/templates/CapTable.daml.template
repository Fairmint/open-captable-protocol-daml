convertibleConversionOutputShareLot maps stockClassIndex issuanceData conversionData = do
  (stockClassIdOpt, quantityOpt) <- convertibleConversionExpectedResult maps issuanceData conversionData
  case (stockClassIdOpt, quantityOpt) of
    (Some stockClassId, Some quantity) -> do
