validateSecurityQuantityBalanceEvent : Text -> Optional Decimal -> SecurityQuantityEvent -> Update (Optional Decimal)
validateSecurityQuantityBalanceEvent securityId currentOpt event = case currentOpt of
  Some current -> case event of
    SecurityQuantityDelta with quantity_delta -> do
      let next = current + quantity_delta
