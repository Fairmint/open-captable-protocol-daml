stockPlanCancellationQuantityAt : Text -> [StockClassShareEvent] -> Time -> Update Decimal
stockPlanCancellationQuantityAt securityId events asOf =
  case foldl
      applyStockClassShareEventOptional
      (Some 0.0)
      (sortOn stockClassShareEventSortKey (filter (stockClassShareEventOnOrBefore asOf) events)) of
    Some quantity -> do
      assertNonNegativeQuantity ("Stock plan split-adjusted cancellation quantity for " <> securityId <> " on " <> show asOf) quantity
      pure quantity
    None -> do
      assertMsg ("Stock plan cancellation quantity history is invalid for " <> securityId <> " on " <> show asOf) False
