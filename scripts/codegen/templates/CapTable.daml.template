      assertNonNegativeQuantity ("Stock plan return-to-pool quantity for " <> returnToPool.return_data.id) returnToPool.return_data.quantity
      returnedQuantityOpt <- stockPlanReturnToPoolQuantity maps returnToPool.return_data
      case returnedQuantityOpt of
