  OcfRightWarrant warrantRight ->
    validateOptionalStockClassReference (label <> " warrant conversion target") maps warrantRight.converts_to_stock_class_id
  OcfRightStockClass stockClassRight -> do
    validateStockClassReference (label <> " stock class conversion target") maps stockClassRight.converts_to_stock_class_id
    validateAnyConversionRightStockClassReferences (label <> " stock class nested trigger") maps stockClassRight.conversion_trigger.conversion_right

