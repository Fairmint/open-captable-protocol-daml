validateVestingSourceTransactionDate : CapTableMaps -> Text -> Time -> Text -> Update ()
validateVestingSourceTransactionDate maps label transactionDate securityId =
  case Map.lookup securityId maps.stock_issuances_by_security_id of
    Some _ -> validateStockSourceTransactionDate maps label transactionDate securityId
    None -> case Map.lookup securityId maps.warrant_issuances_by_security_id of
      Some _ -> validateWarrantSourceTransactionDate maps label transactionDate securityId
      None -> case Map.lookup securityId maps.equity_compensation_issuances_by_security_id of
        Some _ -> validateEquityCompensationSourceTransactionDate maps label transactionDate securityId
        None -> pure ()

