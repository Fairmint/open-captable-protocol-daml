stockPlanNetAllocatedQuantityIndexAt : StockClassShareEventIndex -> CapTableMaps -> Time -> Update (Map Text Decimal)
stockPlanNetAllocatedQuantityIndexAt eventIndex maps asOf = do
  successorIndex <- stockPlanSuccessorIndex maps
  stockAllocation <- stockIssuancePlanAllocationIndexAt eventIndex successorIndex maps asOf
  equityCompensationAllocation <- equityCompensationPlanAllocationIndexAt successorIndex maps asOf
  successorExcessAllocation <- stockPlanSuccessorExcessAllocationIndexAt eventIndex successorIndex maps asOf
