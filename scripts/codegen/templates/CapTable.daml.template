                    pure totals
              else pure totals
          None -> pure totals)
    Map.empty
    (Map.values maps.equity_compensation_issuances)

stockPlanReturnedQuantityIndexAt : CapTableMaps -> Time -> Update (Map Text Decimal)
stockPlanReturnedQuantityIndexAt maps asOf =
  foldlA
    (\totals returnCid -> do
      returnToPool <- fetch returnCid
      if returnToPool.return_data.date <= asOf
        then do
          assertNonNegativeQuantity ("Stock plan return-to-pool quantity for " <> returnToPool.return_data.id <> " on " <> show asOf) returnToPool.return_data.quantity
          returnedQuantityOpt <- stockPlanReturnToPoolQuantityAt maps returnToPool.return_data asOf
