addStockClassAuthorizedContribution : Optional Decimal -> AuthorizedSharesCeiling -> Optional Decimal
addStockClassAuthorizedContribution totalOpt ceiling = case (totalOpt, ceiling) of
  (Some total, AuthorizedSharesFinite shares) -> Some (total + shares)
  (Some total, AuthorizedSharesNotApplicable) -> Some total
  (_, AuthorizedSharesUnlimited) -> None
  (None, _) -> None

