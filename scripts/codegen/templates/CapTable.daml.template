    (None, _) -> do
      assertMsg
        ("Convertible conversion output cannot be reconstructed because trigger has no destination stock class: " <> conversionData.trigger_id)
        False
      pure None
    (_, None) -> do
      assertMsg
        ("Convertible conversion output cannot be reconstructed for its conversion mechanism; resulting stock issuances are required: " <> conversionData.id)
        False
      pure None

warrantExerciseOutputSecurityEvents : CapTableMaps -> WarrantIssuanceOcfData -> Update [StockClassShareEvent]
