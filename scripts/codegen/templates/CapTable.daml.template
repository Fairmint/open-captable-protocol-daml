      if conversion.conversion_data.security_id == issuanceData.security_id
        then
          let delta = StockClassShareDelta with
                event_date = conversion.conversion_data.date
                event_priority = 1
                quantity_delta = 0.0 - conversion.conversion_data.quantity_converted
          in pure (delta :: (balanceSecurityTerminalEvents conversion.conversion_data.date conversion.conversion_data.balance_security_id ++ events))
        else pure events)
    []
    (Map.values maps.stock_conversions)

  retractionEvents <- foldlA
    (\events retractionCid -> do
      retraction <- fetch retractionCid
      if retraction.retraction_data.security_id == issuanceData.security_id
        then pure ((StockClassShareRetraction with
            event_date = retraction.retraction_data.date
            event_priority = 3)
          :: events)
        else pure events)
    []
    (Map.values maps.stock_retractions)

  reissuanceEvents <- foldlA
    (\events reissuanceCid -> do
      reissuance <- fetch reissuanceCid
      if reissuance.reissuance_data.security_id == issuanceData.security_id
        then pure ((StockClassShareRetraction with
