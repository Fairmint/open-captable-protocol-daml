module Fairmint.Subscriptions.Types.PaymentResult where

import Splice.AmuletRules (TransferResult(..))

-- | Result of processing a subscription payment
-- Note: subscriptionCid type parameter allows this to work without circular dependency
data ProcessPaymentResult t = ProcessPaymentResult
  with
    subscriptionCid : ContractId t
      -- ^ Updated subscription contract
    transferResult : TransferResult
      -- ^ Transfer result for payment
  deriving (Eq, Show)
