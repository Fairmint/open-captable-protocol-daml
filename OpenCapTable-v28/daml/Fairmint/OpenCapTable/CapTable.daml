-- =============================================================================
-- CapTable Template
-- =============================================================================

template CapTable
  with
    context: Context

    -- Issuer (exactly 1, edit only - no create/delete)
    issuer: ContractId Issuer

    -- OCF object/transaction maps
    convertible_acceptances: Map Text (ContractId ConvertibleAcceptance)
    convertible_cancellations: Map Text (ContractId ConvertibleCancellation)
    convertible_conversions: Map Text (ContractId ConvertibleConversion)
    convertible_issuances: Map Text (ContractId ConvertibleIssuance)
    convertible_retractions: Map Text (ContractId ConvertibleRetraction)
    convertible_transfers: Map Text (ContractId ConvertibleTransfer)
    documents: Map Text (ContractId Document)
    equity_compensation_acceptances: Map Text (ContractId EquityCompensationAcceptance)
    equity_compensation_cancellations: Map Text (ContractId EquityCompensationCancellation)
    equity_compensation_exercises: Map Text (ContractId EquityCompensationExercise)
    equity_compensation_issuances: Map Text (ContractId EquityCompensationIssuance)
    equity_compensation_releases: Map Text (ContractId EquityCompensationRelease)
    equity_compensation_repricings: Map Text (ContractId EquityCompensationRepricing)
    equity_compensation_retractions: Map Text (ContractId EquityCompensationRetraction)
    equity_compensation_transfers: Map Text (ContractId EquityCompensationTransfer)
    issuer_authorized_shares_adjustments: Map Text (ContractId IssuerAuthorizedSharesAdjustment)
    stakeholders: Map Text (ContractId Stakeholder)
    stakeholder_relationship_change_events: Map Text (ContractId StakeholderRelationshipChangeEvent)
    stakeholder_status_change_events: Map Text (ContractId StakeholderStatusChangeEvent)
    stock_acceptances: Map Text (ContractId StockAcceptance)
    stock_cancellations: Map Text (ContractId StockCancellation)
    stock_classes: Map Text (ContractId StockClass)
    stock_class_authorized_shares_adjustments: Map Text (ContractId StockClassAuthorizedSharesAdjustment)
    stock_class_conversion_ratio_adjustments: Map Text (ContractId StockClassConversionRatioAdjustment)
    stock_class_splits: Map Text (ContractId StockClassSplit)
    stock_consolidations: Map Text (ContractId StockConsolidation)
    stock_conversions: Map Text (ContractId StockConversion)
    stock_issuances: Map Text (ContractId StockIssuance)
    stock_legend_templates: Map Text (ContractId StockLegendTemplate)
    stock_plans: Map Text (ContractId StockPlan)
    stock_plan_pool_adjustments: Map Text (ContractId StockPlanPoolAdjustment)
    stock_plan_return_to_pools: Map Text (ContractId StockPlanReturnToPool)
    stock_reissuances: Map Text (ContractId StockReissuance)
    stock_repurchases: Map Text (ContractId StockRepurchase)
    stock_retractions: Map Text (ContractId StockRetraction)
    stock_transfers: Map Text (ContractId StockTransfer)
    valuations: Map Text (ContractId Valuation)
    vesting_accelerations: Map Text (ContractId VestingAcceleration)
    vesting_events: Map Text (ContractId VestingEvent)
    vesting_starts: Map Text (ContractId VestingStart)
    vesting_terms: Map Text (ContractId VestingTerms)
    warrant_acceptances: Map Text (ContractId WarrantAcceptance)
    warrant_cancellations: Map Text (ContractId WarrantCancellation)
    warrant_exercises: Map Text (ContractId WarrantExercise)
    warrant_issuances: Map Text (ContractId WarrantIssuance)
    warrant_retractions: Map Text (ContractId WarrantRetraction)
    warrant_transfers: Map Text (ContractId WarrantTransfer)

  where
    signatory context.issuer, context.system_operator

    -- ==========================================================================
    -- ISSUER (Edit only - no Create/Delete)
    -- ==========================================================================

    choice EditIssuer : EditIssuerResult
      with
        new_issuer_data: IssuerOcfData
      controller context.issuer
      do
        archive issuer
        new_issuer_cid <- create Issuer with
          context = context
          issuer_data = new_issuer_data

        new_cap_table_cid <- create this with issuer = new_issuer_cid
        pure EditIssuerResult with
          updatedCapTableCid = new_cap_table_cid
          editedIssuerCid = new_issuer_cid

    -- ==========================================================================
    -- BATCH UPDATE (Create/Edit/Delete)
    -- ==========================================================================

    -- | Batch update choice for efficient bulk operations.
    -- This is the primary choice for cap table mutations.
    --
    -- Parameters:
    -- - creates: List of OCF objects to create (processed in tier order for dependencies)
    -- - edits: List of OCF objects to edit (ID is in the data record)
    -- - deletes: List of OCF object IDs to delete
    choice UpdateCapTable : UpdateCapTableResult
      with
        creates: [OcfCreateData]
        edits: [OcfEditData]
        deletes: [OcfDeleteData]
      controller context.issuer
      do
        -- Start with current maps
        let initialMaps = toMaps this

        -- Sort creates by tier for dependency ordering
        let sortedCreates = sortOn getCreateTier creates

        -- Process creates in tier order
        (mapsAfterCreates, createdCids) <- foldlA
          (\(maps, cids) createData -> do
            (newMaps, cid) <- processCreate context maps createData
            pure (newMaps, cids ++ [cid]))
          (initialMaps, [])
          sortedCreates

        -- Process edits
        (mapsAfterEdits, editedCids) <- foldlA
          (\(maps, cids) editData -> do
            (newMaps, cid) <- processEdit context maps editData
            pure (newMaps, cids ++ [cid]))
          (mapsAfterCreates, [])
          edits

        -- Process deletes
        finalMaps <- foldlA
          (\maps deleteRef -> processDelete maps deleteRef)
          mapsAfterEdits
          deletes

        -- Create new CapTable with updated maps
        newCapTableCid <- create this with
          convertible_acceptances = finalMaps.convertible_acceptances
          convertible_cancellations = finalMaps.convertible_cancellations
          convertible_conversions = finalMaps.convertible_conversions
          convertible_issuances = finalMaps.convertible_issuances
          convertible_retractions = finalMaps.convertible_retractions
          convertible_transfers = finalMaps.convertible_transfers
          documents = finalMaps.documents
          equity_compensation_acceptances = finalMaps.equity_compensation_acceptances
          equity_compensation_cancellations = finalMaps.equity_compensation_cancellations
          equity_compensation_exercises = finalMaps.equity_compensation_exercises
          equity_compensation_issuances = finalMaps.equity_compensation_issuances
          equity_compensation_releases = finalMaps.equity_compensation_releases
          equity_compensation_repricings = finalMaps.equity_compensation_repricings
          equity_compensation_retractions = finalMaps.equity_compensation_retractions
          equity_compensation_transfers = finalMaps.equity_compensation_transfers
          issuer_authorized_shares_adjustments = finalMaps.issuer_authorized_shares_adjustments
          stakeholders = finalMaps.stakeholders
          stakeholder_relationship_change_events = finalMaps.stakeholder_relationship_change_events
          stakeholder_status_change_events = finalMaps.stakeholder_status_change_events
          stock_acceptances = finalMaps.stock_acceptances
          stock_cancellations = finalMaps.stock_cancellations
          stock_classes = finalMaps.stock_classes
          stock_class_authorized_shares_adjustments = finalMaps.stock_class_authorized_shares_adjustments
          stock_class_conversion_ratio_adjustments = finalMaps.stock_class_conversion_ratio_adjustments
          stock_class_splits = finalMaps.stock_class_splits
          stock_consolidations = finalMaps.stock_consolidations
          stock_conversions = finalMaps.stock_conversions
          stock_issuances = finalMaps.stock_issuances
          stock_legend_templates = finalMaps.stock_legend_templates
          stock_plans = finalMaps.stock_plans
          stock_plan_pool_adjustments = finalMaps.stock_plan_pool_adjustments
          stock_plan_return_to_pools = finalMaps.stock_plan_return_to_pools
          stock_reissuances = finalMaps.stock_reissuances
          stock_repurchases = finalMaps.stock_repurchases
          stock_retractions = finalMaps.stock_retractions
          stock_transfers = finalMaps.stock_transfers
          valuations = finalMaps.valuations
          vesting_accelerations = finalMaps.vesting_accelerations
          vesting_events = finalMaps.vesting_events
          vesting_starts = finalMaps.vesting_starts
          vesting_terms = finalMaps.vesting_terms
          warrant_acceptances = finalMaps.warrant_acceptances
          warrant_cancellations = finalMaps.warrant_cancellations
          warrant_exercises = finalMaps.warrant_exercises
          warrant_issuances = finalMaps.warrant_issuances
          warrant_retractions = finalMaps.warrant_retractions
          warrant_transfers = finalMaps.warrant_transfers

        pure UpdateCapTableResult with
          updatedCapTableCid = newCapTableCid
          createdCids = createdCids
          editedCids = editedCids
