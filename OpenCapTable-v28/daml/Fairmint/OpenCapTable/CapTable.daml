-- | Process a single delete operation, returning updated maps
processDelete : CapTableMaps -> OcfDeleteData -> Update CapTableMaps
processDelete maps deleteData = case deleteData of
      OcfDeleteConvertibleAcceptance delId -> do
        let oldCidOpt = Map.lookup delId maps.convertible_acceptances
        assertMsg "ConvertibleAcceptance not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        pure (maps with convertible_acceptances = Map.delete delId maps.convertible_acceptances)
      OcfDeleteConvertibleCancellation delId -> do
        let oldCidOpt = Map.lookup delId maps.convertible_cancellations
        assertMsg "ConvertibleCancellation not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        pure (maps with convertible_cancellations = Map.delete delId maps.convertible_cancellations)
      OcfDeleteConvertibleConversion delId -> do
        let oldCidOpt = Map.lookup delId maps.convertible_conversions
        assertMsg "ConvertibleConversion not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        pure (maps with convertible_conversions = Map.delete delId maps.convertible_conversions)
      OcfDeleteConvertibleIssuance delId -> do
        let oldCidOpt = Map.lookup delId maps.convertible_issuances
        assertMsg "ConvertibleIssuance not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        pure (maps with convertible_issuances = Map.delete delId maps.convertible_issuances)
      OcfDeleteConvertibleRetraction delId -> do
        let oldCidOpt = Map.lookup delId maps.convertible_retractions
        assertMsg "ConvertibleRetraction not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
