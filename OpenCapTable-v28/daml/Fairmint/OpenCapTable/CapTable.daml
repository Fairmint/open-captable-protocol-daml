      OcfDeleteConvertibleTransfer delId -> do
        let oldCidOpt = Map.lookup delId maps.convertible_transfers
        assertMsg "ConvertibleTransfer not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
