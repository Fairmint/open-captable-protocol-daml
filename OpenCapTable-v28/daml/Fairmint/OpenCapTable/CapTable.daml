        assertMsg "StockClassAuthorizedSharesAdjustment not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        pure (maps with stock_class_authorized_shares_adjustments = Map.delete delId maps.stock_class_authorized_shares_adjustments)
