-- | Get the processing tier for a create operation
getCreateTier : OcfCreateData -> Int
getCreateTier createData = case createData of
  OcfCreateConvertibleAcceptance _ -> 4
  OcfCreateConvertibleCancellation _ -> 4
  OcfCreateConvertibleConversion _ -> 4
  OcfCreateConvertibleIssuance _ -> 3
  OcfCreateConvertibleRetraction _ -> 4
  OcfCreateConvertibleTransfer _ -> 4
  OcfCreateDocument _ -> 1
  OcfCreateEquityCompensationAcceptance _ -> 4
  OcfCreateEquityCompensationCancellation _ -> 4
  OcfCreateEquityCompensationExercise _ -> 4
  OcfCreateEquityCompensationIssuance _ -> 3
  OcfCreateEquityCompensationRelease _ -> 4
  OcfCreateEquityCompensationRepricing _ -> 4
  OcfCreateEquityCompensationRetraction _ -> 4
  OcfCreateEquityCompensationTransfer _ -> 4
  OcfCreateIssuerAuthorizedSharesAdjustment _ -> 2
  OcfCreateStakeholder _ -> 1
  OcfCreateStakeholderRelationshipChangeEvent _ -> 2
  OcfCreateStakeholderStatusChangeEvent _ -> 2
  OcfCreateStockAcceptance _ -> 4
  OcfCreateStockCancellation _ -> 4
  OcfCreateStockClass _ -> 1
  OcfCreateStockClassAuthorizedSharesAdjustment _ -> 2
  OcfCreateStockClassConversionRatioAdjustment _ -> 2
  OcfCreateStockClassSplit _ -> 2
  OcfCreateStockConsolidation _ -> 4
  OcfCreateStockConversion _ -> 4
  OcfCreateStockIssuance _ -> 3
  OcfCreateStockLegendTemplate _ -> 1
  OcfCreateStockPlan _ -> 1
  OcfCreateStockPlanPoolAdjustment _ -> 2
  OcfCreateStockPlanReturnToPool _ -> 2
  OcfCreateStockReissuance _ -> 4
  OcfCreateStockRepurchase _ -> 4
  OcfCreateStockRetraction _ -> 4
  OcfCreateStockTransfer _ -> 4
  OcfCreateValuation _ -> 2
  OcfCreateVestingAcceleration _ -> 4
  OcfCreateVestingEvent _ -> 4
  OcfCreateVestingStart _ -> 4
  OcfCreateVestingTerms _ -> 1
  OcfCreateWarrantAcceptance _ -> 4
  OcfCreateWarrantCancellation _ -> 4
  OcfCreateWarrantExercise _ -> 4
  OcfCreateWarrantIssuance _ -> 3
  OcfCreateWarrantRetraction _ -> 4
  OcfCreateWarrantTransfer _ -> 4

-- | Process a single create operation, returning updated maps and the created ContractId
processCreate : Context -> CapTableMaps -> OcfCreateData -> Update (CapTableMaps, OcfContractId)
processCreate ctx maps createData = case createData of
      OcfCreateDocument d -> do
        assertMsg "Document ID already exists" (Map.lookup d.id maps.documents == None)
        cid <- create Document with context = ctx, document_data = d
        let newMaps = maps with documents = Map.insert d.id cid maps.documents
        pure (newMaps, CidDocument cid)
      OcfCreateStakeholder d -> do
        assertMsg "Stakeholder ID already exists" (Map.lookup d.id maps.stakeholders == None)
        cid <- create Stakeholder with context = ctx, stakeholder_data = d
        let newMaps = maps with stakeholders = Map.insert d.id cid maps.stakeholders
