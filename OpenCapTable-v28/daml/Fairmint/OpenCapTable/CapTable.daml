-- | Process a single edit operation, returning updated maps and the edited ContractId
processEdit : Context -> CapTableMaps -> OcfEditData -> Update (CapTableMaps, OcfContractId)
processEdit ctx maps editData = case editData of
      OcfEditConvertibleAcceptance d -> do
        let oldCidOpt = Map.lookup d.id maps.convertible_acceptances
        assertMsg "ConvertibleAcceptance not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create ConvertibleAcceptance with context = ctx, acceptance_data = d
        let newMaps = maps with convertible_acceptances = Map.insert d.id newCid maps.convertible_acceptances
        pure (newMaps, CidConvertibleAcceptance newCid)
      OcfEditConvertibleCancellation d -> do
        let oldCidOpt = Map.lookup d.id maps.convertible_cancellations
        assertMsg "ConvertibleCancellation not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create ConvertibleCancellation with context = ctx, cancellation_data = d
        let newMaps = maps with convertible_cancellations = Map.insert d.id newCid maps.convertible_cancellations
        pure (newMaps, CidConvertibleCancellation newCid)
      OcfEditConvertibleConversion d -> do
        let oldCidOpt = Map.lookup d.id maps.convertible_conversions
        assertMsg "ConvertibleConversion not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create ConvertibleConversion with context = ctx, conversion_data = d
        let newMaps = maps with convertible_conversions = Map.insert d.id newCid maps.convertible_conversions
        pure (newMaps, CidConvertibleConversion newCid)
      OcfEditConvertibleIssuance d -> do
        let oldCidOpt = Map.lookup d.id maps.convertible_issuances
        assertMsg "ConvertibleIssuance not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        assertMsg ("Stakeholder not found: " <> d.stakeholder_id) (Map.lookup d.stakeholder_id maps.stakeholders /= None)
        archive oldCid
        newCid <- create ConvertibleIssuance with context = ctx, issuance_data = d
        let newMaps = maps with convertible_issuances = Map.insert d.id newCid maps.convertible_issuances
        pure (newMaps, CidConvertibleIssuance newCid)
      OcfEditConvertibleRetraction d -> do
        let oldCidOpt = Map.lookup d.id maps.convertible_retractions
        assertMsg "ConvertibleRetraction not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create ConvertibleRetraction with context = ctx, retraction_data = d
        let newMaps = maps with convertible_retractions = Map.insert d.id newCid maps.convertible_retractions
        pure (newMaps, CidConvertibleRetraction newCid)
      OcfEditConvertibleTransfer d -> do
        let oldCidOpt = Map.lookup d.id maps.convertible_transfers
        assertMsg "ConvertibleTransfer not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create ConvertibleTransfer with context = ctx, transfer_data = d
        let newMaps = maps with convertible_transfers = Map.insert d.id newCid maps.convertible_transfers
        pure (newMaps, CidConvertibleTransfer newCid)
      OcfEditDocument d -> do
        let oldCidOpt = Map.lookup d.id maps.documents
        assertMsg "Document not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create Document with context = ctx, document_data = d
        let newMaps = maps with documents = Map.insert d.id newCid maps.documents
        pure (newMaps, CidDocument newCid)
      OcfEditEquityCompensationAcceptance d -> do
        let oldCidOpt = Map.lookup d.id maps.equity_compensation_acceptances
        assertMsg "EquityCompensationAcceptance not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create EquityCompensationAcceptance with context = ctx, acceptance_data = d
        let newMaps = maps with equity_compensation_acceptances = Map.insert d.id newCid maps.equity_compensation_acceptances
        pure (newMaps, CidEquityCompensationAcceptance newCid)
      OcfEditEquityCompensationCancellation d -> do
        let oldCidOpt = Map.lookup d.id maps.equity_compensation_cancellations
        assertMsg "EquityCompensationCancellation not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create EquityCompensationCancellation with context = ctx, cancellation_data = d
        let newMaps = maps with equity_compensation_cancellations = Map.insert d.id newCid maps.equity_compensation_cancellations
        pure (newMaps, CidEquityCompensationCancellation newCid)
      OcfEditEquityCompensationExercise d -> do
        let oldCidOpt = Map.lookup d.id maps.equity_compensation_exercises
        assertMsg "EquityCompensationExercise not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create EquityCompensationExercise with context = ctx, exercise_data = d
        let newMaps = maps with equity_compensation_exercises = Map.insert d.id newCid maps.equity_compensation_exercises
        pure (newMaps, CidEquityCompensationExercise newCid)
      OcfEditEquityCompensationIssuance d -> do
        let oldCidOpt = Map.lookup d.id maps.equity_compensation_issuances
        assertMsg "EquityCompensationIssuance not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        assertMsg ("Stakeholder not found: " <> d.stakeholder_id) (Map.lookup d.stakeholder_id maps.stakeholders /= None)
        archive oldCid
        newCid <- create EquityCompensationIssuance with context = ctx, issuance_data = d
        let newMaps = maps with equity_compensation_issuances = Map.insert d.id newCid maps.equity_compensation_issuances
        pure (newMaps, CidEquityCompensationIssuance newCid)
      OcfEditEquityCompensationRelease d -> do
        let oldCidOpt = Map.lookup d.id maps.equity_compensation_releases
        assertMsg "EquityCompensationRelease not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create EquityCompensationRelease with context = ctx, release_data = d
        let newMaps = maps with equity_compensation_releases = Map.insert d.id newCid maps.equity_compensation_releases
        pure (newMaps, CidEquityCompensationRelease newCid)
      OcfEditEquityCompensationRepricing d -> do
        let oldCidOpt = Map.lookup d.id maps.equity_compensation_repricings
        assertMsg "EquityCompensationRepricing not found" (oldCidOpt /= None)
        let Some oldCid = oldCidOpt
        archive oldCid
        newCid <- create EquityCompensationRepricing with context = ctx, repricing_data = d
        let newMaps = maps with equity_compensation_repricings = Map.insert d.id newCid maps.equity_compensation_repricings
