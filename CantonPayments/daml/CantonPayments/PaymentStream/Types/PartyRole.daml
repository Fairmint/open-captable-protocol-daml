-- Enumeration or helpers for payer, recipient, processor roles in a stream.
-- Fits in: Keeps role-specific logic explicit in approvals and authorization checks.
module CantonPayments.PaymentStream.Types.PartyRole where

-- | Role of a party in a paymentStream
data PartyRole
  = Payer
  | Recipient
  | Processor
  deriving (Eq, Show)
