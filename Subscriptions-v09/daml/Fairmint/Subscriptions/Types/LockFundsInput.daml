module Fairmint.Subscriptions.Types.LockFundsInput where

import Splice.Amulet qualified as Amulet
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext)

-- | Input for locking funds in a subscription
-- Used when creating or adding funds to a subscription
data LockFundsInput = LockFundsInput with
    amuletInputs : [ContractId Amulet.Amulet]
    amountToLock : Decimal
    paymentContext : PaymentContext
  deriving (Eq, Show)

