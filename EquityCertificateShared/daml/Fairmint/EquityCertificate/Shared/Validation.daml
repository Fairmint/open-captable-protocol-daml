-- Shared validation for equity certificate domain types.
module Fairmint.EquityCertificate.Shared.Validation where

import DA.Text qualified as Text

import Fairmint.EquityCertificate.Types (PositionIdentity(..), positionIdentityKey)

validateRequiredText : Text -> Bool
validateRequiredText value = value /= ""

-- | Forbid @':'@ in ids so @positionIdentityKey@ cannot collide (e.g. @a:b@ + @c@ vs @a@ + @b:c@).
validateNoColonInPositionPart : Text -> Bool
validateNoColonInPositionPart part =
  case Text.splitOn ":" part of
    [_] -> True
    _ -> False

validatePositionIdentity : PositionIdentity -> Bool
validatePositionIdentity position_identity =
  validateRequiredText position_identity.stakeholder_id
    && validateRequiredText position_identity.security_id
    && validateNoColonInPositionPart position_identity.stakeholder_id
    && validateNoColonInPositionPart position_identity.security_id

-- | Registration token_id must match this canonical position key (stakeholder_id:security_id).
validateRegistrationTokenMatchesPosition :
  Text -> PositionIdentity -> Bool
validateRegistrationTokenMatchesPosition token_id position_identity =
  token_id == positionIdentityKey position_identity
