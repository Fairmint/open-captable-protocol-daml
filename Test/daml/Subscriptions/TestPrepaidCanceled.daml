module Subscriptions.TestPrepaidCanceled where

import Daml.Script
import DA.Time (days, addRelTime)
import Fairmint.Subscriptions.Creation.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.Creation.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Active.Subscriptions
import Fairmint.Subscriptions.Active.PrepaidCanceledSubscription
import Fairmint.Subscriptions.Types (PaymentContext(..))
import Shared.TestUtils (tap, getAmuletRules, getFirstOpenRound, sharedDso)
import Subscriptions.TestUtils

-- | Test PrepaidCanceledSubscription Archive (standard archive)
testPrepaidCanceledSubscriptionArchive : Script ()
testPrepaidCanceledSubscriptionArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = defaultSubscriptionConfig alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  -- Process payment to create prepaid time
  amuletCid <- tap alice 100.0
  dso <- sharedDso
  amuletRulesCid <- getAmuletRules dso
  openRoundCid <- getFirstOpenRound dso
  
  processedResult <- submit processor do
    exerciseCmd subscriptionCid PaidSubscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      processorProvider = processor
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
      processorActivityMarkerFAR = None
  
  let updatedSubscriptionCid = processedResult.subscriptionCid
  
  -- Cancel by subscriber to create PrepaidCanceledSubscription
  maybePrepaidCanceledCid <- submit alice do
    exerciseCmd updatedSubscriptionCid PaidSubscription_CancelBySubscriber with
      reason = Some "Cancel with prepaid time"
  
  prepaidCanceledCid <- case maybePrepaidCanceledCid of
    Some cid -> pure cid
    None -> error "Expected PrepaidCanceledSubscription"
  
  -- Wait for prepaid time to pass
  now <- getTime
  setTime (addRelTime now (days 31))
  
  -- Archive using standard Archive choice
  submitMulti [alice, bob, processor] [] do
    archiveCmd prepaidCanceledCid
  
  pure ()

-- | Test PrepaidCanceledSubscription_Archive choice (custom archive)
testPrepaidCanceledSubscriptionArchiveChoice : Script ()
testPrepaidCanceledSubscriptionArchiveChoice = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = defaultSubscriptionConfig alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  -- Process payment to create prepaid time
  amuletCid <- tap alice 100.0
  dso <- sharedDso
  amuletRulesCid <- getAmuletRules dso
  openRoundCid <- getFirstOpenRound dso
  
  processedResult <- submit processor do
    exerciseCmd subscriptionCid PaidSubscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      processorProvider = processor
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
      processorActivityMarkerFAR = None
  
  let updatedSubscriptionCid = processedResult.subscriptionCid
  
  -- Cancel by subscriber
  maybePrepaidCanceledCid <- submit alice do
    exerciseCmd updatedSubscriptionCid PaidSubscription_CancelBySubscriber with
      reason = None
  
  prepaidCanceledCid <- case maybePrepaidCanceledCid of
    Some cid -> pure cid
    None -> error "Expected PrepaidCanceledSubscription"
  
  -- Wait for prepaid time to pass
  now <- getTime
  setTime (addRelTime now (days 31))
  
  -- Archive using custom choice with archiving party
  submit alice do
    exerciseCmd prepaidCanceledCid PrepaidCanceledSubscription_Archive with
      archivingParty = alice
  
  pure ()

-- | Test PrepaidCanceledSubscription_RecipientRefundAndArchive
testPrepaidCanceledSubscriptionRecipientRefundAndArchive : Script ()
testPrepaidCanceledSubscriptionRecipientRefundAndArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = defaultSubscriptionConfig alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  -- Process payment to create prepaid time
  amuletCid <- tap alice 100.0
  dso <- sharedDso
  amuletRulesCid <- getAmuletRules dso
  openRoundCid <- getFirstOpenRound dso
  
  processedResult <- submit processor do
    exerciseCmd subscriptionCid PaidSubscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      processorProvider = processor
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
      processorActivityMarkerFAR = None
  
  let updatedSubscriptionCid = processedResult.subscriptionCid
  
  -- Cancel by subscriber
  maybePrepaidCanceledCid <- submit alice do
    exerciseCmd updatedSubscriptionCid PaidSubscription_CancelBySubscriber with
      reason = None
  
  prepaidCanceledCid <- case maybePrepaidCanceledCid of
    Some cid -> pure cid
    None -> error "Expected PrepaidCanceledSubscription"
  
  -- Recipient issues refund immediately (before prepaid time passes)
  -- Tap funds for recipient to issue refund
  recipientAmuletCid <- tap bob 100.0
  
  refundResult <- submit bob do
    exerciseCmd prepaidCanceledCid PrepaidCanceledSubscription_RecipientRefundAndArchive with
      paymentContext = PaymentContext with
        amuletInputs = [recipientAmuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
  
  -- Verify contract was archived (refund choice archives immediately)
  result <- queryContractId alice prepaidCanceledCid
  assertMsg "Contract should be archived" (result == None)
  
  pure ()

