module Subscriptions.TestPrepaidCanceled where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Api.FeaturedAppRightV1 (AppRewardBeneficiary(..))
import Splice.Round (OpenMiningRound)
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Fairmint.Subscriptions.Types.ProcessingContext (ProcessingContext(..))
import Shared.TestUtils (tapWithDso, getAmuletRules)
import Subscriptions.TestUtils

-- | Test standard archive of subscription with prepaid time after cancellation
testCanceledSubscriptionArchiveAfterPrepaidTime : Script ()
testCanceledSubscriptionArchiveAfterPrepaidTime = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = defaultSubscriptionProposal alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- TODO: Process a payment to create prepaid time, then cancel
  -- This would require payment processing logic similar to TestPaymentProcessing
  -- For now, this test demonstrates the cancel flow without prepaid time
  
  -- Cancel subscription (no prepaid time, so returns None)
  maybeUpdatedCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Cancel with prepaid time"
  
  case maybeUpdatedCid of
    None -> pure ()  -- Expected when no prepaid time
    Some _ -> error "Expected immediate archive with no prepaid time"
  
  pure ()


-- | Test recipient refund during canceled state
-- Tests the full flow: payment → cancel → refund → archive
testRecipientRefundAfterCancel : Script ()
testRecipientRefundAfterCancel = script do
  TestParties{..} <- allocateTestParties
  
  -- Create subscription with prepay window to allow processing ahead
  expiresAt <- getExpirationTime 365
  now <- getTime
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        prepayWindow = Some (days 60)  -- Allow 60 days of prepayment
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Alice creates amulet for payment (before advancing time)
  amuletCid <- tapWithDso dso alice 100.0
  
  -- Get payment context
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Advance time by 1 day to allow processing a 30-day payment (creates 29 days of prepaid time)
  setTime (addRelTime now (days 1))
  
  -- Get disclosures for contracts the processor needs
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Process payment for 30 days (creating prepaid time)
  paymentResult <- submitWithDisclosures processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingContext = ProcessingContext with
        processorProvider = processor
        processingPeriod = days 30
        recipientProvider = Some bob
        recipientFeaturedAppRight = None
        processorFeaturedAppRight = None
        processorBeneficiaries = [AppRewardBeneficiary processor 1.0]
      paymentContext = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      skipProcessorPayment = False
  
  -- Verify processedAndPaidUntil is in the future
  Some paidSubscription <- queryContractId alice paymentResult.subscriptionCid
  now4 <- getTime
  assertMsg "Should have prepaid time" (paidSubscription.processedAndPaidUntil > now4)
  
  -- Alice cancels subscription (should keep prepaid time)
  Some canceledCid <- submit alice do
    exerciseCmd paymentResult.subscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Cancel with prepaid"
  
  -- Bob creates amulet for refund
  bobAmuletCid <- tapWithDso dso bob 100.0
  
  -- Get fresh disclosures for refund
  openRounds2 <- query @OpenMiningRound dso
  now5 <- getTime
  let currentOpenRounds2 = filter (\(_, r) -> r.opensAt <= now5) openRounds2
  assertMsg "Need at least one open round for refund" (not (null currentOpenRounds2))
  let (openRoundCid2, _) = head currentOpenRounds2
  amuletRulesCid2 <- getAmuletRules dso
  
  Some bobAmuletDisclosure <- queryDisclosure bob bobAmuletCid
  Some amuletRulesDisclosure2 <- queryDisclosure dso amuletRulesCid2
  Some openRoundDisclosure2 <- queryDisclosure dso openRoundCid2
  
  -- Bob refunds prepaid time (this archives the subscription)
  refundResult <- submitWithDisclosures bob [bobAmuletDisclosure, amuletRulesDisclosure2, openRoundDisclosure2] do
    exerciseCmd canceledCid ActiveSubscription_Refund with
      paymentContext = PaymentContext with
        amuletInputs = [bobAmuletCid]
        amuletRulesCid = amuletRulesCid2
        openMiningRoundCid = openRoundCid2
      recipientFeaturedAppRight = None
  
  -- Verify subscription was archived (refund succeeded)
  maybeSubscription <- queryContractId alice canceledCid
  assertMsg "Subscription should be archived after refund" (maybeSubscription == None)
  
  pure ()


-- | Test archiving inactive subscription after payments end and prepaid period passes
-- This test exercises the ActiveSubscription_ArchiveInactiveSubscription choice
-- Similar to refund test but waits for prepaid time to pass instead of refunding
testArchiveInactiveSubscription : Script ()
testArchiveInactiveSubscription = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  now <- getTime
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        prepayWindow = Some (days 60)  -- Allow 60 days of prepayment
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Process a payment to create prepaid time
  amuletCid <- tapWithDso dso alice 100.0
  
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  setTime (addRelTime now (days 1))
  
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  paymentResult <- submitWithDisclosures processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingContext = ProcessingContext with
        processorProvider = processor
        processingPeriod = days 30
        recipientProvider = Some bob
        recipientFeaturedAppRight = None
        processorFeaturedAppRight = None
        processorBeneficiaries = [AppRewardBeneficiary processor 1.0]
      paymentContext = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      skipProcessorPayment = False
  
  -- Cancel subscription (keeps prepaid time)
  Some canceledCid <- submit alice do
    exerciseCmd paymentResult.subscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Cancel with prepaid"
  
  -- Advance time beyond prepaid period
  now4 <- getTime
  setTime (addRelTime now4 (days 32))
  
  -- Archive inactive subscription
  submit alice do
    exerciseCmd canceledCid ActiveSubscription_ArchiveInactiveSubscription with
      actor = alice
  
  -- Verify subscription was archived
  maybeSubscription <- queryContractId alice canceledCid
  assertMsg "Subscription should be archived" (maybeSubscription == None)
  
  pure ()

