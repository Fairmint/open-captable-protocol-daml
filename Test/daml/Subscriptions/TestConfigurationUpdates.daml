-- | Test recipient updating free trial
testRecipientUpdateFreeTrial : Script ()
testRecipientUpdateFreeTrial = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Recipient sets free trial
  let newFreeTrialEndsAt = addRelTime now (days 14)
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid Subscription_RecipientUpdateFreeTrial with
      newFreeTrialEndsAt = Some newFreeTrialEndsAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Free trial should be set" (updated.config.freeTrialEndsAt == Some newFreeTrialEndsAt)
  
  pure ()

-- | Test subscriber increasing payments
testSubscriberIncreasePayments : Script ()
testSubscriberIncreasePayments = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Subscriber increases payments
  updatedCid <- submit alice do
    exerciseCmd subscriptionCid Subscription_SubscriberIncreasePayments with
      newRecipientPayment = PaymentConfig with
        amountPerDay = AmuletAmount 2.0
        featuredAppRight = None
      newProcessorPayment = PaymentConfig with
        amountPerDay = AmuletAmount 0.3
        featuredAppRight = None
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Recipient payment should increase" (updated.config.recipientPayment.amountPerDay == AmuletAmount 2.0)
  assertMsg "Processor payment should increase" (updated.config.processorPayment.amountPerDay == AmuletAmount 0.3)
  
  pure ()

-- | Test subscriber reducing free trial
testSubscriberReduceFreeTrial : Script ()
testSubscriberReduceFreeTrial = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        freeTrialEndsAt = Some freeTrialEndsAt
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Subscriber reduces free trial
  let newFreeTrialEndsAt = addRelTime now (days 15)
  updatedCid <- submit alice do
    exerciseCmd subscriptionCid Subscription_SubscriberReduceFreeTrial with
      newFreeTrialEndsAt = Some newFreeTrialEndsAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Free trial should be reduced" (updated.config.freeTrialEndsAt == Some newFreeTrialEndsAt)
  
  pure ()

