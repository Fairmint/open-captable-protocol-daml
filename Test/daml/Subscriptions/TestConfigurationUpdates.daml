module Subscriptions.TestConfigurationUpdates where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.SubscriptionChanges (SubscriptionChanges(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Subscriptions.TestUtils

-- | Test proposing and applying a simple configuration change
testProposeAndApplyExpirationChange : Script ()
testProposeAndApplyExpirationChange = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Alice proposes extending the expiration
  newExpiresAt <- getExpirationTime 500
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = None
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = Some (Some (PerciseTime newExpiresAt))
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = alice
      changes = changes
  
  -- Processor and recipient approve
  changeProposalCid2 <- submit processor do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with actor = processor
  
  changeProposalCid3 <- submit bob do
    exerciseCmd changeProposalCid2 SubscriptionChangeProposal_Approve with actor = bob
  
  -- Processor applies the changes
  updatedSubscriptionCid <- submit processor do
    exerciseCmd changeProposalCid3 SubscriptionChangeProposal_Apply with
      activeSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedSubscriptionCid
  assertMsg "Expiration should be updated" (updated.subscription.paymentsEndAt == Some newExpiresAt)
  
  pure ()

-- | Test proposing a payment decrease (impacts recipient)
testProposePaymentDecrease : Script ()
testProposePaymentDecrease = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Subscriber proposes decreasing payment
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = Some (AmuletAmount 0.5)  -- Decrease from 1.0
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = None
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = alice
      changes = changes
  
  -- Bob (recipient) must approve since they're impacted
  changeProposalCid2 <- submit bob do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with actor = bob
  
  -- Processor must also approve
  changeProposalCid3 <- submit processor do
    exerciseCmd changeProposalCid2 SubscriptionChangeProposal_Approve with actor = processor
  
  -- Apply changes
  updatedSubscriptionCid <- submit processor do
    exerciseCmd changeProposalCid3 SubscriptionChangeProposal_Apply with
      activeSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedSubscriptionCid
  assertMsg "Payment should be decreased" (updated.subscription.recipientPaymentPerDay == AmuletAmount 0.5)
  
  pure ()

-- | Test rejecting a proposed change
testRejectProposedChange : Script ()
testRejectProposedChange = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Alice proposes a change
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = Some (AmuletAmount 0.1)  -- Big decrease
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = None
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = alice
      changes = changes
  
  -- Bob rejects the change
  submit bob do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Reject with
      actor = bob
      description = Some "Payment too low"
  
  -- Verify proposal is archived
  result <- queryContractId bob changeProposalCid
  assertMsg "Proposal should be archived" (result == None)
  
  pure ()

