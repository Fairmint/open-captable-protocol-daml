module Subscriptions.TestConfigurationUpdates where

import Daml.Script
import DA.Time (days, addRelTime)
import Fairmint.Subscriptions.Creation.ProposedSubscription
import Fairmint.Subscriptions.Active.Subscriptions
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test recipient decreasing expiration
testDecreaseExpiration : Script ()
testDecreaseExpiration = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Recipient decreases expiration (not supported - only subscriber can change)
  -- This test is invalid - only subscriber can update expiration
  let newExpiresAt = addRelTime now (days 180)
  updatedCid <- submit alice do
    exerciseCmd subscriptionCid PaidSubscription_SubscriberUpdateExpiration with
      newExpiresAt = newExpiresAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Expiration should be decreased" (updated.config.expiresAt == newExpiresAt)
  
  pure ()

-- | Test processor decreasing their payment
testProcessorDecreasePayment : Script ()
testProcessorDecreasePayment = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        processorPaymentPerDay = AmuletAmount 0.5
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Processor decreases their payment
  updatedCid <- submit processor do
    exerciseCmd subscriptionCid PaidSubscription_ProcessorDecreasePayment with
      newProcessorPaymentPerDay = AmuletAmount 0.3
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Processor payment should decrease" (updated.config.processorPaymentPerDay == AmuletAmount 0.3)
  
  pure ()

