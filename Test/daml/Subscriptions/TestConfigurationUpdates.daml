-- | Test recipient updating free trial
testRecipientUpdateFreeTrial : Script ()
testRecipientUpdateFreeTrial = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Recipient starts free trial
  let newFreeTrialEndsAt = addRelTime now (days 14)
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid PaidSubscription_RecipientStartFreeTrial with
      trialEndsAt = newFreeTrialEndsAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Free trial should be set" (updated.trialEndsAt == newFreeTrialEndsAt)
  
  pure ()

-- | Test subscriber increasing payments
testSubscriberIncreasePayments : Script ()
testSubscriberIncreasePayments = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Subscriber increases payments
  updatedCid <- submit alice do
    exerciseCmd subscriptionCid PaidSubscription_SubscriberIncreasePayments with
      newRecipientPaymentPerDay = AmuletAmount 2.0
      newProcessorPaymentPerDay = AmuletAmount 0.3
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Recipient payment should increase" (updated.config.recipientPaymentPerDay == AmuletAmount 2.0)
  assertMsg "Processor payment should increase" (updated.config.processorPaymentPerDay == AmuletAmount 0.3)
  
  pure ()

-- | Test subscriber reducing free trial
testSubscriberReduceFreeTrial : Script ()
testSubscriberReduceFreeTrial = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  paidSubscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Recipient starts free trial first
  freeTrialCid <- submit bob do
    exerciseCmd paidSubscriptionCid PaidSubscription_RecipientStartFreeTrial with
      trialEndsAt = freeTrialEndsAt
  
  -- Subscriber reduces free trial
  let newFreeTrialEndsAt = addRelTime now (days 15)
  updatedCid <- submit alice do
    exerciseCmd freeTrialCid FreeTrialSubscription_SubscriberReduceTrial with
      newTrialEndsAt = Some newFreeTrialEndsAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Free trial should be reduced" (updated.trialEndsAt == newFreeTrialEndsAt)
  
  pure ()

-- | Test recipient updating provider for PaidSubscription
testPaidSubscriptionRecipientUpdateProvider : Script ()
testPaidSubscriptionRecipientUpdateProvider = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  charlie <- allocateParty "Charlie"
  
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid PaidSubscription_RecipientUpdateProvider with
      newRecipientProvider = charlie
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Provider should be updated" (updated.recipientProvider == charlie)
  
  pure ()

