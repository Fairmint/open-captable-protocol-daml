-- | Test subscriber proposes and recipient accepts reason update
testSubscriberProposesReasonUpdate : Script ()
testSubscriberProposesReasonUpdate = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Subscriber creates reason update proposal
  reasonProposalCid <- submit alice do
    createCmd PaidSubscriptionReasonUpdateProposal with
      subscriber = alice
      recipient = bob
      proposer = alice
      newReason = Some "Updated subscription reason"
      paidSubscriptionCid = subscriptionCid
  
  -- Recipient accepts the proposal (uses both parties' authority)
  updatedCid <- submitMulti [alice, bob] [] do
    exerciseCmd reasonProposalCid PaidSubscriptionReasonUpdateProposal_Accept
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Reason should be updated" (updated.config.reason == Some "Updated subscription reason")
  
  pure ()

