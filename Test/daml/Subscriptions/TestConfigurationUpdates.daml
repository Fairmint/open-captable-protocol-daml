-- | Test reason update can be rejected
testReasonUpdateRejection : Script ()
testReasonUpdateRejection = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Subscriber creates reason update proposal
  reasonProposalCid <- submit alice do
    createCmd PaidSubscriptionReasonUpdateProposal with
      subscriber = alice
      recipient = bob
      proposer = alice
      newReason = Some "Unwanted reason"
      paidSubscriptionCid = subscriptionCid
  
  -- Recipient rejects the proposal
  submit bob do
    exerciseCmd reasonProposalCid PaidSubscriptionReasonUpdateProposal_Reject
  
  -- Subscription remains unchanged
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Reason should remain unchanged" (subscription.config.reason == Some "Test subscription")
  
  pure ()

-- | Test reason update on free trial subscription
testFreeTrialReasonUpdate : Script ()
testFreeTrialReasonUpdate = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  paidSubscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Recipient starts free trial
  freeTrialCid <- submit bob do
    exerciseCmd paidSubscriptionCid PaidSubscription_RecipientStartFreeTrial with
      trialEndsAt = freeTrialEndsAt
  
  -- Subscriber creates reason update proposal during free trial
  reasonProposalCid <- submit alice do
    createCmd FreeTrialSubscriptionReasonUpdateProposal with
      subscriber = alice
      recipient = bob
      proposer = alice
      newReason = Some "Trial subscription"
      freeTrialSubscriptionCid = freeTrialCid
  
  -- Both parties accept (uses both parties' authority)
  updatedCid <- submitMulti [alice, bob] [] do
    exerciseCmd reasonProposalCid FreeTrialSubscriptionReasonUpdateProposal_Accept
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Reason should be updated during free trial" (updated.config.reason == Some "Trial subscription")
  
  pure ()

