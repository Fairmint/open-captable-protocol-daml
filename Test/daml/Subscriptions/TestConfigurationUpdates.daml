module Subscriptions.TestConfigurationUpdates where

import Daml.Script
import DA.Time (days, addRelTime)
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Subscriptions
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionAmount(..), PaymentConfig(..))
import Subscriptions.TestUtils

-- | Test recipient decreasing expiration
testDecreaseExpiration : Script ()
testDecreaseExpiration = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Recipient decreases expiration
  let newExpiresAt = addRelTime now (days 180)
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid Subscription_DecreaseExpiration with
      newExpiresAt = newExpiresAt
      exercisingParty = bob
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Expiration should be decreased" (updated.config.expiresAt == newExpiresAt)
  
  pure ()

-- | Test processor decreasing their payment
testProcessorDecreasePayment : Script ()
testProcessorDecreasePayment = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        processorPayment = PaymentConfig with
          amountPerDay = AmuletAmount 0.5
          featuredAppRight = None
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Processor decreases their payment
  updatedCid <- submit processor do
    exerciseCmd subscriptionCid Subscription_ProcessorDecreasePayment with
      newProcessorPayment = PaymentConfig with
        amountPerDay = AmuletAmount 0.3
        featuredAppRight = None
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Processor payment should decrease" (updated.config.processorPayment.amountPerDay == AmuletAmount 0.3)
  
  pure ()

