  Some updated <- queryContractId alice updatedCid
  assertMsg "Recipient payment should be decreased" (updated.config.recipientPaymentPerDay == AmuletAmount 0.5)
  
  pure ()

-- | Test processor can decrease their payment during free trial
testFreeTrialProcessorDecreasePayment : Script ()
testFreeTrialProcessorDecreasePayment = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  updatedCid <- submit processor do
    exerciseCmd subscriptionCid FreeTrialSubscription_ProcessorDecreasePayment with
      newProcessorPaymentPerDay = AmuletAmount 0.1
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Processor payment should be decreased" (updated.config.processorPaymentPerDay == AmuletAmount 0.1)
  
  pure ()

-- | Test recipient can extend the free trial period
testFreeTrialRecipientExtendTrial : Script ()
testFreeTrialRecipientExtendTrial = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  now <- getTime
  let newTrialEndsAt = addRelTime now (days 45)
  
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid FreeTrialSubscription_RecipientExtendTrial with
      newTrialEndsAt = newTrialEndsAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Trial end should be extended" (updated.trialEndsAt == newTrialEndsAt)
  
  pure ()

-- | Test subscriber can update expiration during free trial
testFreeTrialSubscriberUpdateExpiration : Script ()
testFreeTrialSubscriberUpdateExpiration = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  now <- getTime
  let newExpiresAt = addRelTime now (days 500)
  
  updatedCid <- submit alice do
    exerciseCmd subscriptionCid FreeTrialSubscription_SubscriberUpdateExpiration with
      newExpiresAt = newExpiresAt
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Expiration should be updated" (updated.config.expiresAt == newExpiresAt)
  
  pure ()

-- | Test recipient can update their provider during free trial
testFreeTrialRecipientUpdateProvider : Script ()
testFreeTrialRecipientUpdateProvider = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  charlie <- allocateParty "Charlie"
  
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid FreeTrialSubscription_RecipientUpdateProvider with
      newRecipientProvider = charlie
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Provider should be updated" (updated.recipientProvider == charlie)
  
  pure ()

