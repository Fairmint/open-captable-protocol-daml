module Subscriptions.TestFreeTrialLifecycle where

import Daml.Script
import DA.Time (days, addRelTime)
import Fairmint.Subscriptions.Creation.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.Creation.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Active.Subscriptions
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionAmount(..), ProcessorContext(..), SubscriptionExpiration(..))
import Fairmint.Subscriptions.Creation.SubscriptionFactory
import Subscriptions.TestUtils

-- | Helper to create a FreeTrialSubscription
createFreeTrialSubscription : Party -> Party -> Party -> Party -> Script (ContractId FreeTrialSubscription)
createFreeTrialSubscription processor subscriber recipient dso = do
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  let config = defaultSubscriptionConfig subscriber recipient expiresAt
  
  proposalCid <- submitMulti [subscriber, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext processor dso)
      (SubscriptionFactory_CreateSubscriberProposal with
        config = config
        freeTrialExpiration = Some (AbsoluteExpiration freeTrialEndsAt))
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit recipient do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = recipient
  
  case result.subscription of
    Left cid -> pure cid  -- FreeTrialSubscription
    Right _ -> error "Expected FreeTrialSubscription"

-- | Test FreeTrialSubscription Archive choice
testFreeTrialSubscriptionArchive : Script ()
testFreeTrialSubscriptionArchive = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  submitMulti [alice, bob, processor] [] do
    archiveCmd subscriptionCid
  
  pure ()

-- | Test subscriber can cancel during free trial
testFreeTrialCancelBySubscriber : Script ()
testFreeTrialCancelBySubscriber = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  submit alice do
    exerciseCmd subscriptionCid FreeTrialSubscription_CancelBySubscriber with
      reason = Some "No longer need this service"
  
  pure ()

-- | Test recipient can cancel during free trial
testFreeTrialCancelByRecipient : Script ()
testFreeTrialCancelByRecipient = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  submit bob do
    exerciseCmd subscriptionCid FreeTrialSubscription_CancelByRecipient with
      reason = Some "Service discontinued"
  
  pure ()

-- | Test processor can cancel during free trial
testFreeTrialCancelByProcessor : Script ()
testFreeTrialCancelByProcessor = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  submit processor do
    exerciseCmd subscriptionCid FreeTrialSubscription_CancelByProcessor with
      reason = None
  
  pure ()

-- | Test subscriber can increase payments during free trial
testFreeTrialSubscriberIncreasePayments : Script ()
testFreeTrialSubscriberIncreasePayments = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
  updatedCid <- submit alice do
    exerciseCmd subscriptionCid FreeTrialSubscription_SubscriberIncreasePayments with
      newRecipientPaymentPerDay = AmuletAmount 2.0
      newProcessorPaymentPerDay = AmuletAmount 0.5
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Recipient payment should be increased" (updated.config.recipientPaymentPerDay == AmuletAmount 2.0)
  assertMsg "Processor payment should be increased" (updated.config.processorPaymentPerDay == AmuletAmount 0.5)
  
  pure ()

-- | Test recipient can decrease their payment during free trial
testFreeTrialRecipientDecreasePayment : Script ()
testFreeTrialRecipientDecreasePayment = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createFreeTrialSubscription processor alice bob dso
  
