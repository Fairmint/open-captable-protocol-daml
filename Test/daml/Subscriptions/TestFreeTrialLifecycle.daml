module Subscriptions.TestFreeTrialLifecycle where

import Daml.Script
import DA.Time (days, addRelTime)
import Splice.Api.FeaturedAppRightV1 (AppRewardBeneficiary(..))
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Fairmint.Subscriptions.Types.ProcessingContext (ProcessingContext(..))
import Fairmint.Subscriptions.SubscriptionFactory
import Subscriptions.TestUtils

-- | Helper to create an ActiveSubscription with free trial
createActiveSubscriptionWithFreeTrial : Party -> Party -> Party -> Party -> Script (ContractId ActiveSubscription)
createActiveSubscriptionWithFreeTrial processor subscriber recipient dso = do
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  let proposal = (defaultSubscriptionProposal subscriber recipient expiresAt) with
        freeTrialExpiration = Some (PreciseTime freeTrialEndsAt)
  
  proposalCid <- submitMulti [subscriber, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext processor dso)
      (SubscriptionFactory_CreateProposedSubscription with
        actor = subscriber
        subscriptionProposal = proposal)
  
  result1 : Either (ContractId ProposedSubscription) (ContractId ActiveSubscription) <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 : Either (ContractId ProposedSubscription) (ContractId ActiveSubscription) <- submit recipient do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = recipient
  
  case result2 of
    Right cid -> pure cid  -- ActiveSubscription (with trial info in subscription.trialEndsAt)
    Left _ -> error "Expected ActiveSubscription to be created"

-- | Test ActiveSubscription with free trial - Archive choice
testFreeTrialSubscriptionArchive : Script ()
testFreeTrialSubscriptionArchive = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createActiveSubscriptionWithFreeTrial processor alice bob dso
  
  submitMulti [alice, bob, processor] [] do
    archiveCmd subscriptionCid
  
  pure ()

-- | Test cancellation during free trial
testFreeTrialCancellationBySubscriber : Script ()
testFreeTrialCancellationBySubscriber = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createActiveSubscriptionWithFreeTrial processor alice bob dso
  
  maybeUpdatedCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Canceling during trial"
  
  -- During free trial with no prepaid time, subscription archives immediately
  case maybeUpdatedCid of
    None -> pure ()  -- Expected
    Some _ -> error "Expected subscription to archive"
  
  pure ()

-- | Test cancellation during free trial by recipient
testFreeTrialCancellationByRecipient : Script ()
testFreeTrialCancellationByRecipient = script do
  TestParties{..} <- allocateTestParties
  subscriptionCid <- createActiveSubscriptionWithFreeTrial processor alice bob dso
  
  maybeUpdatedCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = bob
      disregardAvailablePaidPeriod = False
      description = None
  
  case maybeUpdatedCid of
    None -> pure ()  -- Expected
    Some _ -> error "Expected subscription to archive"
  
  pure ()

