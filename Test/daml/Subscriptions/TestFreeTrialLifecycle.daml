-- | Test processing free trial period
testFreeTrialProcess : Script ()
testFreeTrialProcess = script do
  TestParties{..} <- allocateTestParties
  now <- getTime
  subscriptionCid <- createActiveSubscriptionWithFreeTrial processor alice bob dso
  
  -- Process the free trial
  result <- submit processor do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessFreeTrial with
      processingContext = ProcessingContext with
        processingPeriod = days 7
        recipientProvider = Some bob
        recipientFeaturedAppRight = None
        processorFeaturedAppRight = None
        processorProvider = processor
        processorBeneficiaries = [AppRewardBeneficiary processor 1.0]
  
  Some updated <- queryContractId alice result.subscriptionCid
  assertMsg "processedAndPaidUntil should advance" (updated.processedAndPaidUntil > now)
  
  pure ()

