module Subscriptions.TestChangeProposals where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.TextMap qualified as TM
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.SubscriptionChanges (SubscriptionChanges(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Fairmint.Subscriptions.SubscriptionFactory
import Subscriptions.TestUtils

-- | Test SubscriptionChangeProposal Archive
testSubscriptionChangeProposalArchive : Script ()
testSubscriptionChangeProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  newExpiresAt <- getExpirationTime 500
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = None
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = Some (Some (PerciseTime newExpiresAt))
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = bob
      changes = changes
  
  submitMulti [alice, bob, processor] [] do
    archiveCmd changeProposalCid
  
  pure ()

-- | Test change proposal approval flow
testChangeProposalApprovalFlow : Script ()
testChangeProposalApprovalFlow = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  newExpiresAt <- getExpirationTime 500
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = None
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = Some (Some (PerciseTime newExpiresAt))
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = bob
      changes = changes
  
  -- Processor and subscriber approve
  changeProposalCid2 <- submit processor do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with actor = processor
  
  changeProposalCid3 <- submit alice do
    exerciseCmd changeProposalCid2 SubscriptionChangeProposal_Approve with actor = alice
  
  -- Apply the changes
  updatedSubscriptionCid <- submit processor do
    exerciseCmd changeProposalCid3 SubscriptionChangeProposal_Apply with
      activeSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedSubscriptionCid
  assertMsg "Expiration should be extended" (updated.subscription.paymentsEndAt == Some newExpiresAt)
  
  pure ()

-- | Test change proposal rejection
testChangeProposalReject : Script ()
testChangeProposalReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  newExpiresAt <- getExpirationTime 500
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = None
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = Some (Some (PerciseTime newExpiresAt))
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = bob
      changes = changes
  
  -- Alice rejects
  submit alice do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Reject with
      rejecter = alice
      description = Some "Not interested in extending"
  
  pure ()

