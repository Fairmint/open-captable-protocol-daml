-- | Test MetadataChangeProposal Archive
testMetadataChangeProposalArchive : Script ()
testMetadataChangeProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  proposalExpiresAt <- getExpirationTime 30
  metadataProposalCid <- submit alice do
    createCmd MetadataChangeProposal with
      subscriber = alice
      recipient = bob
      processor = processor
      proposer = alice
      newMetadata = TM.fromList [("key", "value")]
      proposalExpiresAt = proposalExpiresAt
  
  submitMulti [alice, bob, processor] [] do
    archiveCmd metadataProposalCid
  
  pure ()

-- | Test MetadataChangeProposal_ProcessorApprove
testMetadataChangeProposalProcessorApprove : Script ()
testMetadataChangeProposalProcessorApprove = script do
  TestParties{..} <- allocateTestParties
  
  proposalExpiresAt <- getExpirationTime 30
  metadataProposalCid <- submit alice do
    createCmd MetadataChangeProposal with
      subscriber = alice
      recipient = bob
      processor = processor
      proposer = alice
      newMetadata = TM.fromList [("key", "value")]
      proposalExpiresAt = proposalExpiresAt
  
  approvedCid <- submit processor do
    exerciseCmd metadataProposalCid MetadataChangeProposal_ProcessorApprove
  
  Some approved <- queryContractId processor approvedCid
  assertMsg "Metadata should match" (approved.newMetadata == TM.fromList [("key", "value")])
  
  pure ()

