-- | Test PaymentChangeProposal Archive
testPaymentChangeProposalArchive : Script ()
testPaymentChangeProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  proposalExpiresAt <- getExpirationTime 30
  paymentProposalCid <- submit bob do
    createCmd PaymentChangeProposal with
      subscriber = alice
      recipient = bob
      processor = processor
      previousRecipientPaymentPerDay = AmuletAmount 1.0
      previousProcessorPaymentPerDay = AmuletAmount 0.2
      newRecipientPaymentPerDay = AmuletAmount 2.0
      newProcessorPaymentPerDay = AmuletAmount 0.4
      expiresAt = proposalExpiresAt
  
  submitMulti [alice, bob] [processor] do
    archiveCmd paymentProposalCid
  
  pure ()

-- | Test PaymentChangeProposal_AcceptForPaidSubscription
testPaymentChangeProposalAcceptForPaid : Script ()
testPaymentChangeProposalAcceptForPaid = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = defaultSubscriptionConfig alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  proposalExpiresAt <- getExpirationTime 30
  paymentProposalCid <- submit bob do
    createCmd PaymentChangeProposal with
      subscriber = alice
      recipient = bob
      processor = processor
      previousRecipientPaymentPerDay = AmuletAmount 1.0
      previousProcessorPaymentPerDay = AmuletAmount 0.2
      newRecipientPaymentPerDay = AmuletAmount 2.0
      newProcessorPaymentPerDay = AmuletAmount 0.4
      expiresAt = proposalExpiresAt
  
  updatedCid <- submitMulti [alice, bob] [] do
    exerciseCmd paymentProposalCid PaymentChangeProposal_AcceptForPaidSubscription with
      paidSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Recipient payment should be increased" (updated.config.recipientPaymentPerDay == AmuletAmount 2.0)
  assertMsg "Processor payment should be increased" (updated.config.processorPaymentPerDay == AmuletAmount 0.4)
  
  pure ()

