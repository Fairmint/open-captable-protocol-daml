module Subscriptions.TestChangeProposals where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.TextMap qualified as TM
import Fairmint.Subscriptions.Creation.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.Creation.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Active.Subscriptions
import Fairmint.Subscriptions.ChangeProposals.ExpirationExtensionProposal
import Fairmint.Subscriptions.ChangeProposals.MetadataChangeProposal
import Fairmint.Subscriptions.ChangeProposals.PaymentChangeProposal
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionAmount(..), ProcessorContext(..), SubscriptionExpiration(..))
import Fairmint.Subscriptions.Creation.SubscriptionFactory
import Subscriptions.TestUtils

-- | Test ExpirationExtensionProposal Archive
testExpirationExtensionProposalArchive : Script ()
testExpirationExtensionProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = defaultSubscriptionConfig alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  newExpiresAt <- getExpirationTime 500
  extensionProposalCid <- submit bob do
    createCmd ExpirationExtensionProposal with
      subscriber = alice
      recipient = bob
      newExpiresAt = newExpiresAt
      subscriptionCid = Left subscriptionCid
  
  submitMulti [alice, bob] [] do
    archiveCmd extensionProposalCid
  
  pure ()

-- | Test ExpirationExtensionProposal_AcceptForPaidSubscription
testExpirationExtensionProposalAcceptForPaid : Script ()
testExpirationExtensionProposalAcceptForPaid = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = defaultSubscriptionConfig alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> error "Expected PaidSubscription"
  
  newExpiresAt <- getExpirationTime 500
  extensionProposalCid <- submit bob do
    createCmd ExpirationExtensionProposal with
      subscriber = alice
      recipient = bob
      newExpiresAt = newExpiresAt
      subscriptionCid = Left subscriptionCid
  
  updatedCid <- submitMulti [alice, bob] [] do
    exerciseCmd extensionProposalCid ExpirationExtensionProposal_AcceptForPaidSubscription with
      paidSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Expiration should be extended" (updated.config.expiresAt == newExpiresAt)
  
  pure ()

-- | Test ExpirationExtensionProposal_AcceptForFreeTrialSubscription
testExpirationExtensionProposalAcceptForFreeTrial : Script ()
testExpirationExtensionProposalAcceptForFreeTrial = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  let config = defaultSubscriptionConfig alice bob expiresAt
  
  proposalCid <- submitMulti [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext processor dso)
      (SubscriptionFactory_CreateSubscriberProposal with
        config = config
        freeTrialExpiration = Some (AbsoluteExpiration freeTrialEndsAt))
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Left cid -> pure cid  -- FreeTrialSubscription
    Right _ -> error "Expected FreeTrialSubscription"
  
  newExpiresAt <- getExpirationTime 500
  extensionProposalCid <- submit bob do
    createCmd ExpirationExtensionProposal with
      subscriber = alice
      recipient = bob
      newExpiresAt = newExpiresAt
      subscriptionCid = Right subscriptionCid
  
  updatedCid <- submitMulti [alice, bob] [] do
    exerciseCmd extensionProposalCid ExpirationExtensionProposal_AcceptForFreeTrialSubscription with
      freeTrialSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Expiration should be extended" (updated.config.expiresAt == newExpiresAt)
  
  pure ()

