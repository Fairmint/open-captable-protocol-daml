-- | Test metadata change
testMetadataChange : Script ()
testMetadataChange = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  let newMetadata = Some (TM.fromList [("key", "value")])
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = None
        processorPaymentPerDay = None
        prepayWindow = None
        paymentsEndAt = None
        trialEndsAt = None
        description = None
        metadata = Some newMetadata
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = alice
      changes = changes
  
  -- Others approve
  changeProposalCid2 <- submit processor do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with actor = processor
  
  changeProposalCid3 <- submit bob do
    exerciseCmd changeProposalCid2 SubscriptionChangeProposal_Approve with actor = bob
  
  -- Apply
  updatedSubscriptionCid <- submit processor do
    exerciseCmd changeProposalCid3 SubscriptionChangeProposal_Apply with
      activeSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedSubscriptionCid
  assertMsg "Metadata should be updated" (updated.subscription.metadata == newMetadata)
  
  pure ()

-- | Test payment change
testPaymentChange : Script ()
testPaymentChange = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  let changes = SubscriptionChanges with
        subscriber = None
        recipient = None
        processor = None
        dso = None
        recipientProvider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = Some (Some (AmuletAmount 0.4))
        prepayWindow = None
        paymentsEndAt = None
        trialEndsAt = None
        description = None
        metadata = None
        processedAndPaidUntilAdjustment = None
        observers = None
  
  changeProposalCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      proposer = bob
      changes = changes
  
  -- Others approve
  changeProposalCid2 <- submit alice do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with actor = alice
  
  changeProposalCid3 <- submit processor do
    exerciseCmd changeProposalCid2 SubscriptionChangeProposal_Approve with actor = processor
  
  -- Apply
  updatedSubscriptionCid <- submit processor do
    exerciseCmd changeProposalCid3 SubscriptionChangeProposal_Apply with
      activeSubscriptionCid = subscriptionCid
  
  Some updated <- queryContractId alice updatedSubscriptionCid
  assertMsg "Recipient payment should be increased" (updated.subscription.recipientPaymentPerDay == AmuletAmount 2.0)
  assertMsg "Processor payment should be increased" (updated.subscription.processorPaymentPerDay == Some (AmuletAmount 0.4))
  
  pure ()

