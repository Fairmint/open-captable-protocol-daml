module Subscriptions.TestUtils where

import Daml.Script
import DA.Time (days, addRelTime)
import Splice.Api.FeaturedAppRightV1 qualified as Featured
import Splice.AmuletRules qualified
import Splice.Round qualified
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.Types.SubscriptionProposal (SubscriptionProposal(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Shared.TestUtils (setupTestEnv, TestEnv(..))

-- | Test-only FeaturedAppRight template for testing subscription updates
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with ..
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- | Helper to create a SubscriptionFactory
createSubscriptionFactory : Party -> Party -> Script (ContractId SubscriptionFactory)
createSubscriptionFactory processor dso = do
  submit processor do
    createCmd SubscriptionFactory with
      processorContext = ProcessorContext with ..

-- | Helper to create a subscription proposal (subscriber-initiated)
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createSubscriberProposal : Party -> Party -> Party -> SubscriptionProposal -> Script (ContractId ProposedSubscription)
createSubscriberProposal processor subscriber dso proposal = do
  submitMulti [subscriber, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext with ..)
      (SubscriptionFactory_CreateProposedSubscription with actor = subscriber; subscriptionProposal = proposal)

-- | Helper to create a recipient-initiated subscription proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createRecipientProposal : Party -> Party -> Party -> SubscriptionProposal -> Script (ContractId ProposedSubscription)
createRecipientProposal processor recipient dso proposal = do
  submitMulti [recipient, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext with ..)
      (SubscriptionFactory_CreateProposedSubscription with actor = recipient; subscriptionProposal = proposal)

-- | Helper to create a processor-initiated subscription proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction
createProcessorProposal : Party -> Party -> Party -> Party -> SubscriptionProposal -> Script (ContractId ProposedSubscription)
createProcessorProposal processor subscriber recipient dso proposal = do
  submit processor do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext with ..)
      (SubscriptionFactory_CreateProposedSubscription with actor = processor; subscriptionProposal = proposal)

-- | Helper to create default subscription proposal for testing
defaultSubscriptionProposal : Party -> Party -> Time -> SubscriptionProposal
defaultSubscriptionProposal subscriber recipient expiresAt = SubscriptionProposal with
  subscriber = subscriber
  recipient = recipient
  recipientProvider = None
  freeTrialExpiration = None
  recipientPaymentPerDay = AmuletAmount 1.0
  processorPaymentPerDay = Some (AmuletAmount 0.2)
  prepayWindow = None
  paymentsEndAt = Some (PerciseTime expiresAt)
  description = Some "Test subscription"
  metadata = None
  observers = []

-- | Helper to get expiration time for testing (days from now)
getExpirationTime : Int -> Script Time
getExpirationTime numDays = do
  now <- getTime
  pure (addRelTime now (days numDays))

-- | Standard test parties setup with test environment
data TestParties = TestParties with
    alice : Party
    bob : Party
    processor : Party
    dso : Party
    amuletRulesCid : ContractId Splice.AmuletRules.AmuletRules
    openRoundCid : ContractId Splice.Round.OpenMiningRound

-- | Allocate standard test parties
allocateTestParties : Script TestParties
allocateTestParties = do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  TestEnv{..} <- setupTestEnv
  pure TestParties with ..

