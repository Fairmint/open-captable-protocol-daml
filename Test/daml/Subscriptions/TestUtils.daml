module Subscriptions.TestUtils where

import Daml.Script
import DA.Time (days, addRelTime)
import Splice.Api.FeaturedAppRightV1 qualified as Featured
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.RecipientSubscriptionProposal
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionConfig(..), ProcessorContext(..), SubscriptionAmount(..))
import Shared.TestUtils (sharedDso)

-- | Test-only FeaturedAppRight template for testing subscription updates
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with ..
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- | Helper to create a SubscriptionFactory
createSubscriptionFactory : Party -> Script (ContractId SubscriptionFactory)
createSubscriptionFactory processor = do
  dso <- sharedDso
  submit processor do
    createCmd SubscriptionFactory with
      context = ProcessorContext with ..

-- | Helper to create a subscription proposal (subscriber-initiated)
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createSubscriberProposal : Party -> Party -> Party -> SubscriptionConfig -> Script (ContractId SubscriberSubscriptionProposal)
createSubscriberProposal processor subscriber dso config = do
  submitMulti [subscriber, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext with ..)
      (SubscriptionFactory_CreateSubscriberProposal with freeTrialEndsAt = None; ..)

-- | Helper to create a recipient-initiated subscription proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createRecipientProposal : Party -> Party -> Party -> SubscriptionConfig -> Script (ContractId RecipientSubscriptionProposal)
createRecipientProposal processor recipient dso config = do
  submitMulti [recipient, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext with ..)
      (SubscriptionFactory_CreateRecipientProposal with freeTrialEndsAt = None; ..)

-- | Helper to create default subscription config for testing
defaultSubscriptionConfig : Party -> Party -> Time -> SubscriptionConfig
defaultSubscriptionConfig subscriber recipient expiresAt = SubscriptionConfig with
  subscriber = subscriber
  recipient = recipient
  recipientPaymentPerDay = AmuletAmount 1.0
  processorPaymentPerDay = AmuletAmount 0.2
  prepayWindow = days 0
  expiresAt = expiresAt
  reason = Some "Test subscription"

-- | Helper to get expiration time for testing (days from now)
getExpirationTime : Int -> Script Time
getExpirationTime numDays = do
  now <- getTime
  pure (addRelTime now (days numDays))

-- | Standard test parties setup
data TestParties = TestParties with
    alice : Party
    bob : Party
    processor : Party
    dso : Party

-- | Allocate standard test parties
allocateTestParties : Script TestParties
allocateTestParties = do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  pure TestParties with ..

