module Subscriptions.TestUtils where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Api.FeaturedAppRightV1 (AppRewardBeneficiary(..))
import Splice.Api.FeaturedAppRightV1 qualified as Featured
import Splice.AmuletRules qualified
import Splice.Round qualified
import Splice.Amulet qualified
import Fairmint.Subscriptions.SubscriptionFactory qualified as Factory
import Fairmint.Subscriptions.ProposedSubscription qualified as Proposed
import Fairmint.Subscriptions.ActiveSubscription qualified as Active
import Fairmint.Subscriptions.Types.SubscriptionProposal (SubscriptionProposal(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Fairmint.Subscriptions.Types.LockFundsInput (LockFundsInput(..))
import Shared.TestUtils (setupTestEnv, TestEnv(..), tapWithDso, getAmuletRules)

-- | Test-only FeaturedAppRight template for testing subscription updates
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with ..
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- | Helper to create a SubscriptionFactory
createSubscriptionFactory : Party -> Party -> Script (ContractId Factory.SubscriptionFactory)
createSubscriptionFactory processor dso = do
  submit processor do
    createCmd Factory.SubscriptionFactory with
      processorContext = ProcessorContext with ..

-- | Helper to create a subscription proposal (subscriber-initiated)
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createSubscriberProposal : Party -> Party -> Party -> SubscriptionProposal -> Script (ContractId Proposed.ProposedSubscription)
createSubscriberProposal processor subscriber dso proposal = do
  result <- submitMulti [subscriber, processor] [] do
    createAndExerciseCmd
      (Factory.SubscriptionFactory with processorContext = ProcessorContext with ..)
      (Factory.SubscriptionFactory_CreateProposedSubscription with actor = subscriber; subscriptionProposal = proposal; Factory.lockFundsInput = None)
  case result of
    Left proposedCid -> pure proposedCid
    Right _ -> error "Expected ProposedSubscription but got ActiveSubscription"

-- | Helper to create a recipient-initiated subscription proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createRecipientProposal : Party -> Party -> Party -> SubscriptionProposal -> Script (ContractId Proposed.ProposedSubscription)
createRecipientProposal processor recipient dso proposal = do
  result <- submitMulti [recipient, processor] [] do
    createAndExerciseCmd
      (Factory.SubscriptionFactory with processorContext = ProcessorContext with ..)
      (Factory.SubscriptionFactory_CreateProposedSubscription with actor = recipient; subscriptionProposal = proposal; Factory.lockFundsInput = None)
  case result of
    Left proposedCid -> pure proposedCid
    Right _ -> error "Expected ProposedSubscription but got ActiveSubscription"

-- | Helper to create a processor-initiated subscription proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction
createProcessorProposal : Party -> Party -> Party -> Party -> SubscriptionProposal -> Script (ContractId Proposed.ProposedSubscription)
createProcessorProposal processor subscriber recipient dso proposal = do
  result <- submit processor do
    createAndExerciseCmd
      (Factory.SubscriptionFactory with processorContext = ProcessorContext with ..)
      (Factory.SubscriptionFactory_CreateProposedSubscription with actor = processor; subscriptionProposal = proposal; Factory.lockFundsInput = None)
  case result of
    Left proposedCid -> pure proposedCid
    Right _ -> error "Expected ProposedSubscription but got ActiveSubscription"

-- | Helper to create default subscription proposal for testing
defaultSubscriptionProposal : Party -> Party -> Time -> SubscriptionProposal
defaultSubscriptionProposal subscriber recipient expiresAt = SubscriptionProposal with
  subscriber = subscriber
  recipient = recipient
  provider = subscriber  -- Use subscriber as default provider
  appRewardBeneficiaries = [AppRewardBeneficiary subscriber 1.0]  -- Default to subscriber as sole beneficiary
  freeTrialExpiration = None
  recipientPaymentPerDay = AmuletAmount 1.0
  processorPaymentPerDay = Some (AmuletAmount 0.2)
  prepayWindow = days 0
  paymentsEndAt = Some (PreciseTime expiresAt)
  description = Some "Test subscription"
  metadata = None
  observers = []

-- | Helper to get expiration time for testing (days from now)
getExpirationTime : Int -> Script Time
getExpirationTime numDays = do
  now <- getTime
  pure (addRelTime now (days numDays))

-- | Standard test parties setup with test environment
data TestParties = TestParties with
    alice : Party
    bob : Party
    processor : Party
    dso : Party
    amuletRulesCid : ContractId Splice.AmuletRules.AmuletRules
    openRoundCid : ContractId Splice.Round.OpenMiningRound

-- | Allocate standard test parties
allocateTestParties : Script TestParties
allocateTestParties = do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  TestEnv{..} <- setupTestEnv
  pure TestParties with ..

-- | Helper to fully approve a proposal and return the ActiveSubscription
-- Handles the approval flow including escrow locking
approveProposalFully : ContractId Proposed.ProposedSubscription -> Party -> Party -> Party -> Party -> Script (ContractId Active.ActiveSubscription)
approveProposalFully proposalCid processor recipient subscriber dso = do
  -- Processor approves first
  proposedCid1 <- submit processor do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = processor
  
  -- Recipient approves next
  proposedCid2 <- submit recipient do
    exerciseCmd proposedCid1 Proposed.ProposedSubscription_Approve with 
      actor = recipient
  
  -- Create amulet for locking
  amuletCid <- tapWithDso dso subscriber 100.0
  
  -- Get payment context
  openRounds <- query @Splice.Round.OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Subscriber starts the subscription with funds
  -- Use readAs [dso] to provide visibility to DSO contracts
  (activeCid, _) <- submitMulti [subscriber] [dso] do
    exerciseCmd proposedCid2 Proposed.ProposedSubscription_StartSubscription with 
      lockFundsInput = LockFundsInput with
        amuletInputs = [amuletCid]
        amountToLock = 50.0
        paymentContext = PaymentContext with
          amuletRulesCid = amuletRulesCid
          openMiningRoundCid = openRoundCid
          featuredAppRight = None
  
  pure activeCid


