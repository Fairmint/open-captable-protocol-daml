module Subscriptions.TestValidation where

import Daml.Script
import DA.Time (days)
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionConfig(..), ProcessorContext(..), SubscriptionAmount(..), PaymentConfig(..))
import Subscriptions.TestUtils

-- | Test validation: negative amount not allowed
testNegativeAmountNotAllowed : Script ()
testNegativeAmountNotAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext processor dso)
      (SubscriptionFactory_CreateSubscriberProposal SubscriptionConfig with
        subscriber = alice
        recipient = bob
        recipientPayment = PaymentConfig with
          amountPerDay = AmuletAmount (-5.0)
          featuredAppRight = None
        processorPayment = PaymentConfig with
          amountPerDay = AmuletAmount 1.0
          featuredAppRight = None
        prepayWindow = days 0
        expiresAt = expiresAt
        freeTrialEndsAt = None
        reason = Some "Service")
  
  pure ()

-- | Test validation: negative fee not allowed
testNegativeFeeNotAllowed : Script ()
testNegativeFeeNotAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext processor dso)
      (SubscriptionFactory_CreateSubscriberProposal SubscriptionConfig with
        subscriber = alice
        recipient = bob
        recipientPayment = PaymentConfig with
          amountPerDay = AmuletAmount 5.0
          featuredAppRight = None
        processorPayment = PaymentConfig with
          amountPerDay = AmuletAmount (-1.0)
          featuredAppRight = None
        prepayWindow = days 0
        expiresAt = expiresAt
        freeTrialEndsAt = None
        reason = Some "Service")
  
  pure ()

-- | Test validation: zero fee is allowed
testZeroFeeAllowed : Script ()
testZeroFeeAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        processorPayment = PaymentConfig with
          amountPerDay = AmuletAmount 0.0
          featuredAppRight = None
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  Some proposal <- queryContractId alice proposalCid
  assertMsg "Fee should be 0.0" (proposal.config.processorPayment.amountPerDay == AmuletAmount 0.0)
  
  pure ()

-- | Test validation: empty string reason not allowed when Some is provided
testEmptyStringReasonNotAllowed : Script ()
testEmptyStringReasonNotAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext processor dso)
      (SubscriptionFactory_CreateSubscriberProposal SubscriptionConfig with
        subscriber = alice
        recipient = bob
        recipientPayment = PaymentConfig with
          amountPerDay = AmuletAmount 5.0
          featuredAppRight = None
        processorPayment = PaymentConfig with
          amountPerDay = AmuletAmount 1.0
          featuredAppRight = None
        prepayWindow = days 0
        expiresAt = expiresAt
        freeTrialEndsAt = None
        reason = Some "")
  
  pure ()

-- | Test validation: None reason is allowed
testNoneReasonAllowed : Script ()
testNoneReasonAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        reason = None
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  Some proposal <- queryContractId alice proposalCid
  assertMsg "Reason should be None" (proposal.config.reason == None)
  
  pure ()

-- | Test validation: subscriber and recipient must be different
testSubscriberRecipientMustBeDifferent : Script ()
testSubscriberRecipientMustBeDifferent = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with context = ProcessorContext processor dso)
      (SubscriptionFactory_CreateSubscriberProposal SubscriptionConfig with
        subscriber = alice
        recipient = alice  -- Same as subscriber
        recipientPayment = PaymentConfig with
          amountPerDay = AmuletAmount 5.0
          featuredAppRight = None
        processorPayment = PaymentConfig with
          amountPerDay = AmuletAmount 1.0
          featuredAppRight = None
        prepayWindow = days 0
        expiresAt = expiresAt
        freeTrialEndsAt = None
        reason = Some "Service")
  
  pure ()

