  pure ()

-- | Test validation: zero fee is allowed
testZeroFeeAllowed : Script ()
testZeroFeeAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        processorPaymentPerDay = Some (AmuletAmount 0.0)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  Some proposedSub <- queryContractId alice proposalCid
  assertMsg "Fee should be 0.0" (proposedSub.subscriptionProposal.processorPaymentPerDay == Some (AmuletAmount 0.0))
  
  pure ()

-- | Test validation: subscriber and recipient must be different
testSubscriberRecipientMustBeDifferent : Script ()
testSubscriberRecipientMustBeDifferent = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext processor dso)
      (SubscriptionFactory_CreateProposedSubscription with
        actor = alice
        subscriptionProposal = SubscriptionProposal with
          subscriber = alice
          recipient = alice  -- Same as subscriber
          provider = alice
          appRewardBeneficiaries = []
          freeTrialExpiration = None
          recipientPaymentPerDay = AmuletAmount 5.0
          processorPaymentPerDay = Some (AmuletAmount 1.0)
          prepayWindow = days 0
          paymentsEndAt = Some (PreciseTime expiresAt)
          description = Some "Service"
          metadata = None
          observers = [])
  
  pure ()

