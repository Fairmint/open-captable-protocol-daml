module Subscriptions.TestValidation where

import Daml.Script
import DA.Time (days)
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.Types.SubscriptionProposal (SubscriptionProposal(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test validation: negative amount not allowed
testNegativeAmountNotAllowed : Script ()
testNegativeAmountNotAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext processor dso)
      (SubscriptionFactory_CreateProposedSubscription with
        actor = alice
        subscriptionProposal = SubscriptionProposal with
          subscriber = alice
          recipient = bob
          provider = alice
          appRewardBeneficiaries = []
          freeTrialExpiration = None
          recipientPaymentPerDay = AmuletAmount (-5.0)
          processorPaymentPerDay = Some (AmuletAmount 1.0)
          prepayWindow = days 0
          paymentsEndAt = Some (PreciseTime expiresAt)
          description = Some "Service"
          metadata = None
          observers = [])
  
  pure ()

-- | Test validation: negative fee not allowed
testNegativeFeeNotAllowed : Script ()
testNegativeFeeNotAllowed = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  submitMultiMustFail [alice, processor] [] do
    createAndExerciseCmd
