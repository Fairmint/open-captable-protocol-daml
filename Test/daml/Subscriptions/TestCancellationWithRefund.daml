module Subscriptions.TestCancellationWithRefund where

import Daml.Script
import DA.Time (days)
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Subscriptions.TestUtils

-- | Test recipient canceling with refund
testRecipientCancelWithRefund : Script ()
testRecipientCancelWithRefund = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        prepayWindow = Some (days 7)  -- Allow prepaying for 7 days
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Cancel subscription
  maybeUpdatedCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = bob
      disregardAvailablePaidPeriod = False
      description = Some "Canceling with refund test"
  
  pure ()

-- | Test recipient canceling without refund
testRecipientCancelWithoutRefund : Script ()
testRecipientCancelWithoutRefund = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        prepayWindow = Some (days 7)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Cancel subscription without refund
  maybeUpdatedCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = bob
      disregardAvailablePaidPeriod = True  -- Don't keep prepaid time
      description = None
  
  case maybeUpdatedCid of
    None -> pure ()  -- Expected - archived immediately
    Some _ -> error "Expected subscription to be archived"
  
  pure ()

-- | Test recipient canceling when no prepaid time (immediate cancel)
testRecipientCancelImmediate : Script ()
testRecipientCancelImmediate = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Test immediate cancellation (when processedAndPaidUntil <= now, subscription archives immediately)
  maybeUpdatedCid <- submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = bob
      disregardAvailablePaidPeriod = False
      description = None
  
  -- Verify subscription is archived (no prepaid time, so returns None)
  case maybeUpdatedCid of
    None -> pure ()  -- Expected
    Some _ -> error "Expected subscription to be archived immediately"
  
  pure ()

