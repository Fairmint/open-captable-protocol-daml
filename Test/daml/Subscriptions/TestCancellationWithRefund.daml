module Subscriptions.TestCancellationWithRefund where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round (OpenMiningRound)
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Subscriptions
import Shared.TestUtils (tapWithDso, getAmuletRules)
import Subscriptions.TestUtils

-- | Test recipient canceling with refund
testRecipientCancelWithRefund : Script ()
testRecipientCancelWithRefund = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        prepayWindow = days 7  -- Allow prepaying for 7 days
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Extract PaidSubscription contract ID
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- Process a payment to create prepaid time
  amuletRulesCid <- getAmuletRules dso
  bobAmulets <- tapWithDso bob 100.0
  let bobAmuletCid = head bobAmulets
  
  openMiningRoundCids <- query @OpenMiningRound dso
  assertMsg "Expected at least one open mining round" (not (null openMiningRoundCids))
  let (openMiningRoundCid, _) = head openMiningRoundCids
  
  -- Process payment for 1 day
  submit processor do
    exerciseCmd subscriptionCid PaidSubscription_ProcessPayment with
      processingPeriod = days 1
      paymentCtx = PaymentContext with
        amuletInputs = [bobAmuletCid]
        ..
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
  
  -- Now recipient cancels with refund
  bobRefundAmulets <- tapWithDso bob 100.0
  
  result <- submit bob do
    exerciseCmd subscriptionCid PaidSubscription_CancelByRecipient with
      refund = True
      refundPaymentCtx = Some PaymentContext with
        amuletInputs = bobRefundAmulets
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openMiningRoundCid
  
  -- Verify subscription was canceled with refund
  case result.result of
    CancelWithRefund transferResult -> do
      -- Refund was processed successfully
      pure ()
    _ -> assertFail "Expected CancelWithRefund result"
  
  -- Verify subscription is archived
  subscription <- queryContractId bob subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)

-- | Test recipient canceling without refund
testRecipientCancelWithoutRefund : Script ()
testRecipientCancelWithoutRefund = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        prepayWindow = days 7
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- Process a payment to create prepaid time
  amuletRulesCid <- getAmuletRules dso
  bobAmulets <- tapWithDso bob 100.0
  let bobAmuletCid = head bobAmulets
  
  openMiningRoundCids <- query @OpenMiningRound dso
  let (openMiningRoundCid, _) = head openMiningRoundCids
  
  submit processor do
    exerciseCmd subscriptionCid PaidSubscription_ProcessPayment with
      processingPeriod = days 1
      paymentCtx = PaymentContext with
        amuletInputs = [bobAmuletCid]
        ..
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
  
  -- Recipient cancels without refund
  result <- submit bob do
    exerciseCmd subscriptionCid PaidSubscription_CancelByRecipient with
      refund = False
      refundPaymentCtx = None
  
  -- Verify PrepaidCanceledSubscription was created
  case result.result of
    CancelWithPrepaid prepaidCid -> do
      Some prepaid <- queryContractId bob prepaidCid
      assertMsg "Canceled by should be recipient" (prepaid.canceledBy == bob)
    _ -> assertFail "Expected CancelWithPrepaid result"

-- | Test recipient canceling when no prepaid time (immediate cancel)
testRecipientCancelImmediate : Script ()
testRecipientCancelImmediate = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- Cancel immediately without any prepaid time
  result <- submit bob do
    exerciseCmd subscriptionCid PaidSubscription_CancelByRecipient with
      refund = False
      refundPaymentCtx = None
  
  -- Verify immediate cancellation (no prepaid contract created)
  case result.result of
    CancelImmediate -> pure ()
    _ -> assertFail "Expected CancelImmediate result"
  
  -- Verify subscription is archived
  subscription <- queryContractId bob subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)

