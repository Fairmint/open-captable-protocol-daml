module Subscriptions.TestCancellationWithRefund where

import Daml.Script
import DA.Time (days)
import Fairmint.Subscriptions.Creation.ProposedSubscription
import Fairmint.Subscriptions.Active.Subscriptions
import Subscriptions.TestUtils

-- | Test recipient canceling with refund
testRecipientCancelWithRefund : Script ()
testRecipientCancelWithRefund = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        prepayWindow = Some (days 7)  -- Allow prepaying for 7 days
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  processorApprovedCid <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  fullyApprovedCid <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  result <- submit bob do
    exerciseCmd fullyApprovedCid ProposedSubscription_CreateSubscription with actor = bob
  
  -- Extract PaidSubscription contract ID
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription, got FreeTrialSubscription"
  
  -- TODO: This test needs to be rewritten for the new cancellation/refund flow
  -- The new flow creates a PrepaidCanceledSubscription and uses PrepaidCanceledSubscription_RecipientRefundAndArchive
  pure ()

-- | Test recipient canceling without refund
testRecipientCancelWithoutRefund : Script ()
testRecipientCancelWithoutRefund = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        prepayWindow = Some (days 7)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  processorApprovedCid <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  fullyApprovedCid <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  result <- submit bob do
    exerciseCmd fullyApprovedCid ProposedSubscription_CreateSubscription with actor = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- TODO: This test needs to be rewritten for the new cancellation/refund flow
  pure ()

-- | Test recipient canceling when no prepaid time (immediate cancel)
testRecipientCancelImmediate : Script ()
testRecipientCancelImmediate = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorApprovedCid <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  fullyApprovedCid <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  result <- submit bob do
    exerciseCmd fullyApprovedCid ProposedSubscription_CreateSubscription with actor = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- Test immediate cancellation (when paidUntil <= now, subscription archives immediately)
  submit bob do
    exerciseCmd subscriptionCid PaidSubscription_CancelByRecipient with
      reason = None
  
  -- Verify subscription is archived
  subscription <- queryContractId bob subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()
