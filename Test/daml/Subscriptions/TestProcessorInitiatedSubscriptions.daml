module Subscriptions.TestProcessorInitiatedSubscriptions where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription qualified as Proposed
import Subscriptions.TestUtils

-- | Test ProcessorSubscriptionProposal Archive
testProcessorSubscriptionProposalArchive : Script ()
testProcessorSubscriptionProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = defaultSubscriptionProposal alice bob expiresAt
  proposalCid <- createProcessorProposal processor alice bob dso proposal
  
  submitMulti [processor] [alice, bob] do
    archiveCmd proposalCid
  
  pure ()

-- | Test OnePartyApprovedProcessorSubscriptionProposal Archive
-- Processor creates proposal (auto-approved), recipient approves, then archive
testOnePartyApprovedProcessorSubscriptionProposalArchive : Script ()
testOnePartyApprovedProcessorSubscriptionProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = defaultSubscriptionProposal alice bob expiresAt
  proposalCid <- createProcessorProposal processor alice bob dso proposal
  
  -- Recipient approves (processor is already approved as initiator)
  approvedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = bob
  
  submitMulti [processor, bob] [alice] do
    archiveCmd approvedCid
  
  pure ()
