module Subscriptions.TestSubscriberInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Subscriptions
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test the full happy path: factory → proposal → approval → acceptance
testFactoryProposalAcceptance : Script ()
testFactoryProposalAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  result <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Result is Either FreeTrialSubscription PaidSubscription - should be Right (PaidSubscription) since no trial
  case result.subscription of
    Right subscriptionCid -> do
      Some subscription <- queryContractId alice subscriptionCid
      assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
      assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
      assertMsg "Processor should match" (subscription.context.processor == processor)
      assertMsg "Amount per day should be 1.0" (subscription.config.recipientPayment.amountPerDay == AmuletAmount 1.0)
      assertMsg "Fee amount per day should be 0.2" (subscription.config.processorPayment.amountPerDay == AmuletAmount 0.2)
    Left _ -> assertFail "Expected PaidSubscription, got FreeTrialSubscription"
  
  pure ()

-- | Test proposal rejection by recipient (before processor approval)
testProposalRejectionByRecipient : Script ()
testProposalRejectionByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  submit bob do
    exerciseCmd proposalCid SubscriptionProposal_RecipientReject
  
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test proposal rejection by processor
testProposalRejectionByProcessor : Script ()
testProposalRejectionByProcessor = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorReject
  
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

