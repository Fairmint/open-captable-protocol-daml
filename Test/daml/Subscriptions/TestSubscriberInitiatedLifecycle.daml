module Subscriptions.TestSubscriberInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.Creation.ProposedSubscription
import Fairmint.Subscriptions.Active.Subscriptions
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test the full happy path: factory → proposal → approval → acceptance
testFactoryProposalAcceptance : Script ()
testFactoryProposalAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorApprovedCid <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  fullyApprovedCid <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  result <- submit bob do
    exerciseCmd fullyApprovedCid ProposedSubscription_CreateSubscription with actor = bob
  
  -- Result is Either FreeTrialSubscription PaidSubscription - should be Right (PaidSubscription) since no trial
  case result.subscription of
    Right subscriptionCid -> do
      Some subscription <- queryContractId alice subscriptionCid
      assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
      assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
      assertMsg "Processor should match" (subscription.context.processor == processor)
      assertMsg "Amount per day should be 1.0" (subscription.config.recipientPaymentPerDay == AmuletAmount 1.0)
      assertMsg "Fee amount per day should be 0.2" (subscription.config.processorPaymentPerDay == Some (AmuletAmount 0.2))
    Left _ -> assertFail "Expected PaidSubscription, got FreeTrialSubscription"
  
  pure ()

-- | Test proposal rejection by recipient (before processor approval)
testProposalRejectionByRecipient : Script ()
testProposalRejectionByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  submit bob do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = bob; reason = None
  
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

