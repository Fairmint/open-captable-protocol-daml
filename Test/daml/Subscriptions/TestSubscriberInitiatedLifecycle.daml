module Subscriptions.TestSubscriberInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test the full happy path: factory → proposal → approval → acceptance
testFactoryProposalAcceptance : Script ()
testFactoryProposalAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid  -- Subscription automatically created
    Left _ -> error "Expected subscription to be created"
  
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.subscription.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.subscription.recipient == bob)
  assertMsg "Processor should match" (subscription.processorContext.processor == processor)
  assertMsg "Amount per day should be 1.0" (subscription.subscription.recipientPaymentPerDay == AmuletAmount 1.0)
  assertMsg "Fee amount per day should be 0.2" (subscription.subscription.processorPaymentPerDay == Some (AmuletAmount 0.2))
  
  pure ()

-- | Test proposal rejection by recipient (before processor approval)
testProposalRejectionByRecipient : Script ()
testProposalRejectionByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  submit bob do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = bob; description = None
  
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

