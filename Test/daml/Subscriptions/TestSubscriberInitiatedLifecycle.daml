-- | Test processor withdrawing after approval (but before recipient accepts)
testProcessorApprovedProposalProcessorWithdraw : Script ()
testProcessorApprovedProposalProcessorWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  submit processor do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_ProcessorWithdraw
  
  pure ()

