-- | Test cancellation by subscriber (after subscription is active)
testCancelBySubscriber : Script ()
testCancelBySubscriber = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorApprovedCid <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  fullyApprovedCid <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  result <- submit bob do
    exerciseCmd fullyApprovedCid ProposedSubscription_CreateSubscription with actor = bob
  
  -- Extract PaidSubscription contract ID
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  submit alice do
    exerciseCmd subscriptionCid PaidSubscription_CancelBySubscriber with
      reason = None
  
  subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()

