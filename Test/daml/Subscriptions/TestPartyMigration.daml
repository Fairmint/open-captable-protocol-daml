module Subscriptions.TestPartyMigration where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.PartyMigrationProposal
import Fairmint.Subscriptions.Types.PartyRole (PartyRole(..))
import Subscriptions.TestUtils

-- | Test PartyMigrationProposal_Approve by old party
testPartyMigrationProposalApproveOldParty : Script ()
testPartyMigrationProposalApproveOldParty = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create migration proposal (initiated by new party)
  proposalCid <- submitMulti [newSubscriber] [alice] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = False
      newPartyApproved = True
  
  -- Old party approves
  approvedCid <- submit alice do
    exerciseCmd proposalCid PartyMigrationProposal_Approve with
      actor = alice
  
  pure ()

-- | Test PartyMigrationProposal_Approve by new party
testPartyMigrationProposalApproveNewParty : Script ()
testPartyMigrationProposalApproveNewParty = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create migration proposal (initiated by old party)
  proposalCid <- submitMulti [alice] [newSubscriber] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = False
  
  -- New party approves
  approvedCid <- submit newSubscriber do
    exerciseCmd proposalCid PartyMigrationProposal_Approve with
      actor = newSubscriber
  
  pure ()

-- | Test PartyMigrationProposal_Archive
testPartyMigrationProposalArchive : Script ()
testPartyMigrationProposalArchive = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create migration proposal
  proposalCid <- submitMulti [alice] [newSubscriber] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = False
  
  -- Old party withdraws
  submit alice do
    exerciseCmd proposalCid PartyMigrationProposal_Archive with
      actor = alice
      description = Some "Changed my mind"
  
  pure ()

-- NOTE: Active subscription migration tests removed due to complexity with locked amulet visibility
-- These need to be rewritten to properly handle amulet escrow, visibility, and stakeholder requirements

-- | Test PartyMigrationProposal_MigrateProposedSubscription for subscriber
testMigrateProposedSubscriptionSubscriber : Script ()
testMigrateProposedSubscriptionSubscriber = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create proposed subscription
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [alice, newSubscriber] [] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration
  newProposalCid <- submit alice do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateProposedSubscription with
      actor = alice
      proposedSubscriptionCid = proposalCid
  
  pure ()

-- | Test PartyMigrationProposal_MigrateProposedSubscription for recipient
testMigrateProposedSubscriptionRecipient : Script ()
testMigrateProposedSubscriptionRecipient = script do
  TestParties{..} <- allocateTestParties
  newRecipient <- allocateParty "NewBob"
  
  -- Create proposed subscription
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [bob, newRecipient] [] do
    createCmd PartyMigrationProposal with
      partyType = Recipient
      oldParty = bob
      newParty = newRecipient
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration
  newProposalCid <- submit bob do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateProposedSubscription with
      actor = bob
      proposedSubscriptionCid = proposalCid
  
  pure ()

-- | Test ProposedSubscription_ChangeParty for subscriber (via migration proposal)
testProposedSubscriptionChangePartySubscriber : Script ()
testProposedSubscriptionChangePartySubscriber = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create proposed subscription
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Directly exercise ChangeParty choice (requires both old and new party authorization)
  newProposalCid <- submitMulti [alice, newSubscriber] [] do
    exerciseCmd proposalCid ProposedSubscription_ChangeParty with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
  
  pure ()

-- | Test ActiveSubscription_ChangeParty for subscriber
-- Tests directly changing a party in an active subscription
testActiveSubscriptionChangeParty : Script ()
testActiveSubscriptionChangeParty = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Change subscriber from alice to newSubscriber
  newSubscriptionCid <- submitMulti [alice, newSubscriber] [] do
    exerciseCmd subscriptionCid ActiveSubscription_ChangeParty with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
  
  Some updatedSubscription <- queryContractId newSubscriber newSubscriptionCid
  assertMsg "Subscriber should be newSubscriber" (updatedSubscription.subscription.subscriber == newSubscriber)
  
  pure ()

-- | Test PartyMigrationProposal_MigrateActiveSubscription
-- Tests migrating an active subscription through a migration proposal
testPartyMigrationProposalMigrateActiveSubscription : Script ()
testPartyMigrationProposalMigrateActiveSubscription = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [alice, newSubscriber] [] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration to active subscription
  newSubscriptionCid <- submit alice do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateActiveSubscription with
      actor = alice
      activeSubscriptionCid = subscriptionCid
  
  Some updatedSubscription <- queryContractId newSubscriber newSubscriptionCid
  assertMsg "Subscriber should be newSubscriber" (updatedSubscription.subscription.subscriber == newSubscriber)
  
  pure ()

-- | Test archiving PartyMigrationProposal using implicit Archive choice
-- This exercises the implicit Archive that all templates have
testPartyMigrationProposalImplicitArchive : Script ()
testPartyMigrationProposalImplicitArchive = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create fully approved migration proposal (both parties are signatories)
  proposalCid <- submitMulti [alice, newSubscriber] [] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Archive using implicit Archive choice (requires both signatories)
  submitMulti [alice, newSubscriber] [] do
    exerciseCmd proposalCid Archive
  
  pure ()

