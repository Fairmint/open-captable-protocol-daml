module Subscriptions.TestPartyMigration where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.PartyMigrationProposal
import Fairmint.Subscriptions.Types.PartyRole (PartyRole(..))
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Subscriptions.TestUtils
import Shared.TestUtils (tapWithDso)

-- | Test PartyMigrationProposal_Approve by old party
testPartyMigrationProposalApproveOldParty : Script ()
testPartyMigrationProposalApproveOldParty = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create migration proposal (initiated by new party)
  proposalCid <- submitMulti [newSubscriber] [alice] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = False
      newPartyApproved = True
  
  -- Old party approves
  approvedCid <- submit alice do
    exerciseCmd proposalCid PartyMigrationProposal_Approve with
      actor = alice
  
  pure ()

-- | Test PartyMigrationProposal_Approve by new party
testPartyMigrationProposalApproveNewParty : Script ()
testPartyMigrationProposalApproveNewParty = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create migration proposal (initiated by old party)
  proposalCid <- submitMulti [alice] [newSubscriber] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = False
  
  -- New party approves
  approvedCid <- submit newSubscriber do
    exerciseCmd proposalCid PartyMigrationProposal_Approve with
      actor = newSubscriber
  
  pure ()

-- | Test PartyMigrationProposal_Archive
testPartyMigrationProposalArchive : Script ()
testPartyMigrationProposalArchive = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create migration proposal
  proposalCid <- submitMulti [alice] [newSubscriber] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = False
  
  -- Old party withdraws
  submit alice do
    exerciseCmd proposalCid PartyMigrationProposal_Archive with
      actor = alice
      description = Some "Changed my mind"
  
  pure ()

-- | Test PartyMigrationProposal_MigrateActiveSubscription for subscriber
testMigrateActiveSubscriptionSubscriber : Script ()
testMigrateActiveSubscriptionSubscriber = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create active subscription
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with
      actor = processor
      subscriberAmulets = []
      amountToLock = 0.0
      paymentContext = None
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  -- Tap amulet for final approval
  amulet <- tapWithDso dso alice 100.0
  let paymentCtx = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with
      actor = bob
      subscriberAmulets = [amulet]
      amountToLock = 50.0
      paymentContext = Some paymentCtx
  
  subscriptionCid <- case result2 of
    Right (cid, _changeAmulet) -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [alice, newSubscriber] [] do
    createCmd PartyMigrationProposal with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration
  newSubscriptionCid <- submit alice do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateActiveSubscription with
      actor = alice
      activeSubscriptionCid = subscriptionCid
  
  pure ()

