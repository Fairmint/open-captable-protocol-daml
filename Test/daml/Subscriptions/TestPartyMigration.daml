-- | Test ProposedSubscription_ChangeParty for subscriber (via migration proposal)
testProposedSubscriptionChangePartySubscriber : Script ()
testProposedSubscriptionChangePartySubscriber = script do
  TestParties{..} <- allocateTestParties
  newSubscriber <- allocateParty "NewAlice"
  
  -- Create proposed subscription
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Directly exercise ChangeParty choice (requires both old and new party authorization)
  newProposalCid <- submitMulti [alice, newSubscriber] [] do
    exerciseCmd proposalCid ProposedSubscription_ChangeParty with
      partyType = Subscriber
      oldParty = alice
      newParty = newSubscriber
  
  pure ()

