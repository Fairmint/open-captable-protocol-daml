module Subscriptions.TestPartyMigration where

import Daml.Script
import DA.Time (days, addRelTime)
import Subscriptions.TestUtils
import Fairmint.Subscriptions.PartyMigrationProposal
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.SubscriptionProposal (SubscriptionProposal(..))
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.PartyRole (PartyRole(..))

-- | Test creating a party migration proposal
testCreateMigrationProposal : Script ()
testCreateMigrationProposal = do
  TestParties{..} <- allocateTestParties
  aliceNew <- allocateParty "AliceNew"
  
  -- Create migration proposal (alice approves first)
  unapprovedCid <- submit alice do
    createCmd PartyMigrationProposal with
      oldParty = alice
      newParty = aliceNew
      partyRole = SubscriberRole
      oldPartyApproved = True
      newPartyApproved = False
      description = Some "Migrating Alice to new account"
  
  -- Verify unapproved proposal exists
  proposal <- queryContractId alice unapprovedCid
  assertMsg "Unapproved proposal should exist" (isSome proposal)
  
  -- AliceNew approves
  approvedCid <- submit aliceNew do
    exerciseCmd unapprovedCid (PartyMigrationProposal_Approve aliceNew)
  
  -- Verify approved proposal exists
  approvedProposal <- queryContractId alice approvedCid
  assertMsg "Approved proposal should exist" (isSome approvedProposal)

-- | Test migrating subscriber in an active subscription
testMigrateSubscriberInActiveSubscription : Script ()
testMigrateSubscriberInActiveSubscription = do
  TestParties{..} <- allocateTestParties
  aliceNew <- allocateParty "AliceNew"
  expiresAt <- getExpirationTime 30
  
  -- Create and activate a subscription with Alice as subscriber
  let proposal = defaultSubscriptionProposal alice bob expiresAt
  proposedCid <- createSubscriberProposal processor alice dso proposal
  
  -- Bob approves to activate
  result <- submit bob do
    exerciseCmd proposedCid (ProposedSubscription_Approve bob)
  
  activeCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected active subscription"
  
  -- Create and approve migration proposal
  unapprovedCid <- submit alice do
    createCmd PartyMigrationProposal with
      oldParty = alice
      newParty = aliceNew
      partyRole = SubscriberRole
      oldPartyApproved = True
      newPartyApproved = False
      description = Some "Migrating subscriber"
  
  migrationProposalCid <- submit aliceNew do
    exerciseCmd unapprovedCid (PartyMigrationProposal_Approve aliceNew)
  
  -- Use migration proposal to migrate the subscription (nonconsuming)
  migratedCid <- submit processor do
    exerciseCmd migrationProposalCid (PartyMigrationProposal_MigrateActiveSubscription processor activeCid)
  
  -- Verify the subscription was migrated
  Some migratedSubscription <- queryContractId processor migratedCid
  assertMsg "Subscriber should be migrated" (migratedSubscription.subscription.subscriber == aliceNew)
  
  -- Verify original subscription is archived
  originalSubscription <- queryContractId processor activeCid
  assertMsg "Original subscription should be archived" (isNone originalSubscription)
  
  -- Verify migration proposal still exists (nonconsuming)
  migrationProposal <- queryContractId alice migrationProposalCid
  assertMsg "Migration proposal should still exist" (isSome migrationProposal)

-- | Test migrating recipient in an active subscription
testMigrateRecipientInActiveSubscription : Script ()
testMigrateRecipientInActiveSubscription = do
  TestParties{..} <- allocateTestParties
  bobNew <- allocateParty "BobNew"
  expiresAt <- getExpirationTime 30
  
  -- Create and activate a subscription with Bob as recipient
  let proposal = defaultSubscriptionProposal alice bob expiresAt
  proposedCid <- createSubscriberProposal processor alice dso proposal
  
  result <- submit bob do
    exerciseCmd proposedCid (ProposedSubscription_Approve bob)
  
  activeCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected active subscription"
  
  -- Create and approve migration proposal
  unapprovedCid <- submit bob do
    createCmd PartyMigrationProposal with
      oldParty = bob
      newParty = bobNew
      partyRole = RecipientRole
      oldPartyApproved = True
      newPartyApproved = False
      description = Some "Migrating recipient"
  
  migrationProposalCid <- submit bobNew do
    exerciseCmd unapprovedCid (PartyMigrationProposal_Approve bobNew)
  
  -- Migrate the subscription
  migratedCid <- submit alice do
    exerciseCmd migrationProposalCid (PartyMigrationProposal_MigrateActiveSubscription alice activeCid)
  
  -- Verify the subscription was migrated
  Some migratedSubscription <- queryContractId alice migratedCid
  assertMsg "Recipient should be migrated" (migratedSubscription.subscription.recipient == bobNew)

