module Subscriptions.TestFeaturedAppRight where

import Daml.Script
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Subscriptions
import Subscriptions.TestUtils

-- | Test recipient can update their own FeaturedAppRight
testRecipientUpdatesFeaturedAppRight : Script ()
testRecipientUpdatesFeaturedAppRight = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Bob
  bobFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = bob
  
  -- Bob updates their own FeaturedAppRight
  updatedSubscriptionCid <- submit bob do
    exerciseCmd subscriptionCid Subscription_UpdateRecipientFeaturedAppRight with
      newFeaturedAppRight = Some (coerceContractId bobFarCid)
  
  -- Verify update
  Some updatedSub <- queryContractId bob updatedSubscriptionCid
  assertMsg "Recipient FeaturedAppRight should be updated" 
    (updatedSub.config.recipientPayment.featuredAppRight == Some (coerceContractId bobFarCid))
  
  -- Bob removes their FeaturedAppRight
  finalSubscriptionCid <- submit bob do
    exerciseCmd updatedSubscriptionCid Subscription_UpdateRecipientFeaturedAppRight with
      newFeaturedAppRight = None
  
  -- Verify removal
  Some finalSub <- queryContractId bob finalSubscriptionCid
  assertMsg "Recipient FeaturedAppRight should be None" 
    (finalSub.config.recipientPayment.featuredAppRight == None)
  
  pure ()

-- | Test processor can update their own FeaturedAppRight
testProcessorUpdatesFeaturedAppRight : Script ()
testProcessorUpdatesFeaturedAppRight = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Processor
  processorFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = processor
  
  -- Processor updates their own FeaturedAppRight
  updatedSubscriptionCid <- submit processor do
    exerciseCmd subscriptionCid Subscription_UpdateProcessorFeaturedAppRight with
      newFeaturedAppRight = Some (coerceContractId processorFarCid)
  
  -- Verify update
  Some updatedSub <- queryContractId alice updatedSubscriptionCid
  assertMsg "Processor FeaturedAppRight should be updated" 
    (updatedSub.config.processorPayment.featuredAppRight == Some (coerceContractId processorFarCid))
  
  pure ()

-- | Test processor can set recipient's FeaturedAppRight
testProcessorSetsRecipientFeaturedAppRight : Script ()
testProcessorSetsRecipientFeaturedAppRight = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Bob
  bobFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = bob
  
  -- Get disclosure for the FeaturedAppRight so processor can validate it
  Some bobFarDisclosure <- queryDisclosure bob bobFarCid
  
  -- Processor sets recipient's FeaturedAppRight with explicit disclosure
  let coercedBobFarCid = coerceContractId bobFarCid
  updatedSubscriptionCid <- submitWithDisclosures processor [bobFarDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessorSetRecipientFeaturedAppRight with
      newFeaturedAppRight = coercedBobFarCid
  
  -- Verify update
  Some updatedSub <- queryContractId alice updatedSubscriptionCid
  assertMsg "Recipient FeaturedAppRight should be updated by processor" 
    (updatedSub.config.recipientPayment.featuredAppRight == Some coercedBobFarCid)
  
  pure ()

-- | Test validation: recipient cannot use processor's FeaturedAppRight
testRecipientCannotUseWrongFeaturedAppRight : Script ()
testRecipientCannotUseWrongFeaturedAppRight = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Processor (not Bob)
  processorFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = processor
  
  -- Bob tries to use processor's FeaturedAppRight (should fail)
  submitMustFail bob do
    exerciseCmd subscriptionCid Subscription_UpdateRecipientFeaturedAppRight with
      newFeaturedAppRight = Some (coerceContractId processorFarCid)
  
  pure ()

-- | Test validation: processor cannot use recipient's FeaturedAppRight
testProcessorCannotUseWrongFeaturedAppRight : Script ()
testProcessorCannotUseWrongFeaturedAppRight = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Bob (not Processor)
  bobFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = bob
  
  -- Processor tries to use Bob's FeaturedAppRight for themselves (should fail)
  submitMustFail processor do
    exerciseCmd subscriptionCid Subscription_UpdateProcessorFeaturedAppRight with
      newFeaturedAppRight = Some (coerceContractId bobFarCid)
  
  pure ()

-- | Test validation: processor cannot set wrong FeaturedAppRight for recipient
testProcessorCannotSetWrongFeaturedAppRightForRecipient : Script ()
testProcessorCannotSetWrongFeaturedAppRightForRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Processor (not Bob)
  processorFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = processor
  
  -- Processor tries to set their own FeaturedAppRight for recipient (should fail)
  submitMustFail processor do
    exerciseCmd subscriptionCid Subscription_ProcessorSetRecipientFeaturedAppRight with
      newFeaturedAppRight = coerceContractId processorFarCid
  
  pure ()

