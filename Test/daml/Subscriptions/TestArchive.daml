-- | Test ActiveSubscription_ArchiveInactiveSubscription with prepaid time
-- After processing a payment and canceling, wait for prepaid time to pass and archive
testArchiveInactiveSubscriptionWithPrepaidTime : Script ()
testArchiveInactiveSubscriptionWithPrepaidTime = script do
  TestParties{..} <- allocateTestParties
  
  -- Create and approve subscription with smaller processing period
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 10.0
        processorPaymentPerDay = Some (AmuletAmount 2.0)
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Alice creates amulet for payment
  amuletCid <- tapWithDso dso alice 100.0
  
  -- Get payment context
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Process immediately to create 1 day of prepaid time
  -- Get disclosures
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Process payment to create prepaid time
  paymentResult <- submitWithDisclosures processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingContext = ProcessingContext with
        processorProvider = processor
        processingPeriod = days 1  -- Process just 1 day to keep amounts manageable
        recipientProvider = Some bob
        recipientFeaturedAppRight = None
        processorFeaturedAppRight = None
      paymentContext = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
  
  let updatedSubscriptionCid = paymentResult.subscriptionCid
  
  -- Verify the subscription has prepaid time (processedAndPaidUntil is in the future)
  Some updatedSub <- queryContractId alice updatedSubscriptionCid
  now4 <- getTime
  assertMsg "Should have prepaid time" (updatedSub.processedAndPaidUntil > now4)
  
  -- Cancel the subscription (should return Some because processedAndPaidUntil > now)
  maybeCanceledCid <- submit alice do
    exerciseCmd updatedSubscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Canceling subscription"
  
  canceledCid <- case maybeCanceledCid of
    Some cid -> pure cid
    None -> error "Expected canceled subscription with prepaid time"
  
  -- Wait for prepaid time to pass (wait 2 days since we have 1 day prepaid)
  now3 <- getTime
  setTime (addRelTime now3 (days 2))
  
  -- Archive the inactive subscription using the custom choice
  submit alice do
    exerciseCmd canceledCid ActiveSubscription_ArchiveInactiveSubscription with
      actor = alice
  
  pure ()
