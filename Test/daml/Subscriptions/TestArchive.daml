module Subscriptions.TestArchive where

import Daml.Script
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.RecipientSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedRecipientInitiatedSubscriptionProposal ()
import Subscriptions.TestUtils

-- | Test SubscriptionFactory Archive choice
testSubscriptionFactoryArchive : Script ()
testSubscriptionFactoryArchive = script do
  TestParties{..} <- allocateTestParties
  factoryCid <- createSubscriptionFactory processor
  
  submit processor do
    archiveCmd factoryCid
  
  pure ()

-- | Test SubscriptionProposal Archive choice
testSubscriptionProposalArchive : Script ()
testSubscriptionProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  submitMulti [alice, processor] [bob] do
    archiveCmd proposalCid
  
  pure ()

-- | Test ProcessorApprovedSubscriptionProposal Archive choice
testProcessorApprovedProposalArchive : Script ()
testProcessorApprovedProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  submitMulti [alice, processor] [bob] do
    archiveCmd approvedProposalCid
  
  pure ()

-- | Test Subscription Archive choice
testSubscriptionArchive : Script ()
testSubscriptionArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  submitMulti [alice, bob] [processor] do
    archiveCmd subscriptionCid
  
  pure ()

-- | Test RecipientInitiatedSubscriptionProposal Archive choice
testRecipientInitiatedSubscriptionProposalArchive : Script ()
testRecipientInitiatedSubscriptionProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  submitMulti [bob, processor] [alice] do
    archiveCmd proposalCid
  
  pure ()

-- | Test ProcessorApprovedRecipientInitiatedSubscriptionProposal Archive choice
testProcessorApprovedRecipientInitiatedProposalArchive : Script ()
testProcessorApprovedRecipientInitiatedProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid RecipientInitiatedSubscriberSubscriptionProposal_ProcessorApprove
  
  submitMulti [bob, processor] [alice] do
    archiveCmd approvedProposalCid
  
  pure ()
