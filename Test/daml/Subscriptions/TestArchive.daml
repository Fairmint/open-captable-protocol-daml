-- | Test ProcessorApprovedRecipientInitiatedSubscriptionProposal Archive choice
testProcessorApprovedRecipientInitiatedProposalArchive : Script ()
testProcessorApprovedRecipientInitiatedProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = processor
  
  submitMulti [bob, processor] [alice] do
    archiveCmd approvedProposalCid
  
  pure ()

-- | Test Active.ActiveSubscription_ArchiveInactiveSubscription choice
-- Tests archiving a canceled subscription after the prepaid period has passed
testActiveSubscriptionArchiveInactive : Script ()
testActiveSubscriptionArchiveInactive = script do
  TestParties{..} <- allocateTestParties
  
  -- Create subscription that expires in 30 days
  now <- getTime
  let expiresAt = addRelTime now (days 30)
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = Some (AmuletAmount 0.5)
        paymentsEndAt = Some (PreciseTime expiresAt)
        prepayWindow = days 15  -- Allow processing up to 15 days ahead
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Process a payment to advance processedAndPaidUntil
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Advance 7 days and process payment for 10 days
  let paymentTime = addRelTime now (days 7)
  setTime paymentTime
  
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid Active.ActiveSubscription_ProcessPayment with
      processingPeriod = days 10  -- Process 10 days ahead
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = True
  
  -- Cancel the subscription (keep prepaid period)
  -- processedAndPaidUntil is now day 17 (day 7 + 10 days)
  -- Cancel at day 8 (after payment processing, but before processedAndPaidUntil)
  let cancelTime = addRelTime now (days 8)
  setTime cancelTime
  
  (Some canceledCid, _) <- submitMulti [alice] [dso] do
    exerciseCmd result.subscriptionCid Active.ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False  -- Keep prepaid period
      description = Some "Testing cancellation"
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
  
  -- Verify subscription has been canceled
  Some canceled <- queryContractId alice canceledCid
  assertMsg "Should be in canceled state" (canceled.subscription.paymentsEndAt <= Some cancelTime)
  
  -- Wait for prepaid period to pass
  -- processedAndPaidUntil is at day 11 (day 1 + 10 days)
  -- We need to wait until after day 11
  let archiveTime = addRelTime now (days 12)
  setTime archiveTime
  
  -- Now archive the inactive subscription (any party can do this)
  unlockedAmuletCid <- submitMulti [alice] [dso] do
    exerciseCmd canceledCid Active.ActiveSubscription_ArchiveInactiveSubscription with
      actor = alice
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
  
  -- Verify the subscription was archived
  archivedSub <- queryContractId alice canceledCid
  assertMsg "Subscription should be archived" (archivedSub == None)
  
  -- Verify the locked amulet was returned
  Some unlockedAmulet <- queryContractId alice unlockedAmuletCid
  assertMsg "Amulet should belong to subscriber" (unlockedAmulet.owner == alice)
  
  pure ()

-- | Test Active.ActiveSubscription_Refund choice
-- Tests recipient refunding prepaid time after cancellation
testActiveSubscriptionRefund : Script ()
testActiveSubscriptionRefund = script do
  TestParties{..} <- allocateTestParties
  
  -- Create subscription
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = Some (AmuletAmount 0.5)
        prepayWindow = days 15  -- Allow processing up to 15 days ahead
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Process a payment to advance processedAndPaidUntil
  let paymentTime = addRelTime now (days 7)
  setTime paymentTime
  
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid Active.ActiveSubscription_ProcessPayment with
      processingPeriod = days 10  -- Process 10 days ahead
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = True
  
  -- Cancel subscription (keep prepaid period)
  -- processedAndPaidUntil is now day 11 (day 1 + 10 days)
  -- Cancel at day 8 (after payment at day 7, but before processedAndPaidUntil at day 11)
  let cancelTime = addRelTime now (days 8)
  setTime cancelTime
  
  (Some canceledCid, _) <- submitMulti [alice] [dso] do
    exerciseCmd result.subscriptionCid Active.ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Testing cancellation for refund"
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
  
  -- Verify subscription has prepaid time (processedAndPaidUntil > now)
  Some canceled <- queryContractId bob canceledCid
  assertMsg "Should have prepaid time" (canceled.processedAndPaidUntil > cancelTime)
  assertMsg "Payments should have ended" (canceled.subscription.paymentsEndAt <= Some cancelTime)
  
  -- Create amulets for recipient to refund with
  recipientAmuletCid <- tapWithDso dso bob 100.0
  
  -- Recipient refunds the prepaid period
  (refundResult, unlockedAmuletCid) <- submitMulti [bob] [dso] do
    exerciseCmd canceledCid Active.ActiveSubscription_Refund with
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      recipientAmuletInputs = [recipientAmuletCid]
      recipientFeaturedAppRight = None
  
  -- Verify the subscription was archived
  archivedSub <- queryContractId bob canceledCid
  assertMsg "Subscription should be archived after refund" (archivedSub == None)
  
  -- Verify locked amulet was returned to subscriber
  Some unlockedAmulet <- queryContractId alice unlockedAmuletCid
  assertMsg "Amulet should belong to subscriber" (unlockedAmulet.owner == alice)
  
  -- Verify refund was processed (check that some amulets were transferred)
  assertMsg "Refund should have created amulets" (not (null refundResult.createdAmulets))
  
  pure ()
