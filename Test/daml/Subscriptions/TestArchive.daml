module Subscriptions.TestArchive where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round (OpenMiningRound)
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Fairmint.Subscriptions.Types.ProcessingContext (ProcessingContext(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Shared.TestUtils (tapWithDso, getAmuletRules)
import Subscriptions.TestUtils

-- | Test SubscriptionFactory Archive choice
testSubscriptionFactoryArchive : Script ()
testSubscriptionFactoryArchive = script do
  TestParties{..} <- allocateTestParties
  factoryCid <- createSubscriptionFactory processor dso
  
  submit processor do
    archiveCmd factoryCid
  
  pure ()

-- | Test SubscriptionProposal Archive choice
testSubscriptionProposalArchive : Script ()
testSubscriptionProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  submitMulti [alice, processor] [bob] do
    archiveCmd proposalCid
  
  pure ()

-- | Test ProcessorApprovedSubscriptionProposal Archive choice
testProcessorApprovedProposalArchive : Script ()
testProcessorApprovedProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  approvedProposalCid <- case result of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  submitMulti [alice, processor] [bob] do
    archiveCmd approvedProposalCid
  
  pure ()

-- | Test Subscription Archive choice
testSubscriptionArchive : Script ()
testSubscriptionArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  approvedProposalCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd approvedProposalCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid  -- All parties approved, subscription created
    Left _ -> error "Expected subscription to be created"
  
  submitMulti [alice, bob, processor] [] do
    archiveCmd subscriptionCid
  
  pure ()

