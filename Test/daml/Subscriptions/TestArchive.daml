-- | Test ActiveSubscription_ArchiveInactiveSubscription
-- Cancel subscription and wait for time to pass, then archive
testArchiveInactiveSubscriptionWithPrepaidTime : Script ()
testArchiveInactiveSubscriptionWithPrepaidTime = script do
  TestParties{..} <- allocateTestParties
  
  -- Create and approve subscription
  expiresAt <- getExpirationTime 365
  let proposal = defaultSubscriptionProposal alice bob expiresAt
  proposalCid <- createSubscriberProposal processor alice dso proposal
  
  result1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case result1 of
    Left cid -> pure cid
    Right _ -> error "Expected more approvals needed"
  
  result2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result2 of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Wait 1 day to simulate time passing
  now2 <- getTime
  setTime (addRelTime now2 (days 1))
  
  -- Cancel the subscription (returns Some because we haven't passed processedAndPaidUntil yet)
  maybeCanceledCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Canceling subscription"
  
  canceledCid <- case maybeCanceledCid of
    Some cid -> pure cid
    None -> error "Expected canceled subscription"
  
  -- Wait for the canceled time to pass (paymentsEndAt is now set to cancel time)
  -- Since processedAndPaidUntil was creation time and we're past that, we can archive
  now3 <- getTime
  setTime (addRelTime now3 (days 1))
  
  -- Archive the inactive subscription using the custom choice
  submit alice do
    exerciseCmd canceledCid ActiveSubscription_ArchiveInactiveSubscription with
      actor = alice
  
  pure ()
