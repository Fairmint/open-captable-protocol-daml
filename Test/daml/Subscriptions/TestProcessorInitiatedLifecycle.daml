testProcessorProposalRecipientFirstAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  recipientResult <- submit bob do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = bob
  
  recipientApprovedCid <- case recipientResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  result <- submit alice do
    exerciseCmd recipientApprovedCid ProposedSubscription_Approve with actor = alice
  
  subscriptionCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.subscription.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.subscription.recipient == bob)
  assertMsg "Processor should match" (subscription.processorContext.processor == processor)
  
  pure ()

-- | Test processor withdrawing initial proposal (before any party accepts)
testProcessorWithdrawBeforeAcceptance : Script ()
testProcessorWithdrawBeforeAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  submit processor do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

