module Subscriptions.TestProcessorInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test the full happy path: subscriber accepts first, then recipient accepts
testProcessorProposalSubscriberFirstAcceptance : Script ()
testProcessorProposalSubscriberFirstAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriberResult <- submit alice do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = alice
  
  subscriberApprovedCid <- case subscriberResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  result <- submit bob do
    exerciseCmd subscriberApprovedCid ProposedSubscription_Approve with actor = bob
  
  subscriptionCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.subscription.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.subscription.recipient == bob)
  assertMsg "Processor should match" (subscription.processorContext.processor == processor)
  assertMsg "Amount per day should be 1.0" (subscription.subscription.recipientPaymentPerDay == AmuletAmount 1.0)
  assertMsg "Fee amount per day should be 0.2" (subscription.subscription.processorPaymentPerDay == Some (AmuletAmount 0.2))
  
  pure ()

-- | Test the full happy path: recipient accepts first, then subscriber accepts
