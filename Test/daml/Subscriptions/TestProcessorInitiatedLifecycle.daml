-- | Test cancellation by subscriber after full acceptance
testCancelBySubscriberAfterProcessorProposal : Script ()
testCancelBySubscriberAfterProcessorProposal = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  onePartyApprovedCid <- submit alice do
    exerciseCmd proposalCid ProcessorSubscriptionProposal_SubscriberAccept
  
  result <- submit bob do
    exerciseCmd onePartyApprovedCid OnePartyApprovedProcessorSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  -- Extract PaidSubscription contract ID
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  submit alice do
    exerciseCmd subscriptionCid PaidSubscription_CancelBySubscriber with
      reason = None
  
  subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()

