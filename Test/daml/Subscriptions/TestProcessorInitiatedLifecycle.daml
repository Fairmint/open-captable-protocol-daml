-- | Test subscriber rejecting after recipient approved (processor already approved as initiator)
testRecipientRejectAfterSubscriberAccepted : Script ()
testRecipientRejectAfterSubscriberAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Recipient approves
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = bob
  
  -- Subscriber rejects (note: subscribers cannot approve, but they can reject/withdraw)
  submit alice do
    exerciseCmd recipientApprovedCid Proposed.ProposedSubscription_Withdraw with actor = alice; description = None
  
  proposal <- queryContractId alice recipientApprovedCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test subscriber rejecting after recipient accepted
testSubscriberRejectAfterRecipientAccepted : Script ()
testSubscriberRejectAfterRecipientAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = bob
  
  submit alice do
    exerciseCmd recipientApprovedCid Proposed.ProposedSubscription_Withdraw with actor = alice; description = None
  
  proposal <- queryContractId alice recipientApprovedCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

