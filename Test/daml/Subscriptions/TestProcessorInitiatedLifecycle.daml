-- | Test processor withdrawing after recipient accepted (processor is already approved as initiator)
testProcessorWithdrawAfterSubscriberAccepted : Script ()
testProcessorWithdrawAfterSubscriberAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Recipient approves (processor already approved as initiator)
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = bob
  
  submit processor do
    exerciseCmd recipientApprovedCid Proposed.ProposedSubscription_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor recipientApprovedCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test processor withdrawing after recipient accepted (but before subscriber accepts)
testProcessorWithdrawAfterRecipientAccepted : Script ()
testProcessorWithdrawAfterRecipientAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedSubscription_Approve with 
      actor = bob
  
  submit processor do
    exerciseCmd recipientApprovedCid Proposed.ProposedSubscription_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor recipientApprovedCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

