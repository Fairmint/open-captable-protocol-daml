  result <- submit alice do
    exerciseCmd fullyApprovedCid ProposedSubscription_CreateSubscription with actor = alice
  
  -- Result is Either FreeTrialSubscription PaidSubscription - should be Right (PaidSubscription) since no trial
  case result.subscription of
    Right subscriptionCid -> do
      Some subscription <- queryContractId alice subscriptionCid
      assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
      assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
      assertMsg "Processor should match" (subscription.context.processor == processor)
    Left _ -> assertFail "Expected PaidSubscription, got FreeTrialSubscription"
  
  pure ()

-- | Test processor withdrawing initial proposal (before any party accepts)
testProcessorWithdrawBeforeAcceptance : Script ()
testProcessorWithdrawBeforeAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  submit processor do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = processor; reason = None
  
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

