module Subscriptions.TestProcessorInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.Creation.ProcessorSubscriptionProposal
import Fairmint.Subscriptions.Creation.OnePartyApprovedProcessorSubscriptionProposal
import Fairmint.Subscriptions.Active.Subscriptions
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionAmount(..))
import Subscriptions.TestUtils

-- | Test the full happy path: subscriber accepts first, then recipient accepts
testProcessorProposalSubscriberFirstAcceptance : Script ()
testProcessorProposalSubscriberFirstAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  onePartyApprovedCid <- submit alice do
    exerciseCmd proposalCid ProcessorSubscriptionProposal_SubscriberAccept
  
  result <- submit bob do
    exerciseCmd onePartyApprovedCid OnePartyApprovedProcessorSubscriptionProposal_RecipientAccept with
      recipientProvider = bob
  
  -- Result is Either FreeTrialSubscription PaidSubscription - should be Right (PaidSubscription) since no trial
  case result.subscription of
    Right subscriptionCid -> do
      Some subscription <- queryContractId alice subscriptionCid
      assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
      assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
      assertMsg "Processor should match" (subscription.context.processor == processor)
      assertMsg "Amount per day should be 1.0" (subscription.config.recipientPaymentPerDay == AmuletAmount 1.0)
      assertMsg "Fee amount per day should be 0.2" (subscription.config.processorPaymentPerDay == AmuletAmount 0.2)
    Left _ -> assertFail "Expected PaidSubscription, got FreeTrialSubscription"
  
  pure ()

