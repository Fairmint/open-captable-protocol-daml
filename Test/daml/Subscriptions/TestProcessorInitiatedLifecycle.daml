-- | Test processor withdrawing after subscriber accepted (but before recipient accepts)
testProcessorWithdrawAfterSubscriberAccepted : Script ()
testProcessorWithdrawAfterSubscriberAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorProposal processor alice bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriberResult <- submit alice do
    exerciseCmd proposalCid ProposedSubscription_Approve with 
      actor = alice
      subscriberAmulets = []
      amountToLock = 0.0
      paymentContext = None
  
  subscriberApprovedCid <- case subscriberResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  submit processor do
    exerciseCmd subscriberApprovedCid ProposedSubscription_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor subscriberApprovedCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

