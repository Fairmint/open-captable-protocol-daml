-- | Test processor withdrawing after approval (but before subscriber accepts)
testProcessorApprovedRecipientProposalProcessorWithdraw : Script ()
testProcessorApprovedRecipientProposalProcessorWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid RecipientSubscriptionProposal_ProcessorApprove
  
  -- Processor withdraws their approval
  submit processor do
    exerciseCmd approvedProposalCid ProcessorApprovedRecipientInitiatedSubscriptionProposal_ProcessorWithdraw with reason = None
  
  pure ()

-- | Test cancellation flows work the same for recipient-initiated subscriptions
-- Once accepted, recipient-initiated subscriptions become regular Subscriptions
testRecipientInitiatedCancellationBySubscriber : Script ()
testRecipientInitiatedCancellationBySubscriber = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid RecipientSubscriptionProposal_ProcessorApprove
  
  result <- submit alice do
    exerciseCmd approvedProposalCid ProcessorApprovedRecipientInitiatedSubscriptionProposal_SubscriberAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- Alice (subscriber) can cancel
  submit alice do
    exerciseCmd subscriptionCid PaidSubscription_CancelBySubscriber with
      reason = None
  
  subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()

-- | Test cancellation by recipient on recipient-initiated subscription
testRecipientInitiatedCancellationByRecipient : Script ()
testRecipientInitiatedCancellationByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid RecipientSubscriptionProposal_ProcessorApprove
  
  result <- submit alice do
    exerciseCmd approvedProposalCid ProcessorApprovedRecipientInitiatedSubscriptionProposal_SubscriberAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- Bob (recipient) can cancel without refund
  submit bob do
    exerciseCmd subscriptionCid PaidSubscription_CancelByRecipient with
      reason = None
  
  subscription <- queryContractId bob subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()

