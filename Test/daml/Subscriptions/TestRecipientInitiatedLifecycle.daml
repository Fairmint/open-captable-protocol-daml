module Subscriptions.TestRecipientInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.RecipientSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedRecipientInitiatedSubscriptionProposal
import Fairmint.Subscriptions.Subscriptions
import Subscriptions.TestUtils

-- | Test the full happy path: recipient creates proposal → processor approves → subscriber accepts
testRecipientProposalAcceptance : Script ()
testRecipientProposalAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates the proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  -- Processor approves the proposal
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid RecipientSubscriptionProposal_ProcessorApprove
  
  -- Alice (subscriber) accepts the approved proposal
  result <- submit alice do
    exerciseCmd approvedProposalCid ProcessorApprovedRecipientInitiatedSubscriptionProposal_SubscriberAccept with
      recipientProvider = bob
  
  subscriptionCid <- case result.subscription of
    Right cid -> pure cid
    Left _ -> assertFail "Expected PaidSubscription"
  
  -- Verify subscription was created
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
  assertMsg "Processor should match" (subscription.context.processor == processor)
  
  pure ()

-- | Test subscriber rejecting recipient's proposal (before processor approval)
testRecipientProposalRejectionBySubscriber : Script ()
testRecipientProposalRejectionBySubscriber = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  -- Alice (subscriber) rejects before processor approval
  submit alice do
    exerciseCmd proposalCid RecipientSubscriptionProposal_SubscriberReject with reason = None
  
  -- Verify proposal is archived
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test recipient withdrawing their own proposal (before processor approval)
testRecipientProposalWithdrawByRecipient : Script ()
testRecipientProposalWithdrawByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  -- Bob withdraws before processor approval
  submit bob do
    exerciseCmd proposalCid RecipientSubscriptionProposal_RecipientWithdraw with reason = None
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test processor rejecting recipient's proposal
testRecipientProposalProcessorReject : Script ()
testRecipientProposalProcessorReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  -- Processor rejects
  submit processor do
    exerciseCmd proposalCid RecipientSubscriptionProposal_ProcessorReject with reason = None
  
  -- Verify proposal is archived
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test subscriber rejecting after processor approval
testProcessorApprovedRecipientProposalSubscriberReject : Script ()
testProcessorApprovedRecipientProposalSubscriberReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionConfig alice bob expiresAt)
  
  -- Processor approves
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid RecipientSubscriptionProposal_ProcessorApprove
  
  -- Alice (subscriber) rejects after processor approval
  submit alice do
    exerciseCmd approvedProposalCid ProcessorApprovedRecipientInitiatedSubscriptionProposal_SubscriberReject with reason = None
  
  pure ()

