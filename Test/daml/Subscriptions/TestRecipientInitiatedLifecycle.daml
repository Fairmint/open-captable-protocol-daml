module Subscriptions.TestRecipientInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.ActiveSubscription
import Subscriptions.TestUtils

-- | Test the full happy path: recipient creates proposal → processor approves → subscriber accepts
testRecipientProposalAcceptance : Script ()
testRecipientProposalAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates the proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Processor approves the proposal
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  -- Alice (subscriber) approves - this creates the subscription
  result <- submit alice do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = alice
  
  subscriptionCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Verify subscription was created
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.subscription.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.subscription.recipient == bob)
  assertMsg "Processor should match" (subscription.processorContext.processor == processor)
  
  pure ()

-- | Test subscriber rejecting recipient's proposal (before processor approval)
testRecipientProposalRejectionBySubscriber : Script ()
testRecipientProposalRejectionBySubscriber = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Alice (subscriber) rejects before processor approval
  submit alice do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = alice; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test recipient withdrawing their own proposal (before processor approval)
testRecipientProposalWithdrawByRecipient : Script ()
testRecipientProposalWithdrawByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Bob withdraws before processor approval
  submit bob do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = bob; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test processor rejecting recipient's proposal
testRecipientProposalProcessorReject : Script ()
testRecipientProposalProcessorReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Processor rejects
  submit processor do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = processor; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test subscriber rejecting after processor approval
