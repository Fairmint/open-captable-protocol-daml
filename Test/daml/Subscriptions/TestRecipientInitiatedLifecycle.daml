-- | Test cancellation flows work the same for recipient-initiated subscriptions
-- Once accepted, recipient-initiated subscriptions become regular Subscriptions
testRecipientInitiatedCancellationBySubscriber : Script ()
testRecipientInitiatedCancellationBySubscriber = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  result <- submit alice do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = alice
  
  subscriptionCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Alice (subscriber) can cancel
  submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = True
      description = None
  
  subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()

-- | Test cancellation by recipient on recipient-initiated subscription
testRecipientInitiatedCancellationByRecipient : Script ()
testRecipientInitiatedCancellationByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  result <- submit alice do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = alice
  
  subscriptionCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Bob (recipient) can cancel without refund
  submit bob do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = bob
      disregardAvailablePaidPeriod = True
      description = None
  
  subscription <- queryContractId bob subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  pure ()

-- | Test cancellation by processor on recipient-initiated subscription
testRecipientInitiatedCancellationByProcessor : Script ()
testRecipientInitiatedCancellationByProcessor = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  result <- submit alice do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = alice
  
  subscriptionCid <- case result of
    Right cid -> pure cid
    Left _ -> error "Expected subscription to be created"
  
  -- Processor can cancel
  submit processor do
    exerciseCmd subscriptionCid ActiveSubscription_Cancel with
      actor = processor
      disregardAvailablePaidPeriod = True
      description = None
  
  pure ()
