testProcessorApprovedRecipientProposalSubscriberReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Processor approves
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  approvedProposalCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  -- Alice (subscriber) rejects after processor approval
  submit alice do
    exerciseCmd approvedProposalCid ProposedSubscription_Withdraw with actor = alice; description = None
  
  pure ()

