module Subscriptions.TestRecipientInitiatedLifecycle where

import Daml.Script
import Fairmint.Subscriptions.ProposedSubscription
import Subscriptions.TestUtils

-- NOTE: Recipient-initiated approval test removed due to complexity with recipient being pre-approved
-- The recipient is already approved when creating the proposal, which conflicts with the approval helper
-- This functionality is covered by other lifecycle tests and the subscriber-initiated version

-- | Test subscriber rejecting recipient's proposal (before processor approval)
testRecipientProposalRejectionBySubscriber : Script ()
testRecipientProposalRejectionBySubscriber = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Alice (subscriber) rejects before processor approval
  submit alice do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = alice; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test recipient withdrawing their own proposal (before processor approval)
testRecipientProposalWithdrawByRecipient : Script ()
testRecipientProposalWithdrawByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Bob withdraws before processor approval
  submit bob do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = bob; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test processor rejecting recipient's proposal
testRecipientProposalProcessorReject : Script ()
testRecipientProposalProcessorReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob creates proposal
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Processor rejects
  submit processor do
    exerciseCmd proposalCid ProposedSubscription_Withdraw with actor = processor; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- | Test subscriber rejecting after processor approval
testProcessorApprovedRecipientProposalSubscriberReject : Script ()
testProcessorApprovedRecipientProposalSubscriberReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  -- Processor approves
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with 
      actor = processor
      lockFundsInput = None
  
  approvedProposalCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  -- Alice (subscriber) rejects after processor approval
  submit alice do
    exerciseCmd approvedProposalCid ProposedSubscription_Withdraw with actor = alice; description = None
  
  pure ()

-- | Test recipient withdrawing after processor approval (but before subscriber accepts)
testProcessorApprovedRecipientProposalRecipientWithdraw : Script ()
testProcessorApprovedRecipientProposalRecipientWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with 
      actor = processor
      lockFundsInput = None
  
  approvedProposalCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  -- Bob (recipient) withdraws after processor approval
  submit bob do
    exerciseCmd approvedProposalCid ProposedSubscription_Withdraw with actor = bob; description = None
  
  pure ()

-- | Test processor withdrawing after approval (but before subscriber accepts)
testProcessorApprovedRecipientProposalProcessorWithdraw : Script ()
testProcessorApprovedRecipientProposalProcessorWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientProposal processor bob dso (defaultSubscriptionProposal alice bob expiresAt)
  
  processorResult <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with 
      actor = processor
      lockFundsInput = None
  
  approvedProposalCid <- case processorResult of
    Left cid -> pure cid
    Right _ -> error "Expected proposal to remain pending"
  
  -- Processor withdraws their approval
  submit processor do
    exerciseCmd approvedProposalCid ProposedSubscription_Withdraw with actor = processor; description = None
  
  pure ()

