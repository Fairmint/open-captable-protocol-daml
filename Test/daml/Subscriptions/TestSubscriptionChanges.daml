module Subscriptions.TestSubscriptionChanges where

import Daml.Script
import DA.Time (days, addRelTime)
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.SubscriptionChanges (SubscriptionChanges(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Subscriptions.TestUtils

-- | Test ActiveSubscription_ProposeChanges
-- Tests proposing changes to an active subscription
testProposeChanges : Script ()
testProposeChanges = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Propose changes to the subscription
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      actor = alice
      subscriptionChanges = SubscriptionChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"
  
  Some changeProposal <- queryContractId alice changeProposalCid
  assertMsg "Change proposal should exist" True
  
  pure ()

-- | Test SubscriptionChangeProposal_Approve
-- Tests approving a subscription change proposal
testApproveChangeProposal : Script ()
testApproveChangeProposal = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      actor = alice
      subscriptionChanges = SubscriptionChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"
  
  -- Bob approves the changes
  approvedCid <- submit bob do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with
      actor = bob
  
  Some approvedProposal <- queryContractId bob approvedCid
  assertMsg "Approval should be recorded" True
  
  pure ()

-- | Test SubscriptionChangeProposal_Apply
-- Tests applying approved changes to an active subscription
testApplyChangeProposal : Script ()
testApplyChangeProposal = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      actor = alice
      subscriptionChanges = SubscriptionChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"
  
  -- Bob and processor approve the changes
  approvedCid1 <- submit bob do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Approve with
      actor = bob
  
  approvedCid2 <- submit processor do
    exerciseCmd approvedCid1 SubscriptionChangeProposal_Approve with
      actor = processor
  
  -- Apply the changes
  updatedSubscriptionCid <- submit alice do
    exerciseCmd approvedCid2 SubscriptionChangeProposal_Apply with
      actor = alice
      activeSubscriptionCid = subscriptionCid
  
  Some updatedSubscription <- queryContractId alice updatedSubscriptionCid
  assertMsg "Payment per day should be updated" (updatedSubscription.subscription.recipientPaymentPerDay == AmuletAmount 2.0)
  
  pure ()

-- | Test SubscriptionChangeProposal_Reject
-- Tests rejecting a subscription change proposal
testRejectChangeProposal : Script ()
testRejectChangeProposal = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      actor = alice
      subscriptionChanges = SubscriptionChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"
  
  -- Bob rejects the changes
  submit bob do
    exerciseCmd changeProposalCid SubscriptionChangeProposal_Reject with
      actor = bob
      description = Some "I don't agree with this change"
  
  changeProposal <- queryContractId bob changeProposalCid
  assertMsg "Change proposal should be archived" (changeProposal == None)
  
  pure ()

-- | Test archiving SubscriptionChangeProposal using implicit Archive choice
testArchiveChangeProposal : Script ()
testArchiveChangeProposal = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionProposal alice bob expiresAt)
  
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd subscriptionCid ActiveSubscription_ProposeChanges with
      actor = alice
      subscriptionChanges = SubscriptionChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"
  
  -- Archive using implicit Archive choice (requires all signatories)
  submitMulti [alice, bob, processor] [] do
    exerciseCmd changeProposalCid Archive
  
  changeProposal <- queryContractId alice changeProposalCid
  assertMsg "Change proposal should be archived" (changeProposal == None)
  
  pure ()

