module Subscriptions.TestDebug where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round (OpenMiningRound)
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Shared.TestUtils (getAmuletRules)
import Subscriptions.TestUtils

-- Debug test to see actual values
testDebugPayment : Script ()
testDebugPayment = script do
  TestParties{..} <- allocateTestParties
  
  -- Create a subscription
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = Some (AmuletAmount 0.5)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get the subscription and check locked amulet
  Some sub <- queryContractId alice subscriptionCid
  Some lockedAmulet <- queryContractId alice sub.lockedAmuletCid
  
  debug ("Locked amulet initial amount: " <> show lockedAmulet.amulet.amount.initialAmount)
  debug ("Locked amulet created at round: " <> show lockedAmulet.amulet.amount.createdAt.number)
  debug ("Locked amulet rate per round: " <> show lockedAmulet.amulet.amount.ratePerRound.rate)
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  let (openRoundCid, openRound) = head currentOpenRounds
  
  debug ("Current round number: " <> show openRound.round.number)
  
  -- Advance time
  setTime (addRelTime now (days 7))
  
  -- Try to process payment
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = True
  
  -- Check the stats
  Some updatedSub <- queryContractId alice result.subscriptionCid
  debug ("Stats - Subscriber paid CC: " <> show updatedSub.stats.totalPaidBySubscriberCC)
  debug ("Stats - Recipient received CC: " <> show updatedSub.stats.totalReceivedByRecipientCC)
  debug ("Stats - Processor received CC: " <> show updatedSub.stats.totalReceivedByProcessorCC)
  
  pure ()

