module Subscriptions.TestPaymentStats where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round (OpenMiningRound)
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Fairmint.Subscriptions.Types.SubscriptionAmount (SubscriptionAmount(..))
import Shared.TestUtils (getAmuletRules)
import Subscriptions.TestUtils

-- | Test stats tracking with recipient payment only (no processor fee)
-- Verifies that totalPaidBySubscriber >= totalReceivedByRecipient due to transaction fees
testStatsRecipientOnlyPayment : Script ()
testStatsRecipientOnlyPayment = script do
  TestParties{..} <- allocateTestParties
  
  -- Create a subscription with only recipient payment
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = None  -- No processor fee
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Check initial stats
  Some initialSub <- queryContractId alice subscriptionCid
  assertMsg "Initial rounds should be 0" (initialSub.stats.roundsProcessed == 0)
  assertMsg "Initial subscriber CC should be 0" (initialSub.stats.totalPaidBySubscriberCC == 0.0)
  assertMsg "Initial recipient CC should be 0" (initialSub.stats.totalReceivedByRecipientCC == 0.0)
  assertMsg "Initial processor CC should be 0" (initialSub.stats.totalReceivedByProcessorCC == 0.0)
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Advance time and process payment
  setTime (addRelTime now (days 7))
  
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  -- Verify stats were updated
  Some updatedSub <- queryContractId alice result.subscriptionCid
  let stats = updatedSub.stats
  
  -- Verify rounds incremented
  assertMsg "Rounds should increment by 1" (stats.roundsProcessed == 1)
  
  -- Verify amounts tracked
  assertMsg "Subscriber CC should be positive" (stats.totalPaidBySubscriberCC > 0.0)
  assertMsg "Recipient CC should be positive" (stats.totalReceivedByRecipientCC > 0.0)
  assertMsg "Processor CC should be 0 (no fee)" (stats.totalReceivedByProcessorCC == 0.0)
  
  -- Key assertion: paid amount should be >= received due to transaction fees
  -- Fees cause drift between amount paid and amount received
  assertMsg "Subscriber paid >= recipient received (fees cause drift)" 
    (stats.totalPaidBySubscriberCC >= stats.totalReceivedByRecipientCC)
  
  -- USD values should be calculated
  assertMsg "Subscriber USD should be positive" (stats.totalPaidBySubscriberUSD > 0.0)
  assertMsg "Recipient USD should be positive" (stats.totalReceivedByRecipientUSD > 0.0)
  
  -- Verify relationship between CC and USD values (proportional to amulet price)
  let ccRatio = if stats.totalPaidBySubscriberCC > 0.0 
                then stats.totalReceivedByRecipientCC / stats.totalPaidBySubscriberCC 
                else 0.0
  let usdRatio = if stats.totalPaidBySubscriberUSD > 0.0 
                 then stats.totalReceivedByRecipientUSD / stats.totalPaidBySubscriberUSD 
                 else 0.0
  assertMsg "CC and USD ratios should be similar" (abs (ccRatio - usdRatio) < 0.01)
  
  pure ()

-- | Test stats tracking with both recipient and processor payments
-- Verifies all three parties' amounts are tracked correctly with fees
testStatsWithProcessorFee : Script ()
testStatsWithProcessorFee = script do
  TestParties{..} <- allocateTestParties
  
  -- Create a subscription with both recipient and processor payments
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 3.0
        processorPaymentPerDay = Some (AmuletAmount 1.0)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Advance time and process payment
  setTime (addRelTime now (days 7))
  
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False  -- Include processor payment
  
  -- Verify all three parties have non-zero amounts
  Some updatedSub <- queryContractId alice result.subscriptionCid
  let stats = updatedSub.stats
  
  assertMsg "Subscriber CC should be positive" (stats.totalPaidBySubscriberCC > 0.0)
  assertMsg "Recipient CC should be positive" (stats.totalReceivedByRecipientCC > 0.0)
  assertMsg "Processor CC should be positive" (stats.totalReceivedByProcessorCC > 0.0)
  
  -- Key assertion: subscriber paid >= recipient received + processor received
  -- Transaction fees cause the subscriber to pay more than recipients receive
  let totalReceived = stats.totalReceivedByRecipientCC + stats.totalReceivedByProcessorCC
  assertMsg "Subscriber paid >= total received by all (fees cause drift)" 
    (stats.totalPaidBySubscriberCC >= totalReceived)
  
  -- Calculate fee/drift amount
  let feeDrift = stats.totalPaidBySubscriberCC - totalReceived
  assertMsg "Fee drift should be positive (network fees)" (feeDrift > 0.0)
  
  -- All USD values should be positive
  assertMsg "Subscriber USD should be positive" (stats.totalPaidBySubscriberUSD > 0.0)
  assertMsg "Recipient USD should be positive" (stats.totalReceivedByRecipientUSD > 0.0)
  assertMsg "Processor USD should be positive" (stats.totalReceivedByProcessorUSD > 0.0)
  
  pure ()

-- | Test stats accumulation across multiple payment rounds
-- Verifies that stats properly accumulate over multiple payments
testStatsMultiplePayments : Script ()
testStatsMultiplePayments = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = Some (AmuletAmount 0.5)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- First payment
  setTime (addRelTime now (days 7))
  result1 <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some sub1 <- queryContractId alice result1.subscriptionCid
  let stats1 = sub1.stats
  
  -- Verify first payment stats
  assertMsg "After first payment: rounds = 1" (stats1.roundsProcessed == 1)
  let subscriber1 = stats1.totalPaidBySubscriberCC
  let recipient1 = stats1.totalReceivedByRecipientCC
  let processor1 = stats1.totalReceivedByProcessorCC
  
  -- Second payment
  now2 <- getTime
  setTime (addRelTime now2 (days 7))
  result2 <- submitMulti [processor] [dso] do
    exerciseCmd result1.subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some sub2 <- queryContractId alice result2.subscriptionCid
  let stats2 = sub2.stats
  
  -- Verify stats accumulated
  assertMsg "After second payment: rounds = 2" (stats2.roundsProcessed == 2)
  
  -- All amounts should have increased
  assertMsg "Subscriber CC increased" (stats2.totalPaidBySubscriberCC > subscriber1)
  assertMsg "Recipient CC increased" (stats2.totalReceivedByRecipientCC > recipient1)
  assertMsg "Processor CC increased" (stats2.totalReceivedByProcessorCC > processor1)
  
  -- Second payment amounts should be roughly equal to first (same period)
  let subscriber2 = stats2.totalPaidBySubscriberCC - subscriber1
  let recipient2 = stats2.totalReceivedByRecipientCC - recipient1
  let processor2 = stats2.totalReceivedByProcessorCC - processor1
  
  -- Verify consistency: each payment period should have similar amounts
  -- Allow for small variations due to rounding and fee calculations
  assertMsg "Subscriber amounts consistent across payments" 
    (abs (subscriber2 - subscriber1) < subscriber1 * 0.1)  -- Within 10%
  assertMsg "Recipient amounts consistent across payments" 
    (abs (recipient2 - recipient1) < recipient1 * 0.1)
  assertMsg "Processor amounts consistent across payments" 
    (abs (processor2 - processor1) < processor1 * 0.1)
  
  pure ()

-- | Test stats with skipProcessorPayment flag
-- Verifies processor stats remain zero when processor payment is skipped
testStatsSkipProcessorPayment : Script ()
testStatsSkipProcessorPayment = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = Some (AmuletAmount 0.5)  -- Fee configured but will be skipped
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Process payment with skipProcessorPayment = True
  setTime (addRelTime now (days 7))
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = True  -- Skip processor payment
  
  Some updatedSub <- queryContractId alice result.subscriptionCid
  let stats = updatedSub.stats
  
  -- Verify processor received nothing despite having a configured fee
  assertMsg "Subscriber CC should be positive" (stats.totalPaidBySubscriberCC > 0.0)
  assertMsg "Recipient CC should be positive" (stats.totalReceivedByRecipientCC > 0.0)
  assertMsg "Processor CC should be 0 (skipped)" (stats.totalReceivedByProcessorCC == 0.0)
  assertMsg "Processor USD should be 0 (skipped)" (stats.totalReceivedByProcessorUSD == 0.0)
  
  pure ()

-- | Test balance consistency by verifying subscriber paid equals recipient + processor + fees
-- This verifies that the accounting is consistent across all parties
testStatsBalanceConsistency : Script ()
testStatsBalanceConsistency = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.5
        processorPaymentPerDay = Some (AmuletAmount 0.5)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Process multiple payments to accumulate stats
  setTime (addRelTime now (days 7))
  result1 <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some sub1 <- queryContractId alice result1.subscriptionCid
  let stats1 = sub1.stats
  
  -- Verify accounting consistency after first payment
  let totalReceived1 = stats1.totalReceivedByRecipientCC + stats1.totalReceivedByProcessorCC
  assertMsg "Subscriber paid >= total received (accounting consistency)" 
    (stats1.totalPaidBySubscriberCC >= totalReceived1)
  
  -- Process second payment
  now2 <- getTime
  setTime (addRelTime now2 (days 7))
  result2 <- submitMulti [processor] [dso] do
    exerciseCmd result1.subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some sub2 <- queryContractId alice result2.subscriptionCid
  let stats2 = sub2.stats
  
  -- Verify accounting consistency after second payment
  let totalReceived2 = stats2.totalReceivedByRecipientCC + stats2.totalReceivedByProcessorCC
  assertMsg "Subscriber paid >= total received after multiple payments" 
    (stats2.totalPaidBySubscriberCC >= totalReceived2)
  
  -- Verify USD consistency: ratios should match between CC and USD
  let ccPaidReceivedRatio = totalReceived2 / stats2.totalPaidBySubscriberCC
  let usdPaidReceivedRatio = (stats2.totalReceivedByRecipientUSD + stats2.totalReceivedByProcessorUSD) / stats2.totalPaidBySubscriberUSD
  
  assertMsg "CC and USD accounting ratios are consistent" 
    (abs (ccPaidReceivedRatio - usdPaidReceivedRatio) < 0.01)
  
  pure ()

-- | Test fee drift calculation with payment processing
-- Demonstrates how transaction fees cause drift between paid and received amounts
testFeesDriftVariation : Script ()
testFeesDriftVariation = script do
  TestParties{..} <- allocateTestParties
  
  -- Test with payment amounts
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.5
        processorPaymentPerDay = Some (AmuletAmount 0.5)
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Process first payment
  setTime (addRelTime now (days 7))
  result1 <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some sub1 <- queryContractId alice result1.subscriptionCid
  let stats1 = sub1.stats
  let totalReceived1 = stats1.totalReceivedByRecipientCC + stats1.totalReceivedByProcessorCC
  let feeDrift1 = stats1.totalPaidBySubscriberCC - totalReceived1
  let driftPercent1 = (feeDrift1 / stats1.totalPaidBySubscriberCC) * 100.0
  
  -- Verify drift exists and is reasonable
  assertMsg "Fee drift exists after first payment" (feeDrift1 > 0.0)
  assertMsg "Fee drift is reasonable (< 10%)" (driftPercent1 < 10.0)
  
  -- Process second payment to see if drift pattern continues
  now2 <- getTime
  setTime (addRelTime now2 (days 7))
  result2 <- submitMulti [processor] [dso] do
    exerciseCmd result1.subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some sub2 <- queryContractId alice result2.subscriptionCid
  let stats2 = sub2.stats
  let totalReceived2 = stats2.totalReceivedByRecipientCC + stats2.totalReceivedByProcessorCC
  let feeDrift2 = stats2.totalPaidBySubscriberCC - totalReceived2
  let driftPercent2 = (feeDrift2 / stats2.totalPaidBySubscriberCC) * 100.0
  
  -- Verify drift exists for second payment too
  assertMsg "Fee drift exists after second payment" (feeDrift2 > 0.0)
  assertMsg "Fee drift remains reasonable after multiple payments (< 10%)" (driftPercent2 < 10.0)
  
  -- Verify drift increases with more payments (accumulates)
  assertMsg "Total drift increases with more payments" (feeDrift2 > feeDrift1)
  
  -- Output drift percentages for debugging
  debug ("First payment drift %: " <> show driftPercent1)
  debug ("After two payments drift %: " <> show driftPercent2)
  
  pure ()

-- | Test zero processor fee (None value)
-- Verifies stats work correctly when processor fee is None vs Some 0.0
testStatsZeroProcessorFee : Script ()
testStatsZeroProcessorFee = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        recipientPaymentPerDay = AmuletAmount 2.0
        processorPaymentPerDay = None  -- Explicitly None
  
  proposalCid <- createSubscriberProposal processor alice dso proposal
  subscriptionCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  setTime (addRelTime now (days 7))
  result <- submitMulti [processor] [dso] do
    exerciseCmd subscriptionCid ActiveSubscription_ProcessPayment with
      processingPeriod = days 7
      paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
      skipProcessorPayment = False
  
  Some updatedSub <- queryContractId alice result.subscriptionCid
  let stats = updatedSub.stats
  
  -- With None processor fee, processor should receive nothing
  assertMsg "Processor CC is 0 with None fee" (stats.totalReceivedByProcessorCC == 0.0)
  assertMsg "Processor USD is 0 with None fee" (stats.totalReceivedByProcessorUSD == 0.0)
  
  -- But subscriber still pays for recipient + fees
  assertMsg "Subscriber still pays" (stats.totalPaidBySubscriberCC > 0.0)
  assertMsg "Recipient still receives" (stats.totalReceivedByRecipientCC > 0.0)
  
  pure ()

