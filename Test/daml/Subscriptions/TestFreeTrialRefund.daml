module Subscriptions.TestFreeTrialRefund where

import Daml.Script
import DA.Time (days, addRelTime)
import Fairmint.Subscriptions.ActiveSubscription
import Fairmint.Subscriptions.ProposedSubscription
import Fairmint.Subscriptions.Types.ProcessorContext (ProcessorContext(..))
import Fairmint.Subscriptions.Types.SubscriptionTime (SubscriptionTime(..))
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.Types.ProcessingContext (ProcessingContext(..))
import Fairmint.Subscriptions.Types.PaymentContext (PaymentContext(..))
import Subscriptions.TestUtils

-- | Test that processing free trial and then canceling doesn't allow refunds for the trial period
-- This verifies that even though we process the trial into the future, we can't get a refund for it
testFreeTrialProcessAndCancelNoRefund : Script ()
testFreeTrialProcessAndCancelNoRefund = script do
  TestParties{..} <- allocateTestParties
  
  -- Create subscription with 30 day free trial
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  let proposal = (defaultSubscriptionProposal alice bob expiresAt) with
        freeTrialExpiration = Some (PerciseTime freeTrialEndsAt)
  
  -- Create and approve subscription
  proposalCid <- submitMulti [alice, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with processorContext = ProcessorContext processor dso)
      (SubscriptionFactory_CreateProposedSubscription with
        actor = alice
        subscriptionProposal = proposal)
  
  approveResult1 <- submit processor do
    exerciseCmd proposalCid ProposedSubscription_Approve with actor = processor
  
  processorApprovedCid <- case approveResult1 of
    Left cid -> pure cid
    Right _ -> error "Expected ProposedSubscription, got ActiveSubscription"
  
  approveResult2 <- submit bob do
    exerciseCmd processorApprovedCid ProposedSubscription_Approve with actor = bob
  
  activeSubscriptionCid <- case approveResult2 of
    Right cid -> pure cid
    Left _ -> error "Expected ActiveSubscription, got ProposedSubscription"
  
  -- Process the entire free trial period (advance processedAndPaidUntil to freeTrialEndsAt)
  let processingPeriod = days 30
  let processingContext = ProcessingContext with
        processingPeriod = processingPeriod
        recipientProvider = Some bob
        recipientFeaturedAppRight = None
        processorFeaturedAppRight = None
        processorProvider = processor
  
  processedCid <- submit processor do
    exerciseCmd activeSubscriptionCid ActiveSubscription_ProcessFreeTrial with ..
  
  -- Verify processedAndPaidUntil is at freeTrialEndsAt
  Some processed <- queryContractId alice processedCid
  assertMsg "processedAndPaidUntil should be at freeTrialEndsAt" (processed.processedAndPaidUntil == freeTrialEndsAt)
  
  -- Cancel immediately after processing (still on day 0/1)
  Some canceledCid <- submit alice do
    exerciseCmd processedCid ActiveSubscription_Cancel with
      actor = alice
      disregardAvailablePaidPeriod = False
      description = Some "Testing cancellation"
  
  -- Verify paymentsEndAt is set to freeTrialEndsAt (to honor the trial period)
  Some canceled <- queryContractId alice canceledCid
  assertMsg "paymentsEndAt should be set to freeTrialEndsAt" 
    (canceled.subscription.paymentsEndAt == Some freeTrialEndsAt)
  assertMsg "processedAndPaidUntil should still be at freeTrialEndsAt" 
    (canceled.processedAndPaidUntil == freeTrialEndsAt)
  
  -- Advance time to after the trial period ends
  setTime (addRelTime freeTrialEndsAt (days 1))
  
  -- Attempt to refund - this should fail because there's no prepaid time remaining
  -- The free trial period was free, so there's nothing to refund
  let paymentContext = PaymentContext with
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        amuletInputs = []  -- Won't get here anyway
  
  submitMustFail bob do
    exerciseCmd canceledCid ActiveSubscription_Refund with
      paymentContext = paymentContext
      recipientFeaturedAppRight = None
  
  pure ()

