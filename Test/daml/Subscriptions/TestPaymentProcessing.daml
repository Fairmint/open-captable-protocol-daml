module Subscriptions.TestPaymentProcessing where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round (OpenMiningRound)
import Fairmint.Subscriptions.SubscriberSubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.Subscriptions
import Shared.TestUtils (tapWithDso, getAmuletRules)
import Subscriptions.TestUtils

-- | Test processing a subscription payment
testProcessPayment : Script ()
testProcessPayment = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  now <- getTime
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Alice creates amulet for payment (before advancing time so mining rounds exist)
  amuletCid <- tapWithDso dso alice 100.0
  
  -- Get payment context - query for rounds that are actually open at current time
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Wait for the processing period to elapse
  now2 <- getTime
  setTime (addRelTime now2 (days 31))
  
  -- Get disclosures for contracts the processor needs
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Process payment with explicit contract disclosures
  result <- submitWithDisclosures processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
  
  -- Verify the subscription was updated
  Some updatedSubscription <- queryContractId alice result.subscriptionCid
  assertMsg "Subscription should be updated" (updatedSubscription.paidUntil > now)
  
  pure ()

-- | Test processing payment fails before period elapses
testProcessPaymentFailsBeforePeriodElapses : Script ()
testProcessPaymentFailsBeforePeriodElapses = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createSubscriberProposal processor alice dso (defaultSubscriptionConfig alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create amulet for payment
  amuletCid <- tapWithDso dso alice 50.0
  
  -- Get payment context
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Get disclosures
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Try to process payment immediately (should fail - period hasn't elapsed)
  submitWithDisclosuresMustFail processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
  
  pure ()

-- | Test processing payment fails after expiration
testProcessPaymentFailsAfterExpiration : Script ()
testProcessPaymentFailsAfterExpiration = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  let expiresAt = addRelTime now (days 60)  -- Expires in 60 days
  proposalCid <- createSubscriberProposal processor alice dso 
    ((defaultSubscriptionConfig alice bob expiresAt) with expiresAt = expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Create amulet for payment before advancing time
  amuletCid <- tapWithDso dso alice 50.0
  
  -- Get payment context
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Wait past expiration
  now2 <- getTime
  setTime (addRelTime now2 (days 61))
  
  -- Get disclosures
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Try to process payment after expiration (should fail)
  submitWithDisclosuresMustFail processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
  
  pure ()

-- | Test processing free trial
testProcessFreeTrial : Script ()
testProcessFreeTrial = script do
  TestParties{..} <- allocateTestParties
  
  now <- getTime
  expiresAt <- getExpirationTime 365
  let freeTrialEndsAt = addRelTime now (days 30)
  let config = (defaultSubscriptionConfig alice bob expiresAt) with
        freeTrialEndsAt = Some freeTrialEndsAt
  
  proposalCid <- createSubscriberProposal processor alice dso config
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriberSubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriberSubscriptionProposal_RecipientAccept
  
  -- Wait 10 days then process free trial
  setTime (addRelTime now (days 10))
  
  result <- submit processor do
    exerciseCmd subscriptionCid Subscription_ProcessFreeTrial with
      processingPeriod = days 7
      recipientFeaturedAppRight = None
      processorFeaturedAppRight = None
  
  Some updated <- queryContractId alice result.subscriptionCid
  assertMsg "paidUntil should advance" (updated.paidUntil > now)
  
  pure ()

