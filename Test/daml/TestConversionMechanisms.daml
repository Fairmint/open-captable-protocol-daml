module TestConversionMechanisms where

import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import Daml.Script

-- Helpers
mkUSD : Decimal -> OcfMonetary
mkUSD amt = OcfMonetary with amount = amt; currency = "USD"

baseStockClass : OcfStockClassData
baseStockClass = OcfStockClassData with
  name = "Test Class"
  class_type = OcfStockClassTypePreferred
  default_id_prefix = "PS-"
  initial_shares_authorized = OcfInitialSharesNumeric 1_000.0
  votes_per_share = 1.0
  seniority = 1.0
  board_approval_date = None
  stockholder_approval_date = None
  par_value = None
  price_per_share = None
  liquidation_preference_multiple = None
  participation_cap_multiple = None
  conversion_rights = []
  comments = None

-- RatioConversion: valid
ratioConversion_valid = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  _ <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = baseStockClass with
      conversion_rights =
        [ OcfStockClassConversionRight with
            type_ = "STOCK_CLASS_CONVERSION_RIGHT"
            conversion_mechanism = OcfConversionMechanismRatioConversion
            conversion_trigger = OcfTriggerAutomaticOnCondition
            converts_to_stock_class_id = "Common"
            ratio = Some (OcfRatio with numerator = 2.0; denominator = 1.0)
            percent_of_capitalization = None
            conversion_price = None
            reference_share_price = None
            reference_valuation_price_per_share = None
            discount_rate = None
            valuation_cap = None
            floor_price_per_share = None
            ceiling_price_per_share = None
            custom_description = None
            expires_at = None
        ]
  pure ()

-- RatioConversion: invalid (missing ratio)
ratioConversion_invalid_missing = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  submitMustFail issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = baseStockClass with
      conversion_rights =
        [ OcfStockClassConversionRight with
            type_ = "STOCK_CLASS_CONVERSION_RIGHT"
            conversion_mechanism = OcfConversionMechanismRatioConversion
            conversion_trigger = OcfTriggerAutomaticOnCondition
            converts_to_stock_class_id = "Common"
            ratio = None
            percent_of_capitalization = None
            conversion_price = None
            reference_share_price = None
            reference_valuation_price_per_share = None
            discount_rate = None
            valuation_cap = None
            floor_price_per_share = None
            ceiling_price_per_share = None
            custom_description = None
            expires_at = None
        ]

