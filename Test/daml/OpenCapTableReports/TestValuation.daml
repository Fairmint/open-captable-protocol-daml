module OpenCapTableReports.TestValuation where
import Fairmint.OpenCapTable.Valuation
import OpenCapTable.Setup
import Daml.Script
import DA.Date
import DA.Time
import Fairmint.OpenCapTable.Types

createValuation issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd Valuation with
      context = ctx
      valuation_data = OcfValuationData with
        id = "VAL_409A_2025"
        provider = Some "Acme Advisory"
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
        price_per_share = OcfMonetary with amount = 1.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"

testCreateValuation = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  _ <- createValuation issuer system_operator ctx
  do
    cids <- query @Valuation issuer
    case cids of
      (cid, _) :: _ -> submit issuer do
        exerciseCmd cid Fairmint.OpenCapTable.Valuation.ArchiveByIssuer
      _ -> pure ()
  pure ()

testCreateValuationArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  _ <- createValuation issuer system_operator ctx
  do
    cids <- query @Valuation issuer
    case cids of
      (cid, _) :: _ -> submitMulti [issuer, system_operator] [] do
        exerciseCmd cid Archive
      _ -> pure ()
  pure ()

-- Base helper covers None/empty where applicable

-- Optionals Some and arrays non-empty
testValuation_OptionalsSome_ArraysNonEmpty = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd Valuation with
      context = ctx
      valuation_data = OcfValuationData with
        id = "VAL_SOME"
        provider = Some "Acme Advisory"
        board_approval_date = Some (DA.Time.time (DA.Date.date 2025 Jan 2) 0 0 0)
        stockholder_approval_date = Some (DA.Time.time (DA.Date.date 2025 Jan 3) 0 0 0)
        comments = ["Approved"]
        price_per_share = OcfMonetary with amount = 2.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Feb 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
