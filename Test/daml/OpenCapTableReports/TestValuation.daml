module OpenCapTableReports.TestValuation where
import Fairmint.OpenCapTable.OCF.Valuation
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStockClass)
import Daml.Script
import DA.Date
import DA.Time
import Fairmint.OpenCapTable.Types

createValuation issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateValuation ValuationOcfData with
        id = "VAL_409A_2025"
        provider = Some "Acme Advisory"
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
        price_per_share = OcfMonetary with amount = 1.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"]
      edits = []
      deletes = []

testCreateValuation = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStockClass issuer cap_table
  result <- createValuation issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteValuation "VAL_409A_2025"]
  pure ()

testCreateValuationArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStockClass issuer cap_table
  result <- createValuation issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteValuation "VAL_409A_2025"]
  pure ()

-- Base helper covers None/empty where applicable

-- Optionals Some and arrays non-empty
testValuation_OptionalsSome_ArraysNonEmpty = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStockClass issuer cap_table
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateValuation ValuationOcfData with
        id = "VAL_SOME"
        provider = Some "Acme Advisory"
        board_approval_date = Some (DA.Time.time (DA.Date.date 2025 Jan 2) 0 0 0)
        stockholder_approval_date = Some (DA.Time.time (DA.Date.date 2025 Jan 3) 0 0 0)
        comments = ["Approved"]
        price_per_share = OcfMonetary with amount = 2.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Feb 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"]
      edits = []
      deletes = []
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteValuation "VAL_SOME"]
  pure ()
