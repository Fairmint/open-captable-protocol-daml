module TestUtils where
import Daml.Script
import DA.Time
import qualified DA.Set as Set
import DA.List (head)
import Splice.Amulet qualified as Amulet
import Splice.AmuletRules
import Splice.Schedule
import Splice.AmuletConfig
import Splice.Issuance
import Splice.Fees
import Splice.DecentralizedSynchronizer
import Splice.Round (OpenMiningRound)
-- Minimal AmuletConfig for tests
defaultTestAmuletConfig : AmuletConfig USD
defaultTestAmuletConfig = AmuletConfig with
  transferConfig = TransferConfig with
    createFee = FixedFee 0.01
    holdingFee = RatePerRound 0.01
    transferFee = SteppedRate with initialRate = 0.0; steps = [(1.0, 0.0)]
    lockHolderFee = FixedFee 0.01
    extraFeaturedAppRewardAmount = 0.0
    maxNumInputs = 1
    maxNumOutputs = 1
    maxNumLockHolders = 1
  issuanceCurve = Schedule with
    initialValue = IssuanceConfig with
      amuletToIssuePerYear = 1000.0
      validatorRewardPercentage = 0.0
      appRewardPercentage = 0.0
      validatorRewardCap = 0.0
      featuredAppRewardCap = 0.0
      unfeaturedAppRewardCap = 0.0
      optValidatorFaucetCap = None
    futureValues = []
  decentralizedSynchronizer = AmuletDecentralizedSynchronizerConfig with
    requiredSynchronizers = Set.fromList ["sync"]
    activeSynchronizer = "sync"
    fees = SynchronizerFeesConfig with
      baseRateTrafficLimits = BaseRateTrafficLimits with burstAmount = 1; burstWindow = minutes 1
      extraTrafficPrice = 0.0
      readVsWriteScalingFactor = 1
      minTopupAmount = 1
  tickDuration = minutes 1
  packageConfig = PackageConfig with
    amulet = "0"
    amuletNameService = "0"
    dsoGovernance = "0"
    validatorLifecycle = "0"
    wallet = "0"
    walletPayments = "0"
  transferPreapprovalFee = None
  featuredAppActivityMarkerAmount = None
-- Setup AmuletRules with default configuration
setupAmuletRules : Party -> Script (ContractId AmuletRules)
setupAmuletRules dso = do
  amuletRulesCid <- submit dso do
    createCmd AmuletRules with
      dso = dso
      configSchedule = Schedule with
        initialValue = defaultTestAmuletConfig
        futureValues = []
      isDevNet = True
  _ <- submit dso do
    exerciseCmd amuletRulesCid AmuletRules_Bootstrap_Rounds with
      amuletPrice = 1.0
      round0Duration = hours 24
      initialRound = None
  pure amuletRulesCid
-- Get the first open mining round
getFirstOpenRound : Party -> Script (ContractId OpenMiningRound)
getFirstOpenRound dso = do
  openRounds <- query @OpenMiningRound dso
  case openRounds of
    [] -> abort "No open mining rounds found"
    rounds -> do
      let (openRoundCid, _) = head rounds
      pure openRoundCid
-- Shared DSO party for all tap operations
sharedDso : Script Party
sharedDso = allocateParty "dso"
-- Tap funds for a party using shared DSO
-- Usage: alice <- allocateParty "alice"; amuletCid <- tap alice 420
tap : Party -> Decimal -> Script (ContractId Amulet.Amulet)
tap receiver amount = do
  dso <- sharedDso
  amuletRulesCid <- setupAmuletRules dso
  openRoundCid <- getFirstOpenRound dso
  
  result <- submitMulti [dso, receiver] [] do
    exerciseCmd amuletRulesCid AmuletRules_DevNet_Tap with
      receiver = receiver
      amount = amount
      openRound = openRoundCid
  
  pure result.amuletSum.amulet 