module TestStakeholder where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Stakeholder
import Fairmint.OpenCapTable.Types

-- Happy path: create and update Stakeholder
happyCase = script do
  TestUsers{system_operator, issuer, alice, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Create individual stakeholder Alice
  aliceStakeholderCid <- submit issuer do
    exerciseCmd issuerCid CreateStakeholder with
      stakeholder = alice
      stakeholder_data = OcfStakeholderData with
        name = "Alice Doe"
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = Some "E-1001"
        current_relationships = ["EMPLOYEE"]
        current_status = None
        primary_contact = None
        contact_info = Some (OcfContactInfoWithoutName with
          email = None
          phone = None
          address = None)
        addresses = []
        tax_ids = []
        comments = None

  -- Update stakeholder
  submit issuer do
    exerciseCmd aliceStakeholderCid UpdateStakeholderData with
      new_stakeholder_data = OcfStakeholderData with
        name = "Alice Doe"
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = Some "E-1001"
        current_relationships = ["EMPLOYEE"]
        current_status = None
        primary_contact = Some (OcfContactInfo with
          name = "Alice Doe"
          email = None
          phone = Some (OcfPhone with phone_type = OcfPhoneBusiness; phone_number = "+1-555-0100")
          address = None)
        contact_info = Some (OcfContactInfoWithoutName with
          email = None
          phone = None
          address = None)
        addresses = []
        tax_ids = []
        comments = None

  pure ()

-- Validation: name cannot be empty
nameCannotBeEmpty = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  submitMustFail issuer do
    exerciseCmd issuerCid CreateStakeholder with
      stakeholder = alice
      stakeholder_data = OcfStakeholderData with
        name = ""
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = None

  pure ()
