module TestStakeholder where
import Fairmint.OpenCapTable.Stakeholder
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script

testCreateAndArchiveStakeholder = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  _cid <- submitMulti [issuer, system_operator] [] do
    createCmd Stakeholder with
      context = ctx
      stakeholder_data = OcfStakeholderData with
        ocf_id = "STKH_Alice"
        name = OcfName with legal_name = "Alice", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []
  pure ()
