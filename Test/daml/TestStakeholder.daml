module TestStakeholder where
import Fairmint.OpenCapTable.Stakeholder
import Setup
import Daml.Script

testCreateAndArchiveStakeholder = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd Stakeholder with
      context = ctx
      stakeholder_data = OcfStakeholderData with
        id = "STKH_Alice"
        name = OcfName with legal_name = "Alice", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.Stakeholder.ArchiveByIssuer
  pure ()

testCreateAndArchiveStakeholderBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd Stakeholder with
      context = ctx
      stakeholder_data = OcfStakeholderData with
        id = "STKH_Bob"
        name = OcfName with legal_name = "Bob", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
