module TestPlanSecurityIssuance where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockPlan
import Fairmint.OpenCapTable.Types
import DA.Date
import DA.Time

happyOption = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  planCid <- submit issuer $ exerciseCmd issuerCid CreateStockPlan with
    stock_classes = [stockClassCid]
    plan_data = OcfStockPlanData with
      plan_name = "2025 Plan"
      board_approval_date = None
      stockholder_approval_date = None
      initial_shares_reserved = 1000000.0
      default_cancellation_behavior = None
      comments = None
  grantCid <- submit issuer $ exerciseCmd planCid IssuePlanSecurity with
    stakeholder = alice
    stock_class = stockClassCid
    vesting_terms = None
    issuance_data = OcfEquityCompensationIssuanceData with
      compensation_type = OcfCompensationTypeOptionNSO
      quantity = 10000.0
      exercise_price = Some (OcfMonetary with amount = 1.00, currency = "USD")
      base_price = None
      early_exercisable = Some False
      vestings = Some [OcfVesting with date = time (DA.Date.date 2025 Jan 1) 0 0 0, amount = 2500.0]
      expiration_date = Some (time (DA.Date.date 2032 Jan 1) 0 0 0)
      termination_exercise_windows = [OcfTerminationWindow with reason = OcfTermVoluntaryOther, period = 90, period_type = OcfPeriodDays]
      comments = None
  Some _ <- queryContractId issuer grantCid
  -- Exercise a portion of the grant
  _alicePos <- submit issuer $ exerciseCmd grantCid ExerciseGrant with
    stock_class = stockClassCid
    quantity = 1000.0
    date = time (DA.Date.date 2025 Jan 10) 0 0 0
  -- Start vesting with a start trigger id
  _ <- submit issuer $ exerciseCmd grantCid StartVesting with
    vesting_condition_id = "start"
    date = time (DA.Date.date 2025 Jan 1) 0 0 0
  -- Exercise lifecycle choices
  _ <- submit alice $ exerciseCmd grantCid AcceptGrant with date = time (DA.Date.date 2025 Jan 2) 0 0 0
  _ <- submit issuer $ exerciseCmd grantCid ReleaseGrant with date = time (DA.Date.date 2025 Jan 3) 0 0 0
  _ <- submit alice $ exerciseCmd grantCid RetractGrant with date = time (DA.Date.date 2025 Jan 4) 0 0 0
  _ <- submit issuer $ exerciseCmd grantCid CancelGrant with date = time (DA.Date.date 2025 Jan 5) 0 0 0
  pure ()

invalidRequiresExercisePrice = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  planCid <- submit issuer $ exerciseCmd issuerCid CreateStockPlan with
    stock_classes = [stockClassCid]
    plan_data = OcfStockPlanData with
      plan_name = "2025 Plan"
      board_approval_date = None
      stockholder_approval_date = None
      initial_shares_reserved = 1000000.0
      default_cancellation_behavior = None
      comments = None
  submitMustFail issuer $ exerciseCmd planCid IssuePlanSecurity with
    stakeholder = alice
    stock_class = stockClassCid
    vesting_terms = None
    issuance_data = OcfEquityCompensationIssuanceData with
      compensation_type = OcfCompensationTypeOptionNSO
      quantity = 10000.0
      exercise_price = None -- required for options
      base_price = None
      early_exercisable = Some False
      vestings = None
      expiration_date = None
      termination_exercise_windows = []
      comments = None
  pure ()
