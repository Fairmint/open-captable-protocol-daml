module TestPayFeeAndCreateIssuer where

import Daml.Script
import Setup

import Fairmint.OpenCapTable.OcpFactory

-- | Example of how PayFeeAndCreateIssuer would be called in a full Splice environment
-- This function shows the structure but cannot be executed without proper Splice setup
examplePayFeeAndCreateIssuer = script do
  TestUsers{system_operator, issuer, alice, bob, rando} <- setupUsers
  
    -- Create OcpFactory and propose issuer onboarding
  openCapTableFactoryCid <- submit system_operator do
    createCmd OcpFactory with ..
  
  issuerAuthorizationCid <- submit system_operator do
    exerciseCmd openCapTableFactoryCid AuthorizeIssuer with issuer = issuer
  
