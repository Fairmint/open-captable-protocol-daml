module Fairmint.EquityCertificate.TestHelpers where

import DA.Map qualified as Map
import DA.TextMap qualified as TextMap
import Daml.Script

import Fairmint.EquityCertificate.CertificateRegistry qualified as Reg
import Fairmint.EquityCertificate.Types
import Nft.Api.V1.Types
import Nft.Reference.V1.Metadata (standardMetadataKey)

data CertificateTestParties = CertificateTestParties with
    registry_authority : Party
    operator : Party
    holder : Party
    other : Party
  deriving (Eq, Show)

defaultRegistry : RegistryIdentity
defaultRegistry = RegistryIdentity with
  registry_id = "EQUITY-CERT-REGISTRY"

defaultCollection : CollectionIdentity
defaultCollection = CollectionIdentity with
  registry_id = defaultRegistry.registry_id
  collection_id = "ISSUER-A"

samplePosition : PositionIdentity
samplePosition = PositionIdentity with
  stakeholder_id = "stakeholder-1"
  security_id = "security-1"

equityCertificateMetadata : NftMetadata
equityCertificateMetadata = NftMetadata with
  standard_metadata =
    TextMap.fromList
      [ (standardMetadataKey "name", MetadataText with text = "Equity Certificate")
      , ( standardMetadataKey "description"
        , MetadataText with text = "Soulbound OCP equity certificate credential"
        )
      , (standardMetadataKey "image_uri", MetadataText with text = "ipfs://fairmint/equity-certificate")
      ]
  extension_metadata = TextMap.empty
  public_metadata = TextMap.empty

registrationForPosition : PositionIdentity -> NftRegistration
registrationForPosition position_identity =
  NftRegistration with
    nft_id =
      NftId with
        collection = defaultCollection
        token_id = positionIdentityKey position_identity
    metadata = equityCertificateMetadata
    confidentiality_ref = None

allocateCertificateParties : Text -> Script CertificateTestParties
allocateCertificateParties label = do
  registry_authority <- allocateParty (label <> "-RegistryAuthority")
  operator <- allocateParty (label <> "-Operator")
  holder <- allocateParty (label <> "-Holder")
  other <- allocateParty (label <> "-Other")
  pure CertificateTestParties with
    registry_authority
    operator
    holder
    other

createIssuerWithEmptyMap : CertificateTestParties -> Script (ContractId Reg.EquityCertificateIssuer)
createIssuerWithEmptyMap parties =
  submit (actAs [parties.registry_authority, parties.operator]) do
    createCmd Reg.EquityCertificateIssuer with
      registry_authority = parties.registry_authority
      nft_operator = parties.operator
      registry = defaultRegistry
      collection = defaultCollection
      minted_positions = Map.empty
