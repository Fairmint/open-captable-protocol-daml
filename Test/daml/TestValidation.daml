module TestValidation where

import Daml.Script
import Fairmint.OpenCapTable.OcfObjects
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.OcpFactory
import DA.Date

-- Test to demonstrate validation working
testValidation = script do
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  
  -- Create factory
  factoryCid <- submit system_operator do
    createCmd OcpFactory with system_operator = system_operator
  
  -- Authorize issuer
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  
  -- This should fail due to invalid country code (empty string)
  submitMustFail issuer do
    exerciseCmd authCid CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = ""  -- Invalid: empty string
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- This should succeed with valid data
  issuerCid <- submit issuer do
    exerciseCmd authCid CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  pure () 