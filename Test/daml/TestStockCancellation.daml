module TestStockCancellation where
import Fairmint.OpenCapTable.StockIssuance
import Fairmint.OpenCapTable.StockCancellation
import qualified Fairmint.OpenCapTable.StockCancellation as SC
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.Types
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveStockCancellation = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create a stock class to reference
  _scid <- submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = OcfStockClassData with
        ocf_id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []
  -- Create Stock Issuance to get a security_id
  _cidIss <- submitMulti [issuer, system_operator] [] do
    createCmd StockIssuance with
      context = ctx
      issuance_data = OcfStockIssuanceData with
        ocf_id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-1"
        custom_id = "CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        stock_plan_id = None
        share_numbers_issued = []
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = 100.0
        vesting_terms_id = None
        vestings = []
        cost_basis = None
        stock_legend_ids = ["L1"]
        issuance_type = None
        comments = []
  -- Create Stock Cancellation
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd StockCancellation with
      context = ctx
      cancellation_data = OcfStockCancellationData with
        ocf_id = "TX_STOCK_CANCEL_1"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        security_id = "SEC-1"
        quantity = 50.0
        balance_security_id = Some "SEC-1-BAL"
        reason_text = "Forfeit"
        comments = []
  submit issuer do
    exerciseCmd cid SC.ArchiveByIssuer
  pure ()


