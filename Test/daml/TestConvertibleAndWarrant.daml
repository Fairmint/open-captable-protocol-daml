module TestConvertibleAndWarrant where
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import Daml.Script
import DA.Date
import DA.Time

-- Convertible issuance happy path
convertibleHappy = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  cCid <- submit issuer $ exerciseCmd issuerCid IssueConvertible with
    stakeholder = alice
    issuance_data = OcfConvertibleIssuanceData with
      investment_amount = OcfMonetary with amount = 100000.0; currency = "USD"
      convertible_type = OcfConvertibleNote
      conversion_triggers = [OcfTriggerElectiveAtWill]
      seniority = 1
      pro_rata = None
      comments = None
  -- create a stock class and convert
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  _ <- submit issuer $ exerciseCmd cCid Convert with
    stock_class = stockClassCid
    quantity = 100.0
    date = time (DA.Date.date 2025 Jan 12) 0 0 0
  pure ()

-- Warrant issuance happy path
warrantHappy = script do
  TestUsers{system_operator, issuer, bob} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  -- create a stock class to exercise into
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  wCid <- submit issuer $ exerciseCmd issuerCid IssueWarrant with
    stakeholder = bob
    stock_class = stockClassCid
    issuance_data = OcfWarrantIssuanceData with
      quantity = 1000.0
      exercise_price = OcfMonetary with amount = 1.0; currency = "USD"
      purchase_price = OcfMonetary with amount = 0.0; currency = "USD"
      exercise_triggers = [OcfTriggerElectiveAtWill]
      warrant_expiration_date = None
      vesting_terms_id = None
      comments = None
  -- exercise part of the warrant
  _ <- submit issuer $ exerciseCmd wCid ExerciseWarrant with
    quantity = 100.0
    date = time (DA.Date.date 2025 Jan 11) 0 0 0
  pure ()

-- Negative: convertible requires at least one trigger and non-negative seniority
convertibleInvalid = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  submitMustFail issuer $ exerciseCmd issuerCid IssueConvertible with
    stakeholder = alice
    issuance_data = OcfConvertibleIssuanceData with
      investment_amount = OcfMonetary with amount = 100000.0; currency = "USD"
      convertible_type = OcfConvertibleNote
      conversion_triggers = []
      seniority = -1
      pro_rata = None
      comments = None
  pure ()

-- Negative: warrant requires positive quantity and valid monetary fields
warrantInvalid = script do
  TestUsers{system_operator, issuer, bob} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  -- need a stock class now that IssueWarrant requires it
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  submitMustFail issuer $ exerciseCmd issuerCid IssueWarrant with
    stakeholder = bob
    stock_class = stockClassCid
    issuance_data = OcfWarrantIssuanceData with
      quantity = 0.0
      exercise_price = OcfMonetary with amount = -1.0; currency = "USD"
      purchase_price = OcfMonetary with amount = 0.0; currency = "USD"
      exercise_triggers = []
      warrant_expiration_date = None
      vesting_terms_id = None
      comments = None
  pure ()

-- Negative: convertible invalid monetary data
convertibleInvalidMonetary = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  submitMustFail issuer $ exerciseCmd issuerCid IssueConvertible with
    stakeholder = alice
    issuance_data = OcfConvertibleIssuanceData with
      investment_amount = OcfMonetary with amount = -1.0; currency = "USD"
      convertible_type = OcfConvertibleNote
      conversion_triggers = [OcfTriggerElectiveAtWill]
      seniority = 0
      pro_rata = None
      comments = None
  pure ()
