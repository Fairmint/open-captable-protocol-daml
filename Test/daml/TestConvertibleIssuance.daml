module TestConvertibleIssuance where
import Fairmint.OpenCapTable.ConvertibleIssuance
import Fairmint.OpenCapTable.StockClass (OcfConvertibleType(..), OcfConversionTrigger(..))
import Fairmint.OpenCapTable.Types
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveConvertibleIssuance = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create Issuer to use creation choices
  issuerCid <- submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        ocf_id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = Some (DT.time (DA.date 2020 Jan 15) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []
  -- Create Convertible Issuance
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateConvertibleIssuance with
      issuance_data = OcfConvertibleIssuanceTxData with
        ocf_id = "TX_CONV_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "CN-1"
        custom_id = "NOTE-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [ OcfTriggerAutomaticOnDate ]
        pro_rata = None
        seniority = 1
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.ConvertibleIssuance.ArchiveByIssuer
  pure ()


