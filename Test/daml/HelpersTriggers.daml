module HelpersTriggers where
import Fairmint.OpenCapTable.Types
import Fairmint.OpenCapTable.ConvertibleIssuance (OcfConvertibleConversionTrigger(..))

ocfTriggerAutomaticOnDate : OcfConversionTrigger
ocfTriggerAutomaticOnDate = OcfConversionTrigger with
  type_ = OcfTriggerTypeTypeAutomaticOnDate
  trigger_id = "AUTO_DATE"
  nickname = None
  trigger_description = None
  conversion_right = OcfRightConvertible (OcfConvertibleConversionRight with
    type_ = "CONVERTIBLE_CONVERSION_RIGHT"
    conversion_mechanism = OcfConvMechCustom (OcfCustomConversionMechanism with custom_conversion_description = "Custom")
    converts_to_future_round = None
    converts_to_stock_class_id = None)
  trigger_date = None
  trigger_condition = None

ocfTriggerElectiveAtWill : OcfConversionTrigger
ocfTriggerElectiveAtWill = OcfConversionTrigger with
  type_ = OcfTriggerTypeTypeElectiveAtWill
  trigger_id = "ELECTIVE_AT_WILL"
  nickname = None
  trigger_description = None
  conversion_right = OcfRightConvertible (OcfConvertibleConversionRight with
    type_ = "CONVERTIBLE_CONVERSION_RIGHT"
    conversion_mechanism = OcfConvMechCustom (OcfCustomConversionMechanism with custom_conversion_description = "Custom")
    converts_to_future_round = None
    converts_to_stock_class_id = None)
  trigger_date = None
  trigger_condition = None

ocfConvTriggerAutomaticOnDate : OcfConvertibleConversionTrigger
ocfConvTriggerAutomaticOnDate = OcfConvertibleConversionTrigger with
  type_ = OcfTriggerTypeTypeAutomaticOnDate
  trigger_id = "AUTO_DATE"
  nickname = None
  trigger_description = None
  conversion_right = OcfConvertibleConversionRight with
    type_ = "CONVERTIBLE_CONVERSION_RIGHT"
    conversion_mechanism = OcfConvMechCustom (OcfCustomConversionMechanism with custom_conversion_description = "Custom")
    converts_to_future_round = None
