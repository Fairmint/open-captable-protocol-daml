module TestTap where
import Daml.Script
import DA.Assert
import TestUtils
import Splice.Amulet qualified as Amulet
-- Minimal tap test using shared utilities
testTap = script do
  alice <- allocateParty "alice"
  amuletCid <- tap alice 100.0
  
  Some amulet <- queryContractId @Amulet.Amulet alice amuletCid
  amulet.amount.initialAmount === 100.0
  amulet.owner === alice
  pure ()
-- Example of using the tap function with custom parties
testTapWithCustomParties = script do
  bob <- allocateParty "bob"
  
  amuletCid <- tap bob 420.0
  
  Some amulet <- queryContractId @Amulet.Amulet bob amuletCid
  amulet.amount.initialAmount === 420.0
  amulet.owner === bob
  pure () 