module TestUpdateIssuerData where

import Setup
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.Types
import Splice.Api.FeaturedAppRightV1 as Featured
import Daml.Script
import DA.Optional
import DA.Date

-- Happy Case --

happyCase = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Update issuer data with new information
  newIssuerData <- pure $ OcfIssuerData with
    legal_name = "Updated TestIssuer Inc."
    formation_date = Some (date 2020 Jan 15)
    country_of_formation = "US"
    dba = Some "TestIssuer"
    country_subdivision_of_formation = Some "CA"
    tax_ids = Some []
    email = Some "updated@testissuer.com"
    phone = Some "+1-555-0123"
    address = None
    initial_shares_authorized = Some 2000.0

  updatedIssuerCid <- submit issuer $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = newIssuerData

  -- Verify the update was successful
  updatedContract <- queryContractId issuer updatedIssuerCid
  assertMsg "Updated issuer contract not found" (isSome updatedContract)

  -- Verify old contract is archived
  oldContract <- queryContractId issuer issuerCid
  assertMsg "Old issuer contract should be archived" (isNone oldContract)

  pure()

-- Validation Tests --

invalidLegalName = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Try to update with invalid legal name
  invalidIssuerData <- pure $ OcfIssuerData with
    legal_name = ""  -- Empty name should fail validation
    formation_date = Some (date 2020 Jan 15)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some 1000.0

  submitMustFail issuer $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = invalidIssuerData

invalidCountryCode = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Try to update with invalid country code
  invalidIssuerData <- pure $ OcfIssuerData with
    legal_name = "TestIssuer Inc."
    formation_date = Some (date 2020 Jan 15)
    country_of_formation = "INVALID"  -- Invalid country code should fail validation
    dba = None
    country_subdivision_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some 1000.0

  submitMustFail issuer $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = invalidIssuerData

invalidEmail = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Try to update with invalid email
  invalidIssuerData <- pure $ OcfIssuerData with
    legal_name = "TestIssuer Inc."
    formation_date = Some (date 2020 Jan 15)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    tax_ids = Some []
    email = Some ""  -- Empty email should fail validation
    phone = None
    address = None
    initial_shares_authorized = Some 1000.0

  submitMustFail issuer $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = invalidIssuerData

-- Authorization Tests --

nonIssuerCannotUpdate = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Try to update issuer data as non-issuer party
  newIssuerData <- pure $ OcfIssuerData with
    legal_name = "Unauthorized Update Inc."
    formation_date = Some (date 2020 Jan 15)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some 1000.0

  submitMustFail rando $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = newIssuerData

systemOperatorCannotUpdate = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- Try to update issuer data as system operator
  newIssuerData <- pure $ OcfIssuerData with
    legal_name = "System Operator Update Inc."
    formation_date = Some (date 2020 Jan 15)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some 1000.0

  submitMustFail system_operator $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = newIssuerData 