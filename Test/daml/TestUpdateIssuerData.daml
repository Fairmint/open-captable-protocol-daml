-- Authorization Tests --
nonIssuerCannotUpdate = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  -- Try to update issuer data as non-issuer party
  newIssuerData <- pure $ OcfIssuerData with
    legal_name = "Unauthorized Update Inc."
    formation_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    country_subdivision_name_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
    comments = None
  submitMustFail rando $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = newIssuerData
systemOperatorCannotUpdate = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  -- Try to update issuer data as system operator
  newIssuerData <- pure $ OcfIssuerData with
    legal_name = "System Operator Update Inc."
    formation_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    country_subdivision_name_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
    comments = None
  submitMustFail system_operator $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = newIssuerData
