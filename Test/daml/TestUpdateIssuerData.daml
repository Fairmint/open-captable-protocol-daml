module TestUpdateIssuerData where
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import Daml.Script
import DA.Optional
import DA.Date
import DA.Time
-- Happy Case --
happyCase = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  -- Update issuer data with new information
  newIssuerData <- pure $ OcfIssuerData with
    legal_name = "Updated TestIssuer Inc."
    formation_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
    country_of_formation = "US"
    dba = Some "TestIssuer"
    country_subdivision_of_formation = Some "CA"
    country_subdivision_name_of_formation = None
    tax_ids = Some []
    email = Some (OcfEmail with
      email_type = OcfEmailTypeBusiness
      email_address = "updated@testissuer.com")
    phone = Some (OcfPhone with phone_type = OcfPhoneBusiness; phone_number = "+1-555-0123")
    address = None
    initial_shares_authorized = Some (OcfInitialSharesNumeric 2000.0)
    comments = None
  updatedIssuerCid <- submit issuer $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = newIssuerData
  -- Verify the update was successful
  updatedContract <- queryContractId issuer updatedIssuerCid
  assertMsg "Updated issuer contract not found" (isSome updatedContract)
  -- Verify old contract is archived
  oldContract <- queryContractId issuer issuerCid
  assertMsg "Old issuer contract should be archived" (isNone oldContract)
  pure()
-- Validation Tests --
invalidLegalName = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  -- Try to update with invalid legal name
  invalidIssuerData <- pure $ OcfIssuerData with
    legal_name = ""  -- Empty name should fail validation
    formation_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
    country_of_formation = "US"
    dba = None
    country_subdivision_of_formation = None
    country_subdivision_name_of_formation = None
    tax_ids = Some []
    email = None
    phone = None
    address = None
    initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
    comments = None
  submitMustFail issuer $ exerciseCmd issuerCid UpdateIssuerData with
    new_issuer_data = invalidIssuerData
