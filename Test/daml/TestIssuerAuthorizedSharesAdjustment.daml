module TestIssuerAuthorizedSharesAdjustment where
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Fairmint.OpenCapTable.IssuerAuthorizedSharesAdjustment
import Fairmint.OpenCapTable.Types
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveIssuerAuthorizedSharesAdjustment = script do
  TestUsers{system_operator, issuer} <- setupUsers
  -- Create Issuer
  context <- do
    rightCid <- submit system_operator do
      createCmd TestFeaturedAppRight with
        dso = system_operator
        provider = system_operator
        issuer = issuer
        alice = system_operator
        bob = system_operator
        charlie = system_operator
        rando = system_operator
    let ctx = Context with issuer = issuer, system_operator = system_operator, featured_app_right = toInterfaceContractId rightCid
    _ <- submitMulti [system_operator, issuer] [] do
      createCmd Iss.Issuer with
        context = ctx
        issuer_data = Iss.OcfIssuerData with
          ocf_id = "ISSUER_1"
          legal_name = "TestIssuer Inc."
          formation_date = Some (DT.time (DA.date 2020 Jan 15) 12 0 0)
          country_of_formation = "US"
          dba = None
          country_subdivision_of_formation = None
          country_subdivision_name_of_formation = None
          tax_ids = []
          email = None
          phone = None
          address = None
          initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
          comments = []
    pure ctx
  -- Create Issuer Authorized Shares Adjustment
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd IssuerAuthorizedSharesAdjustment with
      context = context
      adjustment_data = OcfIssuerAuthorizedSharesAdjustmentData with
        ocf_id = "TX_ISSUER_AUTH_SHARES_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        issuer_id = "ISSUER_1"
        new_shares_authorized = 2000.0
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.IssuerAuthorizedSharesAdjustment.ArchiveByIssuer
  pure ()


