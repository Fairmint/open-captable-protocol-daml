module OpenCapTable.TestIssuerAuthorizedSharesAdjustment where
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Fairmint.OpenCapTable.OCF.IssuerAuthorizedSharesAdjustment
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []

createIssuerAuthorizedSharesAdjustment issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateIssuerAuthorizedSharesAdjustment with
      adjustment_data = IssuerAuthorizedSharesAdjustmentOcfData with
        id = "TX_ISSUER_AUTH_SHARES_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        issuer_id = "ISSUER_1"
        new_shares_authorized = 2000.0
        board_approval_date = None
        stockholder_approval_date = None
        comments = []

testCreateAndArchiveIssuerAuthorizedSharesAdjustment = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- createIssuerAuthorizedSharesAdjustment issuer issuerCid
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.OCF.IssuerAuthorizedSharesAdjustment.ArchiveByIssuer
  pure ()

testCreateAndArchiveIssuerAuthorizedSharesAdjustmentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- createIssuerAuthorizedSharesAdjustment issuer issuerCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Optionals Some
testIssuerAuthorizedSharesAdjustment_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateIssuerAuthorizedSharesAdjustment with
      adjustment_data = IssuerAuthorizedSharesAdjustmentOcfData with
        id = "TX_ISSUER_AUTH_SHARES_ADJ_2"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        issuer_id = "ISSUER_1"
        new_shares_authorized = 2500.0
        board_approval_date = Some (DT.time (DA.date 2024 Jan 03) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 04) 0 0 0)
        comments = ["Increase"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


