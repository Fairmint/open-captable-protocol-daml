module OpenCapTable.TestStockClassAuthorizedSharesAdjustment where
import Fairmint.OpenCapTable.OCF.StockClass
import Fairmint.OpenCapTable.OCF.StockClassAuthorizedSharesAdjustment
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import Fairmint.OpenCapTable.Types (OcfStockClassType(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveStockClassAuthorizedSharesAdjustment = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- submit issuer do
    createCmd StockClass with
      context = ctx
      stock_class_data = StockClassOcfData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockClassAuthorizedSharesAdjustment with
      adjustment_data = StockClassAuthorizedSharesAdjustmentOcfData with
        id = "TX_SC_AUTH_SHARES_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        stock_class_id = "SC_COMMON"
        new_shares_authorized = 2_000_000.0
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
  submit issuer do
    archiveCmd cid
  pure ()

testCreateAndArchiveStockClassAuthorizedSharesAdjustmentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- submit issuer do
    createCmd StockClass with
      context = ctx
      stock_class_data = StockClassOcfData with
        id = "SC_COMMON_2"
        name = "Common 2"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS2-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockClassAuthorizedSharesAdjustment with
      adjustment_data = StockClassAuthorizedSharesAdjustmentOcfData with
        id = "TX_SC_AUTH_SHARES_ADJ_2"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        stock_class_id = "SC_COMMON_2"
        new_shares_authorized = 1_500_000.0
        board_approval_date = Some (DT.time (DA.date 2024 Jan 03) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 05) 0 0 0)
        comments = ["Authorized change"]
  submit issuer do
    exerciseCmd cid Archive
  pure ()


