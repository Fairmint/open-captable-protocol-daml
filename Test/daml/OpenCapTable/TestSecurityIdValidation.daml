-- =============================================================================
-- Test: Valid security_id succeeds
-- =============================================================================

-- Test: StockTransfer succeeds when using correct stock security_id
testStockTransfer_CorrectSecurityIdSucceeds = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisites and stock issuance
  cap_table <- addPrerequisites issuer cap_table
  cap_table <- addDefaultStockIssuance issuer cap_table
  -- Create a stock transfer using the correct stock security_id
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStockTransfer ST.StockTransferOcfData with
        id = "TX_TRANSFER_VALID"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-STOCK-1"  -- Correct stock security_id
        quantity = 100.0
        comments = []
        resulting_security_ids = ["NEW-SEC-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

-- Test: WarrantTransfer succeeds when using correct warrant security_id
testWarrantTransfer_CorrectSecurityIdSucceeds = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisites and warrant issuance
  cap_table <- addPrerequisites issuer cap_table
  cap_table <- addDefaultWarrantIssuance issuer cap_table
  -- Create a warrant transfer using the correct warrant security_id
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantTransfer WT.WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_VALID"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-WR-1"  -- Correct warrant security_id
        quantity = 100.0
        comments = []
        resulting_security_ids = ["NEW-WARRANT-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()
