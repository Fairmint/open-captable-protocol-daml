module OpenCapTable.TestSecurityIdValidation where

-- =============================================================================
-- Security ID Validation Tests
-- =============================================================================
-- Tests for security_id validation in tier 4 transactions.
-- These tests verify:
-- 1. Transactions fail with clear error when security_id doesn't exist
-- 2. Cross-type validation works (can't use stock security_id in warrant transaction)
-- =============================================================================

import qualified Fairmint.OpenCapTable.OCF.StockTransfer as ST
import qualified Fairmint.OpenCapTable.OCF.WarrantTransfer as WT
import qualified Fairmint.OpenCapTable.OCF.ConvertibleTransfer as CVT
import qualified Fairmint.OpenCapTable.OCF.EquityCompensationTransfer as ECT
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites, addDefaultStockIssuance, addDefaultWarrantIssuance, addDefaultConvertibleIssuance, addDefaultEquityCompensationIssuance)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


-- =============================================================================
-- Test: Non-existent security_id fails with clear error
-- =============================================================================

-- Test: StockTransfer fails when security_id doesn't exist
testStockTransfer_NonExistentSecurityIdFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisites (stakeholder and stock class) but NO stock issuance
  cap_table <- addPrerequisites issuer cap_table
  -- Attempt to create a stock transfer without an existing stock issuance
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStockTransfer ST.StockTransferOcfData with
        id = "TX_TRANSFER_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "NONEXISTENT-STOCK-SEC"  -- This security_id doesn't exist
        quantity = 50.0
        comments = []
        resulting_security_ids = ["NEW-SEC-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

-- Test: WarrantTransfer fails when security_id doesn't exist
testWarrantTransfer_NonExistentSecurityIdFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add only stakeholder (required for validation) but NO warrant issuance
  cap_table <- addPrerequisites issuer cap_table
  -- Attempt to create a warrant transfer without an existing warrant issuance
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantTransfer WT.WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "NONEXISTENT-WARRANT-SEC"  -- This security_id doesn't exist
        quantity = 25.0
        comments = []
        resulting_security_ids = ["NEW-WARRANT-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

-- Test: ConvertibleTransfer fails when security_id doesn't exist
testConvertibleTransfer_NonExistentSecurityIdFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add only stakeholder but NO convertible issuance
  cap_table <- addPrerequisites issuer cap_table
  -- Attempt to create a convertible transfer without an existing convertible issuance
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleTransfer CVT.ConvertibleTransferOcfData with
        id = "TX_CONV_TRANSFER_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "NONEXISTENT-CONV-SEC"  -- This security_id doesn't exist
        amount = OcfMonetary with amount = 1000.0; currency = "USD"
        comments = []
        resulting_security_ids = ["NEW-CONV-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

