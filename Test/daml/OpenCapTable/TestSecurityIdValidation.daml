  cap_table <- addPrerequisites issuer cap_table
  cap_table <- addDefaultEquityCompensationIssuance issuer cap_table
  -- Attempt to create a convertible transfer using the EC's security_id
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [convertibleSuccessorIssuance "CV-ISS-WRONG-SOURCE-TYPE" "NEW-CONV-1" "SH-1" (DT.time (DA.date 2024 Jan 01) 0 0 0) 1000.0
        , CT.OcfCreateConvertibleTransfer CVT.ConvertibleTransferOcfData with
        id = "TX_CONV_TRANSFER_WRONG_TYPE"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
