-- =============================================================================
-- Test: Cross-type validation (type-safe security references)
-- =============================================================================

-- Test: StockTransfer fails when using warrant security_id (wrong type)
testStockTransfer_WrongSecurityTypeFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisites and a WARRANT issuance (not stock)
  cap_table <- addPrerequisites issuer cap_table
  cap_table <- addDefaultWarrantIssuance issuer cap_table
  -- Attempt to create a stock transfer using the warrant's security_id
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStockTransfer ST.StockTransferOcfData with
        id = "TX_TRANSFER_WRONG_TYPE"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-WR-1"  -- This is a warrant security_id, not stock
        quantity = 50.0
        comments = []
        resulting_security_ids = ["NEW-SEC-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

-- Test: WarrantTransfer fails when using stock security_id (wrong type)
testWarrantTransfer_WrongSecurityTypeFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisites and a STOCK issuance (not warrant)
  cap_table <- addPrerequisites issuer cap_table
  cap_table <- addDefaultStockIssuance issuer cap_table
  -- Attempt to create a warrant transfer using the stock's security_id
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantTransfer WT.WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_WRONG_TYPE"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-STOCK-1"  -- This is a stock security_id, not warrant
        quantity = 25.0
        comments = []
        resulting_security_ids = ["NEW-WARRANT-1"]
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

