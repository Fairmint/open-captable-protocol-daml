module OpenCapTable.TestVestingTerms where
import Fairmint.OpenCapTable.OCF.VestingTerms
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import Daml.Script

createVestingTerms issuer capTableCid =
  let vtCond = OcfVestingCondition with
        id = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  in
  submit issuer do
    exerciseCmd capTableCid CT.AddVestingTerms with
      vesting_terms_data = VestingTermsOcfData with
        id = "VT_1"
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = []

testCreateAndArchiveVestingTerms = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  vtCid <- createVestingTerms issuer cap_table
  -- Archive created VestingTerms via issuer

  pure ()

-- Secondary test: archive built-in Archive via submitMulti
testCreateAndArchiveVestingTermsBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  vtCid <- createVestingTerms issuer cap_table

  pure ()

-- Optionals Some: portion instead of quantity; comments non-empty; relative schedule
testVestingTerms_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let vtCond1 = OcfVestingCondition with
        id = "c1"
        description = Some "Relative schedule"
        portion = Some (OcfVestingConditionPortion with numerator = 1.0, denominator = 4.0, remainder = False)
        quantity = None
        trigger = OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodMonths with length_ = 1, occurrences = 4, day_of_month = OcfVestingDay15, cliff_installment = Some 1
          relative_to_condition_id = "start"
        next_condition_ids = []
  let vtCondStart = OcfVestingCondition with
        id = "start"
        description = Some "Start"
        portion = None
        quantity = Some 1.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = ["c1"]
  _ <- submit issuer do
    exerciseCmd cap_table CT.AddVestingTerms with
      vesting_terms_data = VestingTermsOcfData with
        id = "VT_SOME"
        name = "Monthly 4x"
        description = "1/4 monthly"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCondStart, vtCond1]
        comments = ["Scheduled"]

  pure ()
