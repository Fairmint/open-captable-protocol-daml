module OpenCapTable.TestVestingTerms where
import Fairmint.OpenCapTable.OCF.VestingTerms
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import Daml.Script

createVestingTerms issuer capTableCid =
  let vtCond = OcfVestingCondition with
        id = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  in
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms VestingTermsOcfData with
        id = "VT_1"
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = []]
      edits = []
      deletes = []

vestingCondition : Text -> OcfVestingTrigger -> [Text] -> OcfVestingCondition
vestingCondition conditionId trigger nextConditionIds =
  OcfVestingCondition with
    id = conditionId
    description = Some conditionId
    portion = None
    quantity = Some 1.0
    trigger = trigger
    next_condition_ids = nextConditionIds

vestingTermsData : Text -> [OcfVestingCondition] -> VestingTermsOcfData
vestingTermsData vestingTermsId conditions =
  VestingTermsOcfData with
    id = vestingTermsId
    name = vestingTermsId
    description = vestingTermsId
    allocation_type = OcfAllocationCumulativeRounding
    vesting_conditions = conditions
    comments = []

createVestingTermsData issuer capTableCid data_ =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms data_]
      edits = []
      deletes = []

createVestingTermsDataMustFail issuer capTableCid data_ =
  submitMustFail issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms data_]
      edits = []
      deletes = []

testCreateAndArchiveVestingTerms = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  _ <- createVestingTerms issuer cap_table
  -- Archive created VestingTerms via issuer
  pure ()

-- Secondary test: archive built-in Archive via submit with multi-party actAs
testCreateAndArchiveVestingTermsBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  _ <- createVestingTerms issuer cap_table
  pure ()

-- Optionals Some: portion instead of quantity; comments non-empty; relative schedule
testVestingTerms_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let vtCond1 = OcfVestingCondition with
        id = "c1"
        description = Some "Relative schedule"
        portion = Some (OcfVestingConditionPortion with numerator = 1.0, denominator = 4.0, remainder = False)
        quantity = None
        trigger = OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodMonths with length_ = 1, occurrences = 4, day_of_month = OcfVestingDay15, cliff_installment = Some 1
          relative_to_condition_id = "start"
        next_condition_ids = []
  let vtCondStart = OcfVestingCondition with
        id = "start"
        description = Some "Start"
        portion = None
        quantity = Some 1.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = ["c1"]
  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms VestingTermsOcfData with
        id = "VT_SOME"
        name = "Monthly 4x"
        description = "1/4 monthly"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCondStart, vtCond1]
        comments = ["Scheduled"]]
      edits = []
      deletes = []
  pure ()

-- Zero portion numerator is schema-valid and should be accepted.
testVestingTerms_ZeroPortionNumerator = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let vtCondStart = OcfVestingCondition with
        id = "start"
        description = Some "Start"
        portion = Some (OcfVestingConditionPortion with numerator = 0.0, denominator = 1.0, remainder = False)
        quantity = None
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms VestingTermsOcfData with
        id = "VT_ZERO_NUM"
        name = "Zero numerator start"
        description = "Zero-portion start condition"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCondStart]
        comments = []]
      edits = []
      deletes = []
  pure ()

-- Denominator must remain strictly positive.
testVestingTerms_ZeroDenominatorFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let invalidCond = OcfVestingCondition with
        id = "bad"
        description = Some "Invalid ratio"
        portion = Some (OcfVestingConditionPortion with numerator = 1.0, denominator = 0.0, remainder = False)
        quantity = None
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms VestingTermsOcfData with
        id = "VT_ZERO_DEN"
        name = "Invalid denominator"
        description = "Should fail"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [invalidCond]
        comments = []]
      edits = []
      deletes = []

testVestingTerms_DuplicateConditionIdsFail = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let duplicateA = vestingCondition "dup" OcfVestingStartTrigger []
  let duplicateB = vestingCondition "dup" (OcfVestingEventTrigger) []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_DUP_COND" [duplicateA, duplicateB])
  pure ()

testVestingTerms_DuplicateNextConditionIdsFail = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let start = vestingCondition "start" OcfVestingStartTrigger ["next", "next"]
  let next = vestingCondition "next" OcfVestingEventTrigger []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_DUP_NEXT" [start, next])
  pure ()

testVestingTerms_MissingNextConditionIdFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let start = vestingCondition "start" OcfVestingStartTrigger ["missing"]
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_MISSING_NEXT" [start])
  pure ()

testVestingTerms_MissingRelativeConditionIdFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let relative = vestingCondition
        "relative"
        (OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodDays with length_ = 30, occurrences = 1, cliff_installment = None
          relative_to_condition_id = "missing")
        []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_MISSING_RELATIVE" [relative])
  pure ()

testVestingTerms_RelativeConditionMustBePredecessorFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let start = vestingCondition "start" OcfVestingStartTrigger ["relative"]
  let other = vestingCondition "other" OcfVestingEventTrigger []
  let relative = vestingCondition
        "relative"
        (OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodDays with length_ = 30, occurrences = 1, cliff_installment = None
          relative_to_condition_id = "other")
        []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_RELATIVE_PREDECESSOR" [start, other, relative])
  pure ()

testVestingTerms_RelativeAnchorMustDominateAllPathsFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let start = vestingCondition "start" OcfVestingStartTrigger ["anchor", "bypass"]
  let anchor = vestingCondition "anchor" OcfVestingEventTrigger ["relative"]
  let bypass = vestingCondition "bypass" OcfVestingEventTrigger ["relative"]
  let relative = vestingCondition
        "relative"
        (OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodDays with length_ = 30, occurrences = 1, cliff_installment = None
          relative_to_condition_id = "anchor")
        []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_RELATIVE_DOMINATOR" [start, anchor, bypass, relative])
  pure ()

testVestingTerms_OrphanConditionFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let start = vestingCondition "start" OcfVestingStartTrigger []
  let orphan = vestingCondition "orphan" OcfVestingEventTrigger []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_ORPHAN" [start, orphan])
  pure ()

testVestingTerms_CyclicNextConditionsFail = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let first = vestingCondition "first" OcfVestingStartTrigger ["second"]
  let second = vestingCondition "second" OcfVestingEventTrigger ["first"]
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_CYCLE" [first, second])
  pure ()

testVestingTerms_RelativeCycleFail = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let first = vestingCondition
        "first"
        (OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodDays with length_ = 30, occurrences = 1, cliff_installment = None
          relative_to_condition_id = "second")
        []
  let second = vestingCondition
        "second"
        (OcfVestingScheduleRelativeTrigger with
          period = OcfVestingPeriodDays with length_ = 30, occurrences = 1, cliff_installment = None
          relative_to_condition_id = "first")
        []
  createVestingTermsDataMustFail issuer cap_table (vestingTermsData "VT_CYCLE_RELATIVE" [first, second])
  pure ()

testVestingTerms_EditCannotCreateInvalidGraph = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let validStart = vestingCondition "start" OcfVestingStartTrigger ["next"]
  let validNext = vestingCondition "next" OcfVestingEventTrigger []
  result <- createVestingTermsData issuer cap_table (vestingTermsData "VT_EDIT_GRAPH" [validStart, validNext])
  let invalidEdit = vestingTermsData "VT_EDIT_GRAPH" [(validStart with next_condition_ids = ["missing"]), validNext]
  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditVestingTerms invalidEdit]
      deletes = []
  pure ()
