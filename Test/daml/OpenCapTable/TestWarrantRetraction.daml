module OpenCapTable.TestWarrantRetraction where

import Fairmint.OpenCapTable.OCF.WarrantIssuance
import Fairmint.OpenCapTable.OCF.WarrantRetraction
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import OpenCapTable.HelpersTriggers (ocfTriggerElectiveAtWill)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

createWarrantIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantIssuance WarrantIssuanceOcfData with
        id = "TX_WARRANT_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-WARRANT-1"
        custom_id = "W-001"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = Some "Issued as part of debt financing"
        security_law_exemptions = []
        quantity = Some 10000.0
        quantity_source = Some OcfQuantityUnspecified
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        purchase_price = OcfMonetary with amount = 0.01, currency = "USD"
        exercise_triggers = [ ocfTriggerElectiveAtWill ]
        warrant_expiration_date = None
        vesting_terms_id = None
        vestings = []
        comments = []]
      edits = []
      deletes = []

createWarrantRetraction issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantRetraction WarrantRetractionOcfData with
        id = "TX_WARRANT_RETRACT_1"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        security_id = "SEC-WARRANT-1"
        reason_text = "Administrative error - incorrect warrant quantity"
        comments = []]
      edits = []
      deletes = []

testWarrantRetraction_CreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  result <- createWarrantIssuance issuer capTableCid
  _ <- createWarrantRetraction issuer result.updatedCapTableCid
  pure ()

testWarrantRetraction_CreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  result <- createWarrantIssuance issuer capTableCid
  _ <- createWarrantRetraction issuer result.updatedCapTableCid
  pure ()

-- Test with comments (non-empty array)
testWarrantRetraction_WithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  result <- createWarrantIssuance issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantRetraction WarrantRetractionOcfData with
        id = "TX_WARRANT_RETRACT_2"
        date = DT.time (DA.date 2024 Jan 03) 0 0 0
        security_id = "SEC-WARRANT-1"
        reason_text = "Warrant void ab initio - debt financing fell through"
        comments = ["Board resolution 2024-005", "Holder acknowledged"]]
      edits = []
      deletes = []
  pure ()
