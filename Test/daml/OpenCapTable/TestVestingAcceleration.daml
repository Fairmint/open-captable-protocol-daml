module OpenCapTable.TestVestingAcceleration where

import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance
import Fairmint.OpenCapTable.OCF.VestingAcceleration
import Fairmint.OpenCapTable.Types (OcfMonetary(..), OcfCompensationType(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Create an equity compensation issuance with vesting
createEquityCompensationIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationIssuance EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "OPT-001"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_plan_id = Some "ESOP-2024"
        stock_class_id = Some "COMMON"
        compensation_type = OcfCompensationTypeOptionISO
        quantity = quantity
        base_price = None
        early_exercisable = Some False
        exercise_price = Some (OcfMonetary with amount = 1.25, currency = "USD")
        expiration_date = Some (DT.time (DA.date 2034 Jan 01) 0 0 0)
        termination_exercise_windows = []
        vestings = []
        vesting_terms_id = Some "standard-4yr-1yr-cliff"
        comments = []]
      edits = []
      deletes = []

-- Test 1: Single-trigger acceleration (change of control)
-- 50% of unvested shares accelerate upon acquisition
testVestingAcceleration_SingleTrigger = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let securityId = "ECSEC-001"
  result <- createEquityCompensationIssuance issuer capTableCid securityId 100000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration VestingAccelerationOcfData with
        id = "TX_VESTING_ACCEL_1"
        date = DT.time (DA.date 2025 Nov 15) 0 0 0
        security_id = securityId
        quantity = 25000.0
        reason_text = "Single-trigger acceleration upon change of control per equity agreement Section 5.2"
        comments = []]
      edits = []
      deletes = []
  pure ()

-- Test 2: Double-trigger acceleration (termination after acquisition)
-- 100% of unvested shares accelerate
testVestingAcceleration_DoubleTrigger = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let securityId = "ECSEC-002"
  result <- createEquityCompensationIssuance issuer capTableCid securityId 200000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration VestingAccelerationOcfData with
        id = "TX_VESTING_ACCEL_2"
        date = DT.time (DA.date 2026 Feb 28) 0 0 0
        security_id = securityId
        quantity = 100000.0
        reason_text = "Double-trigger acceleration: involuntary termination within 12 months of change of control"
        comments = ["All unvested shares accelerated per employment agreement.", "Employee terminated without cause on 2026-02-28."]]
      edits = []
      deletes = []
  pure ()

-- Test 3: Discretionary board acceleration
testVestingAcceleration_BoardDiscretion = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let securityId = "ECSEC-003"
  result <- createEquityCompensationIssuance issuer capTableCid securityId 50000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration VestingAccelerationOcfData with
        id = "TX_VESTING_ACCEL_3"
        date = DT.time (DA.date 2025 Dec 01) 0 0 0
        security_id = securityId
        quantity = 12500.0
        reason_text = "Board-approved discretionary acceleration for exceptional performance"
        comments = []]
      edits = []
      deletes = []
  pure ()
