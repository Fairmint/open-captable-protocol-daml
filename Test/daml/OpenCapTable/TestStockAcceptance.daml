module OpenCapTable.TestStockAcceptance where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockAcceptance
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Helper to create stock issuance (needs stakeholder + stock class)
createStockIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance StockIssuanceOcfData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-STOCK-1"
        custom_id = "CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        stock_plan_id = None
        share_numbers_issued = []
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = 100.0
        vesting_terms_id = None
        vestings = []
        cost_basis = None
        stock_legend_ids = ["L1"]
        issuance_type = None
        comments = []]
      edits = []
      deletes = []

testStockAcceptance_Create = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- addPrerequisites adds stakeholder "SH-1" and stock class "SC_COMMON"
  capTableCid <- addPrerequisites issuer cap_table
  result <- createStockIssuance issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockAcceptance StockAcceptanceOcfData with
        id = "TX_STOCK_ACCEPT_1"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        security_id = "SEC-STOCK-1"
        comments = []]
      edits = []
      deletes = []
  pure ()

testStockAcceptance_WithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  result <- createStockIssuance issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockAcceptance StockAcceptanceOcfData with
        id = "TX_STOCK_ACCEPT_2"
        date = DT.time (DA.date 2024 Jan 03) 0 0 0
        security_id = "SEC-STOCK-1"
        comments = ["Stakeholder accepted via DocuSign", "Certificate mailed"]]
      edits = []
      deletes = []
  pure ()
