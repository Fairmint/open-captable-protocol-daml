testConvertibleSecurityBalance_NegativeTransferAmountFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-NEGATIVE-TRANSFER-SOURCE" "CSEC-NEGATIVE-TRANSFER-SOURCE" "SH-1" jan01 100.0
        , convertibleSuccessorIssuance "CV-ISS-NEGATIVE-TRANSFER-RESULT" "CSEC-NEGATIVE-TRANSFER-RESULT" "SH-1" jan02 (-1.0)
        , CT.OcfCreateConvertibleTransfer (convertibleTransfer
            "TX-CV-NEGATIVE-TRANSFER"
            "CSEC-NEGATIVE-TRANSFER-SOURCE"
            (-1.0)
            jan02
            ["CSEC-NEGATIVE-TRANSFER-RESULT"]
            None)
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_TransferResultAmountMustMatch = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-RESULT-AMOUNT-SOURCE" "CSEC-RESULT-AMOUNT-SOURCE" "SH-1" jan01 100.0
        , convertibleSuccessorIssuance "CV-ISS-RESULT-AMOUNT-WRONG" "CSEC-RESULT-AMOUNT-WRONG" "SH-1" jan02 59.0
        , CT.OcfCreateConvertibleTransfer (convertibleTransfer
            "TX-CV-RESULT-AMOUNT-MISMATCH"
            "CSEC-RESULT-AMOUNT-SOURCE"
            60.0
            jan02
            ["CSEC-RESULT-AMOUNT-WRONG"]
            None)
        ]
      edits = []
      deletes = []

