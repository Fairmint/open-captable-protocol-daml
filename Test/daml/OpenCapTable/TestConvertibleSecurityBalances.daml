        , CT.OcfCreateConvertibleCancellation (convertibleCancellation "TX-CV-NEGATIVE-CANCEL" "CSEC-NEGATIVE-CANCEL" (-1.0) jan02 None)
        ]
      edits = []
      deletes = []

