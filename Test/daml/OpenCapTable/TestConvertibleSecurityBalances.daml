module OpenCapTable.TestConvertibleSecurityBalances where

import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OCF.ConvertibleCancellation (ConvertibleCancellationOcfData(..))
import Fairmint.OpenCapTable.OCF.ConvertibleConversion (ConvertibleConversionOcfData(..))
import Fairmint.OpenCapTable.OCF.ConvertibleTransfer (ConvertibleTransferOcfData(..))
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import OpenCapTable.Setup
import OpenCapTable.TestHelpers
  ( addDefaultStakeholder
  , addPrerequisites
  , convertibleSuccessorIssuance
  , stockSuccessorIssuance
  )
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

jan01 : Time
jan01 = DT.time (DA.date 2024 Jan 01) 0 0 0

jan02 : Time
jan02 = DT.time (DA.date 2024 Jan 02) 0 0 0

jan03 : Time
jan03 = DT.time (DA.date 2024 Jan 03) 0 0 0

convertibleCancellation : Text -> Text -> Decimal -> Time -> Optional Text -> ConvertibleCancellationOcfData
convertibleCancellation transactionId securityId amount date balanceSecurityId =
  ConvertibleCancellationOcfData with
    id = transactionId
    amount = OcfMonetary with amount = amount, currency = "USD"
    date = date
    reason_text = "Convertible cancellation"
    security_id = securityId
    comments = []
    balance_security_id = balanceSecurityId

convertibleTransfer : Text -> Text -> Decimal -> Time -> [Text] -> Optional Text -> ConvertibleTransferOcfData
convertibleTransfer transactionId securityId amount date resultingSecurityIds balanceSecurityId =
  ConvertibleTransferOcfData with
    id = transactionId
    amount = OcfMonetary with amount = amount, currency = "USD"
    date = date
    security_id = securityId
    resulting_security_ids = resultingSecurityIds
    balance_security_id = balanceSecurityId
    consideration_text = None
    comments = []

convertibleConversion : Text -> Text -> Text -> Time -> [Text] -> Optional Text -> Optional Decimal -> ConvertibleConversionOcfData
convertibleConversion transactionId securityId triggerId date resultingSecurityIds balanceSecurityId quantityConverted =
  ConvertibleConversionOcfData with
    id = transactionId
    date = date
    security_id = securityId
    trigger_id = triggerId
    reason_text = "Convertible conversion"
    resulting_security_ids = resultingSecurityIds
    comments = []
    balance_security_id = balanceSecurityId
    capitalization_definition = None
    quantity_converted = quantityConverted

testConvertibleSecurityBalance_CancellationCannotExceedInvestmentAmount = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-OVER-CANCEL" "CSEC-OVER-CANCEL" "SH-1" jan01 100.0
        , CT.OcfCreateConvertibleCancellation (convertibleCancellation "TX-CV-OVER-CANCEL" "CSEC-OVER-CANCEL" 101.0 jan02 None)
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_CancellationCurrencyMustMatchIssuance = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table
  let cancellation = (convertibleCancellation "TX-CV-CURRENCY-MISMATCH" "CSEC-CURRENCY-MISMATCH" 10.0 jan02 None) with
        amount = OcfMonetary with amount = 10.0, currency = "EUR"

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-CURRENCY-MISMATCH" "CSEC-CURRENCY-MISMATCH" "SH-1" jan01 100.0
        , CT.OcfCreateConvertibleCancellation cancellation
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_NegativeCancellationAmountFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table

  submitMustFail issuer do
