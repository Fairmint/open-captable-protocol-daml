testConvertibleSecurityBalance_TransferCannotChangeSuccessorConversionTerms = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table
  let source = convertibleIssuance "CV-ISS-TRIGGER-TERMS-SOURCE" "CSEC-TRIGGER-TERMS-SOURCE" "SH-1" jan01 100.0
      baseResult = convertibleIssuance "CV-ISS-TRIGGER-TERMS-RESULT" "CSEC-TRIGGER-TERMS-RESULT" "SH-1" jan02 60.0
      result = baseResult with
        conversion_triggers = map
          (\trigger -> trigger with trigger_description = Some "Amended during transfer")
          baseResult.conversion_triggers

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateConvertibleIssuance source
        , CT.OcfCreateConvertibleIssuance result
        , CT.OcfCreateConvertibleTransfer (convertibleTransfer
            "TX-CV-TRIGGER-TERMS-MISMATCH"
            source.security_id
            60.0
            jan02
            [result.security_id]
            None)
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_PartialTransferScalesSuccessorProRata = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table
  (capTableReady, transfereeId) <- setupStakeholderWithId issuer capTableReady "SH-CV-PRO-RATA-TRANSFEREE" "Convertible Pro Rata Transferee"
  let source = (convertibleIssuance "CV-ISS-PRO-RATA-SOURCE" "CSEC-PRO-RATA-SOURCE" "SH-1" jan01 100.0) with
        pro_rata = Some 1_000.0
      result = (convertibleIssuance "CV-ISS-PRO-RATA-RESULT" "CSEC-PRO-RATA-RESULT" transfereeId jan02 60.0) with
        pro_rata = Some 600.0
      balance = (convertibleIssuance "CV-ISS-PRO-RATA-BALANCE" "CSEC-PRO-RATA-BALANCE" "SH-1" jan02 40.0) with
        pro_rata = Some 400.0

  _ <- submit issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateConvertibleIssuance source
        , CT.OcfCreateConvertibleIssuance result
        , CT.OcfCreateConvertibleIssuance balance
        , CT.OcfCreateConvertibleTransfer (convertibleTransfer
            "TX-CV-PRO-RATA-PARTIAL"
            source.security_id
            60.0
            jan02
            [result.security_id]
            (Some balance.security_id))
        ]
      edits = []
      deletes = []
  pure ()

testConvertibleSecurityBalance_TransferBalanceMustKeepSourceStakeholder = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table
  (capTableReady, transfereeId) <- setupStakeholderWithId issuer capTableReady "SH-CV-TRANSFEREE" "Convertible Transferee"
  let source = convertibleIssuance "CV-ISS-HOLDER-SOURCE" "CSEC-HOLDER-SOURCE" "SH-1" jan01 100.0
      result = convertibleIssuance "CV-ISS-HOLDER-RESULT" "CSEC-HOLDER-RESULT" transfereeId jan02 60.0
      balance = convertibleIssuance "CV-ISS-HOLDER-BALANCE" "CSEC-HOLDER-BALANCE" transfereeId jan02 40.0

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateConvertibleIssuance source
        , CT.OcfCreateConvertibleIssuance result
        , CT.OcfCreateConvertibleIssuance balance
        , CT.OcfCreateConvertibleTransfer (convertibleTransfer
            "TX-CV-BALANCE-HOLDER-MISMATCH"
            source.security_id
            60.0
            jan02
            [result.security_id]
            (Some balance.security_id))
        ]
      edits = []
      deletes = []

