testConvertibleSecurityBalance_ConversionWithBalanceRetiresSource = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addPrerequisites issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-CONVERSION-SOURCE" "CSEC-CONVERSION-SOURCE" "SH-1" jan01 100.0
        , convertibleSuccessorIssuance "CV-ISS-CONVERSION-BALANCE" "CSEC-CONVERSION-BALANCE" "SH-1" jan02 40.0
        , stockSuccessorIssuance "STOCK-ISS-CONVERSION-RESULT" "SSEC-CONVERSION-RESULT" "SH-1" "SC_COMMON" jan02 60.0
        , CT.OcfCreateConvertibleConversion (convertibleConversion
            "TX-CV-CONVERSION-BALANCE"
            "CSEC-CONVERSION-SOURCE"
            "TRIGGER-CV-ISS-CONVERSION-SOURCE"
            jan02
            ["SSEC-CONVERSION-RESULT"]
            (Some "CSEC-CONVERSION-BALANCE")
            (Some 60.0))
        , CT.OcfCreateConvertibleCancellation (convertibleCancellation
            "TX-CV-CANCEL-OLD-CONVERSION-SOURCE"
            "CSEC-CONVERSION-SOURCE"
            1.0
            jan03
            None)
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_ConversionWithoutBalanceRetiresSource = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addPrerequisites issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-FULL-CONVERSION-SOURCE" "CSEC-FULL-CONVERSION-SOURCE" "SH-1" jan01 100.0
        , stockSuccessorIssuance "STOCK-ISS-FULL-CONVERSION-RESULT" "SSEC-FULL-CONVERSION-RESULT" "SH-1" "SC_COMMON" jan02 25.0
        , CT.OcfCreateConvertibleConversion (convertibleConversion
            "TX-CV-FULL-CONVERSION"
            "CSEC-FULL-CONVERSION-SOURCE"
            "TRIGGER-CV-ISS-FULL-CONVERSION-SOURCE"
            jan02
            ["SSEC-FULL-CONVERSION-RESULT"]
            None
            (Some 25.0))
        , CT.OcfCreateConvertibleCancellation (convertibleCancellation
            "TX-CV-CANCEL-FULL-CONVERSION-SOURCE"
            "CSEC-FULL-CONVERSION-SOURCE"
            1.0
            jan03
            None)
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_PartialCancellationWithBalanceSucceeds = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table

  _ <- submit issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-PARTIAL-CANCEL-SOURCE" "CSEC-PARTIAL-CANCEL-SOURCE" "SH-1" jan01 100.0
        , convertibleSuccessorIssuance "CV-ISS-PARTIAL-CANCEL-BALANCE" "CSEC-PARTIAL-CANCEL-BALANCE" "SH-1" jan02 60.0
        , CT.OcfCreateConvertibleCancellation (convertibleCancellation
            "TX-CV-PARTIAL-CANCEL"
            "CSEC-PARTIAL-CANCEL-SOURCE"
            40.0
            jan02
            (Some "CSEC-PARTIAL-CANCEL-BALANCE"))
        ]
      edits = []
      deletes = []
  pure ()
