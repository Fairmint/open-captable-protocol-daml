testConvertibleSecurityBalance_TransferWithBalanceRetiresSource = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addDefaultStakeholder issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-TRANSFER-SOURCE" "CSEC-TRANSFER-SOURCE" "SH-1" jan01 100.0
        , convertibleSuccessorIssuance "CV-ISS-TRANSFER-RESULT" "CSEC-TRANSFER-RESULT" "SH-1" jan02 60.0
        , convertibleSuccessorIssuance "CV-ISS-TRANSFER-BALANCE" "CSEC-TRANSFER-BALANCE" "SH-1" jan02 40.0
        , CT.OcfCreateConvertibleTransfer (convertibleTransfer
            "TX-CV-TRANSFER-BALANCE"
            "CSEC-TRANSFER-SOURCE"
            60.0
            jan02
            ["CSEC-TRANSFER-RESULT"]
            (Some "CSEC-TRANSFER-BALANCE"))
        , CT.OcfCreateConvertibleCancellation (convertibleCancellation
            "TX-CV-CANCEL-OLD-TRANSFER-SOURCE"
            "CSEC-TRANSFER-SOURCE"
            1.0
            jan03
            None)
        ]
      edits = []
      deletes = []

