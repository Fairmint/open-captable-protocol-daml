        , CT.OcfCreateConvertibleCancellation (convertibleCancellation
            "TX-CV-FULL-CANCEL-ZERO-BALANCE"
            "CSEC-FULL-CANCEL-ZERO-SOURCE"
            100.0
            jan02
            (Some "CSEC-FULL-CANCEL-ZERO-BALANCE"))
        ]
      edits = []
      deletes = []

testConvertibleSecurityBalance_ConversionCannotCreateZeroBalance = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableReady <- addPrerequisites issuer cap_table

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ convertibleSuccessorIssuance "CV-ISS-CONVERSION-ZERO-SOURCE" "CSEC-CONVERSION-ZERO-SOURCE" "SH-1" jan01 100.0
        , convertibleSuccessorIssuance "CV-ISS-CONVERSION-ZERO-BALANCE" "CSEC-CONVERSION-ZERO-BALANCE" "SH-1" jan02 0.0
        , stockSuccessorIssuance "STOCK-ISS-CONVERSION-ZERO-RESULT" "SSEC-CONVERSION-ZERO-RESULT" "SH-1" "SC_COMMON" jan02 25.0
        , CT.OcfCreateConvertibleConversion (convertibleConversion
            "TX-CV-CONVERSION-ZERO-BALANCE"
            "CSEC-CONVERSION-ZERO-SOURCE"
            "TRIGGER-CV-ISS-CONVERSION-ZERO-SOURCE"
            jan02
            ["SSEC-CONVERSION-ZERO-RESULT"]
            (Some "CSEC-CONVERSION-ZERO-BALANCE")
            (Some 25.0))
        ]
      edits = []
      deletes = []
