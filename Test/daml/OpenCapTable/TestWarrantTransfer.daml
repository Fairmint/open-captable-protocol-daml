module OpenCapTable.TestWarrantTransfer where

import Fairmint.OpenCapTable.OCF.WarrantIssuance
import Fairmint.OpenCapTable.OCF.WarrantTransfer
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import OpenCapTable.HelpersTriggers (ocfTriggerElectiveAtWill)
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers
  ( addDefaultStakeholder
  , createWarrantIssuance
  , setupStakeholderWithId
  , warrantSuccessorIssuance
  )
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

warrantTransferSuccessorIssuance : Text -> Text -> Text -> Time -> Decimal -> CT.OcfCreateData
warrantTransferSuccessorIssuance issuanceId securityId stakeholderId date quantity =
  CT.OcfCreateWarrantIssuance WarrantIssuanceOcfData with
    id = issuanceId
    date = date
    security_id = securityId
    custom_id = "WR-" <> issuanceId
    stakeholder_id = stakeholderId
    board_approval_date = None
    stockholder_approval_date = None
    consideration_text = None
    security_law_exemptions = []
    quantity = Some quantity
    quantity_source = None
    exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
    purchase_price = OcfMonetary with amount = 0.0, currency = "USD"
    exercise_triggers = [ocfTriggerElectiveAtWill]
    warrant_expiration_date = None
    vesting_terms_id = None
    vestings = []
    comments = []

-- Test: Warrant transfer per secondary sale agreement
-- No prod/dev examples (warrants usually exercised, not transferred)
-- Extrapolated from stock transfer pattern
testWarrantTransfer_SecondarySale = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-ASSIGNEE" "Warrant Assignee"
  let securityId = "WSEC-001"
  result <- createWarrantIssuance issuer capTableCid securityId 10000.0 (DT.time (DA.date 2023 Jun 01) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [warrantTransferSuccessorIssuance "WR-ISS-TRANSFERRED-001" "WSEC-TRANSFERRED-001" assigneeId (DT.time (DA.date 2025 Mar 15) 0 0 0) 10000.0
        , CT.OcfCreateWarrantTransfer WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_1"
        date = DT.time (DA.date 2025 Mar 15) 0 0 0
        quantity = 10000.0
        security_id = securityId
        resulting_security_ids = ["WSEC-TRANSFERRED-001"]
        comments = ["Warrant transfer per secondary sale agreement"]
        balance_security_id = None
        consideration_text = Some "10,000 warrants transferred at $0.50 per warrant."]
      edits = []
      deletes = []
  pure ()

-- Test: Partial warrant transfer with balance
testWarrantTransfer_PartialTransfer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-ASSIGNEE" "Warrant Assignee"
  let securityId = "WSEC-PARTIAL"
  result <- createWarrantIssuance issuer capTableCid securityId 50000.0 (DT.time (DA.date 2023 Jun 01) 0 0 0)
  let transferDate = DT.time (DA.date 2025 Jun 01) 0 0 0
  balanceResult <- createWarrantIssuance issuer result.updatedCapTableCid "WSEC-PARTIAL-REMAIN" 30000.0 transferDate
  _ <- submit issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [warrantTransferSuccessorIssuance "WR-ISS-NEW-HOLDER" "WSEC-NEW-HOLDER" assigneeId transferDate 20000.0
        , CT.OcfCreateWarrantTransfer WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_PARTIAL"
        date = transferDate
        quantity = 20000.0
        security_id = securityId
        resulting_security_ids = ["WSEC-NEW-HOLDER"]
        comments = ["Partial warrant transfer", "Remaining warrants retained by original holder"]
        balance_security_id = Some "WSEC-PARTIAL-REMAIN"
        consideration_text = Some "Partial transfer of 20,000 warrants at $0.75 per warrant."]
      edits = []
      deletes = []
  pure ()

testWarrantTransfer_BalanceMustKeepSourceStakeholder = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-WARRANT-BALANCE-ASSIGNEE" "Warrant Balance Assignee"
  let securityId = "WSEC-BALANCE-HOLDER-SOURCE"
      transferDate = DT.time (DA.date 2025 Jun 01) 0 0 0
  sourceResult <- createWarrantIssuance issuer capTableCid securityId 100.0 (DT.time (DA.date 2023 Jun 01) 0 0 0)

  submitMustFail issuer do
    exerciseCmd sourceResult.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ warrantTransferSuccessorIssuance "WR-ISS-BALANCE-HOLDER-RESULT" "WSEC-BALANCE-HOLDER-RESULT" assigneeId transferDate 60.0
        , warrantTransferSuccessorIssuance "WR-ISS-BALANCE-HOLDER-REMAINDER" "WSEC-BALANCE-HOLDER-REMAINDER" assigneeId transferDate 40.0
        , CT.OcfCreateWarrantTransfer WarrantTransferOcfData with
            id = "TX-WARRANT-BALANCE-HOLDER-MISMATCH"
            date = transferDate
            quantity = 60.0
            security_id = securityId
            resulting_security_ids = ["WSEC-BALANCE-HOLDER-RESULT"]
            comments = []
            balance_security_id = Some "WSEC-BALANCE-HOLDER-REMAINDER"
            consideration_text = None
        ]
      edits = []
      deletes = []

testWarrantTransfer_OverstatedBalanceQuantityFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-OVERSTATED-ASSIGNEE" "Overstated Balance Assignee"
  let securityId = "WSEC-OVERSTATED-BALANCE-SOURCE"
  sourceResult <- createWarrantIssuance issuer capTableCid securityId 100.0 (DT.time (DA.date 2023 Jun 01) 0 0 0)
  balanceResult <- createWarrantIssuance issuer sourceResult.updatedCapTableCid "WSEC-OVERSTATED-BALANCE" 60.0 (DT.time (DA.date 2025 Jun 01) 0 0 0)

  submitMustFail issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ warrantSuccessorIssuance "WR-ISS-OVERSTATED-RESULT" "WSEC-OVERSTATED-RESULT" assigneeId (DT.time (DA.date 2025 Jun 01) 0 0 0) 60.0
        , CT.OcfCreateWarrantTransfer WarrantTransferOcfData with
            id = "TX-WARRANT-TRANSFER-OVERSTATED-BALANCE"
            date = DT.time (DA.date 2025 Jun 01) 0 0 0
            quantity = 60.0
            security_id = securityId
            resulting_security_ids = ["WSEC-OVERSTATED-RESULT"]
            comments = []
            balance_security_id = Some "WSEC-OVERSTATED-BALANCE"
            consideration_text = None
        ]
      edits = []
      deletes = []

-- Test: Full transfer with no balance and no consideration text
testWarrantTransfer_FullTransferNoConsideration = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-ASSIGNEE" "Warrant Assignee"
  let securityId = "WSEC-FULL"
  result <- createWarrantIssuance issuer capTableCid securityId 5000.0 (DT.time (DA.date 2023 Jun 01) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [warrantTransferSuccessorIssuance "WR-ISS-NEWOWNER" "WSEC-NEWOWNER" assigneeId (DT.time (DA.date 2025 Jul 20) 0 0 0) 5000.0
        , CT.OcfCreateWarrantTransfer WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_FULL"
        date = DT.time (DA.date 2025 Jul 20) 0 0 0
        quantity = 5000.0
        security_id = securityId
        resulting_security_ids = ["WSEC-NEWOWNER"]
        comments = []
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()
