module OpenCapTable.TestWarrantTransfer where

import Fairmint.OpenCapTable.OCF.WarrantIssuance
import Fairmint.OpenCapTable.OCF.WarrantTransfer
import qualified Fairmint.OpenCapTable.OCF.WarrantTransfer as WT
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import OpenCapTable.HelpersTriggers (ocfTriggerElectiveAtWill)
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

-- Create a warrant issuance to transfer (follows real workflow)
createWarrantIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.AddWarrantIssuance with
      issuance_data = WarrantIssuanceOcfData with
        id = "TX_WARRANT_ISS_1"
        date = DT.time (DA.date 2023 Jun 01) 0 0 0
        security_id = securityId
        custom_id = "W-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        quantity = Some quantity
        quantity_source = None
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        purchase_price = OcfMonetary with amount = 0.0, currency = "USD"
        exercise_triggers = [ ocfTriggerElectiveAtWill ]
        warrant_expiration_date = None
        vesting_terms_id = None
        vestings = []
        comments = []

-- Test: Warrant transfer per secondary sale agreement
-- No prod/dev examples (warrants usually exercised, not transferred)
-- Extrapolated from stock transfer pattern
testWarrantTransfer_SecondarySale = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "WSEC-001"
  _ <- createWarrantIssuance issuer capTableCid securityId 10000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddWarrantTransfer with
      transfer_data = WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_1"
        date = DT.time (DA.date 2025 Mar 15) 0 0 0
        quantity = 10000.0
        security_id = securityId
        resulting_security_ids = ["WSEC-TRANSFERRED-001"]
        comments = ["Warrant transfer per secondary sale agreement"]
        balance_security_id = None
        consideration_text = Some "10,000 warrants transferred at $0.50 per warrant."

  pure ()

-- Test: Partial warrant transfer with balance
testWarrantTransfer_PartialTransfer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "WSEC-PARTIAL"
  _ <- createWarrantIssuance issuer capTableCid securityId 50000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddWarrantTransfer with
      transfer_data = WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_PARTIAL"
        date = DT.time (DA.date 2025 Jun 01) 0 0 0
        quantity = 20000.0
        security_id = securityId
        resulting_security_ids = ["WSEC-NEW-HOLDER"]
        comments = ["Partial warrant transfer", "Remaining warrants retained by original holder"]
        balance_security_id = Some "WSEC-PARTIAL-REMAIN"
        consideration_text = Some "Partial transfer of 20,000 warrants at $0.75 per warrant."

  pure ()

-- Test: Full transfer with no balance and no consideration text
testWarrantTransfer_FullTransferNoConsideration = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "WSEC-FULL"
  _ <- createWarrantIssuance issuer capTableCid securityId 5000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddWarrantTransfer with
      transfer_data = WarrantTransferOcfData with
        id = "TX_WARRANT_TRANSFER_FULL"
        date = DT.time (DA.date 2025 Jul 20) 0 0 0
        quantity = 5000.0
        security_id = securityId
        resulting_security_ids = ["WSEC-NEWOWNER"]
        comments = []
        balance_security_id = None
        consideration_text = None

  pure ()
