module OpenCapTable.TestOcpFactory where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.OCF.Issuer
import Fairmint.OpenCapTable.Types.Stock (OcfInitialSharesAuthorized(..))
import OpenCapTable.Setup
import Daml.Script
import DA.Assert ((===))
import DA.Date
import DA.Time

createFactory system_operator =
  submit system_operator do
    createCmd OcpFactory with
      system_operator = system_operator

defaultIssuerData : IssuerOcfData
defaultIssuerData = IssuerOcfData with
  id = "ISSUER_KEYS"
  legal_name = "Keyed Issuer Inc."
  formation_date = time (DA.Date.date 2020 Jan 15) 12 0 0
  country_of_formation = "US"
  dba = None
  country_subdivision_of_formation = None
  country_subdivision_name_of_formation = None
  tax_ids = []
  email = None
  phone = None
  address = None
  initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
  comments = []

testAuthorizeAndWithdraw = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  factoryCid <- createFactory system_operator
  -- First authorization: archive it to cover built-in Archive
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  submit system_operator do
    exerciseCmd authCid Archive
  -- Second authorization: withdraw it to cover WithdrawAuthorization
  authCid2 <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  -- Withdraw authorization
  _ <- submit system_operator do
    exerciseCmd authCid2 WithdrawAuthorization
  -- Archive OcpFactory by system operator
  submit system_operator do
    exerciseCmd factoryCid Archive
  pure ()

testContractKeyLookups = script do
  TestUsers{tu_system_operator = system_operator, tu_issuer = issuer} <- setupUsers
  factoryCid <- createFactory system_operator

  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer

  authAfter <- submit system_operator do
    exerciseCmd factoryCid LookupIssuerAuthorization with issuer = issuer
  authAfter === Some authCid

  capTableCid <- submit issuer do
    exerciseCmd authCid CreateCapTable with issuer_data = defaultIssuerData

  capTableAfter <- submit system_operator do
    exerciseCmd factoryCid LookupCapTable with issuer = issuer
  capTableAfter === Some capTableCid
