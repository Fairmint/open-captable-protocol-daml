module OpenCapTable.TestStockPlan where
import Fairmint.OpenCapTable.OCF.StockPlan
import Fairmint.OpenCapTable.OCF.VestingTerms
import OpenCapTable.Setup
import Daml.Script
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT

testCreatePlanAndArchive = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let vtCond = OcfVestingCondition with
        id = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  _vtCid <- submit issuer do
    createCmd VestingTerms with
      context = ctx
      vesting_terms_data = VestingTermsOcfData with
        id = "VT_PLAN"
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = []
  planCid <- submit issuer do
    createCmd StockPlan with
      context = ctx
      plan_data = StockPlanOcfData with
        id = "PLAN_2025"
        plan_name = "2025 Equity Incentive Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1_000_000.0
        default_cancellation_behavior = None
        stock_class_ids = ["SC_COMMON"]
        comments = []
  submit issuer do
    archiveCmd planCid
  pure ()

testCreatePlanAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  planCid <- submit issuer do
    createCmd StockPlan with
      context = ctx
      plan_data = StockPlanOcfData with
        id = "PLAN_2026"
        plan_name = "2026 Equity Incentive Plan"
        board_approval_date = Some (DT.time (DA.date 2026 Jan 1) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2026 Jan 15) 0 0 0)
        initial_shares_reserved = 500_000.0
        default_cancellation_behavior = Some OcfPlanCancelReturnToPool
        stock_class_ids = ["SC_COMMON"]
        comments = ["Approved"]
  submit issuer do
    exerciseCmd planCid Archive
  pure ()

-- Optionals Some and arrays non-empty
testStockPlan_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  planCid <- submit issuer do
    createCmd StockPlan with
      context = ctx
      plan_data = StockPlanOcfData with
        id = "PLAN_2027"
        plan_name = "2027 Equity Incentive Plan"
        board_approval_date = Some (DT.time (DA.date 2027 Jan 1) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2027 Jan 15) 0 0 0)
        initial_shares_reserved = 600_000.0
        default_cancellation_behavior = Some OcfPlanCancelReturnToPool
        stock_class_ids = ["SC_COMMON"]
        comments = ["Approved"]
  submit issuer do
    exerciseCmd planCid Archive
  pure ()
