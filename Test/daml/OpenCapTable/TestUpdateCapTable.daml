module OpenCapTable.TestUpdateCapTable where
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OCF.Stakeholder
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import Daml.Script

-- Test UpdateCapTable without app rewards (appRewards = None)
-- Note: We cannot verify marker creation in tests because TestFeaturedAppRight returns empty marker lists
testUpdateCapTableWithoutAppRewards = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Call UpdateCapTable with empty operations and no app rewards
  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = []
      appRewards = None
  pure ()

-- Test UpdateCapTable with app rewards
-- Note: TestFeaturedAppRight mock returns empty marker lists, so we can only verify the code path executes
testUpdateCapTableWithAppRewards = script do
  TestOcp{system_operator, issuer, ctx, cap_table, featured_app_right} <- setupTestOcp
  -- Call UpdateCapTable with app rewards config
  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = []
      appRewards = Some CT.AppRewardsConfig with
        couponCount = 3
        featuredAppRight = featured_app_right
  pure ()

-- Test UpdateCapTable with zero coupons
testUpdateCapTableWithZeroCoupons = script do
  TestOcp{system_operator, issuer, ctx, cap_table, featured_app_right} <- setupTestOcp
  -- Call UpdateCapTable with zero coupon count - should not create any markers
  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = []
      appRewards = Some CT.AppRewardsConfig with
        couponCount = 0
        featuredAppRight = featured_app_right
  pure ()

-- Test UpdateCapTable with creates
testUpdateCapTableWithCreates = script do
  TestOcp{system_operator, issuer, ctx, cap_table, featured_app_right} <- setupTestOcp
  -- Create a stakeholder via batch update
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "BATCH_SH_1"
        name = OcfName with legal_name = "Batch Created", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
      appRewards = None
  -- Verify the stakeholder was created
  assertMsg "Should have created 1 object" (result.createdIds == ["BATCH_SH_1"])
  pure ()
