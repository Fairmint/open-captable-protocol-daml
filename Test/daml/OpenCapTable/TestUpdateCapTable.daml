module OpenCapTable.TestUpdateCapTable where
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import Splice.Api.FeaturedAppRightV1 as Featured
import Daml.Script

-- Test UpdateCapTable without app rewards (appRewards = None)
testUpdateCapTableWithoutAppRewards = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Call UpdateCapTable with None for appRewards - should do nothing
  submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      appRewards = None
  pure ()

-- Test UpdateCapTable with app rewards
testUpdateCapTableWithAppRewards = script do
  TestOcp{system_operator, issuer, ctx, cap_table, featured_app_right} <- setupTestOcp
  -- Call UpdateCapTable with app rewards config
  submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      appRewards = Some CT.AppRewardsConfig with
        couponCount = 3
        featuredAppRight = featured_app_right
  pure ()

-- Test UpdateCapTable with zero coupons
testUpdateCapTableWithZeroCoupons = script do
  TestOcp{system_operator, issuer, ctx, cap_table, featured_app_right} <- setupTestOcp
  -- Call UpdateCapTable with zero coupon count - should not create any markers
  submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      appRewards = Some CT.AppRewardsConfig with
        couponCount = 0
        featuredAppRight = featured_app_right
  pure ()
