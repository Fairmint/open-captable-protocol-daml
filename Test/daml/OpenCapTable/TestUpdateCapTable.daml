module OpenCapTable.TestUpdateCapTable where
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OCF.Stakeholder
import OpenCapTable.Setup
import Daml.Script

-- Test UpdateCapTable with empty operations
testUpdateCapTableEmpty = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Call UpdateCapTable with empty operations
  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = []
  pure ()

-- Test UpdateCapTable with creates
testUpdateCapTableWithCreates = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Create a stakeholder via batch update
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "BATCH_SH_1"
        name = OcfName with legal_name = "Batch Created", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
  -- Verify the stakeholder was created (one CidStakeholder in createdCids)
  case result.createdCids of
    [CT.CidStakeholder _] -> pure ()
    _ -> assertFail "Expected exactly one stakeholder to be created"
