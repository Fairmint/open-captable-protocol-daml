module OpenCapTable.TestIssuer where
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.OCF.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.Types.Contact (OcfEmail(..), OcfEmailType(..), OcfPhone(..), OcfPhoneType(..))
import Fairmint.OpenCapTable.Types.Monetary (OcfTaxID(..), OcfAddress(..), OcfAddressType(..))
import Fairmint.OpenCapTable.Types.Stock (OcfInitialSharesAuthorized(..))
import OpenCapTable.Setup
import Daml.Script
import DA.Date
import DA.Time

createFactory system_operator =
  submit system_operator do
    createCmd OcpFactory with
      system_operator = system_operator

createCapTableViaAuth issuer authCid =
  submit issuer do
    exerciseCmd authCid CreateCapTable with
      issuer_data = IssuerOcfData with
        id = "ISSUER_2"
        legal_name = "Acme Inc"
        formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []

testCreateAndArchiveIssuer = script do
  -- Test factory-based flow to create CapTable
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  factoryCid <- createFactory system_operator
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  capTableCid <- createCapTableViaAuth issuer authCid
  -- Archive the CapTable (requires both signatories)
  submit (actAs [issuer, system_operator]) do
    archiveCmd capTableCid
  pure ()

testCreateAndArchiveIssuerBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  factoryCid <- createFactory system_operator
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  capTableCid <- createCapTableViaAuth issuer authCid
  submit (actAs [issuer, system_operator]) do
    exerciseCmd capTableCid Archive
  pure ()

-- Optionals Some and arrays non-empty variant
testCreateIssuerWithOptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  factoryCid <- createFactory system_operator
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  capTableCid <- submit issuer do
    exerciseCmd authCid CreateCapTable with
      issuer_data = IssuerOcfData with
        id = "ISSUER_OPT_SOME"
        legal_name = "Acme Incorporated"
        formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = Some "Acme"
        country_subdivision_of_formation = Some "CA"
        country_subdivision_name_of_formation = None
        tax_ids = [ OcfTaxID with tax_id = "12-3456789", country = "US" ]
        email = Some (OcfEmail with email_type = OcfEmailTypeBusiness, email_address = "info@acme.example")
        phone = Some (OcfPhone with phone_type = OcfPhoneBusiness, phone_number = "+1 555 0100")
        address = Some (OcfAddress with address_type = OcfAddressTypeLegal, street_suite = Some "1 Market St", city = Some "SF", country_subdivision = Some "CA", country = "US", postal_code = Some "94105")
        initial_shares_authorized = Some (OcfInitialSharesNumeric 2000000.0)
        comments = ["Seed stage"]
  submit (actAs [issuer, system_operator]) do
    exerciseCmd capTableCid Archive
  pure ()

-- Test editing issuer via UpdateCapTable batch operation
testEditIssuerViaBatch = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Edit the issuer via UpdateCapTable with OcfEditIssuer
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditIssuer IssuerOcfData with
        id = "ISSUER_1"  -- Must match the original issuer ID from setupTestOcp
        legal_name = "Test Corp Updated"  -- Changed legal name
        formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = Some "Updated DBA"  -- Added DBA
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = ["Edited via UpdateCapTable"]]
      deletes = []
  -- Verify the issuer edit was included in editedCids
  case result.editedCids of
    [CT.CidIssuer _] -> pure ()
    _ -> assertFail "Expected exactly one CidIssuer in editedCids"

-- Test that multiple issuer edits in one batch are rejected
testMultipleIssuerEditsRejected = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let edit1 = CT.OcfEditIssuer IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "Test Corp First Edit"
        formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  let edit2 = CT.OcfEditIssuer IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "Test Corp Second Edit"
        formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  -- Try to edit the issuer twice in one batch - should fail
  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = []
      edits = [edit1, edit2]
      deletes = []
  pure ()
