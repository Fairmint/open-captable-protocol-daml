module OpenCapTable.TestStockTransfer where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockTransfer
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites, setupStakeholderWithId, stockClassSplit, stockSuccessorIssuance)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Create a stock issuance to transfer (follows real workflow)
createStockIssuance issuer capTableCid securityId quantity issuanceDate =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance StockIssuanceOcfData with
        id = "TX_STOCK_ISS_" <> securityId
        date = issuanceDate
        security_id = securityId
        custom_id = "CS-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = Some (OcfMonetary with amount = 0.0, currency = "USD")
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []]
      edits = []
      deletes = []

-- Test 1: Basic transfer with multiple resulting securities (split transfer)
-- Based on prod: 400,000 shares transferred in full, split to 2 recipients
testStockTransfer_SplitTransfer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  (capTableCid, firstTransfereeId) <- setupStakeholderWithId issuer capTableCid "SH-TRANSFEREE-1" "First Transferee"
  (capTableCid, secondTransfereeId) <- setupStakeholderWithId issuer capTableCid "SH-TRANSFEREE-2" "Second Transferee"
  let securityId = "SSEC-ORIGINAL-001"
  result <- createStockIssuance issuer capTableCid securityId 400000.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-TRANSFER-1A" "SSEC-NEW-001" firstTransfereeId "SC_COMMON" (DT.time (DA.date 2025 Aug 05) 0 0 0) 200000.0
        , stockSuccessorIssuance "STOCK-ISS-TRANSFER-1B" "SSEC-NEW-002" secondTransfereeId "SC_COMMON" (DT.time (DA.date 2025 Aug 05) 0 0 0) 200000.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
        id = "TX_STOCK_TRANSFER_1"
        date = DT.time (DA.date 2025 Aug 05) 0 0 0
        quantity = 400000.0
        security_id = securityId
        resulting_security_ids = ["SSEC-NEW-001", "SSEC-NEW-002"]
        comments = []
        balance_security_id = None  -- No remainder: transferring all 400,000 shares
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

testStockTransfer_DuplicateResultingSecurityIdsRejected = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-DUP-TRANSFER-001"
  result <- createStockIssuance issuer capTableCid securityId 100.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)
  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-DUP-RESULT" "SSEC-DUP-RESULT" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Aug 05) 0 0 0) 50.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
        id = "TX_STOCK_TRANSFER_DUP_RESULT"
        date = DT.time (DA.date 2025 Aug 05) 0 0 0
        quantity = 50.0
        security_id = securityId
        resulting_security_ids = ["SSEC-DUP-RESULT", "SSEC-DUP-RESULT"]
        comments = []
        balance_security_id = None
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

testStockTransfer_SourceCannotBeItsOwnBalanceSecurity = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  (capTableCid, transfereeId) <- setupStakeholderWithId issuer capTableCid "SH-SELF-BALANCE-TRANSFEREE" "Self Balance Transferee"
  let securityId = "SSEC-SELF-BALANCE-SOURCE"
  result <- createStockIssuance issuer capTableCid securityId 100.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-SELF-BALANCE-RESULT" "SSEC-SELF-BALANCE-RESULT" transfereeId "SC_COMMON" (DT.time (DA.date 2025 Aug 05) 0 0 0) 40.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
            id = "TX-STOCK-TRANSFER-SELF-BALANCE"
            date = DT.time (DA.date 2025 Aug 05) 0 0 0
            quantity = 40.0
            security_id = securityId
            resulting_security_ids = ["SSEC-SELF-BALANCE-RESULT"]
            comments = []
            balance_security_id = Some securityId
            consideration_text = None
        ]
      edits = []
      deletes = []

testStockTransfer_ResultQuantityMustMatchTransfer = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  (capTableCid, transfereeId) <- setupStakeholderWithId issuer capTableCid "SH-QUANTITY-MISMATCH-TRANSFEREE" "Quantity Mismatch Transferee"
  let securityId = "SSEC-QUANTITY-MISMATCH-SOURCE"
  result <- createStockIssuance issuer capTableCid securityId 100.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-QUANTITY-MISMATCH" "SSEC-QUANTITY-MISMATCH-RESULT" transfereeId "SC_COMMON" (DT.time (DA.date 2025 Aug 05) 0 0 0) 39.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
            id = "TX-STOCK-TRANSFER-QUANTITY-MISMATCH"
            date = DT.time (DA.date 2025 Aug 05) 0 0 0
            quantity = 40.0
            security_id = securityId
            resulting_security_ids = ["SSEC-QUANTITY-MISMATCH-RESULT"]
            comments = []
            balance_security_id = None
            consideration_text = None
        ]
      edits = []
      deletes = []

testStockTransfer_ResultQuantityNormalizesInterveningSplit = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  (capTableCid, transfereeId) <- setupStakeholderWithId issuer capTableCid "SH-SPLIT-TRANSFEREE" "Split Transferee"
  let securityId = "SSEC-SPLIT-TRANSFER-SOURCE"
  result <- createStockIssuance issuer capTableCid securityId 100.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)
  let transferDate = DT.time (DA.date 2025 Jan 01) 0 0 0
      splitDate = DT.time (DA.date 2025 Jan 02) 0 0 0
      issuanceDate = DT.time (DA.date 2025 Jan 03) 0 0 0

  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-SPLIT-TRANSFER-RESULT" "SSEC-SPLIT-TRANSFER-RESULT" transfereeId "SC_COMMON" issuanceDate 200.0
        , CT.OcfCreateStockClassSplit ((stockClassSplit "TX-STOCK-TRANSFER-INTERVENING-SPLIT" "SC_COMMON" 2.0 1.0) with date = splitDate)
        , CT.OcfCreateStockTransfer StockTransferOcfData with
            id = "TX-STOCK-TRANSFER-BEFORE-SPLIT"
            date = transferDate
            quantity = 100.0
            security_id = securityId
            resulting_security_ids = ["SSEC-SPLIT-TRANSFER-RESULT"]
            comments = []
            balance_security_id = None
            consideration_text = None
        ]
      edits = []
      deletes = []
  pure ()

-- Test 2: Transfer with consideration text and comments (founder transfer)
-- Based on prod: Early founder stock transfer with detailed consideration
testStockTransfer_FounderTransferWithConsideration = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  (capTableCid, transfereeId) <- setupStakeholderWithId issuer capTableCid "SH-FOUNDER-B" "Founder B"
  let securityId = "SSEC-FOUNDER-001"
  result <- createStockIssuance issuer capTableCid securityId 1000.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)
  balanceResult <- createStockIssuance issuer result.updatedCapTableCid "SSEC-FOUNDER-REMAIN" 925.0 (DT.time (DA.date 2024 Apr 18) 0 0 0)
  _ <- submit issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-TRANSFER-2" "SSEC-TRANSFEREE-001" transfereeId "SC_COMMON" (DT.time (DA.date 2024 Apr 18) 0 0 0) 75.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
        id = "TX_STOCK_TRANSFER_2"
        date = DT.time (DA.date 2024 Apr 18) 0 0 0
        quantity = 75.0
        security_id = securityId
        resulting_security_ids = ["SSEC-TRANSFEREE-001"]
        comments = ["Stock transfer from Founder A to Founder B per Stock Transfer Agreement. Transferee assumes all obligations including vesting schedule and repurchase option."]
        balance_security_id = Some "SSEC-FOUNDER-REMAIN"
        consideration_text = Some "Transfer of 75 shares at $0.0001 per share for aggregate consideration of $0.01."]
      edits = []
      deletes = []
  pure ()

-- Test 3: Simple transfer with no balance (full transfer)
testStockTransfer_FullTransfer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  (capTableCid, transfereeId) <- setupStakeholderWithId issuer capTableCid "SH-NEW-OWNER" "New Owner"
  let securityId = "SSEC-FULL-001"
  result <- createStockIssuance issuer capTableCid securityId 10000.0 (DT.time (DA.date 2023 Jan 01) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-TRANSFER-FULL" "SSEC-NEWOWNER-001" transfereeId "SC_COMMON" (DT.time (DA.date 2025 Jan 15) 0 0 0) 10000.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
        id = "TX_STOCK_TRANSFER_FULL"
        date = DT.time (DA.date 2025 Jan 15) 0 0 0
        quantity = 10000.0
        security_id = securityId
        resulting_security_ids = ["SSEC-NEWOWNER-001"]
        comments = []
        balance_security_id = None
        consideration_text = Some "Secondary sale at $1.50 per share."]
      edits = []
      deletes = []
  pure ()
