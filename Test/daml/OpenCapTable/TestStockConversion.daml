module OpenCapTable.TestStockConversion where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockConversion
import qualified Fairmint.OpenCapTable.OCF.StockConversion as SC
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 10000000.0)
        comments = []

-- Create a stock issuance to convert (follows real workflow)
createStockIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockIssuance with
      issuance_data = StockIssuanceOcfData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2023 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "PREF-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "PREFERRED"
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []

-- Test 1: Full conversion of preferred stock to common
-- Typical scenario: IPO or M&A triggers automatic conversion
testStockConversion_PreferredToCommon = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "SSEC-PREF-001"
  _ <- createStockIssuance issuer capTableCid securityId 100000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockConversion with
      conversion_data = StockConversionOcfData with
        id = "TX_STOCK_CONVERSION_1"
        date = DT.time (DA.date 2025 Dec 15) 0 0 0
        security_id = securityId
        quantity_converted = 100000.0
        resulting_security_ids = ["SSEC-COMMON-001"]
        comments = ["Automatic conversion of Series A Preferred to Common upon IPO"]
        balance_security_id = None
  submit issuer do
    archiveCmd cid
  pure ()

-- Test 2: Partial conversion with balance security
testStockConversion_PartialConversion = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "SSEC-PREF-002"
  _ <- createStockIssuance issuer capTableCid securityId 50000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockConversion with
      conversion_data = StockConversionOcfData with
        id = "TX_STOCK_CONVERSION_2"
        date = DT.time (DA.date 2025 Nov 01) 0 0 0
        security_id = securityId
        quantity_converted = 30000.0
        resulting_security_ids = ["SSEC-COMMON-002"]
        comments = ["Elective partial conversion by investor"]
        balance_security_id = Some "SSEC-PREF-002-REMAIN"
  submit issuer do
    exerciseCmd cid Archive
  pure ()

-- Test 3: Conversion with multiple resulting securities (split conversion)
testStockConversion_MultipleResulting = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "SSEC-PREF-003"
  _ <- createStockIssuance issuer capTableCid securityId 200000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockConversion with
      conversion_data = StockConversionOcfData with
        id = "TX_STOCK_CONVERSION_3"
        date = DT.time (DA.date 2025 Oct 15) 0 0 0
        security_id = securityId
        quantity_converted = 200000.0
        resulting_security_ids = ["SSEC-COMMON-003A", "SSEC-COMMON-003B"]
        comments = []
        balance_security_id = None
  submit issuer do
    archiveCmd cid
  pure ()
