module OpenCapTable.Demo where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.OCF.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OCF.StockClass
import Fairmint.OpenCapTable.OCF.StockPlan
import Fairmint.OpenCapTable.OCF.StockLegendTemplate
import Fairmint.OpenCapTable.OCF.VestingTerms
import Fairmint.OpenCapTable.OCF.Stakeholder
import Fairmint.OpenCapTable.Types (OcfStockClassType(..))
import OpenCapTable.Setup
import Daml.Script
import DA.Date
import DA.Time
-- The goal as described by Thibauld (adapted for simplified implementation):
-- 1. Authorize and create the issuer "Acme Inc" with 15M authorized issuer shares
-- 2. Create a stockclass "Common" with 12M authorized shares
-- 3. Create 2 stakeholders: "Alice" and "Bob"
-- 4. Create a stock legend template
-- 5. Create vesting terms and a stock plan

testDemo = script do
  -- Pre-req: create parties
  TestUsers{tu_system_operator = system_operator, tu_issuer = issuer, tu_alice = alice, tu_bob = bob, tu_rando = rando} <- setupUsers
  -- Pre-req: deploy OcpFactory (this is not strictly required ATM)
  openCapTableFactoryCid <- submit system_operator do
    createCmd OcpFactory
      with
        system_operator = system_operator
  -- 1.1: System operator authorizes issuer
  issuerAuthorizationCid <- submit system_operator do
    exerciseCmd openCapTableFactoryCid AuthorizeIssuer
      with
        issuer = issuer
  -- 1.2: Issuer creates CapTable (with embedded Issuer)
  capTableCid <- submit issuer do
    exerciseCmd issuerAuthorizationCid CreateCapTable
      with
        issuer_data = IssuerOcfData with
          id = "ISSUER_DEMO"
          legal_name = "Acme Inc"
          formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
          country_of_formation = "US"
          dba = None
          country_subdivision_of_formation = None
          country_subdivision_name_of_formation = None
          tax_ids = []
          email = None
          phone = None
          address = None
          initial_shares_authorized = Some (OcfInitialSharesNumeric 15_000_000.0)
          comments = []
  -- 2.1: Create stockclass "Common" with 12M authorized shares (via CapTable)
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClass (StockClassOcfData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 12_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = [])]
      edits = []
      deletes = []
  let capTableCid = result.updatedCapTableCid

  -- 3.1: Create stakeholders for Alice and Bob (via CapTable)
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder (StakeholderOcfData with
        id = "STKH_Alice"
        name = OcfName with legal_name = "Alice", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = [])]
      edits = []
      deletes = []
  let capTableCid = result.updatedCapTableCid
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder (StakeholderOcfData with
        id = "STKH_Bob"
        name = OcfName with legal_name = "Bob", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = [])]
      edits = []
      deletes = []
  let capTableCid = result.updatedCapTableCid

  -- 4.1: Create a stock legend template (via CapTable)
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockLegendTemplate (StockLegendTemplateOcfData with
        id = "LEG_STD"
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = [])]
      edits = []
      deletes = []
  let capTableCid = result.updatedCapTableCid

  -- 5.1: Create vesting terms (single start condition) (via CapTable)
  let vtCond = OcfVestingCondition with
        id = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingTerms (VestingTermsOcfData with
        id = "VT_DEMO"
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = [])]
      edits = []
      deletes = []
  let capTableCid = result.updatedCapTableCid

  -- 5.2: Create a stock plan (via CapTable)
  _ <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockPlan (StockPlanOcfData with
        id = "PLAN_2025"
        plan_name = "2025 Equity Incentive Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1_000_000.0
        default_cancellation_behavior = None
        stock_class_ids = ["SC_COMMON"]
        comments = [])]
      edits = []
      deletes = []
  pure ()
