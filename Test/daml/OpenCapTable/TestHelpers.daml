module OpenCapTable.TestHelpers where

import Fairmint.OpenCapTable.OCF.Stakeholder
import Fairmint.OpenCapTable.OCF.StockClass
import Fairmint.OpenCapTable.Types
import qualified Fairmint.OpenCapTable.CapTable as CT
import Daml.Script

-- Helper to add a default stakeholder (required for issuance validations)
addDefaultStakeholder : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultStakeholder issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "SH-1"
        name = OcfName with legal_name = "Test Holder", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
      appRewards = None
  pure result.updatedCapTableCid

-- Helper to add a default stock class (required for stock issuance validations)
addDefaultStockClass : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultStockClass issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClass StockClassOcfData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []]
      edits = []
      deletes = []
      appRewards = None
  pure result.updatedCapTableCid

-- Helper to add both stakeholder and stock class (common setup for stock issuances)
addPrerequisites : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addPrerequisites issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder StakeholderOcfData with
            id = "SH-1"
            name = OcfName with legal_name = "Test Holder", first_name = None, last_name = None
            stakeholder_type = OcfStakeholderTypeIndividual
            issuer_assigned_id = None
            current_relationships = []
            current_status = None
            primary_contact = None
            contact_info = None
            addresses = []
            tax_ids = []
            comments = []
        , CT.OcfCreateStockClass StockClassOcfData with
            id = "SC_COMMON"
            name = "Common"
            class_type = OcfStockClassTypeCommon
            default_id_prefix = "CS-"
            initial_shares_authorized = 1_000_000.0
            votes_per_share = 1.0
            seniority = 1.0
            board_approval_date = None
            stockholder_approval_date = None
            par_value = None
            price_per_share = None
            liquidation_preference_multiple = None
            participation_cap_multiple = None
            conversion_rights = []
            comments = []
        ]
      edits = []
      deletes = []
      appRewards = None
  pure result.updatedCapTableCid
