module OpenCapTable.TestHelpers where

import Fairmint.OpenCapTable.OCF.Stakeholder
import Fairmint.OpenCapTable.OCF.StockClass
import Fairmint.OpenCapTable.OCF.StockIssuance (StockIssuanceOcfData(..))
import Fairmint.OpenCapTable.OCF.WarrantIssuance (WarrantIssuanceOcfData(..))
import Fairmint.OpenCapTable.OCF.ConvertibleIssuance (ConvertibleIssuanceOcfData(..), OcfConvertibleConversionTrigger(..))
import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance (EquityCompensationIssuanceOcfData(..))
import Fairmint.OpenCapTable.Types (OcfStockClassType(..), OcfInitialSharesAuthorized(..), OcfMonetary(..), OcfCompensationType(..), OcfConvertibleType(..), OcfConversionTriggerType(..), OcfConvertibleConversionRight(..), OcfConvertibleConversionMechanism(..), OcfSAFEConversionMechanism(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import Daml.Script
import qualified DA.Date as DA
import DA.Date (Month(..))
import DA.Time (time)

-- Helper to add a default stakeholder (required for issuance validations)
addDefaultStakeholder : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultStakeholder issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "SH-1"
        name = OcfName with legal_name = "Test Holder", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Helper to add a default stock class (required for stock issuance validations)
addDefaultStockClass : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultStockClass issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClass StockClassOcfData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = OcfInitialSharesNumeric 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Helper to add both stakeholder and stock class (common setup for stock issuances)
addPrerequisites : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addPrerequisites issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder StakeholderOcfData with
            id = "SH-1"
            name = OcfName with legal_name = "Test Holder", first_name = None, last_name = None
            stakeholder_type = OcfStakeholderTypeIndividual
            issuer_assigned_id = None
            current_relationships = []
            current_status = None
            primary_contact = None
            contact_info = None
            addresses = []
            tax_ids = []
            comments = []
        , CT.OcfCreateStockClass StockClassOcfData with
            id = "SC_COMMON"
            name = "Common"
            class_type = OcfStockClassTypeCommon
            default_id_prefix = "CS-"
            initial_shares_authorized = OcfInitialSharesNumeric 1_000_000.0
            votes_per_share = 1.0
            seniority = 1.0
            board_approval_date = None
            stockholder_approval_date = None
            par_value = None
            price_per_share = None
            liquidation_preference_multiple = None
            participation_cap_multiple = None
            conversion_rights = []
            comments = []
        ]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- =============================================================================
-- ISSUANCE HELPERS
-- =============================================================================
-- These helpers create test issuances with known security_ids.
-- Required for testing tier 4 transactions (transfers, cancellations, etc.)
-- which require a valid security_id to reference.

-- Helper to add a stock issuance (requires stakeholder and stock class)
-- Returns the cap table and the security_id used
addStockIssuance : Party -> ContractId CT.CapTable -> Text -> Text -> Text -> Text -> Script (ContractId CT.CapTable)
addStockIssuance issuer capTableCid issuanceId securityId stakeholderId stockClassId = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance StockIssuanceOcfData with
        id = issuanceId
        custom_id = "CS-" <> issuanceId
        date = time (DA.date 2024 Jan 01) 0 0 0
        quantity = 100.0
        security_id = securityId
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        stakeholder_id = stakeholderId
        stock_class_id = stockClassId
        comments = []
        security_law_exemptions = []
        share_numbers_issued = []
        stock_legend_ids = []
        vestings = []
        board_approval_date = None
        consideration_text = None
        cost_basis = None
        issuance_type = None
        stock_plan_id = None
        stockholder_approval_date = None
        vesting_terms_id = None]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Helper to add a default stock issuance with standard test values
addDefaultStockIssuance : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultStockIssuance issuer capTableCid = 
  addStockIssuance issuer capTableCid "STOCK-ISS-1" "SEC-STOCK-1" "SH-1" "SC_COMMON"

-- Helper to add an equity compensation issuance (requires stakeholder)
addEquityCompensationIssuance : Party -> ContractId CT.CapTable -> Text -> Text -> Text -> Script (ContractId CT.CapTable)
addEquityCompensationIssuance issuer capTableCid issuanceId securityId stakeholderId = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationIssuance EquityCompensationIssuanceOcfData with
        id = issuanceId
        custom_id = "EC-" <> issuanceId
        date = time (DA.date 2024 Jan 01) 0 0 0
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 100.0
        security_id = securityId
        stakeholder_id = stakeholderId
        comments = []
        security_law_exemptions = []
        vestings = []
        termination_exercise_windows = []
        base_price = None
        board_approval_date = None
        consideration_text = None
        early_exercisable = None
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        expiration_date = None
        stock_class_id = None
        stock_plan_id = None
        stockholder_approval_date = None
        vesting_terms_id = None]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Helper to add a default equity compensation issuance with standard test values
addDefaultEquityCompensationIssuance : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultEquityCompensationIssuance issuer capTableCid = 
  addEquityCompensationIssuance issuer capTableCid "EC-ISS-1" "SEC-EC-1" "SH-1"

-- Helper to add a warrant issuance (requires stakeholder)
addWarrantIssuance : Party -> ContractId CT.CapTable -> Text -> Text -> Text -> Script (ContractId CT.CapTable)
addWarrantIssuance issuer capTableCid issuanceId securityId stakeholderId = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantIssuance WarrantIssuanceOcfData with
        id = issuanceId
        custom_id = "WR-" <> issuanceId
        date = time (DA.date 2024 Jan 01) 0 0 0
        purchase_price = OcfMonetary with amount = 1.0, currency = "USD"
        security_id = securityId
        stakeholder_id = stakeholderId
        comments = []
        exercise_triggers = []
        security_law_exemptions = []
        vestings = []
        board_approval_date = None
        consideration_text = None
        exercise_price = None
        quantity = Some 100.0
        quantity_source = None
        stockholder_approval_date = None
        vesting_terms_id = None
        warrant_expiration_date = None]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Helper to add a default warrant issuance with standard test values
addDefaultWarrantIssuance : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultWarrantIssuance issuer capTableCid = 
  addWarrantIssuance issuer capTableCid "WR-ISS-1" "SEC-WR-1" "SH-1"

-- Helper to add a convertible issuance (requires stakeholder)
addConvertibleIssuance : Party -> ContractId CT.CapTable -> Text -> Text -> Text -> Script (ContractId CT.CapTable)
addConvertibleIssuance issuer capTableCid issuanceId securityId stakeholderId = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = issuanceId
        convertible_type = OcfConvertibleSafe
        custom_id = "CV-" <> issuanceId
        date = time (DA.date 2024 Jan 01) 0 0 0
        investment_amount = OcfMonetary with amount = 10000.0, currency = "USD"
        security_id = securityId
        seniority = 1
        stakeholder_id = stakeholderId
        comments = []
        conversion_triggers = [OcfConvertibleConversionTrigger with
          trigger_id = "TRIGGER-1"
          type_ = OcfTriggerTypeTypeUnspecified
          conversion_right = OcfConvertibleConversionRight with
            conversion_mechanism = OcfConvMechSAFE (OcfSAFEConversionMechanism with
              conversion_mfn = False
              capitalization_definition = None
              capitalization_definition_rules = None
              conversion_discount = Some 0.2
              conversion_timing = None
              conversion_valuation_cap = None
              exit_multiple = None)
            type_ = "convertible_conversion_right"
            converts_to_stock_class_id = None
            converts_to_future_round = None
          nickname = None
          trigger_condition = None
          trigger_date = None
          trigger_description = None]
        security_law_exemptions = []
        board_approval_date = None
        consideration_text = None
        pro_rata = None
        stockholder_approval_date = None]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Helper to add a default convertible issuance with standard test values
addDefaultConvertibleIssuance : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addDefaultConvertibleIssuance issuer capTableCid = 
  addConvertibleIssuance issuer capTableCid "CV-ISS-1" "SEC-CV-1" "SH-1"

-- Helper to add all prerequisites and all issuance types with their known security_ids
-- This is useful for integration tests that need multiple security types
addFullTestSetup : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addFullTestSetup issuer capTableCid = do
  -- Add stakeholder and stock class
  capTableCid <- addPrerequisites issuer capTableCid
  -- Add issuances of each type
  capTableCid <- addDefaultStockIssuance issuer capTableCid
  capTableCid <- addDefaultEquityCompensationIssuance issuer capTableCid
  capTableCid <- addDefaultWarrantIssuance issuer capTableCid
  capTableCid <- addDefaultConvertibleIssuance issuer capTableCid
  pure capTableCid
