import DA.Foldable (mapA_)
import Daml.Script

accelerationVestingTermsId : Text
accelerationVestingTermsId = "VESTING-TERMS-ACCELERATION"

accelerationVestingTerms : VestingTermsOcfData
accelerationVestingTerms = VestingTermsOcfData with
  id = accelerationVestingTermsId
  allocation_type = OcfAllocationFractional
  description = "All shares follow one vesting condition"
  name = "Acceleration test vesting terms"
  comments = []
  vesting_conditions = [OcfVestingCondition with
    id = "ACCELERATION-TEST-START"
    trigger = OcfVestingStartTrigger
    next_condition_ids = []
    description = None
    portion = Some (OcfVestingConditionPortion with
      numerator = 1.0
      denominator = 1.0
      remainder = False)
    quantity = None]

alternateAccelerationVestingTermsId : Text
alternateAccelerationVestingTermsId = "VESTING-TERMS-ACCELERATION-ALTERNATE"

alternateAccelerationVestingTerms : VestingTermsOcfData
alternateAccelerationVestingTerms = accelerationVestingTerms with
  id = alternateAccelerationVestingTermsId
  name = "Alternate acceleration test vesting terms"

defaultStockIssuance : Text -> Text -> Text -> Text -> StockIssuanceOcfData
defaultStockIssuance issuanceId securityId stakeholderId stockClassId =
  (TestHelpers.defaultStockIssuance issuanceId securityId stakeholderId stockClassId) with
    vesting_terms_id = Some accelerationVestingTermsId

defaultEquityCompensationIssuance : Text -> Text -> Text -> EquityCompensationIssuanceOcfData
defaultEquityCompensationIssuance issuanceId securityId stakeholderId =
  (TestHelpers.defaultEquityCompensationIssuance issuanceId securityId stakeholderId) with
    vesting_terms_id = Some accelerationVestingTermsId

defaultWarrantIssuance : Text -> Text -> Text -> WarrantIssuanceOcfData
defaultWarrantIssuance issuanceId securityId stakeholderId =
  (TestHelpers.defaultWarrantIssuance issuanceId securityId stakeholderId) with
    vesting_terms_id = Some accelerationVestingTermsId

stockSuccessorIssuance : Text -> Text -> Text -> Text -> Time -> Decimal -> CT.OcfCreateData
stockSuccessorIssuance issuanceId securityId stakeholderId stockClassId date quantity =
  CT.OcfCreateStockIssuance ((defaultStockIssuance issuanceId securityId stakeholderId stockClassId) with
    date = date
    quantity = quantity)

fullyVestedStockSuccessorIssuance : Text -> Text -> Text -> Text -> Time -> Decimal -> CT.OcfCreateData
fullyVestedStockSuccessorIssuance issuanceId securityId stakeholderId stockClassId date quantity =
  CT.OcfCreateStockIssuance ((TestHelpers.defaultStockIssuance issuanceId securityId stakeholderId stockClassId) with
    date = date
    quantity = quantity)

equityCompensationSuccessorIssuance : Text -> Text -> Text -> Time -> Decimal -> Optional Time -> CT.OcfCreateData
equityCompensationSuccessorIssuance issuanceId securityId stakeholderId date quantity expirationDate =
  CT.OcfCreateEquityCompensationIssuance ((defaultEquityCompensationIssuance issuanceId securityId stakeholderId) with
    date = date
    quantity = quantity
    expiration_date = expirationDate)

warrantExerciseTrigger : Decimal -> OcfConversionTrigger
warrantExerciseTrigger quantity = OcfConversionTrigger with
  conversion_right = OcfRightWarrant (OcfWarrantConversionRight with
    conversion_mechanism = OcfWarrantMechanismFixedAmount with converts_to_quantity = quantity
    converts_to_future_round = None
    converts_to_stock_class_id = Some "SC_COMMON"
    type_ = "WARRANT_CONVERSION_RIGHT")
  end_date = None
  nickname = None
  start_date = None
  trigger_condition = None
  trigger_date = None
  trigger_description = None
  trigger_id = "ELECTIVE_AT_WILL"
  type_ = OcfTriggerTypeTypeElectiveAtWill

firstVestingDate : Time
firstVestingDate = DT.time (DA.date 2025 Jan 01) 0 0 0

secondVestingDate : Time
secondVestingDate = DT.time (DA.date 2026 Jan 01) 0 0 0

accelerationDate : Time
accelerationDate = DT.time (DA.date 2025 Jun 01) 0 0 0

earlyExerciseDate : Time
earlyExerciseDate = DT.time (DA.date 2025 Sep 01) 0 0 0

splitDate : Time
splitDate = DT.time (DA.date 2026 Jan 01) 0 0 0

postSplitAccelerationDate : Time
postSplitAccelerationDate = DT.time (DA.date 2026 Jun 01) 0 0 0

successorAccelerationDate : Time
successorAccelerationDate = DT.time (DA.date 2027 Jan 01) 0 0 0

chainedBalanceDate : Time
chainedBalanceDate = DT.time (DA.date 2027 Jun 01) 0 0 0

finalSuccessorAccelerationDate : Time
finalSuccessorAccelerationDate = DT.time (DA.date 2028 Jan 01) 0 0 0

vestingOn : Time -> Decimal -> OcfVesting
vestingOn date amount = OcfVesting with
  date = date
  amount = amount

acceleration : Text -> Text -> Decimal -> VestingAccelerationOcfData
acceleration accelerationId securityId quantity = VestingAccelerationOcfData with
  id = accelerationId
  date = accelerationDate
  security_id = securityId
  quantity = quantity
  reason_text = "Board-approved acceleration"
  comments = []

applyUpdate :
  Party ->
  ContractId CT.CapTable ->
  [CT.OcfCreateData] ->
  [CT.OcfEditData] ->
  [CT.OcfDeleteData] ->
  Script CT.UpdateCapTableResult
applyUpdate issuer capTableCid creates edits deletes =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = creates
      edits = edits
      deletes = deletes

addPrerequisites : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addPrerequisites issuer capTableCid = do
  capTableCid <- TestHelpers.addPrerequisites issuer capTableCid
  result <- applyUpdate
    issuer
    capTableCid
    [CT.OcfCreateVestingTerms accelerationVestingTerms]
    []
    []
  pure result.updatedCapTableCid

assertAdditionalAccelerationRejected :
  Party ->
  ContractId CT.CapTable ->
  Text ->
  Decimal ->
  Decimal ->
  Script ()
assertAdditionalAccelerationRejected issuer capTableCid securityId firstQuantity secondQuantity = do
  firstResult <- applyUpdate
    issuer
    capTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-FIRST" securityId firstQuantity)]
    []
    []
  submitMustFail issuer do
    exerciseCmd firstResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration (acceleration "ACC-SECOND" securityId secondQuantity)]
      edits = []
      deletes = []

testVestingQuantityIntegrity_InlinePartialExactAndUnknownWarrantAccepted = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let stockIssuance =
        (defaultStockIssuance "TX-INLINE-STOCK" "SEC-INLINE-STOCK" "SH-1" "SC_COMMON") with
          quantity = 100.0
          vestings = [vestingOn firstVestingDate 40.0, vestingOn secondVestingDate 60.0]
  let equityCompensationIssuance =
        (defaultEquityCompensationIssuance "TX-INLINE-EC" "SEC-INLINE-EC" "SH-1") with
          quantity = 100.0
          vestings = [vestingOn firstVestingDate 25.0]
  let knownWarrantIssuance =
        (defaultWarrantIssuance "TX-INLINE-WARRANT" "SEC-INLINE-WARRANT" "SH-1") with
          quantity = Some 100.0
          quantity_source = Some OcfQuantityInstrumentFixed
          vestings = [vestingOn firstVestingDate 100.0]
  let unknownWarrantIssuance =
        (defaultWarrantIssuance "TX-INLINE-WARRANT-UNKNOWN" "SEC-INLINE-WARRANT-UNKNOWN" "SH-1") with
          quantity = None
          vestings = [vestingOn firstVestingDate 500.0]
  _ <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateStockIssuance stockIssuance
    , CT.OcfCreateEquityCompensationIssuance equityCompensationIssuance
    , CT.OcfCreateWarrantIssuance knownWarrantIssuance
    , CT.OcfCreateWarrantIssuance unknownWarrantIssuance
    ]
    []
    []
  pure ()

