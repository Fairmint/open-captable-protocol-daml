          quantity = Some 100.0
          quantity_source = Some OcfQuantityInstrumentFixed
  let unknownWarrantIssuance =
        (defaultWarrantIssuance "TX-ACC-WARRANT-UNKNOWN" "SEC-ACC-WARRANT-UNKNOWN" "SH-1") with
          quantity = None
  issuanceResult <- applyUpdate
    issuer
