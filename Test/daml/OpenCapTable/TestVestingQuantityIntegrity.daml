testVestingQuantityIntegrity_EarlyExerciseRetainsScheduleAndAccelerationHistory = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SEC-ACC-EARLY-EXERCISE-SOURCE"
      invalidResultSecurityId = "SEC-ACC-EARLY-EXERCISE-FULLY-VESTED"
      mismatchedResultSecurityId = "SEC-ACC-EARLY-EXERCISE-MISMATCHED-SCHEDULE"
      resultSecurityId = "SEC-ACC-EARLY-EXERCISE-RESULT"
      sourceIssuance =
        (defaultEquityCompensationIssuance "TX-ACC-EARLY-EXERCISE-SOURCE" sourceSecurityId "SH-1") with
          early_exercisable = Some True
          stock_class_id = Some "SC_COMMON"
  issuanceResult <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateVestingTerms alternateAccelerationVestingTerms
    , CT.OcfCreateEquityCompensationIssuance sourceIssuance
    ]
    []
    []
  accelerationResult <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-EARLY-EXERCISE-SOURCE" sourceSecurityId 60.0)]
    []
    []
  submitMustFail issuer do
    exerciseCmd accelerationResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationExercise EquityCompensationExerciseOcfData with
        id = "TX-ACC-EARLY-EXERCISE-UNMATERIALIZED"
        date = postSplitAccelerationDate
        security_id = sourceSecurityId
        quantity = 40.0
        consideration_text = None
        resulting_security_ids = []
        comments = []]
      edits = []
      deletes = []
  submitMustFail issuer do
    exerciseCmd accelerationResult.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ fullyVestedStockSuccessorIssuance
            "TX-ACC-EARLY-EXERCISE-FULLY-VESTED"
            invalidResultSecurityId
            "SH-1"
            "SC_COMMON"
            postSplitAccelerationDate
            40.0
        , CT.OcfCreateEquityCompensationExercise EquityCompensationExerciseOcfData with
            id = "TX-ACC-EARLY-EXERCISE-INVALID"
            date = postSplitAccelerationDate
            security_id = sourceSecurityId
            quantity = 40.0
            consideration_text = None
            resulting_security_ids = [invalidResultSecurityId]
            comments = []
        ]
      edits = []
      deletes = []
  submitMustFail issuer do
    exerciseCmd accelerationResult.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockIssuance ((defaultStockIssuance
            "TX-ACC-EARLY-EXERCISE-MISMATCHED-SCHEDULE"
            mismatchedResultSecurityId
            "SH-1"
            "SC_COMMON") with
              date = postSplitAccelerationDate
              quantity = 40.0
              vesting_terms_id = Some alternateAccelerationVestingTermsId)
        , CT.OcfCreateEquityCompensationExercise EquityCompensationExerciseOcfData with
            id = "TX-ACC-EARLY-EXERCISE-MISMATCHED-SCHEDULE"
            date = postSplitAccelerationDate
            security_id = sourceSecurityId
            quantity = 40.0
            consideration_text = None
            resulting_security_ids = [mismatchedResultSecurityId]
            comments = []
        ]
      edits = []
      deletes = []
  exerciseResult <- applyUpdate
    issuer
    accelerationResult.updatedCapTableCid
    [ stockSuccessorIssuance
        "TX-ACC-EARLY-EXERCISE-RESULT"
        resultSecurityId
        "SH-1"
        "SC_COMMON"
        postSplitAccelerationDate
        40.0
    , CT.OcfCreateEquityCompensationExercise EquityCompensationExerciseOcfData with
        id = "TX-ACC-EARLY-EXERCISE"
        date = postSplitAccelerationDate
        security_id = sourceSecurityId
        quantity = 40.0
        consideration_text = None
        resulting_security_ids = [resultSecurityId]
        comments = []
    ]
    []
    []
  submitMustFail issuer do
    exerciseCmd exerciseResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-EARLY-EXERCISE-SOURCE-OVER" sourceSecurityId 25.0) with
        date = successorAccelerationDate)]
      edits = []
      deletes = []
  sourceExactResult <- applyUpdate
    issuer
    exerciseResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration ((acceleration "ACC-EARLY-EXERCISE-SOURCE-EXACT" sourceSecurityId 24.0) with
      date = successorAccelerationDate)]
    []
    []
  exactResult <- applyUpdate
    issuer
    sourceExactResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration ((acceleration "ACC-EARLY-EXERCISE-RESULT-EXACT" resultSecurityId 16.0) with
      date = successorAccelerationDate)]
    []
    []
  submitMustFail issuer do
    exerciseCmd exactResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-EARLY-EXERCISE-RESULT-OVER" resultSecurityId 1.0) with
        date = finalSuccessorAccelerationDate)]
      edits = []
      deletes = []

