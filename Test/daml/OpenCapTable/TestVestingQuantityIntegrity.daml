testVestingQuantityIntegrity_StockCumulativeAccelerationOversubscriptionRejected = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let issuance =
        (defaultStockIssuance "TX-ACC-STOCK-OVER" "SEC-ACC-STOCK-OVER" "SH-1" "SC_COMMON") with
          quantity = 100.0
  issuanceResult <- applyUpdate issuer capTableCid [CT.OcfCreateStockIssuance issuance] [] []
  assertAdditionalAccelerationRejected issuer issuanceResult.updatedCapTableCid issuance.security_id 60.0 50.0

