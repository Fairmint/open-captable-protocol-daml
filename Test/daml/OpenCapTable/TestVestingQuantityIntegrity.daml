    ]
    []
    []
  _ <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [ CT.OcfCreateVestingAcceleration (acceleration "ACC-STOCK-1" "SEC-ACC-STOCK" 40.0)
