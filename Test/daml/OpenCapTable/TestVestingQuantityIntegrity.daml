    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-WARRANT-EXERCISE-RESULT" warrantResultSecurityId 1.0) with
        date = finalSuccessorAccelerationDate)]
      edits = []
      deletes = []

testVestingQuantityIntegrity_PlanLinkedSuccessorIsNotDoubleScaledAcrossSameDaySplit = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let plan = defaultStockPlan "PLAN-ACC-SAME-DAY-SUCCESSOR" "SC_COMMON"
      sourceSecurityId = "SEC-ACC-PLAN-SAME-DAY-SOURCE"
      successorSecurityId = "SEC-ACC-PLAN-SAME-DAY-SUCCESSOR"
      sourceIssuance =
        (defaultEquityCompensationIssuance "TX-ACC-PLAN-SAME-DAY-SOURCE" sourceSecurityId "SH-1") with
          quantity = 100.0
          stock_plan_id = Some plan.id
      successorIssuance =
        (defaultEquityCompensationIssuance "TX-ACC-PLAN-SAME-DAY-SUCCESSOR" successorSecurityId "SH-1") with
          date = splitDate
          quantity = 20.0
          stock_plan_id = Some plan.id
  issuanceResult <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateStockPlan plan
    , CT.OcfCreateEquityCompensationIssuance sourceIssuance
    ]
    []
    []
  accelerationResult <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-PLAN-SAME-DAY-SOURCE" sourceSecurityId 50.0)]
    []
    []
  successorResult <- applyUpdate
    issuer
    accelerationResult.updatedCapTableCid
    [ CT.OcfCreateStockClassSplit (stockClassSplitOn "SPLIT-ACC-PLAN-SAME-DAY" "SC_COMMON" 2.0 1.0 splitDate)
    , CT.OcfCreateEquityCompensationIssuance successorIssuance
    , CT.OcfCreateEquityCompensationCancellation EquityCompensationCancellationOcfData with
        id = "CANCEL-ACC-PLAN-SAME-DAY"
        date = splitDate
        security_id = sourceSecurityId
        quantity = 80.0
        reason_text = "Partial cancellation after split"
        balance_security_id = Some successorSecurityId
        comments = []
    ]
    []
    []
  exactResult <- applyUpdate
    issuer
    successorResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration ((acceleration "ACC-PLAN-SAME-DAY-SUCCESSOR-EXACT" successorSecurityId 20.0) with
      date = successorAccelerationDate)]
    []
    []
  submitMustFail issuer do
    exerciseCmd exactResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-PLAN-SAME-DAY-SUCCESSOR-OVER" successorSecurityId 1.0) with
        date = finalSuccessorAccelerationDate)]
      edits = []
      deletes = []

testVestingQuantityIntegrity_ScheduledOrdinaryExerciseResultHasIndependentAccelerationHistory = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SEC-ACC-ORDINARY-EXERCISE-SOURCE"
      resultSecurityId = "SEC-ACC-ORDINARY-EXERCISE-RESULT"
      sourceIssuance =
        (defaultEquityCompensationIssuance "TX-ACC-ORDINARY-EXERCISE-SOURCE" sourceSecurityId "SH-1") with
          early_exercisable = Some False
          stock_class_id = Some "SC_COMMON"
  issuanceResult <- applyUpdate issuer capTableCid [CT.OcfCreateEquityCompensationIssuance sourceIssuance] [] []
  accelerationResult <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-ORDINARY-EXERCISE-SOURCE" sourceSecurityId 60.0)]
    []
    []
  exerciseResult <- applyUpdate
    issuer
    accelerationResult.updatedCapTableCid
    [ stockSuccessorIssuance
        "TX-ACC-ORDINARY-EXERCISE-RESULT"
        resultSecurityId
        "SH-1"
        "SC_COMMON"
        postSplitAccelerationDate
        100.0
    , CT.OcfCreateEquityCompensationExercise EquityCompensationExerciseOcfData with
        id = "TX-ACC-ORDINARY-EXERCISE"
        date = postSplitAccelerationDate
        security_id = sourceSecurityId
        quantity = 100.0
        consideration_text = None
        resulting_security_ids = [resultSecurityId]
        comments = []
    ]
    []
    []
  exactResult <- applyUpdate
    issuer
    exerciseResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration ((acceleration "ACC-ORDINARY-EXERCISE-RESULT-EXACT" resultSecurityId 100.0) with
      date = successorAccelerationDate)]
    []
    []
  submitMustFail issuer do
    exerciseCmd exactResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-ORDINARY-EXERCISE-RESULT-OVER" resultSecurityId 1.0) with
        date = finalSuccessorAccelerationDate)]
      edits = []
      deletes = []
