testVestingQuantityIntegrity_NonCeilingWarrantSourcesDoNotCapVestingsOrAccelerations = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let minimumWarrant =
        (defaultWarrantIssuance "TX-WARRANT-MINIMUM" "SEC-WARRANT-MINIMUM" "SH-1") with
          quantity = Some 100.0
          quantity_source = Some OcfQuantityInstrumentMin
          vestings = [vestingOn firstVestingDate 150.0]
  let humanEstimateWarrant =
        (defaultWarrantIssuance "TX-WARRANT-HUMAN-ESTIMATE" "SEC-WARRANT-HUMAN-ESTIMATE" "SH-1") with
          quantity = Some 100.0
          quantity_source = Some OcfQuantityHumanEstimated
          vestings = [vestingOn firstVestingDate 150.0]
  let machineEstimateWarrant =
        (defaultWarrantIssuance "TX-WARRANT-MACHINE-ESTIMATE" "SEC-WARRANT-MACHINE-ESTIMATE" "SH-1") with
          quantity = Some 100.0
          quantity_source = Some OcfQuantityMachineEstimated
          vestings = [vestingOn firstVestingDate 150.0]
  let explicitUnspecifiedWarrant =
        (defaultWarrantIssuance "TX-WARRANT-UNSPECIFIED" "SEC-WARRANT-UNSPECIFIED" "SH-1") with
          quantity = Some 100.0
          quantity_source = Some OcfQuantityUnspecified
          vestings = [vestingOn firstVestingDate 150.0]
  let defaultUnspecifiedWarrant =
        (defaultWarrantIssuance "TX-WARRANT-DEFAULT-UNSPECIFIED" "SEC-WARRANT-DEFAULT-UNSPECIFIED" "SH-1") with
          quantity = Some 100.0
          quantity_source = None
          vestings = [vestingOn firstVestingDate 150.0]
  issuanceResult <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateWarrantIssuance minimumWarrant
    , CT.OcfCreateWarrantIssuance humanEstimateWarrant
    , CT.OcfCreateWarrantIssuance machineEstimateWarrant
    , CT.OcfCreateWarrantIssuance explicitUnspecifiedWarrant
    , CT.OcfCreateWarrantIssuance defaultUnspecifiedWarrant
    ]
    []
    []
  _ <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [ CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-MINIMUM" minimumWarrant.security_id 200.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-HUMAN-ESTIMATE" humanEstimateWarrant.security_id 200.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-MACHINE-ESTIMATE" machineEstimateWarrant.security_id 200.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-UNSPECIFIED" explicitUnspecifiedWarrant.security_id 200.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-DEFAULT-UNSPECIFIED" defaultUnspecifiedWarrant.security_id 200.0)
    ]
    []
    []
  pure ()

testVestingQuantityIntegrity_InlineOversubscriptionEditRejected = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let issuance =
        (defaultStockIssuance "TX-INLINE-EDIT" "SEC-INLINE-EDIT" "SH-1" "SC_COMMON") with
          quantity = 100.0
          vestings = [vestingOn firstVestingDate 60.0]
  issuanceResult <- applyUpdate issuer capTableCid [CT.OcfCreateStockIssuance issuance] [] []
  let invalidEdit = issuance with
        vestings = [vestingOn firstVestingDate 60.0, vestingOn secondVestingDate 50.0]
  submitMustFail issuer do
    exerciseCmd issuanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStockIssuance invalidEdit]
      deletes = []

