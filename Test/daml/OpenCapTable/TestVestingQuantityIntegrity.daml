testVestingQuantityIntegrity_StockBalanceSuccessorCarriesSplitAdjustedAccelerations = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SEC-ACC-STOCK-LINEAGE-SOURCE"
      successorSecurityId = "SEC-ACC-STOCK-LINEAGE-BALANCE"
      sourceIssuance =
        (defaultStockIssuance "TX-ACC-STOCK-LINEAGE-SOURCE" sourceSecurityId "SH-1" "SC_COMMON") with
          quantity = 100.0
  issuanceResult <- applyUpdate issuer capTableCid [CT.OcfCreateStockIssuance sourceIssuance] [] []
  accelerationResult <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-STOCK-LINEAGE-SOURCE" sourceSecurityId 50.0)]
    []
    []
  balanceResult <- applyUpdate
    issuer
    accelerationResult.updatedCapTableCid
    [ CT.OcfCreateStockClassSplit (stockClassSplitOn "SPLIT-ACC-STOCK-LINEAGE" "SC_COMMON" 2.0 1.0 splitDate)
    , stockSuccessorIssuance
        "TX-ACC-STOCK-LINEAGE-BALANCE"
        successorSecurityId
        "SH-1"
        "SC_COMMON"
        splitDate
        60.0
    , CT.OcfCreateStockCancellation
        ((stockCancellationOn "CANCEL-ACC-STOCK-LINEAGE" sourceSecurityId 40.0 splitDate) with
          balance_security_id = Some successorSecurityId)
    , CT.OcfCreateStockCancellation
        (stockCancellationOn "CANCEL-ACC-STOCK-LINEAGE-SUCCESSOR" successorSecurityId 10.0 splitDate)
    ]
    []
    []
  exactResult <- applyUpdate
    issuer
    balanceResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration ((acceleration "ACC-STOCK-LINEAGE-BALANCE-EXACT" successorSecurityId 60.0) with
      date = postSplitAccelerationDate)]
    []
    []
  submitMustFail issuer do
    exerciseCmd exactResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-STOCK-LINEAGE-BALANCE-OVER" successorSecurityId 1.0) with
        date = postSplitAccelerationDate)]
      edits = []
      deletes = []

