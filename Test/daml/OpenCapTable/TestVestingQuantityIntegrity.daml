testVestingQuantityIntegrity_SameDaySplitSuccessorUsesPostSplitAccelerationUnits = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SEC-ACC-SAME-DAY-SPLIT-SOURCE"
      successorSecurityId = "SEC-ACC-SAME-DAY-SPLIT-SUCCESSOR"
      splitId = "SPLIT-ACC-SAME-DAY"
      reissuanceId = "REISSUE-ACC-SAME-DAY"
      sourceIssuance =
        (defaultStockIssuance "TX-ACC-SAME-DAY-SPLIT-SOURCE" sourceSecurityId "SH-1" "SC_COMMON") with
          quantity = 25.0
      reissuance = StockReissuanceOcfData with
        id = reissuanceId
        date = splitDate
        security_id = sourceSecurityId
        resulting_security_ids = [successorSecurityId]
        split_transaction_id = Some splitId
        reason_text = None
        comments = []
  successorResult <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateStockIssuance sourceIssuance
    , CT.OcfCreateStockClassSplit (stockClassSplitOn splitId "SC_COMMON" 2.0 1.0 splitDate)
    , stockSuccessorIssuance "TX-ACC-SAME-DAY-SPLIT-SUCCESSOR" successorSecurityId "SH-1" "SC_COMMON" splitDate 50.0
    , CT.OcfCreateStockReissuance reissuance
    ]
    []
    []
  submitMustFail issuer do
    exerciseCmd successorResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration ((acceleration "ACC-SAME-DAY-SPLIT-SUCCESSOR" successorSecurityId 75.0) with
        date = postSplitAccelerationDate)]
      edits = []
      deletes = []

testVestingQuantityIntegrity_AccelerationCannotExceedLiveStockBalance = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let issuance =
        (defaultStockIssuance "TX-ACC-LIVE-BALANCE" "SEC-ACC-LIVE-BALANCE" "SH-1" "SC_COMMON") with
          quantity = 100.0
  balanceResult <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateStockIssuance issuance
    , CT.OcfCreateStockCancellation (stockCancellationOn "CANCEL-ACC-LIVE-BALANCE" issuance.security_id 80.0 firstVestingDate)
    ]
    []
    []
  submitMustFail issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration (acceleration "ACC-LIVE-BALANCE" issuance.security_id 50.0)]
      edits = []
      deletes = []

