testVestingQuantityIntegrity_StockAccelerationsNormalizeAcrossForwardSplit = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let issuance =
        (defaultStockIssuance "TX-ACC-STOCK-SPLIT" "SEC-ACC-STOCK-SPLIT" "SH-1" "SC_COMMON") with
          quantity = 100.0
  issuanceResult <- applyUpdate issuer capTableCid [CT.OcfCreateStockIssuance issuance] [] []
  firstAccelerationResult <- applyUpdate
    issuer
    issuanceResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-STOCK-PRE-SPLIT" issuance.security_id 75.0)]
    []
    []
  splitResult <- applyUpdate
    issuer
    firstAccelerationResult.updatedCapTableCid
    [CT.OcfCreateStockClassSplit (stockClassSplitOn "SPLIT-STOCK-ACC" "SC_COMMON" 2.0 1.0 splitDate)]
    []
    []
  _ <- applyUpdate
    issuer
    splitResult.updatedCapTableCid
    [CT.OcfCreateVestingAcceleration ((acceleration "ACC-STOCK-POST-SPLIT" issuance.security_id 50.0) with
      date = postSplitAccelerationDate)]
    []
    []
  pure ()

