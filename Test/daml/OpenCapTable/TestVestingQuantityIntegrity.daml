    , CT.OcfCreateVestingAcceleration (acceleration "ACC-EC" "SEC-ACC-EC" 100.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-1" "SEC-ACC-WARRANT" 70.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-2" "SEC-ACC-WARRANT" 30.0)
    , CT.OcfCreateVestingAcceleration (acceleration "ACC-WARRANT-UNKNOWN" "SEC-ACC-WARRANT-UNKNOWN" 1000.0)
