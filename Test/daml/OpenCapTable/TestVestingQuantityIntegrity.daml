module OpenCapTable.TestVestingQuantityIntegrity where

import Fairmint.OpenCapTable.OCF.VestingAcceleration (VestingAccelerationOcfData(..))
import Fairmint.OpenCapTable.OCF.StockReissuance (StockReissuanceOcfData(..))
import Fairmint.OpenCapTable.Types.Stock (OcfQuantitySourceType(..))
import Fairmint.OpenCapTable.Types.Vesting (OcfVesting(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers
  ( addPrerequisites
  , defaultEquityCompensationIssuance
  , defaultStockIssuance
  , defaultStockPlan
  , defaultWarrantIssuance
  , stockCancellationOn
  , stockClassSplitOn
  , stockSuccessorIssuance
  )
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

firstVestingDate : Time
firstVestingDate = DT.time (DA.date 2025 Jan 01) 0 0 0

secondVestingDate : Time
secondVestingDate = DT.time (DA.date 2026 Jan 01) 0 0 0

accelerationDate : Time
accelerationDate = DT.time (DA.date 2025 Jun 01) 0 0 0

splitDate : Time
splitDate = DT.time (DA.date 2026 Jan 01) 0 0 0

postSplitAccelerationDate : Time
postSplitAccelerationDate = DT.time (DA.date 2026 Jun 01) 0 0 0

vestingOn : Time -> Decimal -> OcfVesting
vestingOn date amount = OcfVesting with
  date = date
  amount = amount

acceleration : Text -> Text -> Decimal -> VestingAccelerationOcfData
acceleration accelerationId securityId quantity = VestingAccelerationOcfData with
  id = accelerationId
  date = accelerationDate
  security_id = securityId
  quantity = quantity
  reason_text = "Board-approved acceleration"
  comments = []

applyUpdate :
  Party ->
  ContractId CT.CapTable ->
  [CT.OcfCreateData] ->
  [CT.OcfEditData] ->
  [CT.OcfDeleteData] ->
  Script CT.UpdateCapTableResult
applyUpdate issuer capTableCid creates edits deletes =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = creates
      edits = edits
      deletes = deletes

assertAdditionalAccelerationRejected :
  Party ->
  ContractId CT.CapTable ->
  Text ->
  Decimal ->
  Decimal ->
  Script ()
assertAdditionalAccelerationRejected issuer capTableCid securityId firstQuantity secondQuantity = do
  firstResult <- applyUpdate
    issuer
    capTableCid
    [CT.OcfCreateVestingAcceleration (acceleration "ACC-FIRST" securityId firstQuantity)]
    []
    []
  submitMustFail issuer do
    exerciseCmd firstResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateVestingAcceleration (acceleration "ACC-SECOND" securityId secondQuantity)]
      edits = []
      deletes = []

testVestingQuantityIntegrity_InlinePartialExactAndUnknownWarrantAccepted = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let stockIssuance =
        (defaultStockIssuance "TX-INLINE-STOCK" "SEC-INLINE-STOCK" "SH-1" "SC_COMMON") with
          quantity = 100.0
          vestings = [vestingOn firstVestingDate 40.0, vestingOn secondVestingDate 60.0]
  let equityCompensationIssuance =
        (defaultEquityCompensationIssuance "TX-INLINE-EC" "SEC-INLINE-EC" "SH-1") with
          quantity = 100.0
          vestings = [vestingOn firstVestingDate 25.0]
  let knownWarrantIssuance =
        (defaultWarrantIssuance "TX-INLINE-WARRANT" "SEC-INLINE-WARRANT" "SH-1") with
          quantity = Some 100.0
          quantity_source = Some OcfQuantityInstrumentFixed
          vestings = [vestingOn firstVestingDate 100.0]
  let unknownWarrantIssuance =
        (defaultWarrantIssuance "TX-INLINE-WARRANT-UNKNOWN" "SEC-INLINE-WARRANT-UNKNOWN" "SH-1") with
          quantity = None
          vestings = [vestingOn firstVestingDate 500.0]
  _ <- applyUpdate
    issuer
    capTableCid
    [ CT.OcfCreateStockIssuance stockIssuance
    , CT.OcfCreateEquityCompensationIssuance equityCompensationIssuance
    , CT.OcfCreateWarrantIssuance knownWarrantIssuance
    , CT.OcfCreateWarrantIssuance unknownWarrantIssuance
    ]
    []
    []
  pure ()

