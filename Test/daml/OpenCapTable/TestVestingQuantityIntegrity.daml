module OpenCapTable.TestVestingQuantityIntegrity where

import qualified DA.Date as Date
import DA.Date (Month(..))
import qualified DA.Time as Time
import Daml.Script
import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance
  ( EquityCompensationIssuanceOcfData(..)
  , validateEquityCompensationIssuanceOcfData
  )
import Fairmint.OpenCapTable.OCF.StockIssuance
  ( StockIssuanceOcfData(..)
  , validateOcfStockIssuanceData
  )
import Fairmint.OpenCapTable.OCF.WarrantIssuance
  ( WarrantIssuanceOcfData(..)
  , validateOcfWarrantIssuanceDataTx
  )
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Stock (OcfQuantitySourceType(..))
import Fairmint.OpenCapTable.Types.Vesting (OcfCompensationType(..), OcfVesting(..))

testDate : Time
testDate = Time.time (Date.date 2025 Jan 01) 0 0 0

vesting : Decimal -> OcfVesting
vesting amount = OcfVesting with date = testDate, amount = amount

stockIssuance : Decimal -> [OcfVesting] -> StockIssuanceOcfData
stockIssuance quantity vestings = StockIssuanceOcfData with
  id = "TX-STOCK"
  custom_id = "CS-1"
  date = testDate
  quantity = quantity
  security_id = "SEC-STOCK"
  share_price = OcfMonetary with amount = 1.0, currency = "USD"
  stakeholder_id = "SH-1"
  stock_class_id = "SC-1"
  comments = []
  security_law_exemptions = []
  share_numbers_issued = []
  stock_legend_ids = ["LEGEND-1"]
  vestings = vestings
  board_approval_date = None
  consideration_text = None
  cost_basis = None
  issuance_type = None
  stock_plan_id = None
  stockholder_approval_date = None
  vesting_terms_id = None

equityCompensationIssuance : Decimal -> [OcfVesting] -> EquityCompensationIssuanceOcfData
equityCompensationIssuance quantity vestings = EquityCompensationIssuanceOcfData with
  id = "TX-EQUITY-COMPENSATION"
  custom_id = "RSU-1"
  date = testDate
  compensation_type = OcfCompensationTypeRSU
  quantity = quantity
  security_id = "SEC-EQUITY-COMPENSATION"
  stakeholder_id = "SH-1"
  comments = []
  security_law_exemptions = []
  vestings = vestings
  termination_exercise_windows = []
  base_price = None
  board_approval_date = None
  consideration_text = None
  early_exercisable = None
  exercise_price = None
  expiration_date = None
  stock_class_id = None
  stock_plan_id = None
  stockholder_approval_date = None
  vesting_terms_id = None

warrantIssuance : Optional Decimal -> Optional OcfQuantitySourceType -> [OcfVesting] -> WarrantIssuanceOcfData
warrantIssuance quantity quantitySource vestings = WarrantIssuanceOcfData with
  id = "TX-WARRANT"
  custom_id = "W-1"
  date = testDate
  purchase_price = OcfMonetary with amount = 0.0, currency = "USD"
  security_id = "SEC-WARRANT"
  stakeholder_id = "SH-1"
  comments = []
  exercise_triggers = []
  security_law_exemptions = []
  vestings = vestings
  board_approval_date = None
  consideration_text = None
  exercise_price = None
  quantity = quantity
  quantity_source = quantitySource
  stockholder_approval_date = None
  vesting_terms_id = None
  warrant_expiration_date = None

testVestingQuantityIntegrity_StockAndEquityCompensation = script do
  let exactVestings = [vesting 40.0, vesting 60.0]
  let partialVestings = [vesting 25.0]
  let excessiveVestings = [vesting 60.0, vesting 50.0]
  assertMsg "stock exact vestings should fit" (validateOcfStockIssuanceData (stockIssuance 100.0 exactVestings))
  assertMsg "stock partial vestings should fit" (validateOcfStockIssuanceData (stockIssuance 100.0 partialVestings))
  assertMsg "stock excessive vestings should fail" (not (validateOcfStockIssuanceData (stockIssuance 100.0 excessiveVestings)))
  assertMsg "equity-comp exact vestings should fit" (validateEquityCompensationIssuanceOcfData (equityCompensationIssuance 100.0 exactVestings))
  assertMsg "equity-comp partial vestings should fit" (validateEquityCompensationIssuanceOcfData (equityCompensationIssuance 100.0 partialVestings))
  assertMsg "equity-comp excessive vestings should fail" (not (validateEquityCompensationIssuanceOcfData (equityCompensationIssuance 100.0 excessiveVestings)))

testVestingQuantityIntegrity_WarrantFixedAndMaximumQuantities = script do
  let exactVestings = [vesting 100.0]
  let excessiveVestings = [vesting 101.0]
  assertMsg "fixed warrant exact vestings should fit" (validateOcfWarrantIssuanceDataTx (warrantIssuance (Some 100.0) (Some OcfQuantityInstrumentFixed) exactVestings))
  assertMsg "fixed warrant excessive vestings should fail" (not (validateOcfWarrantIssuanceDataTx (warrantIssuance (Some 100.0) (Some OcfQuantityInstrumentFixed) excessiveVestings)))
  assertMsg "maximum warrant exact vestings should fit" (validateOcfWarrantIssuanceDataTx (warrantIssuance (Some 100.0) (Some OcfQuantityInstrumentMax) exactVestings))
  assertMsg "maximum warrant excessive vestings should fail" (not (validateOcfWarrantIssuanceDataTx (warrantIssuance (Some 100.0) (Some OcfQuantityInstrumentMax) excessiveVestings)))

testVestingQuantityIntegrity_WarrantNonCeilingQuantities = script do
  let excessiveVestings = [vesting 101.0]
  let validates source = validateOcfWarrantIssuanceDataTx (warrantIssuance (Some 100.0) source excessiveVestings)
  assertMsg "minimum warrant quantity is not a ceiling" (validates (Some OcfQuantityInstrumentMin))
  assertMsg "human-estimated warrant quantity is not a ceiling" (validates (Some OcfQuantityHumanEstimated))
  assertMsg "machine-estimated warrant quantity is not a ceiling" (validates (Some OcfQuantityMachineEstimated))
  assertMsg "unspecified warrant quantity is not a ceiling" (validates (Some OcfQuantityUnspecified))
  assertMsg "absent warrant quantity source is not a ceiling" (validates None)
  assertMsg "absent warrant quantity is not a ceiling" (validateOcfWarrantIssuanceDataTx (warrantIssuance None (Some OcfQuantityInstrumentFixed) excessiveVestings))
