module OpenCapTable.TestNftCoreHelpers where

import DA.Date (Month(..), date)
import DA.Map qualified as Map
import DA.Optional qualified as Optional
import DA.TextMap qualified as TextMap
import DA.Time (time)
import Daml.Script

import Fairmint.OpenCapTableNft.Metadata (registeredNftKey, standardMetadataKey)
import Fairmint.OpenCapTableNft.Nft qualified as Nft
import Fairmint.OpenCapTableNft.NftAsset qualified as NftAsset
import Fairmint.OpenCapTableNft.NftRegistry qualified as NftRegistry
import Fairmint.OpenCapTableNft.ReceiveAuthorization qualified as ReceiveAuthorization
import Fairmint.OpenCapTableNft.Types

data NftCoreParties = NftCoreParties with
    registry_admin : Party
    alice : Party
    bob : Party
    charlie : Party
  deriving (Eq, Show)

defaultRegistry : RegistryIdentity
defaultRegistry = RegistryIdentity with
  registry_id = "NFT-REGISTRY"

defaultCollection : CollectionIdentity
defaultCollection = CollectionIdentity with
  registry_id = defaultRegistry.registry_id
  collection_id = "COLLECTION-A"

otherCollection : CollectionIdentity
otherCollection = CollectionIdentity with
  registry_id = defaultRegistry.registry_id
  collection_id = "COLLECTION-B"

defaultTokenId : Text
defaultTokenId = "TOKEN-1"

alternateTokenId : Text
alternateTokenId = "TOKEN-2"

baseTime : Time
baseTime = time (date 2026 Jan 01) 12 0 0

firstTransferExpiry : Time
firstTransferExpiry = time (date 2026 Jan 02) 12 0 0

afterFirstTransferExpiry : Time
afterFirstTransferExpiry = time (date 2026 Jan 03) 12 0 0

defaultMetadata : NftMetadata
defaultMetadata = NftMetadata with
  standard_metadata =
    TextMap.fromList
      [ (standardMetadataKey "name", MetadataText with text = "Founding NFT")
      , (standardMetadataKey "description", MetadataText with text = "Generic transferable NFT core conformance token")
      , (standardMetadataKey "image_uri", MetadataText with text = "ipfs://fairmint/founding-nft")
      ]
  extension_metadata =
    TextMap.fromList
      [ ("series", MetadataText with text = "core")
      ]
  public_metadata =
    TextMap.fromList
      [ ("edition", MetadataText with text = "genesis")
      ]

reservedAwareMetadata : NftMetadata
reservedAwareMetadata = NftMetadata with
  standard_metadata =
    TextMap.fromList
      [ (standardMetadataKey "name", MetadataText with text = "Canonical Name")
      , (standardMetadataKey "description", MetadataText with text = "Canonical Description")
      , (standardMetadataKey "image_uri", MetadataText with text = "ipfs://fairmint/canonical-image")
      ]
  extension_metadata =
    TextMap.fromList
      [ ("attributes", MetadataMap with
          entries =
            TextMap.fromList
              [ ("rarity", MetadataText with text = "legendary")
              ]
        )
      ]
  public_metadata =
    TextMap.fromList
      [ ("name", MetadataText with text = "public-shadow-name")
      , ("description", MetadataText with text = "public-shadow-description")
      , ("image_uri", MetadataText with text = "ipfs://fairmint/public-shadow-image")
      , ("attributes", MetadataMap with
          entries =
            TextMap.fromList
              [ ("rarity", MetadataText with text = "legendary")
              ]
        )
      ]

defaultConfidentialityRef : ConfidentialityRef
defaultConfidentialityRef = ConfidentialityRef with
  reference = "vault://confidentiality/default"

defaultRegistration : NftRegistration
defaultRegistration =
  registrationWithPayload
    defaultCollection
    defaultTokenId
    defaultMetadata
    (Some defaultConfidentialityRef)

registrationWithIds : Text -> Text -> Text -> NftRegistration
registrationWithIds registry_id collection_id token_id =
  registrationWithPayload
    (CollectionIdentity with registry_id, collection_id)
    token_id
    defaultMetadata
    (Some defaultConfidentialityRef)

registrationWithPayload :
  CollectionIdentity ->
  Text ->
  NftMetadata ->
  Optional ConfidentialityRef ->
  NftRegistration
registrationWithPayload collection token_id metadata confidentiality_ref =
  NftRegistration with
    nft_id = NftId with
      collection
      token_id
    metadata
    confidentiality_ref

allocateNftCoreParties : Text -> Script NftCoreParties
allocateNftCoreParties suffix = do
  registry_admin <- allocateParty ("NftRegistryAdmin-" <> suffix)
  alice <- allocateParty ("NftAlice-" <> suffix)
  bob <- allocateParty ("NftBob-" <> suffix)
  charlie <- allocateParty ("NftCharlie-" <> suffix)
  pure NftCoreParties with ..

createRegistry :
  Party ->
  Optional CollectionIdentity ->
  Script (ContractId NftRegistry.NftRegistry)
createRegistry registry_admin collection_scope =
  submit registry_admin do
    createCmd NftRegistry.NftRegistry with
      registry_admin
      registry = defaultRegistry
      collection_scope
      registered_nfts = Map.empty

mintRegistration :
  Party ->
  ContractId NftRegistry.NftRegistry ->
  Party ->
  NftRegistration ->
  Script NftRegistry.MintResult
mintRegistration registry_admin registry_cid holder registration =
  submit registry_admin do
    exerciseCmd registry_cid (NftRegistry.Mint with holder, registration)

mintDefaultRegistration :
  Party ->
  ContractId NftRegistry.NftRegistry ->
  Party ->
  Script NftRegistry.MintResult
mintDefaultRegistration registry_admin registry_cid holder =
  mintRegistration registry_admin registry_cid holder defaultRegistration

createStandingReceiveAuthorization :
  Party ->
  Party ->
  Optional CollectionIdentity ->
  Optional Time ->
  Script (ContractId ReceiveAuthorization.StandingReceiveAuthorization)
createStandingReceiveAuthorization registry_admin receiver collection_scope expires_at =
  submit receiver do
    createCmd ReceiveAuthorization.StandingReceiveAuthorization with
      registry_admin
      receiver
      registry = defaultRegistry
      collection_scope
      expires_at

offerTransfer :
  Party ->
  Party ->
  ContractId Nft.CantonNft ->
  TransferOfferTerms ->
  Optional (ContractId ReceiveAuthorization.StandingReceiveAuthorization) ->
  Script (ContractId Nft.CantonNft)
offerTransfer registry_admin holder nft_cid transfer_offer receive_authorization_cid =
  submit (actAs [registry_admin, holder]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with transfer_offer, receive_authorization_cid)

acceptPendingTransfer :
  Party ->
  Party ->
  ContractId Nft.CantonNft ->
  Script (ContractId Nft.CantonNft)
acceptPendingTransfer registry_admin receiver pending_cid =
  submit (actAs [registry_admin, receiver]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Accept

rejectPendingTransfer :
  Party ->
  Party ->
  ContractId Nft.CantonNft ->
  Script (ContractId Nft.CantonNft)
rejectPendingTransfer registry_admin receiver pending_cid =
  submit (actAs [registry_admin, receiver]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Reject

withdrawPendingTransfer :
  Party ->
  Party ->
  ContractId Nft.CantonNft ->
  Script (ContractId Nft.CantonNft)
withdrawPendingTransfer registry_admin sender pending_cid =
  submit (actAs [registry_admin, sender]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Withdraw

expirePendingTransfer :
  Party ->
  Party ->
  ContractId Nft.CantonNft ->
  Script (ContractId Nft.CantonNft)
expirePendingTransfer registry_admin expiring_actor pending_cid =
  submit (actAs [registry_admin, expiring_actor]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      (NftAsset.Expire with actor = expiring_actor)

assertActiveNftView :
  Party ->
  ContractId Nft.CantonNft ->
  Party ->
  Party ->
  NftRegistration ->
  Script ()
assertActiveNftView querying_party nft_cid expected_registry_admin expected_holder expected_registration = do
  Some nft_view <- queryInterfaceContractId @Nft.CantonNft querying_party nft_cid
  assertMsg "active NFT registry admin mismatch" $
    nft_view.registry_admin == expected_registry_admin
  assertMsg "active NFT registry mismatch" $
    nft_view.registry == registryOfNftId expected_registration.nft_id
  assertMsg "active NFT collection mismatch" $
    nft_view.collection == expected_registration.nft_id.collection
  assertMsg "active NFT id mismatch" $
    nft_view.nft_id == expected_registration.nft_id
  assertMsg "active NFT holder mismatch" $
    nft_view.holder == expected_holder
  assertMsg "active NFT metadata mismatch" $
    nft_view.metadata == expected_registration.metadata
  assertMsg "active NFT confidentiality ref mismatch" $
    nft_view.confidentiality_ref == expected_registration.confidentiality_ref
  assertMsg "active NFT should report active lifecycle state" $
    nft_view.state == NftLifecycleState_Active
  assertMsg "active NFT should not expose transfer offer details" $
    Optional.isNone nft_view.transfer_offer

assertPendingNftView :
  Party ->
  ContractId Nft.CantonNft ->
  Party ->
  Party ->
  NftRegistration ->
  TransferOfferTerms ->
  Script ()
assertPendingNftView querying_party nft_cid expected_registry_admin expected_holder expected_registration transfer_offer = do
  Some nft_view <- queryInterfaceContractId @Nft.CantonNft querying_party nft_cid
  assertMsg "pending NFT registry admin mismatch" $
    nft_view.registry_admin == expected_registry_admin
  assertMsg "pending NFT registry mismatch" $
    nft_view.registry == registryOfNftId expected_registration.nft_id
  assertMsg "pending NFT collection mismatch" $
    nft_view.collection == expected_registration.nft_id.collection
  assertMsg "pending NFT id mismatch" $
    nft_view.nft_id == expected_registration.nft_id
  assertMsg "pending NFT holder mismatch" $
    nft_view.holder == expected_holder
  assertMsg "pending NFT metadata mismatch" $
    nft_view.metadata == expected_registration.metadata
  assertMsg "pending NFT confidentiality ref mismatch" $
    nft_view.confidentiality_ref == expected_registration.confidentiality_ref
  assertMsg "pending NFT should report transfer-offered lifecycle state" $
    nft_view.state == NftLifecycleState_TransferOffered
  assertMsg "pending NFT transfer offer mismatch" $
    nft_view.transfer_offer
      == Some
        (TransferOfferView with
          receiver = transfer_offer.receiver
          expires_at = transfer_offer.expires_at
        )

assertNoNftView : Party -> ContractId Nft.CantonNft -> Script ()
assertNoNftView querying_party nft_cid = do
  None <- queryInterfaceContractId @Nft.CantonNft querying_party nft_cid
  pure ()

assertRegistryTracksNft :
  Party ->
  ContractId NftRegistry.NftRegistry ->
  NftRegistration ->
  Script ()
assertRegistryTracksNft querying_party registry_cid registration = do
  Some registry <- queryContractId querying_party registry_cid
  assertMsg "registry uniqueness ledger missing NFT registration" $
    Map.lookup
      (registeredNftKey registration)
      registry.registered_nfts
      == Some registration

assertRegistryEntryCount :
  Party ->
  ContractId NftRegistry.NftRegistry ->
  Int ->
  Script ()
assertRegistryEntryCount querying_party registry_cid expected_count = do
  Some registry <- queryContractId querying_party registry_cid
  assertMsg "registry entry count mismatch" $
    length (Map.toList registry.registered_nfts) == expected_count

assertRegistryIsEmpty :
  Party ->
  ContractId NftRegistry.NftRegistry ->
  Script ()
assertRegistryIsEmpty querying_party registry_cid = do
  Some registry <- queryContractId querying_party registry_cid
  assertMsg "registry should remain empty after failed mint" $
    registry.registered_nfts == Map.empty

assertRegistryHiddenFrom :
  Party ->
  ContractId NftRegistry.NftRegistry ->
  Script ()
assertRegistryHiddenFrom querying_party registry_cid = do
  None <- queryContractId querying_party registry_cid
  pure ()

assertStandingReceiveAuthorizationVisibleTo :
  Party ->
  ContractId ReceiveAuthorization.StandingReceiveAuthorization ->
  Script ()
assertStandingReceiveAuthorizationVisibleTo querying_party auth_cid = do
  Some _ <- queryContractId querying_party auth_cid
  pure ()

assertStandingReceiveAuthorizationHiddenFrom :
  Party ->
  ContractId ReceiveAuthorization.StandingReceiveAuthorization ->
  Script ()
assertStandingReceiveAuthorizationHiddenFrom querying_party auth_cid = do
  None <- queryContractId querying_party auth_cid
  pure ()
