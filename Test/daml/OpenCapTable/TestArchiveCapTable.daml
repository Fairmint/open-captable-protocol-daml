module OpenCapTable.TestArchiveCapTable where
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OCF.Stakeholder
import OpenCapTable.Setup
import Daml.Script
import DA.Optional (isNone)

-- Test that system_operator can archive a fresh (empty) CapTable
testArchiveCapTableEmpty = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Fresh cap table has empty maps, so ArchiveCapTable should succeed
  submit system_operator do
    exerciseCmd cap_table CT.ArchiveCapTable
  -- Verify contract is consumed (archived)
  result <- queryContractId system_operator cap_table
  assertMsg "CapTable should be archived" (isNone result)
  pure ()

-- Test that ArchiveCapTable fails when entities exist (non-empty maps)
testArchiveCapTableFailsWithEntities = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add a stakeholder so the maps are non-empty
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "SH_1"
        name = OcfName with legal_name = "Test Person", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
  -- ArchiveCapTable should fail because stakeholders map is not empty
  submitMustFail system_operator do
    exerciseCmd result.updatedCapTableCid CT.ArchiveCapTable
  pure ()

-- Test that issuer cannot exercise ArchiveCapTable (wrong controller)
testArchiveCapTableIssuerFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  submitMustFail issuer do
    exerciseCmd cap_table CT.ArchiveCapTable
  pure ()

-- Test that a random party cannot exercise ArchiveCapTable
testArchiveCapTableRandoFails = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  rando <- allocateParty "Rando"
  submitMustFail rando do
    exerciseCmd cap_table CT.ArchiveCapTable
  pure ()
