testFinancing_DuplicateIssuanceIdsRemainSchemaValid = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN_DUP" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN_DUP")
        , CT.OcfCreateStockIssuance (defaultStockIssuance "STOCK_FIN_DUP" "SEC_STOCK_FIN_DUP" "SH_FIN_DUP" "SC_FIN_DUP")
        , CT.OcfCreateFinancing (financingData "FIN_DUP" ["STOCK_FIN_DUP", "STOCK_FIN_DUP"])
        ]
      edits = []
      deletes = []
  pure ()

testFinancing_EmptyNameAndCommentStringsRemainSchemaValid = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  _ <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN_EMPTY_TEXT" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN_EMPTY_TEXT")
        , CT.OcfCreateStockIssuance (defaultStockIssuance "STOCK_FIN_EMPTY_TEXT" "SEC_STOCK_FIN_EMPTY_TEXT" "SH_FIN_EMPTY_TEXT" "SC_FIN_EMPTY_TEXT")
        , CT.OcfCreateFinancing ((financingData "FIN_EMPTY_TEXT" ["STOCK_FIN_EMPTY_TEXT"]) with name = "", comments = [""])
        ]
      edits = []
      deletes = []
  pure ()

testFinancing_EditCanReferenceSameBatchIssuance = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  initial <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN_EDIT" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN_EDIT")
        , CT.OcfCreateStockIssuance (defaultStockIssuance "STOCK_FIN_EDIT" "SEC_STOCK_FIN_EDIT" "SH_FIN_EDIT" "SC_FIN_EDIT")
        , CT.OcfCreateFinancing (financingData "FIN_EDIT" ["STOCK_FIN_EDIT"])
        ]
      edits = []
      deletes = []

  _ <- submit issuer do
    exerciseCmd initial.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance (defaultStockIssuance "STOCK_FIN_EDIT_2" "SEC_STOCK_FIN_EDIT_2" "SH_FIN_EDIT" "SC_FIN_EDIT")]
      edits = [CT.OcfEditFinancing (financingData "FIN_EDIT" ["STOCK_FIN_EDIT", "STOCK_FIN_EDIT_2"])]
      deletes = []
  pure ()

testFinancing_DeleteReferencedIssuanceFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  initial <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN_DELETE" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN_DELETE")
        , CT.OcfCreateStockIssuance (defaultStockIssuance "STOCK_FIN_DELETE" "SEC_STOCK_FIN_DELETE" "SH_FIN_DELETE" "SC_FIN_DELETE")
        , CT.OcfCreateFinancing (financingData "FIN_DELETE" ["STOCK_FIN_DELETE"])
        ]
      edits = []
      deletes = []

  submitMustFail issuer do
    exerciseCmd initial.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteStockIssuance "STOCK_FIN_DELETE"]

testFinancing_DeleteLastFinancingCollapsesMapToNone = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  initialCapTableOpt <- queryContractId issuer cap_table
  let Some initialCapTable = initialCapTableOpt
  assertMsg "New CapTables must represent no financings as None" (isNone initialCapTable.financings)

  created <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN_COLLAPSE" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN_COLLAPSE")
        , CT.OcfCreateStockIssuance (defaultStockIssuance "STOCK_FIN_COLLAPSE" "SEC_STOCK_FIN_COLLAPSE" "SH_FIN_COLLAPSE" "SC_FIN_COLLAPSE")
        , CT.OcfCreateFinancing (financingData "FIN_COLLAPSE" ["STOCK_FIN_COLLAPSE"])
        ]
      edits = []
      deletes = []

  deleted <- submit issuer do
    exerciseCmd created.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteStockIssuance "STOCK_FIN_COLLAPSE", CT.OcfDeleteFinancing "FIN_COLLAPSE"]

  finalCapTableOpt <- queryContractId issuer deleted.updatedCapTableCid
  let Some finalCapTable = finalCapTableOpt
  assertMsg "Deleting the last Financing must restore the downgrade-compatible None representation" (isNone finalCapTable.financings)
