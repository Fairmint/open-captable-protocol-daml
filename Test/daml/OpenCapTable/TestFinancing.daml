testFinancing_CrossFamilyIssuanceIdCollisionFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  prerequisites <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN_COLLISION" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN_COLLISION")
        ]
      edits = []
      deletes = []
  withStock <- addStockIssuance issuer prerequisites.updatedCapTableCid "ISSUANCE_COLLISION" "SEC_STOCK_FIN_COLLISION" "SH_FIN_COLLISION" "SC_FIN_COLLISION"
  withCollision <- addWarrantIssuance issuer withStock "ISSUANCE_COLLISION" "SEC_WARRANT_FIN_COLLISION" "SH_FIN_COLLISION"

  submitMustFail issuer do
    exerciseCmd withCollision CT.UpdateCapTable with
      creates = [CT.OcfCreateFinancing (financingData "FIN_COLLISION" ["ISSUANCE_COLLISION"])]
      edits = []
      deletes = []

