module OpenCapTable.TestFinancing where

import Fairmint.OpenCapTable.OCF.Financing
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers
import Daml.Script
import DA.Optional (isNone, isSome)

financingData : Text -> [Text] -> FinancingOcfData
financingData financingId issuanceIds = FinancingOcfData with
  id = financingId
  date = defaultTestDate
  name = "Series A"
  comments = []
  issuance_ids = issuanceIds

testFinancing_AllIssuanceTypesRoundTrip = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let financing = financingData "FIN_ALL_TYPES" ["STOCK_FIN", "CONVERTIBLE_FIN", "EQUITY_FIN", "WARRANT_FIN"]

  prerequisites <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "SH_FIN" "Financing Holder")
        , CT.OcfCreateStockClass (defaultStockClass "SC_FIN")
        ]
      edits = []
      deletes = []
  withStock <- addStockIssuance issuer prerequisites.updatedCapTableCid "STOCK_FIN" "SEC_STOCK_FIN" "SH_FIN" "SC_FIN"
  withConvertible <- addConvertibleIssuance issuer withStock "CONVERTIBLE_FIN" "SEC_CONVERTIBLE_FIN" "SH_FIN"
  withEquity <- addEquityCompensationIssuance issuer withConvertible "EQUITY_FIN" "SEC_EQUITY_FIN" "SH_FIN"
  withWarrant <- addWarrantIssuance issuer withEquity "WARRANT_FIN" "SEC_WARRANT_FIN" "SH_FIN"

  result <- submit issuer do
    exerciseCmd withWarrant CT.UpdateCapTable with
      creates = [CT.OcfCreateFinancing financing]
      edits = []
      deletes = []

  let financingCids = [cid | CT.CidFinancing cid <- result.createdCids]
  case financingCids of
    [financingCid] -> do
      financingOpt <- queryContractId issuer financingCid
      case financingOpt of
        Some financingContract ->
          assertMsg "Financing payload must round-trip unchanged" (financingContract.financing_data == financing)
        None -> assertFail "Expected the created Financing contract to remain active"
    _ -> assertFail "Expected exactly one Financing contract"

  capTableOpt <- queryContractId issuer result.updatedCapTableCid
  let Some capTableData = capTableOpt
  assertMsg "Financing map must be present after the first Financing write" (isSome capTableData.financings)

testFinancing_MissingIssuanceFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateFinancing (financingData "FIN_MISSING" ["ISSUANCE_MISSING"])]
      edits = []
      deletes = []

