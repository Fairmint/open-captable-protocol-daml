module OpenCapTable.TestConvertibleTransfer where

import Fairmint.OpenCapTable.OCF.ConvertibleIssuance
import Fairmint.OpenCapTable.OCF.ConvertibleTransfer
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Conversion (OcfConvertibleType(..))
import OpenCapTable.HelpersTriggers (ocfConvTriggerAutomaticOnDate)
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder, setupStakeholderWithId)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

convertibleTransferIssuance : Text -> Text -> Text -> Decimal -> Time -> OcfConvertibleType -> Time -> ConvertibleIssuanceOcfData
convertibleTransferIssuance issuanceId securityId stakeholderId amount issuanceDate convertibleType triggerDate =
  ConvertibleIssuanceOcfData with
    id = issuanceId
    date = issuanceDate
    security_id = securityId
    custom_id = "CV-" <> issuanceId
    stakeholder_id = stakeholderId
    board_approval_date = None
    stockholder_approval_date = None
    consideration_text = Some "Cash investment"
    security_law_exemptions = []
    convertible_type = convertibleType
    investment_amount = OcfMonetary with amount = amount, currency = "USD"
    seniority = 1
    pro_rata = None
    conversion_triggers = [(ocfConvTriggerAutomaticOnDate with trigger_date = Some triggerDate)]
    comments = []

-- Create a convertible issuance to transfer (follows real workflow)
createConvertibleIssuance issuer capTableCid securityId amount issuanceDate =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance (convertibleTransferIssuance
        ("TX_CONVERTIBLE_ISS_" <> securityId)
        securityId
        "SH-1"
        amount
        issuanceDate
        OcfConvertibleSafe
        (DT.time (DA.date 2025 Dec 31) 0 0 0))]
      edits = []
      deletes = []

-- Test: SAFE assignment between investors
-- Based on prod: $100,000 SAFE transferred between investors
testConvertibleTransfer_SAFEAssignment = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-ASSIGNEE" "Convertible Assignee"
  let securityId = "CSEC-SAFE-001"
  result <- createConvertibleIssuance issuer capTableCid securityId 100000.0 (DT.time (DA.date 2024 Mar 01) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance (convertibleTransferIssuance
          "CV-ISS-SAFE-ASSIGNED-001" "CSEC-SAFE-ASSIGNED-001" assigneeId 100000.0
          (DT.time (DA.date 2025 Sep 08) 0 0 0) OcfConvertibleSafe
          (DT.time (DA.date 2025 Dec 31) 0 0 0))
        , CT.OcfCreateConvertibleTransfer ConvertibleTransferOcfData with
        id = "TX_CONVERTIBLE_TRANSFER_1"
        date = DT.time (DA.date 2025 Sep 08) 0 0 0
        amount = OcfMonetary with amount = 100000.0, currency = "USD"
        security_id = securityId
        resulting_security_ids = ["CSEC-SAFE-ASSIGNED-001"]
        comments = ["Assignor: ABC Holdings Ltd", "Assignee: New Investor LLC", "Company: Example Corp"]
        balance_security_id = None
        consideration_text = Some "Assignment Price: USD 100,000 per Assignment Agreement between ABC Holdings Ltd and New Investor LLC."]
      edits = []
      deletes = []
  pure ()

-- Test: Partial SAFE transfer with balance
testConvertibleTransfer_PartialSAFE = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-ASSIGNEE" "Convertible Assignee"
  let securityId = "CSEC-SAFE-PARTIAL"
  result <- createConvertibleIssuance issuer capTableCid securityId 500000.0 (DT.time (DA.date 2024 Mar 01) 0 0 0)
  balanceResult <- createConvertibleIssuance issuer result.updatedCapTableCid "CSEC-SAFE-RETAINED" 300000.0 (DT.time (DA.date 2025 Oct 15) 0 0 0)
  _ <- submit issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance (convertibleTransferIssuance
          "CV-ISS-SAFE-SPLIT-001" "CSEC-SAFE-SPLIT-001" assigneeId 200000.0
          (DT.time (DA.date 2025 Oct 15) 0 0 0) OcfConvertibleSafe
          (DT.time (DA.date 2025 Dec 31) 0 0 0))
        , CT.OcfCreateConvertibleTransfer ConvertibleTransferOcfData with
        id = "TX_CONVERTIBLE_TRANSFER_PARTIAL"
        date = DT.time (DA.date 2025 Oct 15) 0 0 0
        amount = OcfMonetary with amount = 200000.0, currency = "USD"
        security_id = securityId
        resulting_security_ids = ["CSEC-SAFE-SPLIT-001"]
        comments = ["Partial assignment of SAFE investment", "Original investment: $500,000", "Transferred: $200,000", "Retained: $300,000"]
        balance_security_id = Some "CSEC-SAFE-RETAINED"
        consideration_text = Some "Partial assignment at face value."]
      edits = []
      deletes = []
  pure ()

-- Test: Convertible note transfer with full assignment
testConvertibleTransfer_NoteFullAssignment = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  (capTableCid, assigneeId) <- setupStakeholderWithId issuer capTableCid "SH-ASSIGNEE" "Convertible Assignee"
  let securityId = "CSEC-NOTE-001"
  -- Create a convertible note issuance
  let noteTriggerDate = DT.time (DA.date 2025 Jun 15) 0 0 0
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance (convertibleTransferIssuance
        "TX_NOTE_ISS_1" securityId "SH-1" 250000.0
        (DT.time (DA.date 2023 Jun 15) 0 0 0) OcfConvertibleNote noteTriggerDate)]
      edits = []
      deletes = []
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance (convertibleTransferIssuance
          "CV-ISS-NOTE-ASSIGNED" "CSEC-NOTE-ASSIGNED" assigneeId 250000.0
          (DT.time (DA.date 2025 Dec 01) 0 0 0) OcfConvertibleNote noteTriggerDate)
        , CT.OcfCreateConvertibleTransfer ConvertibleTransferOcfData with
        id = "TX_NOTE_TRANSFER_1"
        date = DT.time (DA.date 2025 Dec 01) 0 0 0
        amount = OcfMonetary with amount = 250000.0, currency = "USD"
        security_id = securityId
        resulting_security_ids = ["CSEC-NOTE-ASSIGNED"]
        comments = ["Full assignment of convertible note"]
        balance_security_id = None
        consideration_text = Some "Note assigned at principal amount plus accrued interest."]
      edits = []
      deletes = []
  pure ()
