        , CT.OcfCreateConvertibleTransfer
            ((convertibleTransfer "TX-CV-SAME-DAY-TRANSFER" "SEC-CV-SAME-DAY-SOURCE" "SEC-CV-SAME-DAY-RESULT") with
              date = jan02Late)
        ]
      edits = []
      deletes = []
  pure ()

