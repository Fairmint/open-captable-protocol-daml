testTransactionLifecycleDates_StockPlanReturnBeforeIssuanceFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTable <- addPrerequisites issuer cap_table
  planResult <- submit issuer do
    exerciseCmd capTable CT.UpdateCapTable with
      creates = [CT.OcfCreateStockPlan StockPlanOcfData with
        id = "SP-1"
        plan_name = "Lifecycle test plan"
        initial_shares_reserved = 1000.0
        board_approval_date = None
        stockholder_approval_date = None
        default_cancellation_behavior = None
        stock_class_ids = ["SC_COMMON"]
        comments = []]
      edits = []
      deletes = []
  capTable <- addEquityCompensationIssuance issuer planResult.updatedCapTableCid "TX-RETURN-SOURCE" "SEC-RETURN-SOURCE" "SH-1"

  submitMustFail issuer do
    exerciseCmd capTable CT.UpdateCapTable with
      creates = [CT.OcfCreateStockPlanReturnToPool StockPlanReturnToPoolOcfData with
        id = "TX-RETURN-BEFORE"
        date = dec31
        quantity = 10.0
        reason_text = "Predates its source issuance"
        security_id = "SEC-RETURN-SOURCE"
        stock_plan_id = "SP-1"
        comments = []]
      edits = []
      deletes = []

