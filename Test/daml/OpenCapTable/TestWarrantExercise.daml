module OpenCapTable.TestWarrantExercise where

import Fairmint.OpenCapTable.OCF.WarrantIssuance
import Fairmint.OpenCapTable.OCF.WarrantExercise
import Fairmint.OpenCapTable.Types.Conversion
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Stock (OcfQuantitySourceType(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites, defaultStockClass, stockSuccessorIssuance)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

warrantExerciseTriggerWith : OcfWarrantConversionMechanism -> Optional Text -> OcfConversionTrigger
warrantExerciseTriggerWith conversionMechanism stockClassId =
  OcfConversionTrigger with
    conversion_right = OcfRightWarrant (OcfWarrantConversionRight with
      conversion_mechanism = conversionMechanism
      converts_to_future_round = case stockClassId of None -> Some True; Some _ -> None
      converts_to_stock_class_id = stockClassId
      type_ = "WARRANT_CONVERSION_RIGHT")
    end_date = None
    nickname = None
    start_date = None
    trigger_condition = None
    trigger_date = None
    trigger_description = None
    trigger_id = "ELECTIVE_AT_WILL"
    type_ = OcfTriggerTypeTypeElectiveAtWill

warrantExerciseTrigger : Decimal -> OcfConversionTrigger
warrantExerciseTrigger convertsToQuantity =
  warrantExerciseTriggerWith
    (OcfWarrantMechanismFixedAmount with converts_to_quantity = convertsToQuantity)
    (Some "SC_COMMON")

-- Create a warrant issuance to exercise (follows real workflow)
createWarrantIssuanceWithTrigger issuer capTableCid securityId qty trigger =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantIssuance WarrantIssuanceOcfData with
        id = "TX_WARRANT_ISS_1"
        date = DT.time (DA.date 2023 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "W-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        quantity = Some qty
        quantity_source = Some OcfQuantityUnspecified
        exercise_price = Some (OcfMonetary with amount = 0.01, currency = "USD")
        exercise_triggers = [trigger]
        purchase_price = OcfMonetary with amount = 0.01, currency = "USD"
        vestings = []
        vesting_terms_id = None
        warrant_expiration_date = None
        comments = []]
      edits = []
      deletes = []

createWarrantIssuance issuer capTableCid securityId qty =
  createWarrantIssuanceWithTrigger issuer capTableCid securityId qty (warrantExerciseTrigger qty)

-- Test 1: Basic warrant exercise
-- Warrants exercised into common stock
testWarrantExercise_BasicExercise = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "WSEC-001"
  result <- createWarrantIssuance issuer capTableCid securityId 10000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-WARRANT-EXERCISE-1" "SSEC-FROM-WARRANT-001" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Jun 15) 0 0 0) 10000.0
        , CT.OcfCreateWarrantExercise WarrantExerciseOcfData with
        id = "TX_WARRANT_EXERCISE_1"
        date = DT.time (DA.date 2025 Jun 15) 0 0 0
        security_id = securityId
        trigger_id = "ELECTIVE_AT_WILL"
        quantity = Some 10000.0
        resulting_security_ids = ["SSEC-FROM-WARRANT-001"]
        comments = []
        consideration_text = Some "Exercise of 10,000 warrants at $0.01 per warrant"]
      edits = []
      deletes = []
  pure ()

testWarrantExercise_AllowsEmptyResultingSecurityIds = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "WSEC-EMPTY-RESULTS"
  result <- createWarrantIssuance issuer capTableCid securityId 100.0

  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantExercise WarrantExerciseOcfData with
        id = "TX-WARRANT-EXERCISE-EMPTY-RESULTS"
        date = DT.time (DA.date 2025 Jun 15) 0 0 0
        security_id = securityId
        trigger_id = "ELECTIVE_AT_WILL"
        quantity = Some 100.0
        resulting_security_ids = []
        comments = []
        consideration_text = None]
      edits = []
      deletes = []
  pure ()

testWarrantExercise_NonFixedEmptyResultsFailWhenOutputCannotBeReconstructed = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "WSEC-NON-FIXED-EMPTY-RESULTS"
      trigger = warrantExerciseTriggerWith
        (OcfWarrantMechanismCustom with custom_conversion_description = "Output is determined by the exercise agreement")
        (Some "SC_COMMON")
  result <- createWarrantIssuanceWithTrigger issuer capTableCid securityId 100.0 trigger

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantExercise WarrantExerciseOcfData with
        id = "TX-WARRANT-EXERCISE-NON-FIXED-EMPTY-RESULTS"
        date = DT.time (DA.date 2025 Jun 15) 0 0 0
        security_id = securityId
        trigger_id = "ELECTIVE_AT_WILL"
        quantity = Some 100.0
        resulting_security_ids = []
        comments = []
        consideration_text = None]
      edits = []
      deletes = []

