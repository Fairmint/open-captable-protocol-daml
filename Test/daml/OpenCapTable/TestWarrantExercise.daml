  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "WSEC-RESULT-QUANTITY-MISMATCH"
  result <- createWarrantIssuance issuer capTableCid securityId 100.0

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-WARRANT-QUANTITY-MISMATCH" "SSEC-WARRANT-QUANTITY-MISMATCH" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Jun 15) 0 0 0) 99.0
        , CT.OcfCreateWarrantExercise WarrantExerciseOcfData with
            id = "TX-WARRANT-EXERCISE-QUANTITY-MISMATCH"
            date = DT.time (DA.date 2025 Jun 15) 0 0 0
            security_id = securityId
            trigger_id = "ELECTIVE_AT_WILL"
            quantity = Some 100.0
            resulting_security_ids = ["SSEC-WARRANT-QUANTITY-MISMATCH"]
            comments = []
            consideration_text = None
        ]
      edits = []
      deletes = []

testWarrantExercise_ResultStockClassMustMatchTrigger = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  classResult <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClass (defaultStockClass "SC-WARRANT-WRONG-RESULT")]
      edits = []
      deletes = []
  let securityId = "WSEC-RESULT-CLASS-MISMATCH"
  result <- createWarrantIssuance issuer classResult.updatedCapTableCid securityId 100.0

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-WARRANT-CLASS-MISMATCH" "SSEC-WARRANT-CLASS-MISMATCH" "SH-1" "SC-WARRANT-WRONG-RESULT" (DT.time (DA.date 2025 Jun 15) 0 0 0) 100.0
        , CT.OcfCreateWarrantExercise WarrantExerciseOcfData with
            id = "TX-WARRANT-EXERCISE-CLASS-MISMATCH"
            date = DT.time (DA.date 2025 Jun 15) 0 0 0
            security_id = securityId
            trigger_id = "ELECTIVE_AT_WILL"
            quantity = Some 100.0
            resulting_security_ids = ["SSEC-WARRANT-CLASS-MISMATCH"]
            comments = []
            consideration_text = None
        ]
      edits = []
      deletes = []

