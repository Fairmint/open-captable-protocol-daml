  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "WSEC-NON-FIXED-RESULT"
      trigger = warrantExerciseTriggerWith
        (OcfWarrantMechanismCustom with custom_conversion_description = "One warrant converts into a negotiated share quantity")
        (Some "SC_COMMON")
