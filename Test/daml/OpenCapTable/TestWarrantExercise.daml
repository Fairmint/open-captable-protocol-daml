  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-WARRANT-NON-FIXED" "SSEC-WARRANT-NON-FIXED" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Jun 15) 0 0 0) 25.0
        , CT.OcfCreateWarrantExercise WarrantExerciseOcfData with
