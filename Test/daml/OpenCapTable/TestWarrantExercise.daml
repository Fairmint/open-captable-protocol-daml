module OpenCapTable.TestWarrantExercise where

import Fairmint.OpenCapTable.OCF.WarrantIssuance
import Fairmint.OpenCapTable.OCF.WarrantExercise
import qualified Fairmint.OpenCapTable.OCF.WarrantExercise as WE
import Fairmint.OpenCapTable.Types (OcfMonetary(..), OcfQuantitySourceType(..))
import OpenCapTable.HelpersTriggers (ocfTriggerElectiveAtWill)
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 10000000.0)
        comments = []

-- Create a warrant issuance to exercise (follows real workflow)
createWarrantIssuance issuer capTableCid securityId qty =
  submit issuer do
    exerciseCmd capTableCid CT.AddWarrantIssuance with
      issuance_data = WarrantIssuanceOcfData with
        id = "TX_WARRANT_ISS_1"
        date = DT.time (DA.date 2023 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "W-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        quantity = Some qty
        quantity_source = Some OcfQuantityUnspecified
        exercise_price = Some (OcfMonetary with amount = 0.01, currency = "USD")
        exercise_triggers = [ocfTriggerElectiveAtWill]
        purchase_price = OcfMonetary with amount = 0.01, currency = "USD"
        vestings = []
        vesting_terms_id = None
        warrant_expiration_date = None
        comments = []

-- Test 1: Basic warrant exercise
-- Warrants exercised into common stock
testWarrantExercise_BasicExercise = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "WSEC-001"
  _ <- createWarrantIssuance issuer capTableCid securityId 10000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddWarrantExercise with
      exercise_data = WarrantExerciseOcfData with
        id = "TX_WARRANT_EXERCISE_1"
        date = DT.time (DA.date 2025 Jun 15) 0 0 0
        security_id = securityId
        trigger_id = "ELECTIVE_AT_WILL"
        quantity = Some 10000.0
        resulting_security_ids = ["SSEC-FROM-WARRANT-001"]
        comments = []
        consideration_text = Some "Exercise of 10,000 warrants at $0.01 per warrant"
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()

-- Test 2: Warrant exercise with comments (partial exercise scenario)
testWarrantExercise_PartialWithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "WSEC-002"
  _ <- createWarrantIssuance issuer capTableCid securityId 50000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddWarrantExercise with
      exercise_data = WarrantExerciseOcfData with
        id = "TX_WARRANT_EXERCISE_2"
        date = DT.time (DA.date 2025 Aug 01) 0 0 0
        security_id = securityId
        trigger_id = "ELECTIVE_AT_WILL"
        quantity = Some 25000.0
        resulting_security_ids = ["SSEC-FROM-WARRANT-002"]
        comments = ["Partial exercise of warrants issued in Series A financing.", "Remaining 25,000 warrants retained by holder."]
        consideration_text = Some "Cashless exercise pursuant to Section 3.1 of Warrant Agreement"
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()

-- Test 3: Simple exercise with minimal fields
testWarrantExercise_MinimalFields = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  let securityId = "WSEC-003"
  _ <- createWarrantIssuance issuer capTableCid securityId 5000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddWarrantExercise with
      exercise_data = WarrantExerciseOcfData with
        id = "TX_WARRANT_EXERCISE_3"
        date = DT.time (DA.date 2025 Sep 30) 0 0 0
        security_id = securityId
        trigger_id = "ELECTIVE_AT_WILL"
        quantity = None  -- Full exercise, quantity optional
        resulting_security_ids = ["SSEC-FROM-WARRANT-003"]
        comments = []
        consideration_text = None
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()
