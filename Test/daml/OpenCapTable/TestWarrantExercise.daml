            trigger_id = "ELECTIVE_AT_WILL"
            quantity = Some 100.0
            resulting_security_ids = ["SSEC-WARRANT-NON-FIXED"]
            comments = []
            consideration_text = None
        ]
      edits = []
      deletes = []
  pure ()

