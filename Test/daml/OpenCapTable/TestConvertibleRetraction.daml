module OpenCapTable.TestConvertibleRetraction where

import Fairmint.OpenCapTable.OCF.ConvertibleIssuance
import Fairmint.OpenCapTable.OCF.ConvertibleRetraction
import qualified Fairmint.OpenCapTable.OCF.ConvertibleRetraction as CR
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.OCF.Issuer
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import OpenCapTable.HelpersTriggers (ocfConvTriggerAutomaticOnDate)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

createConvertibleIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddConvertibleIssuance with
      issuance_data = ConvertibleIssuanceOcfData with
        id = "TX_CONV_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-CONV-1"
        custom_id = "SAFE-001"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = Some "Cash investment"
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleSafe
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2025 Jan 01) 0 0 0)) ]
        pro_rata = None
        seniority = 1
        comments = []

createConvertibleRetraction issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddConvertibleRetraction with
      retraction_data = ConvertibleRetractionOcfData with
        id = "TX_CONV_RETRACT_1"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        security_id = "SEC-CONV-1"
        reason_text = "Administrative error - incorrect investment amount recorded"
        comments = []

testConvertibleRetraction_CreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  capTableCid <- createConvertibleIssuance issuer capTableCid
  cid <- createConvertibleRetraction issuer capTableCid

  pure ()

testConvertibleRetraction_CreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  capTableCid <- createConvertibleIssuance issuer capTableCid
  cid <- createConvertibleRetraction issuer capTableCid

  pure ()

-- Test with comments (non-empty array)
testConvertibleRetraction_WithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  capTableCid <- createConvertibleIssuance issuer capTableCid
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddConvertibleRetraction with
      retraction_data = ConvertibleRetractionOcfData with
        id = "TX_CONV_RETRACT_2"
        date = DT.time (DA.date 2024 Jan 03) 0 0 0
        security_id = "SEC-CONV-1"
        reason_text = "SAFE void ab initio - wire transfer bounced"
        comments = ["Board resolution 2024-004", "Investor notified"]

  pure ()
