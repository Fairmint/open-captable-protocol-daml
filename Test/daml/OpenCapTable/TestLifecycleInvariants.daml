  (capTableWithClass, stockClassId) <- setupStockClassWith issuer cap_table (limitedStockClass "SC_REISSUE_DOUBLE" 1_000.0)
  (capTableReady, stakeholderId) <- setupStakeholderWithId issuer capTableWithClass "SH_REISSUE_DOUBLE" "Reissuance Double Holder"
  let sourceSecurityId = "SEC_REISSUE_DOUBLE_SOURCE"
