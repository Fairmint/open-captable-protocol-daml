module OpenCapTable.TestStockReissuance where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockReissuance
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Create a stock issuance to reissue
createStockIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance StockIssuanceOcfData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2022 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "CS-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []]
      edits = []
      deletes = []

-- Test 1: Basic reissuance (certificate replacement)
testStockReissuance_CertificateReplacement = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-001"
  result <- createStockIssuance issuer capTableCid securityId 50000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_1"
        date = DT.time (DA.date 2025 Mar 15) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-001-REISSUED"]
        comments = []
        reason_text = Some "Lost certificate replacement"
        split_transaction_id = None]
      edits = []
      deletes = []
  pure ()

-- Test 2: Reissuance due to stock split
testStockReissuance_StockSplit = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-002"
  result <- createStockIssuance issuer capTableCid securityId 25000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_2"
        date = DT.time (DA.date 2025 Jul 01) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-002-SPLIT"]
        comments = ["Certificate re-papered following 2-for-1 stock split.", "New certificate reflects 50,000 shares."]
        reason_text = Some "Stock split adjustment"
        split_transaction_id = Some "TX_STOCK_CLASS_SPLIT_1"]
      edits = []
      deletes = []
  pure ()

-- Test 3: Reissuance with multiple resulting securities (legend removal + split)
testStockReissuance_MultipleResulting = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-003"
  result <- createStockIssuance issuer capTableCid securityId 100000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_3"
        date = DT.time (DA.date 2025 Sep 01) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-003-FREE-A", "SSEC-003-FREE-B"]
        comments = []
        reason_text = Some "Legend removal and certificate split per holder request"
        split_transaction_id = None]
      edits = []
      deletes = []
  pure ()
