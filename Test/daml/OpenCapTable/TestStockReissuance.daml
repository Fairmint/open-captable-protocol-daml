module OpenCapTable.TestStockReissuance where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockReissuance
import Fairmint.OpenCapTable.OCF.StockTransfer
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites, limitedStockClass, stockCancellationOn, stockClassSplit, stockClassSplitOn, stockSuccessorIssuance)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Create a stock issuance to reissue
createStockIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance StockIssuanceOcfData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2022 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "CS-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []]
      edits = []
      deletes = []

-- Test 1: Basic reissuance (certificate replacement)
testStockReissuance_CertificateReplacement = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-001"
  result <- createStockIssuance issuer capTableCid securityId 50000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-REISSUANCE-1" "SSEC-001-REISSUED" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Mar 15) 0 0 0) 50000.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_1"
        date = DT.time (DA.date 2025 Mar 15) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-001-REISSUED"]
        comments = []
        reason_text = Some "Lost certificate replacement"
        split_transaction_id = None]
      edits = []
      deletes = []
  pure ()

-- Test 2: Reissuance due to stock split
testStockReissuance_StockSplit = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-002"
  result <- createStockIssuance issuer capTableCid securityId 25000.0
  splitResult <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClassSplit (stockClassSplit "TX_STOCK_CLASS_SPLIT_1" "SC_COMMON" 2.0 1.0)]
      edits = []
      deletes = []
  _ <- submit issuer do
    exerciseCmd splitResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-REISSUANCE-2" "SSEC-002-SPLIT" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Jul 01) 0 0 0) 50000.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_2"
        date = DT.time (DA.date 2025 Jul 01) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-002-SPLIT"]
        comments = ["Certificate re-papered following 2-for-1 stock split.", "New certificate reflects 50,000 shares."]
        reason_text = Some "Stock split adjustment"
        split_transaction_id = Some "TX_STOCK_CLASS_SPLIT_1"]
      edits = []
      deletes = []
  pure ()

-- Test 3: Reissuance with multiple resulting securities (legend removal + split)
testStockReissuance_MultipleResulting = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-003"
  result <- createStockIssuance issuer capTableCid securityId 100000.0
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-REISSUANCE-3A" "SSEC-003-FREE-A" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Sep 01) 0 0 0) 50000.0
        , stockSuccessorIssuance "STOCK-ISS-REISSUANCE-3B" "SSEC-003-FREE-B" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Sep 01) 0 0 0) 50000.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_3"
        date = DT.time (DA.date 2025 Sep 01) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-003-FREE-A", "SSEC-003-FREE-B"]
        comments = []
        reason_text = Some "Legend removal and certificate split per holder request"
        split_transaction_id = None]
      edits = []
      deletes = []
  pure ()

testStockReissuance_RequiresResultingSecurityOnCapTable = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-EMPTY-REISSUANCE"
  result <- createStockIssuance issuer capTableCid securityId 100.0

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockReissuance StockReissuanceOcfData with
        id = "TX_STOCK_REISSUANCE_EMPTY_RESULT"
        date = DT.time (DA.date 2025 Sep 01) 0 0 0
        security_id = securityId
        resulting_security_ids = []
        comments = []
        reason_text = Some "Invalid reissuance without a successor"
        split_transaction_id = None]
      edits = []
      deletes = []

testStockReissuance_SameTimestampSplitDoesNotResplitSuccessor = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let securityId = "SSEC-SAME-TIMESTAMP-SPLIT"
      eventDate = DT.time (DA.date 2025 Jul 01) 0 0 0
      splitId = "TX_STOCK_CLASS_SPLIT_SAME_TIMESTAMP"
  limitedResult <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStockClass (limitedStockClass "SC_COMMON" 50.0)]
      deletes = []
  result <- createStockIssuance issuer limitedResult.updatedCapTableCid securityId 25.0

  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassSplit (stockClassSplitOn splitId "SC_COMMON" 2.0 1.0 eventDate)
        , stockSuccessorIssuance "STOCK-ISS-REISSUANCE-SAME-TIMESTAMP" "SSEC-SAME-TIMESTAMP-SPLIT-RESULT" "SH-1" "SC_COMMON" eventDate 50.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
            id = "TX_STOCK_REISSUANCE_SAME_TIMESTAMP"
            date = eventDate
            security_id = securityId
            resulting_security_ids = ["SSEC-SAME-TIMESTAMP-SPLIT-RESULT"]
            comments = []
            reason_text = Some "Stock split adjustment"
            split_transaction_id = Some splitId
        ]
      edits = []
      deletes = []
  pure ()

testStockReissuance_SameTimestampSuccessorCanBeReduced = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SSEC-SAME-TIMESTAMP-REDUCTION-SOURCE"
      resultSecurityId = "SSEC-SAME-TIMESTAMP-REDUCTION-RESULT"
      eventDate = DT.time (DA.date 2025 Jul 01) 0 0 0
      splitId = "TX_STOCK_CLASS_SPLIT_SAME_TIMESTAMP_REDUCTION"
  result <- createStockIssuance issuer capTableCid sourceSecurityId 25.0

  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassSplit (stockClassSplitOn splitId "SC_COMMON" 2.0 1.0 eventDate)
        , stockSuccessorIssuance "STOCK-ISS-REISSUANCE-SAME-TIMESTAMP-REDUCTION" resultSecurityId "SH-1" "SC_COMMON" eventDate 50.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
            id = "TX_STOCK_REISSUANCE_SAME_TIMESTAMP_REDUCTION"
            date = eventDate
            security_id = sourceSecurityId
            resulting_security_ids = [resultSecurityId]
            comments = []
            reason_text = Some "Stock split adjustment"
            split_transaction_id = Some splitId
        , CT.OcfCreateStockCancellation (stockCancellationOn
            "TX_STOCK_CANCELLATION_SAME_TIMESTAMP_REDUCTION"
            resultSecurityId
            50.0
            eventDate)
        ]
      edits = []
      deletes = []
  pure ()

testStockReissuance_SameTimestampSuccessorTransferRemainsPostSplit = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SSEC-SAME-TIMESTAMP-CHAIN-SOURCE"
      reissuanceSecurityId = "SSEC-SAME-TIMESTAMP-CHAIN-REISSUANCE"
      transferSecurityId = "SSEC-SAME-TIMESTAMP-CHAIN-TRANSFER"
      eventDate = DT.time (DA.date 2025 Jul 01) 0 0 0
      splitId = "TX_STOCK_CLASS_SPLIT_SAME_TIMESTAMP_CHAIN"
  limitedResult <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStockClass (limitedStockClass "SC_COMMON" 50.0)]
      deletes = []
  result <- createStockIssuance issuer limitedResult.updatedCapTableCid sourceSecurityId 25.0

  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassSplit (stockClassSplitOn splitId "SC_COMMON" 2.0 1.0 eventDate)
        , stockSuccessorIssuance "STOCK-ISS-REISSUANCE-SAME-TIMESTAMP-CHAIN" reissuanceSecurityId "SH-1" "SC_COMMON" eventDate 50.0
        , stockSuccessorIssuance "STOCK-ISS-TRANSFER-SAME-TIMESTAMP-CHAIN" transferSecurityId "SH-1" "SC_COMMON" eventDate 50.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
            id = "TX_STOCK_REISSUANCE_SAME_TIMESTAMP_CHAIN"
            date = eventDate
            security_id = sourceSecurityId
            resulting_security_ids = [reissuanceSecurityId]
            comments = []
            reason_text = Some "Stock split adjustment"
            split_transaction_id = Some splitId
        , CT.OcfCreateStockTransfer StockTransferOcfData with
            id = "TX_STOCK_TRANSFER_SAME_TIMESTAMP_CHAIN"
            date = eventDate
            quantity = 50.0
            security_id = reissuanceSecurityId
            resulting_security_ids = [transferSecurityId]
            balance_security_id = None
            consideration_text = None
            comments = []
        ]
      edits = []
      deletes = []
  pure ()

testStockReissuance_LaterTransferCannotReusePreSplitBalance = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  let sourceSecurityId = "SSEC-LATER-TRANSFER-SOURCE"
      reissuanceSecurityId = "SSEC-LATER-TRANSFER-REISSUANCE"
      eventDate = DT.time (DA.date 2025 Jul 01) 0 0 0
      transferDate = DT.time (DA.date 2025 Aug 01) 0 0 0
      splitId = "TX_STOCK_CLASS_SPLIT_LATER_TRANSFER"
  result <- createStockIssuance issuer capTableCid sourceSecurityId 25.0
  reissuanceResult <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassSplit (stockClassSplitOn splitId "SC_COMMON" 2.0 1.0 eventDate)
        , stockSuccessorIssuance "STOCK-ISS-REISSUANCE-LATER-TRANSFER" reissuanceSecurityId "SH-1" "SC_COMMON" eventDate 50.0
        , CT.OcfCreateStockReissuance StockReissuanceOcfData with
            id = "TX_STOCK_REISSUANCE_LATER_TRANSFER"
            date = eventDate
            security_id = sourceSecurityId
            resulting_security_ids = [reissuanceSecurityId]
            comments = []
            reason_text = Some "Stock split adjustment"
            split_transaction_id = Some splitId
        ]
      edits = []
      deletes = []

  submitMustFail issuer do
    exerciseCmd reissuanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-LATER-TRANSFER-RESULT" "SSEC-LATER-TRANSFER-RESULT" "SH-1" "SC_COMMON" transferDate 50.0
        , stockSuccessorIssuance "STOCK-ISS-LATER-TRANSFER-BALANCE" "SSEC-LATER-TRANSFER-BALANCE" "SH-1" "SC_COMMON" transferDate 50.0
        , CT.OcfCreateStockTransfer StockTransferOcfData with
            id = "TX_STOCK_LATER_TRANSFER"
            date = transferDate
            quantity = 50.0
            security_id = reissuanceSecurityId
            resulting_security_ids = ["SSEC-LATER-TRANSFER-RESULT"]
            balance_security_id = Some "SSEC-LATER-TRANSFER-BALANCE"
            consideration_text = None
            comments = []
        ]
      edits = []
      deletes = []
