module OpenCapTable.TestStockReissuance where

import Fairmint.OpenCapTable.StockIssuance
import Fairmint.OpenCapTable.StockReissuance
import qualified Fairmint.OpenCapTable.StockReissuance as SRI
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []

-- Create a stock issuance to reissue
createStockIssuance issuer issuerCid securityId quantity =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateStockIssuance with
      issuance_data = OcfStockIssuanceData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2022 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "CS-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []

-- Test 1: Basic reissuance (certificate replacement)
testStockReissuance_CertificateReplacement = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "SSEC-001"
  _ <- createStockIssuance issuer issuerCid securityId 50000.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockReissuance with
      reissuance_data = OcfStockReissuanceTxData with
        id = "TX_STOCK_REISSUANCE_1"
        date = DT.time (DA.date 2025 Mar 15) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-001-REISSUED"]
        comments = []
        reason_text = Some "Lost certificate replacement"
        split_transaction_id = None
  submit issuer do
    exerciseCmd cid SRI.ArchiveByIssuer
  pure ()

-- Test 2: Reissuance due to stock split
testStockReissuance_StockSplit = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "SSEC-002"
  _ <- createStockIssuance issuer issuerCid securityId 25000.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockReissuance with
      reissuance_data = OcfStockReissuanceTxData with
        id = "TX_STOCK_REISSUANCE_2"
        date = DT.time (DA.date 2025 Jul 01) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-002-SPLIT"]
        comments = ["Certificate re-papered following 2-for-1 stock split.", "New certificate reflects 50,000 shares."]
        reason_text = Some "Stock split adjustment"
        split_transaction_id = Some "TX_STOCK_CLASS_SPLIT_1"
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Test 3: Reissuance with multiple resulting securities (legend removal + split)
testStockReissuance_MultipleResulting = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "SSEC-003"
  _ <- createStockIssuance issuer issuerCid securityId 100000.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockReissuance with
      reissuance_data = OcfStockReissuanceTxData with
        id = "TX_STOCK_REISSUANCE_3"
        date = DT.time (DA.date 2025 Sep 01) 0 0 0
        security_id = securityId
        resulting_security_ids = ["SSEC-003-FREE-A", "SSEC-003-FREE-B"]
        comments = []
        reason_text = Some "Legend removal and certificate split per holder request"
        split_transaction_id = None
  submit issuer do
    exerciseCmd cid SRI.ArchiveByIssuer
  pure ()
