module OpenCapTable.TestEquityCompensationExercise where
import Fairmint.OpenCapTable.OCF.EquityCompensationExercise
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submit issuer do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

createEquityCompensationExercise issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationExercise with
      exercise_data = EquityCompensationExerciseOcfData with
        id = "TX_EC_EX_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-1"
        quantity = 10.0
        consideration_text = None
        resulting_security_ids = ["SEC-RES-1"]
        comments = []

testCreateAndArchiveEquityCompensationExercise = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  cid <- createEquityCompensationExercise issuer capTableCid
  submit issuer do
    archiveCmd cid
  pure ()

testCreateAndArchiveEquityCompensationExerciseBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  cid <- createEquityCompensationExercise issuer capTableCid
  submit issuer do
    exerciseCmd cid Archive
  pure ()

-- Optionals Some
testEquityCompensationExercise_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationExercise with
      exercise_data = EquityCompensationExerciseOcfData with
        id = "TX_EC_EX_2"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "EC-2"
        quantity = 5.0
        consideration_text = Some "Cashless"
        resulting_security_ids = ["SEC-RES-2", "SEC-RES-3"]
        comments = ["Partial exercise"]
  submit issuer do
    exerciseCmd cid Archive
  pure ()


