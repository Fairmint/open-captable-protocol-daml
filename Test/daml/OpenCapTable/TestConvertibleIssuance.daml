module OpenCapTable.TestConvertibleIssuance where
import Fairmint.OpenCapTable.ConvertibleIssuance
import Fairmint.OpenCapTable.Types (OcfConvertibleType(..), OcfMonetary(..), OcfSecurityExemption(..))
import OpenCapTable.HelpersTriggers (ocfConvTriggerAutomaticOnDate)
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []

createConvertibleIssuance issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateConvertibleIssuance with
      issuance_data = ConvertibleIssuanceOcfData with
        id = "TX_CONV_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "CN-1"
        custom_id = "NOTE-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2024 Jan 01) 0 0 0)) ]
        pro_rata = None
        seniority = 1
        comments = []

testCreateAndArchiveConvertibleIssuance = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- createConvertibleIssuance issuer issuerCid
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.ConvertibleIssuance.ArchiveByIssuer
  pure ()

testCreateAndArchiveConvertibleIssuanceBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- createConvertibleIssuance issuer issuerCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Base helper already covers None/empty where applicable

-- Optionals Some and arrays non-empty
testConvertibleIssuance_OptionalsSome_ArraysNonEmpty = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateConvertibleIssuance with
      issuance_data = ConvertibleIssuanceOcfData with
        id = "TX_CONV_SOME"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "CN-3"
        custom_id = "NOTE-3"
        stakeholder_id = "SH-3"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 15) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 20) 0 0 0)
        consideration_text = Some "Cash consideration"
        security_law_exemptions = [ OcfSecurityExemption with description = "Rule 504", jurisdiction = "US-CA" ]
        investment_amount = OcfMonetary with amount = 5000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2024 Jun 01) 0 0 0)) ]
        pro_rata = Some 0.1
        seniority = 1
        comments = ["Issued"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


