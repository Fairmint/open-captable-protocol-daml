module OpenCapTable.TestConvertibleIssuance where
import Fairmint.OpenCapTable.OCF.ConvertibleIssuance
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Stock (OcfSecurityExemption(..))
import Fairmint.OpenCapTable.Types.Conversion (OcfConvertibleType(..))
import OpenCapTable.HelpersTriggers (ocfConvTriggerAutomaticOnDate)
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateConvertibleIssuance = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisite stakeholder
  capTableCid <- addDefaultStakeholder issuer cap_table
  -- Create convertible issuance
  _ <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = "TX_CONV_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "CN-1"
        custom_id = "NOTE-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2024 Jan 01) 0 0 0)) ]
        pro_rata = None
        seniority = 1
        comments = []]
      edits = []
      deletes = []
  pure ()

testCreateAndDeleteConvertibleIssuance = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = "TX_CONV_DEL"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "CN-DEL"
        custom_id = "NOTE-DEL"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 50000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2025 Jan 01) 0 0 0)) ]
        pro_rata = None
        seniority = 1
        comments = []]
      edits = []
      deletes = []
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteConvertibleIssuance "TX_CONV_DEL"]
  pure ()

testConvertibleIssuance_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  _ <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = "TX_CONV_SOME"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "CN-3"
        custom_id = "NOTE-3"
        stakeholder_id = "SH-1"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 15) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 20) 0 0 0)
        consideration_text = Some "Cash consideration"
        security_law_exemptions = [ OcfSecurityExemption with description = "Rule 504", jurisdiction = "US-CA" ]
        investment_amount = OcfMonetary with amount = 5000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2024 Jun 01) 0 0 0)) ]
        pro_rata = Some 0.1
        seniority = 1
        comments = ["Issued"]]
      edits = []
      deletes = []
  pure ()

testConvertibleIssuance_DuplicateConversionTriggerIdsFail = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let trigger = (ocfConvTriggerAutomaticOnDate with
        trigger_id = "TRIGGER-DUPLICATE"
        trigger_date = Some (DT.time (DA.date 2025 Jan 01) 0 0 0))

  submitMustFail issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = "TX_CONV_DUPLICATE_TRIGGER"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "CN-DUPLICATE-TRIGGER"
        custom_id = "NOTE-DUPLICATE-TRIGGER"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [trigger, trigger]
        pro_rata = None
        seniority = 1
        comments = []]
      edits = []
      deletes = []

testConvertibleIssuance_EditDuplicateConversionTriggerIdsFail = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let trigger = (ocfConvTriggerAutomaticOnDate with
        trigger_id = "TRIGGER-DUPLICATE-EDIT"
        trigger_date = Some (DT.time (DA.date 2025 Jan 01) 0 0 0))
  let issuance = ConvertibleIssuanceOcfData with
        id = "TX_CONV_DUPLICATE_TRIGGER_EDIT"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "CN-DUPLICATE-TRIGGER-EDIT"
        custom_id = "NOTE-DUPLICATE-TRIGGER-EDIT"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [trigger]
        pro_rata = None
        seniority = 1
        comments = []

  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance issuance]
      edits = []
      deletes = []

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditConvertibleIssuance (issuance with conversion_triggers = [trigger, trigger])]
      deletes = []
