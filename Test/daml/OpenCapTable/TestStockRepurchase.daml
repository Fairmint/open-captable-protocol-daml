module OpenCapTable.TestStockRepurchase where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockRepurchase
import qualified Fairmint.OpenCapTable.OCF.StockRepurchase as SR
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []

-- Create a stock issuance to repurchase (follows real workflow)
createStockIssuance issuer issuerCid securityId quantity =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateStockIssuance with
      issuance_data = StockIssuanceOcfData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2022 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "CS-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []

-- Test 1: Full stock repurchase at nominal price
-- Based on prod: Departing employee unvested shares repurchased at $0.01
testStockRepurchase_FullRepurchase = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "a9d6afeb-fae1-449b-adf2-1b233d05cb35"
  _ <- createStockIssuance issuer issuerCid securityId 61792.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockRepurchase with
      repurchase_data = StockRepurchaseOcfData with
        id = "3c18efd8-ee72-4ddc-8b88-6859011848c0"
        date = DT.time (DA.date 2023 Feb 25) 0 0 0
        security_id = securityId
        price = OcfMonetary with amount = 0.01, currency = "USD"
        quantity = 61792.0
        comments = []
        balance_security_id = None
        consideration_text = None
  submit issuer do
    exerciseCmd cid SR.ArchiveByIssuer
  pure ()

-- Test 2: Partial repurchase with balance security
testStockRepurchase_PartialRepurchase = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "SSEC-002"
  _ <- createStockIssuance issuer issuerCid securityId 100000.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockRepurchase with
      repurchase_data = StockRepurchaseOcfData with
        id = "TX_STOCK_REPURCHASE_2"
        date = DT.time (DA.date 2023 Jun 15) 0 0 0
        security_id = securityId
        price = OcfMonetary with amount = 0.01, currency = "USD"
        quantity = 50000.0
        comments = ["Partial repurchase of unvested shares upon voluntary termination."]
        balance_security_id = Some "SSEC-002-REMAIN"
        consideration_text = Some "Repurchase at original issue price per Stock Restriction Agreement Section 3."
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Test 3: Repurchase at fair market value
testStockRepurchase_FMVRepurchase = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "SSEC-003"
  _ <- createStockIssuance issuer issuerCid securityId 75000.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockRepurchase with
      repurchase_data = StockRepurchaseOcfData with
        id = "TX_STOCK_REPURCHASE_3"
        date = DT.time (DA.date 2024 Mar 30) 0 0 0
        security_id = securityId
        price = OcfMonetary with amount = 2.50, currency = "USD"
        quantity = 75000.0
        comments = []
        balance_security_id = None
        consideration_text = Some "Company buyback at current 409A FMV of $2.50 per share."
  submit issuer do
    exerciseCmd cid SR.ArchiveByIssuer
  pure ()
