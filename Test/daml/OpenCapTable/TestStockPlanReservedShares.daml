        , CT.OcfCreateStockIssuance stockIssuance
        , CT.OcfCreateEquityCompensationIssuance positiveEquityCompensation
        , CT.OcfCreateEquityCompensationIssuance negativeEquityCompensation
        ]
      edits = []
      deletes = []

