module OpenCapTable.TestStakeholderRelationshipChangeEvent where

import Fairmint.OpenCapTable.StakeholderRelationshipChangeEvent
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import Fairmint.OpenCapTable.Types (OcfStakeholderRelationshipType(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


-- Test: Create and archive relationship start event (new employee)
testCreateAndArchiveStakeholderRelationshipChangeEventStart = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "ExampleCo Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []
  -- New employee hired
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStakeholderRelationshipChangeEvent with
      event_data = StakeholderRelationshipChangeEventOcfData with
        id = "CE_REL_1"
        date = DT.time (DA.date 2024 Mar 01) 0 0 0
        stakeholder_id = "STK_EMPLOYEE_001"
        relationship_started = Some OcfRelEmployee
        relationship_ended = None
        comments = ["New hire - Software Engineer starting March 1, 2024"]
  submit issuer do
    exerciseCmd cid ArchiveByIssuer
  pure ()


-- Test: Create and archive relationship end event (termination)
testCreateAndArchiveStakeholderRelationshipChangeEventEnd = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_2"
        legal_name = "TechStart Corp."
        formation_date = DT.time (DA.date 2018 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  -- Employee resignation - becomes ex-employee
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStakeholderRelationshipChangeEvent with
      event_data = StakeholderRelationshipChangeEventOcfData with
        id = "CE_REL_2"
        date = DT.time (DA.date 2024 Jun 30) 0 0 0
        stakeholder_id = "STK_EMPLOYEE_002"
        relationship_started = Some OcfRelExEmployee
        relationship_ended = Some OcfRelEmployee
        comments = ["Voluntary resignation effective June 30, 2024"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


-- Test: Board member appointment
testCreateAndArchiveStakeholderRelationshipChangeEventBoardMember = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_3"
        legal_name = "Growth Ventures Inc."
        formation_date = DT.time (DA.date 2019 Sep 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  -- Investor becomes board member
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStakeholderRelationshipChangeEvent with
      event_data = StakeholderRelationshipChangeEventOcfData with
        id = "CE_REL_3"
        date = DT.time (DA.date 2024 Jan 15) 0 0 0
        stakeholder_id = "STK_INVESTOR_001"
        relationship_started = Some OcfRelBoardMember
        relationship_ended = None
        comments = ["Series A lead investor appointed to board"]
  submit issuer do
    exerciseCmd cid ArchiveByIssuer
  pure ()
