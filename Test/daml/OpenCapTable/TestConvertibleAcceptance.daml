module OpenCapTable.TestConvertibleAcceptance where

import Fairmint.OpenCapTable.OCF.ConvertibleIssuance
import Fairmint.OpenCapTable.OCF.ConvertibleAcceptance
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Conversion (OcfConvertibleType(..))
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import OpenCapTable.HelpersTriggers (ocfConvTriggerAutomaticOnDate)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Helper to create issuance (needs stakeholder first)
createConvertibleIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = "TX_CONV_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-CONV-1"
        custom_id = "SAFE-001"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = Some "Cash investment"
        security_law_exemptions = []
        investment_amount = OcfMonetary with amount = 100000.0, currency = "USD"
        convertible_type = OcfConvertibleSafe
        conversion_triggers = [ (ocfConvTriggerAutomaticOnDate with trigger_date = Some (DT.time (DA.date 2025 Jan 01) 0 0 0)) ]
        pro_rata = None
        seniority = 1
        comments = []]
      edits = []
      deletes = []

testConvertibleAcceptance_Create = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  result <- createConvertibleIssuance issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleAcceptance ConvertibleAcceptanceOcfData with
        id = "TX_CONV_ACCEPT_1"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        security_id = "SEC-CONV-1"
        comments = []]
      edits = []
      deletes = []
  pure ()

testConvertibleAcceptance_WithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  result <- createConvertibleIssuance issuer capTableCid
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleAcceptance ConvertibleAcceptanceOcfData with
        id = "TX_CONV_ACCEPT_2"
        date = DT.time (DA.date 2024 Jan 03) 0 0 0
        security_id = "SEC-CONV-1"
        comments = ["SAFE agreement countersigned", "Wire transfer confirmed"]]
      edits = []
      deletes = []
  pure ()
