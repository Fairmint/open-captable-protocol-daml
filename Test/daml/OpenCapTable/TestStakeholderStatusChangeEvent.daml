module OpenCapTable.TestStakeholderStatusChangeEvent where

import Fairmint.OpenCapTable.OCF.StakeholderStatusChangeEvent
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import Fairmint.OpenCapTable.OCF.Stakeholder (OcfStakeholderStatusType(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


-- Test: Create and archive status change (termination)
testCreateAndArchiveStakeholderStatusChangeEventTermination = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "ExampleCo Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []
  -- Voluntary termination
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStakeholderStatusChangeEvent with
      event_data = StakeholderStatusChangeEventOcfData with
        id = "CE_STATUS_1"
        date = DT.time (DA.date 2024 Jun 30) 0 0 0
        stakeholder_id = "STK_EMPLOYEE_001"
        new_status = OcfStakeholderStatusTerminationVoluntaryOther
        comments = ["Employee resignation - last day June 30, 2024"]
  submit issuer do
    exerciseCmd cid ArchiveByIssuer
  pure ()


-- Test: Create and archive status change (leave of absence)
testCreateAndArchiveStakeholderStatusChangeEventLeave = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_2"
        legal_name = "TechStart Corp."
        formation_date = DT.time (DA.date 2018 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  -- Leave of absence
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStakeholderStatusChangeEvent with
      event_data = StakeholderStatusChangeEventOcfData with
        id = "CE_STATUS_2"
        date = DT.time (DA.date 2024 Sep 01) 0 0 0
        stakeholder_id = "STK_EMPLOYEE_002"
        new_status = OcfStakeholderStatusLeaveOfAbsence
        comments = ["Medical leave of absence starting September 1, 2024"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


-- Test: Return to active status
testCreateAndArchiveStakeholderStatusChangeEventActive = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_3"
