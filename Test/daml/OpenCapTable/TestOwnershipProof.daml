module OpenCapTable.TestOwnershipProof where

import Daml.Script
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT

import OpenCapTable.Setup
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Core (Context)
import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockCancellation
import Fairmint.OpenCapTableProof.OwnershipAccessProof (OwnershipAccessCredential(..))
import Fairmint.OpenCapTableProof.OwnershipProof
import Fairmint.OpenCapTableProof.PositionIdentity (OwnershipAuthBinding(..), PositionIdentity(..))

-- Note: OwnershipProof needs actual StockIssuance/StockCancellation contract IDs
-- so we create them directly (not via CapTable) for this test

createIssuanceWith issuer system_operator ctx issuanceId securityId stakeholderId quantity customId =
  submit (actAs [issuer, system_operator]) do
    createCmd StockIssuance with
      context = ctx
      issuance_data = StockIssuanceOcfData with
        id = issuanceId
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = securityId
        custom_id = customId
        stakeholder_id = stakeholderId
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON_OWN"
        stock_plan_id = None
        share_numbers_issued = []
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = quantity
        vesting_terms_id = None
        vestings = []
        cost_basis = None
        stock_legend_ids = ["L1"]
        issuance_type = None
        comments = []

createIssuance issuer system_operator ctx =
  createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_1" "SEC-PROOF-1" "SH-PROOF" 100.0 "CERT-PROOF-1"

createCancellationWith issuer system_operator ctx cancellationId securityId quantity =
  submit (actAs [issuer, system_operator]) do
    createCmd StockCancellation with
      context = ctx
      cancellation_data = StockCancellationOcfData with
        id = cancellationId
        date = DT.time (DA.date 2024 Jan 15) 0 0 0
        security_id = securityId
        quantity = quantity
        balance_security_id = None
        reason_text = "Forfeit"
        comments = []

createCancellation issuer system_operator ctx =
  createCancellationWith issuer system_operator ctx "TX_STOCK_CANCEL_PROOF_1" "SEC-PROOF-1" 40.0

mkAccessCredential : Party -> Text -> Text -> Text -> [Party] -> [Party] -> OwnershipAccessCredential
mkAccessCredential owner stakeholderId issuerId securityId audience authorizedVerifiers =
  OwnershipAccessCredential with
    auth_binding = OwnershipAuthBinding with
      position_identity = PositionIdentity with
        owner = owner
        issuer_id = issuerId
        security_id = securityId
      stakeholder_id = stakeholderId
    audience = audience
    authorized_verifiers = authorizedVerifiers

createOwnershipProof :
  Party ->
  Context ->
  OwnershipAccessCredential ->
  Decimal ->
  [ContractId StockIssuance] ->
  [ContractId StockCancellation] ->
  Script (ContractId OwnershipProof)
createOwnershipProof system_operator ctx accessCredential expectedTotal stockIssuances stockCancellations = do
  now <- getTime
  submit system_operator do
    createCmd OwnershipProof with
      context = ctx
      access_credential = accessCredential
      expected_total = expectedTotal
      stock_issuances = stockIssuances
      stock_cancellations = stockCancellations
      created_at = now

testOwnershipProof_Verify_Succeeds = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuance issuer system_operator ctx
  canCid <- createCancellation issuer system_operator ctx
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-1" [alice, issuer] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 60.0 [issCid] [canCid]
  submit system_operator do
    exerciseCmd proofCid (Verify with verifier = system_operator)
  pure ()

testOwnershipProof_Verify_SucceedsForAuthorizedObserver = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuance issuer system_operator ctx
  canCid <- createCancellation issuer system_operator ctx
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-1" [alice, issuer] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 60.0 [issCid] [canCid]
  submit (actAs alice <> readAs [system_operator]) do
    exerciseCmd proofCid (Verify with verifier = alice)
  pure ()

testOwnershipProof_Verify_FailsForUnauthorizedObserver = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuance issuer system_operator ctx
  canCid <- createCancellation issuer system_operator ctx
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-1" [alice, issuer] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 60.0 [issCid] [canCid]
  submitMustFail issuer do
    exerciseCmd proofCid (Verify with verifier = issuer)
  pure ()

