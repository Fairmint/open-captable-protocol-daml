testOwnershipProof_Verify_FailsAcrossMultipleSecurityIds = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCidA <- createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_A" "SEC-PROOF-A" "SH-PROOF" 100.0 "CERT-PROOF-A"
  issCidB <- createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_B" "SEC-PROOF-B" "SH-PROOF" 25.0 "CERT-PROOF-B"
  canCid <- createCancellationWith issuer system_operator ctx "TX_STOCK_CANCEL_PROOF_B" "SEC-PROOF-B" 10.0
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-A" [alice, issuer] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 115.0 [issCidA, issCidB] [canCid]
  submitMustFail system_operator do
    exerciseCmd proofCid (Verify with verifier = system_operator)
  pure ()

testOwnershipProof_Verify_FailsOnStakeholderMismatch = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCidA <- createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_MATCH" "SEC-PROOF-MATCH" "SH-PROOF" 100.0 "CERT-PROOF-MATCH"
  issCidB <- createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_OTHER" "SEC-PROOF-OTHER" "SH-OTHER" 50.0 "CERT-PROOF-OTHER"
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-MATCH" [alice, issuer] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 150.0 [issCidA, issCidB] []
  submitMustFail system_operator do
    exerciseCmd proofCid (Verify with verifier = system_operator)
  pure ()

