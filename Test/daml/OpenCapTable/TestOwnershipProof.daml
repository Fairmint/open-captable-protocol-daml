testOwnershipProof_Verify_FailsOnUnrelatedCancellation = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_RELATED" "SEC-PROOF-RELATED" "SH-PROOF" 100.0 "CERT-PROOF-RELATED"
  _ <- createIssuanceWith issuer system_operator ctx "TX_STOCK_ISS_PROOF_UNRELATED" "SEC-PROOF-UNRELATED" "SH-PROOF" 25.0 "CERT-PROOF-UNRELATED"
  unrelatedCanCid <- createCancellationWith issuer system_operator ctx "TX_STOCK_CANCEL_PROOF_UNRELATED" "SEC-PROOF-UNRELATED" 5.0
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-RELATED" [alice, issuer] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 95.0 [issCid] [unrelatedCanCid]
  submitMustFail system_operator do
    exerciseCmd proofCid (Verify with verifier = system_operator)
  pure ()

testOwnershipProof_RejectsCredentialWithoutOwnerAudience = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuance issuer system_operator ctx
  canCid <- createCancellation issuer system_operator ctx
  let invalidCredential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-1" [issuer] []
  submitMustFail system_operator do
    createCmd OwnershipProof with
      context = ctx
      access_credential = invalidCredential
      expected_total = 60.0
      stock_issuances = [issCid]
      stock_cancellations = [canCid]
      created_at = DT.time (DA.date 2024 Jan 20) 0 0 0
  pure ()

testOwnershipProof_RejectsCredentialWithoutIssuerIdentity = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuance issuer system_operator ctx
  canCid <- createCancellation issuer system_operator ctx
  let invalidCredential = mkAccessCredential alice "SH-PROOF" "" "SEC-PROOF-1" [alice, issuer] [alice]
  submitMustFail system_operator do
    createCmd OwnershipProof with
      context = ctx
      access_credential = invalidCredential
      expected_total = 60.0
      stock_issuances = [issCid]
      stock_cancellations = [canCid]
      created_at = DT.time (DA.date 2024 Jan 20) 0 0 0
  pure ()

testOwnershipProof_AddObserversAndAuthorizedVerifiers = script do
  TestOcp{system_operator, issuer, alice, ctx} <- setupTestOcp
  issCid <- createIssuance issuer system_operator ctx
  canCid <- createCancellation issuer system_operator ctx
  let credential = mkAccessCredential alice "SH-PROOF" "ISSUER-PROOF" "SEC-PROOF-1" [alice] [alice]
  proofCid <- createOwnershipProof system_operator ctx credential 60.0 [issCid] [canCid]
  newProofCid <- submit system_operator do
    exerciseCmd proofCid (AddObservers with added = [issuer])
  newerProofCid <- submit system_operator do
    exerciseCmd newProofCid (AddAuthorizedVerifiers with added = [issuer])
  submit issuer do
    exerciseCmd newerProofCid (Verify with verifier = issuer)
  submit system_operator do
    exerciseCmd newerProofCid Archive
  pure ()

