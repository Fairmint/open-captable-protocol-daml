module OpenCapTable.TestStockPlanPoolAdjustment where
import Fairmint.OpenCapTable.OCF.StockPlan
import Fairmint.OpenCapTable.OCF.StockPlanPoolAdjustment
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submit issuer do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

createStockPlan issuer system_operator ctx =
  submit issuer do
    createCmd StockPlan with
      context = ctx
      plan_data = StockPlanOcfData with
        id = "PLAN_1"
        plan_name = "2024 Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1000.0
        default_cancellation_behavior = None
        stock_class_ids = ["SC_COMMON"]
        comments = []

createPoolAdjustment issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockPlanPoolAdjustment with
      adjustment_data = StockPlanPoolAdjustmentOcfData with
        id = "TX_STOCK_PLAN_POOL_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        stock_plan_id = "PLAN_1"
        board_approval_date = None
        stockholder_approval_date = None
        shares_reserved = 1500.0
        comments = []

testCreateAndArchiveStockPlanPoolAdjustment = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockPlan issuer system_operator ctx
  cid <- createPoolAdjustment issuer capTableCid
  submit issuer do
    archiveCmd cid
  pure ()

testCreateAndArchiveStockPlanPoolAdjustmentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockPlan issuer system_operator ctx
  cid <- createPoolAdjustment issuer capTableCid
  submit issuer do
    exerciseCmd cid Archive
  pure ()

-- Optionals Some
testStockPlanPoolAdjustment_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockPlan issuer system_operator ctx
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockPlanPoolAdjustment with
      adjustment_data = StockPlanPoolAdjustmentOcfData with
        id = "TX_STOCK_PLAN_POOL_ADJ_2"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        stock_plan_id = "PLAN_1"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 03) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 04) 0 0 0)
        shares_reserved = 1750.0
        comments = ["Top up"]
  submit issuer do
    exerciseCmd cid Archive
  pure ()


