module OpenCapTable.TestStockPlanPoolAdjustment where
import Fairmint.OpenCapTable.OCF.StockPlan
import Fairmint.OpenCapTable.OCF.StockPlanPoolAdjustment
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStockClass)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Helper to create stock plan (needs stock class)
createStockPlan issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockPlan with
      plan_data = StockPlanOcfData with
        id = "PLAN_1"
        plan_name = "2024 Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1000.0
        default_cancellation_behavior = None
        stock_class_ids = ["SC_COMMON"]
        comments = []

testCreateStockPlanPoolAdjustment = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStockClass issuer cap_table
  capTableCid <- createStockPlan issuer capTableCid
  _ <- submit issuer do
    exerciseCmd capTableCid CT.AddStockPlanPoolAdjustment with
      adjustment_data = StockPlanPoolAdjustmentOcfData with
        id = "TX_STOCK_PLAN_POOL_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        stock_plan_id = "PLAN_1"
        board_approval_date = None
        stockholder_approval_date = None
        shares_reserved = 1500.0
        comments = []
  pure ()

testStockPlanPoolAdjustment_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStockClass issuer cap_table
  capTableCid <- createStockPlan issuer capTableCid
  _ <- submit issuer do
    exerciseCmd capTableCid CT.AddStockPlanPoolAdjustment with
      adjustment_data = StockPlanPoolAdjustmentOcfData with
        id = "TX_STOCK_PLAN_POOL_ADJ_2"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        stock_plan_id = "PLAN_1"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 03) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 04) 0 0 0)
        shares_reserved = 1750.0
        comments = ["Top up"]
  pure ()
