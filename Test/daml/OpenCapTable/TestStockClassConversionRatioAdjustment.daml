module OpenCapTable.TestStockClassConversionRatioAdjustment where

import Fairmint.OpenCapTable.OCF.StockClass
import Fairmint.OpenCapTable.OCF.StockClassConversionRatioAdjustment
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (defaultStockClass, successorStockClassConversionRightTo)
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Stock (OcfStockClassType(..), OcfRatio(..), OcfInitialSharesAuthorized(..))
import Fairmint.OpenCapTable.Types.Conversion (OcfRatioConversionMechanism(..), OcfRoundingType(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

conversionRatioAdjustment : Text -> Text -> Time -> Decimal -> Decimal -> OcfRoundingType -> StockClassConversionRatioAdjustmentOcfData
conversionRatioAdjustment adjustmentId stockClassId adjustmentDate conversionPrice numerator roundingType =
  StockClassConversionRatioAdjustmentOcfData with
    id = adjustmentId
    date = adjustmentDate
    stock_class_id = stockClassId
    new_ratio_conversion_mechanism = OcfRatioConversionMechanism with
      conversion_price = OcfMonetary with amount = conversionPrice, currency = "USD"
      ratio = OcfRatio with numerator = numerator, denominator = 1.0
      rounding_type = roundingType
    comments = []


-- Test: Create and archive conversion ratio adjustment (anti-dilution scenario)
testCreateAndArchiveStockClassConversionRatioAdjustment = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClass (defaultStockClass "SC_COMMON_FOR_SERIES_A")
        , CT.OcfCreateStockClass StockClassOcfData with
        id = "SC_SERIES_A"
        name = "Series A Preferred"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "SA-"
        initial_shares_authorized = OcfInitialSharesNumeric 2_000_000.0
        votes_per_share = 1.0
        seniority = 2.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = Some (OcfMonetary with amount = 1.00; currency = "USD")
        liquidation_preference_multiple = Some 1.0
        participation_cap_multiple = None
        conversion_rights = [successorStockClassConversionRightTo "SC_COMMON_FOR_SERIES_A"]
        comments = []]
      edits = []
      deletes = []
  -- Anti-dilution adjustment: down-round triggered broad-based weighted average adjustment
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClassConversionRatioAdjustment StockClassConversionRatioAdjustmentOcfData with
        id = "TX_CONV_RATIO_ADJ_1"
        date = DT.time (DA.date 2024 Mar 15) 0 0 0
        stock_class_id = "SC_SERIES_A"
        new_ratio_conversion_mechanism = OcfRatioConversionMechanism with
          conversion_price = OcfMonetary with amount = 0.75; currency = "USD"
          ratio = OcfRatio with numerator = 1.333; denominator = 1.0
          rounding_type = OcfRoundingFloor
        comments = ["Down-round triggered broad-based weighted average anti-dilution adjustment"]]
      edits = []
      deletes = []
  pure ()


-- Test: Create and archive with Archive choice (both signatories)
testCreateAndArchiveStockClassConversionRatioAdjustmentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClass (defaultStockClass "SC_COMMON_FOR_SERIES_B")
        , CT.OcfCreateStockClass StockClassOcfData with
        id = "SC_SERIES_B"
        name = "Series B Preferred"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "SB-"
        initial_shares_authorized = OcfInitialSharesNumeric 5_000_000.0
        votes_per_share = 1.0
        seniority = 3.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = Some (OcfMonetary with amount = 2.50; currency = "USD")
        liquidation_preference_multiple = Some 1.0
        participation_cap_multiple = None
        conversion_rights = [successorStockClassConversionRightTo "SC_COMMON_FOR_SERIES_B"]
        comments = []]
      edits = []
      deletes = []
  -- Full ratchet anti-dilution adjustment
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClassConversionRatioAdjustment StockClassConversionRatioAdjustmentOcfData with
        id = "TX_CONV_RATIO_ADJ_2"
        date = DT.time (DA.date 2024 Sep 20) 0 0 0
        stock_class_id = "SC_SERIES_B"
        new_ratio_conversion_mechanism = OcfRatioConversionMechanism with
          conversion_price = OcfMonetary with amount = 1.50; currency = "USD"
          ratio = OcfRatio with numerator = 1.667; denominator = 1.0
          rounding_type = OcfRoundingNormal
        comments = ["Full ratchet anti-dilution protection triggered by Series C down-round"]]
      edits = []
      deletes = []
  pure ()

testStockClassConversionRatioAdjustmentRequiresRatioRight = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let stockClassId = "SC_RATIO_ADJUSTMENT_WITHOUT_RIGHT"
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClass (defaultStockClass stockClassId)]
      edits = []
      deletes = []

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassConversionRatioAdjustment
            (conversionRatioAdjustment "TX_RATIO_ADJUSTMENT_WITHOUT_RIGHT" stockClassId (DT.time (DA.date 2024 Jan 01) 0 0 0) 0.75 1.333 OcfRoundingFloor)
        ]
      edits = []
      deletes = []

testStockClassConversionRatioAdjustmentMissingTargetFails = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  submitMustFail issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassConversionRatioAdjustment
            (conversionRatioAdjustment "TX_RATIO_ADJUSTMENT_MISSING_TARGET" "SC_RATIO_ADJUSTMENT_MISSING" (DT.time (DA.date 2024 Jan 01) 0 0 0) 0.75 1.333 OcfRoundingFloor)
        ]
      edits = []
      deletes = []

testStockClassConversionRatioAdjustmentTargetEditUsesFinalState = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let commonClassId = "SC_RATIO_ADJUSTMENT_EDIT_COMMON"
  let sourceClassId = "SC_RATIO_ADJUSTMENT_EDIT_SOURCE"
  let sourceClass = (defaultStockClass sourceClassId) with
        conversion_rights = [successorStockClassConversionRightTo commonClassId]
  let adjustmentId = "TX_RATIO_ADJUSTMENT_EDIT"
  let adjustment = conversionRatioAdjustment adjustmentId sourceClassId (DT.time (DA.date 2024 Jan 01) 0 0 0) 0.75 1.333 OcfRoundingFloor

  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClass (defaultStockClass commonClassId)
        , CT.OcfCreateStockClass sourceClass
        , CT.OcfCreateStockClassConversionRatioAdjustment adjustment
        ]
      edits = []
      deletes = []

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStockClass (sourceClass with conversion_rights = [])]
      deletes = []

  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStockClass (sourceClass with conversion_rights = [])]
      deletes = [CT.OcfDeleteStockClassConversionRatioAdjustment adjustmentId]
  pure ()

testSameOcfDateRatioAdjustmentsCompareFullMechanism = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  let commonClassId = "SC_RATIO_MECHANISM_COMMON"
  let sourceClassId = "SC_RATIO_MECHANISM_SOURCE"
  let sourceClass = (defaultStockClass sourceClassId) with
        conversion_rights = [successorStockClassConversionRightTo commonClassId]
  let morning = DT.time (DA.date 2024 Jan 01) 9 0 0
  let evening = DT.time (DA.date 2024 Jan 01) 17 0 0

  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClass (defaultStockClass commonClassId)
        , CT.OcfCreateStockClass sourceClass
        ]
      edits = []
      deletes = []

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockClassConversionRatioAdjustment
            (conversionRatioAdjustment "TX_RATIO_MECHANISM_FIRST" sourceClassId morning 0.75 2.0 OcfRoundingFloor)
        , CT.OcfCreateStockClassConversionRatioAdjustment
            (conversionRatioAdjustment "TX_RATIO_MECHANISM_SECOND" sourceClassId evening 0.50 2.0 OcfRoundingFloor)
        ]
      edits = []
      deletes = []
