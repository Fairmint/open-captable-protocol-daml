module OpenCapTable.TestStockClassConversionRatioAdjustment where

import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.StockClassConversionRatioAdjustment
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import Fairmint.OpenCapTable.Types (OcfStockClassType(..), OcfRatioConversionMechanism(..), OcfRatio(..), OcfMonetary(..), OcfRoundingType(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


-- Test: Create and archive conversion ratio adjustment (anti-dilution scenario)
testCreateAndArchiveStockClassConversionRatioAdjustment = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "ExampleCo Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []
  _ <- submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = StockClassOcfData with
        id = "SC_SERIES_A"
        name = "Series A Preferred"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "SA-"
        initial_shares_authorized = 2_000_000.0
        votes_per_share = 1.0
        seniority = 2.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = Some (OcfMonetary with amount = 1.00; currency = "USD")
        liquidation_preference_multiple = Some 1.0
        participation_cap_multiple = None
        conversion_rights = []
        comments = []
  -- Anti-dilution adjustment: down-round triggered broad-based weighted average adjustment
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClassConversionRatioAdjustment with
      adjustment_data = StockClassConversionRatioAdjustmentOcfData with
        id = "TX_CONV_RATIO_ADJ_1"
        date = DT.time (DA.date 2024 Mar 15) 0 0 0
        stock_class_id = "SC_SERIES_A"
        new_ratio_conversion_mechanism = OcfRatioConversionMechanism with
          conversion_price = OcfMonetary with amount = 0.75; currency = "USD"
          ratio = OcfRatio with numerator = 1.333; denominator = 1.0
          rounding_type = OcfRoundingFloor
        comments = ["Down-round triggered broad-based weighted average anti-dilution adjustment"]
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.StockClassConversionRatioAdjustment.ArchiveByIssuer
  pure ()


-- Test: Create and archive with Archive choice (both signatories)
testCreateAndArchiveStockClassConversionRatioAdjustmentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_2"
        legal_name = "TechStart Corp."
        formation_date = DT.time (DA.date 2018 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  _ <- submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = StockClassOcfData with
        id = "SC_SERIES_B"
        name = "Series B Preferred"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "SB-"
        initial_shares_authorized = 5_000_000.0
        votes_per_share = 1.0
        seniority = 3.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = Some (OcfMonetary with amount = 2.50; currency = "USD")
        liquidation_preference_multiple = Some 1.0
        participation_cap_multiple = None
        conversion_rights = []
        comments = []
  -- Full ratchet anti-dilution adjustment
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClassConversionRatioAdjustment with
      adjustment_data = StockClassConversionRatioAdjustmentOcfData with
        id = "TX_CONV_RATIO_ADJ_2"
        date = DT.time (DA.date 2024 Sep 20) 0 0 0
        stock_class_id = "SC_SERIES_B"
        new_ratio_conversion_mechanism = OcfRatioConversionMechanism with
          conversion_price = OcfMonetary with amount = 1.50; currency = "USD"
          ratio = OcfRatio with numerator = 1.667; denominator = 1.0
          rounding_type = OcfRoundingNormal
        comments = ["Full ratchet anti-dilution protection triggered by Series C down-round"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
