module OpenCapTable.TestEquityCompensationRepricing where

import Fairmint.OpenCapTable.EquityCompensationRepricing
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


-- Test: Create and archive option repricing (underwater options)
testCreateAndArchiveEquityCompensationRepricing = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_1"
        legal_name = "ExampleCo Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []
  -- Repricing underwater options due to market downturn
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationRepricing with
      repricing_data = OcfEquityCompensationRepricingTxData with
        id = "TX_EC_REPRICE_1"
        date = DT.time (DA.date 2024 Feb 15) 0 0 0
        security_id = "SEC_OPT_001"
        new_exercise_price = OcfMonetary with amount = 15.00; currency = "USD"
        comments = ["Board-approved repricing program for underwater options", "Original exercise price was $35.00, current FMV is $18.00"]
  submit issuer do
    exerciseCmd cid ArchiveByIssuer
  pure ()


-- Test: Create and archive with Archive choice
testCreateAndArchiveEquityCompensationRepricingBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_2"
        legal_name = "TechStart Corp."
        formation_date = DT.time (DA.date 2018 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  -- Retention repricing for key employee
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationRepricing with
      repricing_data = OcfEquityCompensationRepricingTxData with
        id = "TX_EC_REPRICE_2"
        date = DT.time (DA.date 2024 Aug 01) 0 0 0
        security_id = "SEC_OPT_002"
        new_exercise_price = OcfMonetary with amount = 8.50; currency = "USD"
        comments = ["Retention repricing for key employee per Board resolution dated July 25, 2024"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
