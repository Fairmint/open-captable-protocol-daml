  _ <- createStockIssuanceWith issuer result.updatedCapTableCid ((defaultStockIssuance "TX_RETRACTION_REISSUE" "SEC_RETRACTION_REISSUE" stakeholderId stockClassId) with quantity = 100.0)
  pure ()

