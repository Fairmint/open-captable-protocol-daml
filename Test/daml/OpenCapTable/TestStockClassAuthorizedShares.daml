        unknownPartialIssuance.security_id
        None
        ["SEC-CONVERTIBLE-UNIT-UNKNOWN-RESULT"]) with
          balance_security_id = Some "CONV-CONVERTIBLE-UNIT-UNKNOWN-BALANCE"
  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateConvertibleIssuance unknownPartialIssuance
        , CT.OcfCreateConvertibleConversion unknownPartialConversion
        ]
      edits = []
      deletes = []

testRatioConvertibleConversionEnforcesCeiling = script do
