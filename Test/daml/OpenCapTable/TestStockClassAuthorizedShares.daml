testStockConversionReducesIssuedSharesForCeiling = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  (capTableWithDestination, destinationClassId) <- setupStockClassWith issuer cap_table (limitedStockClass "SC_CONVERSION_DEST" 100.0)
  let sourceClassId = "SC_CONVERSION"
  let sourceClass = (limitedStockClass sourceClassId 100.0) with
        conversion_rights = [stockClassConversionRightTo destinationClassId]
  (capTableWithClass, stockClassId) <- setupStockClassWith issuer capTableWithDestination sourceClass
  (capTableReady, stakeholderId) <- setupStakeholderWithId issuer capTableWithClass "SH_CONVERSION" "Conversion Holder"
  capTableIssued <- createStockIssuanceWith issuer capTableReady ((defaultStockIssuance "TX_CONVERSION_ISSUED" "SEC_CONVERSION_ISSUED" stakeholderId stockClassId) with quantity = 100.0)
  result <- submit issuer do
    exerciseCmd capTableIssued CT.UpdateCapTable with
