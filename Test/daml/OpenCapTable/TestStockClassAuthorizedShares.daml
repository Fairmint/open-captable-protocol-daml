      deletes = []

testClasslessCashSettledSarExerciseAllowsNoStockOutput = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  (capTableWithClass, stockClassId) <- setupStockClassWith issuer cap_table (limitedStockClass "SC_CASH_SETTLED_SAR" 100.0)
