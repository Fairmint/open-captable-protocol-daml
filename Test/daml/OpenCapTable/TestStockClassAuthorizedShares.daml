        exercise_triggers = [warrantFixedExerciseTrigger "TRIGGER_FIXED_REMAINDER" stockClassId 1_000.0]
  issued <- submit issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates = [CT.OcfCreateWarrantIssuance issuance]
      edits = []
      deletes = []

