module OpenCapTable.TestStockLegendTemplate where
import Fairmint.OpenCapTable.OCF.StockLegendTemplate
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import Daml.Script

testCreateStockLegendTemplate = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.CreateStockLegendTemplate with
      template_data = StockLegendTemplateOcfData with
        id = "LEG_STD"
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = []
  pure ()

testCreateAndDeleteStockLegendTemplate = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.CreateStockLegendTemplate with
      template_data = StockLegendTemplateOcfData with
        id = "LEG_STD"
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = []
  _ <- submit issuer do
    exerciseCmd capTableCid CT.DeleteStockLegendTemplate with
      id = "LEG_STD"
  pure ()

testStockLegendTemplate_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  _ <- submit issuer do
    exerciseCmd cap_table CT.CreateStockLegendTemplate with
      template_data = StockLegendTemplateOcfData with
        id = "LEG_EXT"
        name = "Extended Legend"
        text = "EXTENDED LEGEND TEXT"
        comments = ["Longer legend text"]
  pure ()

testEditStockLegendTemplate = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.CreateStockLegendTemplate with
      template_data = StockLegendTemplateOcfData with
        id = "LEG_EDIT"
        name = "Original Legend"
        text = "ORIGINAL TEXT"
        comments = []
  _ <- submit issuer do
    exerciseCmd capTableCid CT.EditStockLegendTemplate with
      id = "LEG_EDIT"
      new_template_data = StockLegendTemplateOcfData with
        id = "LEG_EDIT"
        name = "Updated Legend"
        text = "UPDATED TEXT"
        comments = ["Updated"]
  pure ()
