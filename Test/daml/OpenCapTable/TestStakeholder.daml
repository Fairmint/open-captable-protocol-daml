module OpenCapTable.TestStakeholder where

import Fairmint.OpenCapTable.OCF.Stakeholder
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import OpenCapTable.TestHelpers
import Daml.Script

-- Test creating and deleting a stakeholder using helpers
testCreateAndDeleteStakeholder = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  -- Add stakeholder using helper
  (cap_table', stakeholderId) <- setupStakeholderWithId issuer cap_table "STKH_Alice" "Alice"

  -- Delete via CapTable batch
  _ <- submit issuer do
    exerciseCmd cap_table' CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteStakeholder stakeholderId]
  pure ()

-- Test creating a stakeholder with all optional fields populated
testStakeholder_OptionalsSome = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  let bobName = OcfName with legal_name = "Bob", first_name = Some "Robert", last_name = Some "Builder"
  let primary = OcfContactInfo with name = bobName, phone_numbers = [], emails = [OcfEmail with email_type = OcfEmailTypeBusiness, email_address = "bob@example.com"]
  let contact = OcfContactInfoWithoutName with phone_numbers = [], emails = [OcfEmail with email_type = OcfEmailTypePersonal, email_address = "bob.personal@example.com"]

  -- Create stakeholder with all optional fields
  let stakeholderData = (defaultStakeholder "STKH_Bob" "Bob") with
        name = bobName
        issuer_assigned_id = Some "EMP-001"
        current_relationships = [OcfRelEmployee]
        current_status = Some OcfStakeholderStatusActive
        primary_contact = Some primary
        contact_info = Some contact
        addresses = [OcfAddress with address_type = OcfAddressTypeLegal, street_suite = Some "2 Main St", city = Some "SF", country_subdivision = Some "CA", country = "US", postal_code = Some "94105"]
        tax_ids = [OcfTaxID with tax_id = "999-99-9999", country = "US"]
        comments = ["VIP"]

  (cap_table', stakeholderId) <- setupStakeholderWith issuer cap_table stakeholderData

  -- Delete via CapTable batch
  _ <- submit issuer do
    exerciseCmd cap_table' CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteStakeholder stakeholderId]
  pure ()

-- Test editing a stakeholder
testEditStakeholder = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  -- Add stakeholder using helper with default data
  let originalData = defaultStakeholder "STKH_Edit" "Original Name"
  (cap_table', stakeholderId) <- setupStakeholderWith issuer cap_table originalData

  -- Edit stakeholder via batch
  _ <- submit issuer do
    exerciseCmd cap_table' CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStakeholder (originalData with
          name = OcfName with legal_name = "Updated Name", first_name = None, last_name = None
          issuer_assigned_id = Some "EMP-002"
          current_relationships = [OcfRelEmployee]
          current_status = Some OcfStakeholderStatusActive
          comments = ["Updated"])]
      deletes = []
  pure ()

-- Test batch operations with multiple creates in one transaction
testBatchCreateMultipleStakeholders = script do
  TestOcp{issuer, cap_table} <- setupTestOcp

  -- Create multiple stakeholders in a single batch using default factories
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder (defaultStakeholder "STKH_1" "Stakeholder 1")
        , CT.OcfCreateStakeholder (defaultStakeholder "STKH_2" "Stakeholder 2")
        , CT.OcfCreateStakeholder ((defaultStakeholder "STKH_3" "Stakeholder 3") with stakeholder_type = OcfStakeholderTypeInstitution)
        ]
      edits = []
      deletes = []

  -- Verify we got 3 created contract IDs back using assertion helper
  assertCreatedCount 3 result
