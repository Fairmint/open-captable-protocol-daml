module OpenCapTable.TestStakeholder where
import Fairmint.OpenCapTable.OCF.Stakeholder
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import Daml.Script

testCreateAndDeleteStakeholder = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add stakeholder via CapTable batch
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "STKH_Alice"
        name = OcfName with legal_name = "Alice", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
  -- Delete via CapTable batch
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteStakeholder "STKH_Alice"]
  pure ()

testStakeholder_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let bobName = OcfName with legal_name = "Bob", first_name = Some "Robert", last_name = Some "Builder"
  let primary = OcfContactInfo with name = bobName, phone_numbers = [], emails = [OcfEmail with email_type = OcfEmailTypeBusiness, email_address = "bob@example.com"]
  let contact = OcfContactInfoWithoutName with phone_numbers = [], emails = [OcfEmail with email_type = OcfEmailTypePersonal, email_address = "bob.personal@example.com"]
  -- Add stakeholder with all optional fields via CapTable batch
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "STKH_Bob"
        name = bobName
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = Some "EMP-001"
        current_relationships = [OcfRelEmployee]
        current_status = Some OcfStakeholderStatusActive
        primary_contact = Some primary
        contact_info = Some contact
        addresses = [OcfAddress with address_type = OcfAddressTypeLegal, street_suite = Some "2 Main St", city = Some "SF", country_subdivision = Some "CA", country = "US", postal_code = Some "94105"]
        tax_ids = [OcfTaxID with tax_id = "999-99-9999", country = "US"]
        comments = ["VIP"]]
      edits = []
      deletes = []
  -- Delete via CapTable batch
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = []
      deletes = [CT.OcfDeleteStakeholder "STKH_Bob"]
  pure ()

testEditStakeholder = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add stakeholder via batch
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates = [CT.OcfCreateStakeholder StakeholderOcfData with
        id = "STKH_Edit"
        name = OcfName with legal_name = "Original Name", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []]
      edits = []
      deletes = []
  -- Edit stakeholder via batch
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = []
      edits = [CT.OcfEditStakeholder StakeholderOcfData with
          id = "STKH_Edit"
          name = OcfName with legal_name = "Updated Name", first_name = None, last_name = None
          stakeholder_type = OcfStakeholderTypeIndividual
          issuer_assigned_id = Some "EMP-002"
          current_relationships = [OcfRelEmployee]
          current_status = Some OcfStakeholderStatusActive
          primary_contact = None
          contact_info = None
          addresses = []
          tax_ids = []
          comments = ["Updated"]]
      deletes = []
  pure ()

-- Test batch operations with multiple creates in one transaction
testBatchCreateMultipleStakeholders = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Create multiple stakeholders in a single batch
  result <- submit issuer do
    exerciseCmd cap_table CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStakeholder StakeholderOcfData with
            id = "STKH_1"
            name = OcfName with legal_name = "Stakeholder 1", first_name = None, last_name = None
            stakeholder_type = OcfStakeholderTypeIndividual
            issuer_assigned_id = None
            current_relationships = []
            current_status = None
            primary_contact = None
            contact_info = None
            addresses = []
            tax_ids = []
            comments = []
        , CT.OcfCreateStakeholder StakeholderOcfData with
            id = "STKH_2"
            name = OcfName with legal_name = "Stakeholder 2", first_name = None, last_name = None
            stakeholder_type = OcfStakeholderTypeIndividual
            issuer_assigned_id = None
            current_relationships = []
            current_status = None
            primary_contact = None
            contact_info = None
            addresses = []
            tax_ids = []
            comments = []
        , CT.OcfCreateStakeholder StakeholderOcfData with
            id = "STKH_3"
            name = OcfName with legal_name = "Stakeholder 3", first_name = None, last_name = None
            stakeholder_type = OcfStakeholderTypeInstitution
            issuer_assigned_id = None
            current_relationships = []
            current_status = None
            primary_contact = None
            contact_info = None
            addresses = []
            tax_ids = []
            comments = []
        ]
      edits = []
      deletes = []
  -- Verify we got 3 created contract IDs back
  assert (length result.createdCids == 3)
