module OpenCapTable.TestEquityCompensationTransfer where

import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance
import Fairmint.OpenCapTable.OCF.EquityCompensationTransfer
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Vesting (OcfCompensationType(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Create an equity compensation issuance to transfer (follows real workflow)
createEquityCompensationIssuance issuer capTableCid securityId quantity issuanceDate =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationIssuance EquityCompensationIssuanceOcfData with
        id = "TX_EQUITY_COMP_ISS_" <> securityId
        date = issuanceDate
        security_id = securityId
        custom_id = "OPT-1"
        stakeholder_id = "SH-1"
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = quantity
        comments = []
        security_law_exemptions = []
        vestings = []
        termination_exercise_windows = []
        board_approval_date = None
        consideration_text = None
        base_price = None
        exercise_price = Some (OcfMonetary with amount = 0.50, currency = "USD")
        early_exercisable = None
        expiration_date = Some (DT.time (DA.date 2032 Jan 15) 0 0 0)
        stock_class_id = None
        stock_plan_id = None
        vesting_terms_id = None
        stockholder_approval_date = None]
      edits = []
      deletes = []

-- Test: NSO transfer to family trust for estate planning
-- No prod/dev examples (options typically non-transferable except NSOs to trusts)
-- Extrapolated from stock transfer pattern
testEquityCompensationTransfer_NSOToFamilyTrust = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let securityId = "ESEC-NSO-001"
  result <- createEquityCompensationIssuance issuer capTableCid securityId 10000.0 (DT.time (DA.date 2022 Jan 15) 0 0 0)
  let transferDate = DT.time (DA.date 2025 Jun 01) 0 0 0
  balanceResult <- createEquityCompensationIssuance issuer result.updatedCapTableCid "ESEC-NSO-REMAIN" 5000.0 transferDate
  _ <- submit issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationTransfer EquityCompensationTransferOcfData with
        id = "TX_EQUITY_COMP_TRANSFER_1"
        date = transferDate
        quantity = 5000.0
        security_id = securityId
        resulting_security_ids = ["ESEC-NSO-TRANSFERRED-001"]
        comments = ["NSO transfer to family trust per company approval"]
        balance_security_id = Some "ESEC-NSO-REMAIN"
        consideration_text = Some "Transfer of 5,000 NSOs to family trust for estate planning."]
      edits = []
      deletes = []
  pure ()

-- Test: Full NSO transfer with no balance
testEquityCompensationTransfer_FullTransfer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let securityId = "ESEC-NSO-FULL"
  result <- createEquityCompensationIssuance issuer capTableCid securityId 2500.0 (DT.time (DA.date 2022 Jan 15) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationTransfer EquityCompensationTransferOcfData with
        id = "TX_EQUITY_COMP_TRANSFER_FULL"
        date = DT.time (DA.date 2025 Sep 15) 0 0 0
        quantity = 2500.0
        security_id = securityId
        resulting_security_ids = ["ESEC-NSO-NEWHOLDER"]
        comments = ["Full NSO grant transferred to irrevocable trust"]
        balance_security_id = None
        consideration_text = Some "Transfer of entire NSO grant to irrevocable trust per estate planning documents."]
      edits = []
      deletes = []
  pure ()

-- Test: Transfer with multiple comments documenting approval chain
testEquityCompensationTransfer_WithApprovalComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  let securityId = "ESEC-NSO-APPROVAL"
  result <- createEquityCompensationIssuance issuer capTableCid securityId 15000.0 (DT.time (DA.date 2022 Jan 15) 0 0 0)
  let transferDate = DT.time (DA.date 2025 Nov 01) 0 0 0
  balanceResult <- createEquityCompensationIssuance issuer result.updatedCapTableCid "ESEC-NSO-REMAINING" 7000.0 transferDate
  _ <- submit issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateEquityCompensationTransfer EquityCompensationTransferOcfData with
        id = "TX_EQUITY_COMP_TRANSFER_APPROVED"
        date = transferDate
        quantity = 8000.0
        security_id = securityId
        resulting_security_ids = ["ESEC-NSO-TRUST"]
        comments =
          [ "Transfer approved by Board on 2025-10-15"
          , "Transfer approved by Compensation Committee on 2025-10-20"
          , "Transferee: Smith Family Irrevocable Trust dated 2020-03-01"
          ]
        balance_security_id = Some "ESEC-NSO-REMAINING"
        consideration_text = None]
      edits = []
      deletes = []
  pure ()
