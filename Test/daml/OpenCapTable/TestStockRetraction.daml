module OpenCapTable.TestStockRetraction where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockRetraction
import qualified Fairmint.OpenCapTable.OCF.StockRetraction as SR
import Fairmint.OpenCapTable.OCF.StockClass
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


createStockClass issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockClass with
      stock_class_data = StockClassOcfData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []

createStockIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockIssuance with
      issuance_data = StockIssuanceOcfData with
        id = "TX_STOCK_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-STOCK-1"
        custom_id = "CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        stock_plan_id = None
        share_numbers_issued = []
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = 100.0
        vesting_terms_id = None
        vestings = []
        cost_basis = None
        stock_legend_ids = ["L1"]
        issuance_type = None
        comments = []

createStockRetraction issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockRetraction with
      retraction_data = StockRetractionOcfData with
        id = "TX_STOCK_RETRACT_1"
        date = DT.time (DA.date 2024 Jan 02) 0 0 0
        security_id = "SEC-STOCK-1"
        reason_text = "Administrative error - incorrect share count recorded"
        comments = []

testStockRetraction_CreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockClass issuer cap_table
  _ <- createStockIssuance issuer capTableCid
  cid <- createStockRetraction issuer capTableCid

  pure ()

testStockRetraction_CreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockClass issuer cap_table
  _ <- createStockIssuance issuer capTableCid
  cid <- createStockRetraction issuer capTableCid

  pure ()

-- Test with comments (non-empty array)
testStockRetraction_WithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockClass issuer cap_table
  _ <- createStockIssuance issuer capTableCid
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockRetraction with
      retraction_data = StockRetractionOcfData with
        id = "TX_STOCK_RETRACT_2"
        date = DT.time (DA.date 2024 Jan 03) 0 0 0
        security_id = "SEC-STOCK-1"
        reason_text = "Issuance void ab initio due to failed consideration"
        comments = ["Board resolution 2024-003", "Legal counsel reviewed"]

  pure ()
