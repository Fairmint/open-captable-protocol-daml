module OpenCapTable.TestWarrantCancellation where
import Fairmint.OpenCapTable.WarrantIssuance
import Fairmint.OpenCapTable.WarrantCancellation
import qualified Fairmint.OpenCapTable.WarrantCancellation as WC
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import OpenCapTable.HelpersTriggers (ocfTriggerElectiveAtWill)
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []

-- Create a warrant issuance to cancel (follows real workflow)
createWarrantIssuance issuer issuerCid securityId quantity =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateWarrantIssuance with
      issuance_data = OcfWarrantIssuanceData with
        id = "TX_WARRANT_ISS_1"
        date = DT.time (DA.date 2023 Jun 01) 0 0 0
        security_id = securityId
        custom_id = "W-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        quantity = Some quantity
        quantity_source = None
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        purchase_price = OcfMonetary with amount = 0.0, currency = "USD"
        exercise_triggers = [ ocfTriggerElectiveAtWill ]
        warrant_expiration_date = None
        vesting_terms_id = None
        vestings = []
        comments = []

-- Create cancellation based on realistic data pattern
createWarrantCancellation issuer issuerCid securityId quantity =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateWarrantCancellation with
      cancellation_data = OcfWarrantCancellationTxData with
        id = "TX_WARRANT_CANCEL_1"
        date = DT.time (DA.date 2024 Mar 15) 0 0 0
        security_id = securityId
        quantity = quantity
        reason_text = "Warrant expiration - unexercised"
        balance_security_id = None
        comments = []

-- Basic create and archive by issuer (single signer)
testWarrantCancellation_CreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "WSEC-001"
  _ <- createWarrantIssuance issuer issuerCid securityId 50000.0
  cid <- createWarrantCancellation issuer issuerCid securityId 50000.0
  submit issuer do
    exerciseCmd cid WC.ArchiveByIssuer
  pure ()

-- Archive with built-in choice (requires both signatories)
testWarrantCancellation_CreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "WSEC-002"
  _ <- createWarrantIssuance issuer issuerCid securityId 100000.0
  cid <- createWarrantCancellation issuer issuerCid securityId 100000.0
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Partial cancellation with optional fields populated
testWarrantCancellation_PartialWithOptionals = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  let securityId = "WSEC-PARTIAL"
  _ <- createWarrantIssuance issuer issuerCid securityId 75000.0
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateWarrantCancellation with
      cancellation_data = OcfWarrantCancellationTxData with
        id = "TX_WARRANT_CANCEL_PARTIAL"
        date = DT.time (DA.date 2024 Jun 30) 0 0 0
        security_id = securityId
        quantity = 25000.0
        reason_text = "Partial cancellation per warrant amendment agreement"
        balance_security_id = Some "WSEC-PARTIAL-BAL"
        comments = ["Partial cancellation approved by board", "Remaining warrants: 50,000"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

