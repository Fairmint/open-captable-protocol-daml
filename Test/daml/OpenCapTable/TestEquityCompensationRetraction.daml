module OpenCapTable.TestEquityCompensationRetraction where

import Fairmint.OpenCapTable.EquityCompensationIssuance
import Fairmint.OpenCapTable.EquityCompensationRetraction
import qualified Fairmint.OpenCapTable.EquityCompensationRetraction as ER
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []

createEquityCompensationIssuance issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationIssuance with
      issuance_data = OcfEquityCompensationIssuanceTxData with
        id = "TX_EC_ISS_1"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "SEC-OPTION-1"
        custom_id = "OPT-001"
        stakeholder_id = "SH-EMPLOYEE-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = Some "Services rendered"
        security_law_exemptions = []
        stock_plan_id = Some "SP_2024"
        stock_class_id = Some "SC_COMMON"
        compensation_type = OcfCompensationTypeOptionISO
        quantity = 10000.0
        exercise_price = Some (OcfMonetary with amount = 0.50, currency = "USD")
        base_price = None
        vesting_terms_id = None
        vestings = []
        expiration_date = None
        termination_exercise_windows = []
        early_exercisable = None
        comments = []

createEquityCompensationRetraction issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationRetraction with
      retraction_data = OcfEquityCompensationRetractionTxData with
        id = "TX_EC_RETRACT_1"
        date = DT.time (DA.date 2024 Feb 02) 0 0 0
        security_id = "SEC-OPTION-1"
        reason_text = "Administrative error - incorrect vesting schedule recorded"
        comments = []

testEquityCompensationRetraction_CreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createEquityCompensationIssuance issuer issuerCid
  cid <- createEquityCompensationRetraction issuer issuerCid
  submit issuer do
    exerciseCmd cid ER.ArchiveByIssuer
  pure ()

testEquityCompensationRetraction_CreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createEquityCompensationIssuance issuer issuerCid
  cid <- createEquityCompensationRetraction issuer issuerCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Test with comments (non-empty array)
testEquityCompensationRetraction_WithComments = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createEquityCompensationIssuance issuer issuerCid
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationRetraction with
      retraction_data = OcfEquityCompensationRetractionTxData with
        id = "TX_EC_RETRACT_2"
        date = DT.time (DA.date 2024 Feb 03) 0 0 0
        security_id = "SEC-OPTION-1"
        reason_text = "Grant void ab initio - employee never started"
        comments = ["HR confirmed no start date", "Board resolution 2024-006"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
