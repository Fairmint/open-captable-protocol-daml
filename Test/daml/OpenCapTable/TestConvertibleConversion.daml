module OpenCapTable.TestConvertibleConversion where

import Fairmint.OpenCapTable.OCF.ConvertibleIssuance (ConvertibleIssuanceOcfData(..), OcfConvertibleConversionTrigger(..))
import Fairmint.OpenCapTable.OCF.ConvertibleConversion
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import Fairmint.OpenCapTable.Types.Conversion (OcfConversionTriggerType(..), OcfConvertibleConversionRight(..), OcfConvertibleConversionMechanism(..), OcfSAFEConversionMechanism(..), OcfConvertibleType(..), OcfCapitalizationDefinition(..))
import Fairmint.OpenCapTable.Types.Stock (OcfStockClassType(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites, defaultStockClass, defaultStockPlan, stockSuccessorIssuance)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

addPreferredStockClass : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addPreferredStockClass issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockClass ((defaultStockClass "SC_PREFERRED") with
        name = "Series Seed Preferred"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "PS-"
        seniority = 2.0)]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

addConversionStockPlan : Party -> ContractId CT.CapTable -> Script (ContractId CT.CapTable)
addConversionStockPlan issuer capTableCid = do
  result <- submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockPlan (defaultStockPlan "ESOP-2024" "SC_COMMON")]
      edits = []
      deletes = []
  pure result.updatedCapTableCid

-- Create a convertible issuance to convert (follows real workflow)
createConvertibleIssuanceWithTargetClass issuer capTableCid securityId amount issuanceDate targetStockClassId =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateConvertibleIssuance ConvertibleIssuanceOcfData with
        id = "TX_CONV_ISS_" <> securityId
        date = issuanceDate
        security_id = securityId
        custom_id = "SAFE-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        convertible_type = OcfConvertibleSafe
        investment_amount = OcfMonetary with amount = amount, currency = "USD"
        conversion_triggers = [OcfConvertibleConversionTrigger with
          conversion_right = OcfConvertibleConversionRight with
            conversion_mechanism = OcfConvMechSAFE (OcfSAFEConversionMechanism with
              capitalization_definition = None
              capitalization_definition_rules = None
              conversion_discount = Some 0.20
              conversion_mfn = False
              conversion_timing = None
              conversion_valuation_cap = Some (OcfMonetary with amount = 16000000.0, currency = "USD")
              exit_multiple = None)
            converts_to_future_round = case targetStockClassId of
              Some _ -> None
              None -> Some True
            converts_to_stock_class_id = targetStockClassId
            type_ = "CONVERTIBLE_CONVERSION_RIGHT"
          end_date = None
          nickname = Some "Equity Financing"
          start_date = None
          trigger_condition = Some "Qualified equity financing of at least $1,000,000"
          trigger_date = None
          trigger_description = Some "Automatic conversion upon qualified equity financing"
          trigger_id = "equity-financing-trigger"
          type_ = OcfTriggerTypeTypeAutomaticOnCondition]
        pro_rata = None
        seniority = 1
        comments = []]
      edits = []
      deletes = []

createConvertibleIssuance issuer capTableCid securityId amount issuanceDate =
  createConvertibleIssuanceWithTargetClass issuer capTableCid securityId amount issuanceDate None

-- Test 1: SAFE conversion upon equity financing
-- Based on prod: SAFE conversion to Series Seed-2 Preferred
testConvertibleConversion_SAFEConversion = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  capTableCid <- addPreferredStockClass issuer capTableCid
  let securityId = "7b8c9d0e-1f2a-3b4c-5d6e-7f8a9b0c1d2e"
  result <- createConvertibleIssuance issuer capTableCid securityId 100000.0 (DT.time (DA.date 2023 Mar 15) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-CONV-1" "5f4a6b7c-9d0e-2f3a-6b7c-8d9e0f1a2b3c" "SH-1" "SC_PREFERRED" (DT.time (DA.date 2025 Nov 10) 0 0 0) 1.0
        , CT.OcfCreateConvertibleConversion ConvertibleConversionOcfData with
        id = "25d377f8-a8de-4d8d-853c-2d75927e7927"
        date = DT.time (DA.date 2025 Nov 10) 0 0 0
        security_id = securityId
        trigger_id = "equity-financing-trigger"
        reason_text = "Automatic conversion upon Series Seed-2 equity financing"
        resulting_security_ids = ["5f4a6b7c-9d0e-2f3a-6b7c-8d9e0f1a2b3c"]
        comments = ["SAFE conversion to Series Seed-2 Preferred for Investor A"]
        balance_security_id = None
        capitalization_definition = None
        quantity_converted = None]
      edits = []
      deletes = []
  pure ()

-- Test 2: Convertible conversion with capitalization definition
testConvertibleConversion_WithCapDefinition = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  capTableCid <- addPreferredStockClass issuer capTableCid
  capTableCid <- addConversionStockPlan issuer capTableCid
  let securityId = "CONV-SEC-002"
  result <- createConvertibleIssuance issuer capTableCid securityId 250000.0 (DT.time (DA.date 2023 Mar 15) 0 0 0)
  _ <- submit issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-CONV-2" "SSEC-PREFERRED-001" "SH-1" "SC_PREFERRED" (DT.time (DA.date 2025 Dec 01) 0 0 0) 15625.0
        , CT.OcfCreateConvertibleConversion ConvertibleConversionOcfData with
        id = "TX_CONV_CONVERSION_2"
        date = DT.time (DA.date 2025 Dec 01) 0 0 0
        security_id = securityId
        trigger_id = "equity-financing-trigger"
        reason_text = "Conversion based on fully diluted capitalization at $16M valuation cap"
        resulting_security_ids = ["SSEC-PREFERRED-001"]
        comments = ["Conversion of $250,000 SAFE at $16M post-money valuation cap"]
        balance_security_id = None
        capitalization_definition = Some (OcfCapitalizationDefinition with
          exclude_security_ids = []
          include_security_ids = []
          include_stock_class_ids = ["SC_COMMON", "SC_PREFERRED"]
          include_stock_plans_ids = ["ESOP-2024"])
        quantity_converted = Some 15625.0]  -- $250K / $16 per share
      edits = []
      deletes = []
  pure ()

-- Test 3: Partial conversion with balance security
testConvertibleConversion_PartialConversion = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  capTableCid <- addPreferredStockClass issuer capTableCid
  let securityId = "CONV-SEC-003"
  result <- createConvertibleIssuance issuer capTableCid securityId 500000.0 (DT.time (DA.date 2023 Mar 15) 0 0 0)
  balanceResult <- createConvertibleIssuance issuer result.updatedCapTableCid "CONV-SEC-003-REMAINDER" 200000.0 (DT.time (DA.date 2025 Nov 15) 0 0 0)
  _ <- submit issuer do
    exerciseCmd balanceResult.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-CONV-3" "SSEC-PREFERRED-002" "SH-1" "SC_PREFERRED" (DT.time (DA.date 2025 Nov 15) 0 0 0) 300000.0
        , CT.OcfCreateConvertibleConversion ConvertibleConversionOcfData with
        id = "TX_CONV_CONVERSION_3"
        date = DT.time (DA.date 2025 Nov 15) 0 0 0
        security_id = securityId
        trigger_id = "equity-financing-trigger"
        reason_text = "Partial conversion - investor electing to convert $300,000 of $500,000 SAFE"
        resulting_security_ids = ["SSEC-PREFERRED-002"]
        comments = []
        balance_security_id = Some "CONV-SEC-003-REMAINDER"
        capitalization_definition = None
        quantity_converted = Some 300000.0]
      edits = []
      deletes = []
  pure ()

testConvertibleConversion_ResultStockClassMustMatchTrigger = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  capTableCid <- addPreferredStockClass issuer capTableCid
  let securityId = "CONV-SEC-TARGET-CLASS"
      conversionDate = DT.time (DA.date 2025 Nov 15) 0 0 0
  result <- createConvertibleIssuanceWithTargetClass
    issuer
    capTableCid
    securityId
    100000.0
    (DT.time (DA.date 2023 Mar 15) 0 0 0)
    (Some "SC_PREFERRED")

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-CONV-WRONG-CLASS" "SSEC-CONV-WRONG-CLASS" "SH-1" "SC_COMMON" conversionDate 1000.0
        , CT.OcfCreateConvertibleConversion ConvertibleConversionOcfData with
            id = "TX_CONV_CONVERSION_WRONG_CLASS"
            date = conversionDate
            security_id = securityId
            trigger_id = "equity-financing-trigger"
            reason_text = "Conversion result targets the wrong stock class"
            resulting_security_ids = ["SSEC-CONV-WRONG-CLASS"]
            comments = []
            balance_security_id = None
            capitalization_definition = None
            quantity_converted = None
        ]
      edits = []
      deletes = []

testConvertibleConversion_ResultQuantityMustMatchQuantityConverted = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  capTableCid <- addPreferredStockClass issuer capTableCid
  let securityId = "CONV-SEC-RESULT-QUANTITY"
      conversionDate = DT.time (DA.date 2025 Nov 15) 0 0 0
  result <- createConvertibleIssuanceWithTargetClass
    issuer
    capTableCid
    securityId
    100000.0
    (DT.time (DA.date 2023 Mar 15) 0 0 0)
    (Some "SC_PREFERRED")

  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates =
        [ stockSuccessorIssuance "STOCK-ISS-CONV-WRONG-QUANTITY" "SSEC-CONV-WRONG-QUANTITY" "SH-1" "SC_PREFERRED" conversionDate 1.0
        , CT.OcfCreateConvertibleConversion ConvertibleConversionOcfData with
            id = "TX_CONV_CONVERSION_WRONG_QUANTITY"
            date = conversionDate
            security_id = securityId
            trigger_id = "equity-financing-trigger"
            reason_text = "Conversion result has the wrong quantity"
            resulting_security_ids = ["SSEC-CONV-WRONG-QUANTITY"]
            comments = []
            balance_security_id = None
            capitalization_definition = None
            quantity_converted = Some 1000.0
        ]
      edits = []
      deletes = []
