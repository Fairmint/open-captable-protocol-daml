module OpenCapTable.TestEquityCompensationIssuance where
import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance
import Fairmint.OpenCapTable.OCF.Stakeholder
import Fairmint.OpenCapTable.Types
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Helper to add a stakeholder (required prerequisite for issuance validation)
addStakeholder issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddStakeholder with
      stakeholder_data = StakeholderOcfData with
        id = "SH-1"
        name = OcfName with legal_name = "Test Employee", first_name = None, last_name = None
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = [OcfRelEmployee]
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = []

testCreateEquityCompensationIssuance = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add prerequisite stakeholder
  capTableCid <- addStakeholder issuer cap_table
  -- Create equity compensation issuance
  _ <- submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationIssuance with
      issuance_data = EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-1"
        custom_id = "EC-CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_plan_id = None
        stock_class_id = None
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 100.0
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        base_price = None
        early_exercisable = Some False
        vesting_terms_id = None
        vestings = []
        expiration_date = None
        termination_exercise_windows = []
        comments = []
  pure ()

testCreateAndDeleteEquityCompensationIssuance = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addStakeholder issuer cap_table
  capTableCid <- submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationIssuance with
      issuance_data = EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_DEL"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-DEL"
        custom_id = "EC-CERT-DEL"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_plan_id = None
        stock_class_id = None
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 100.0
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        base_price = None
        early_exercisable = Some False
        vesting_terms_id = None
        vestings = []
        expiration_date = None
        termination_exercise_windows = []
        comments = []
  -- Delete via CapTable
  _ <- submit issuer do
    exerciseCmd capTableCid CT.DeleteEquityCompensationIssuance with
      id = "TX_EC_ISS_DEL"
  pure ()

testEquityCompensationIssuance_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addStakeholder issuer cap_table
  _ <- submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationIssuance with
      issuance_data = EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_2"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "EC-2"
        custom_id = "EC-CERT-2"
        stakeholder_id = "SH-1"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 15) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 20) 0 0 0)
        consideration_text = Some "Employee incentive"
        security_law_exemptions = [OcfSecurityExemption with description = "ISO", jurisdiction = "US"]
        stock_plan_id = Some "PLAN-1"
        stock_class_id = Some "SC-1"
        compensation_type = OcfCompensationTypeOptionISO
        quantity = 500.0
        exercise_price = Some (OcfMonetary with amount = 2.5, currency = "USD")
        base_price = Some (OcfMonetary with amount = 2.0, currency = "USD")
        early_exercisable = Some True
        vesting_terms_id = Some "VT-1"
        vestings = [OcfVesting with date = DT.time (DA.date 2025 Jan 01) 0 0 0, amount = 125.0]
        expiration_date = Some (DT.time (DA.date 2034 Feb 01) 0 0 0)
        termination_exercise_windows = [OcfTerminationWindow with
          reason = OcfTermVoluntaryGoodCause
          period = 90
          period_type = OcfPeriodDays]
        comments = ["Initial grant for new hire"]
  pure ()
