module OpenCapTable.TestEquityCompensationIssuance where
import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance
import Fairmint.OpenCapTable.Types
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submit issuer do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

createEquityCompensationIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationIssuance with
      issuance_data = EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-1"
        custom_id = "EC-CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_plan_id = None
        stock_class_id = None
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 100.0
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        base_price = None
        early_exercisable = Some False
        vesting_terms_id = None
        vestings = []
        expiration_date = None
        termination_exercise_windows = []
        comments = []

testCreateAndArchiveEquityCompensationIssuance = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  cid <- createEquityCompensationIssuance issuer capTableCid
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()

testCreateAndArchiveEquityCompensationIssuanceBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  cid <- createEquityCompensationIssuance issuer capTableCid
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()

-- Optionals Some and arrays non-empty variant
testEquityCompensationIssuance_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationIssuance with
      issuance_data = EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_2"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "EC-2"
        custom_id = "EC-CERT-2"
        stakeholder_id = "SH-2"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 15) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 20) 0 0 0)
        consideration_text = Some "Services"
        security_law_exemptions = [ OcfSecurityExemption with description = "Rule 701", jurisdiction = "US-CA" ]
        stock_plan_id = Some "PLAN_1"
        stock_class_id = Some "SC_COMMON"
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 200.0
        exercise_price = Some (OcfMonetary with amount = 2.0, currency = "USD")
        base_price = Some (OcfMonetary with amount = 2.0, currency = "USD")
        early_exercisable = Some True
        vesting_terms_id = Some "VT_1"
        vestings = [ OcfVesting with date = DT.time (DA.date 2024 Mar 01) 0 0 0, amount = 100.0 ]
        expiration_date = Some (DT.time (DA.date 2026 Jan 01) 0 0 0)
        termination_exercise_windows = [ OcfTerminationWindow with reason = OcfTermVoluntaryOther, period = 90, period_type = OcfPeriodDays ]
        comments = ["Grant"]
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()


