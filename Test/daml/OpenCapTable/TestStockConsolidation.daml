module OpenCapTable.TestStockConsolidation where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockConsolidation
import Fairmint.OpenCapTable.Types.Monetary (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addPrerequisites, stockSuccessorIssuance)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

-- Create stock issuances to consolidate
createStockIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockIssuance StockIssuanceOcfData with
        id = "TX_STOCK_ISS_" <> securityId
        date = DT.time (DA.date 2022 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "CS-" <> securityId
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []]
      edits = []
      deletes = []

-- Test 1: Basic consolidation of two securities
-- Holder requests single certificate for two separate holdings
testStockConsolidation_TwoSecurities = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  result <- createStockIssuance issuer capTableCid "SSEC-001A" 25000.0
  result2 <- createStockIssuance issuer result.updatedCapTableCid "SSEC-001B" 25000.0
  _ <- submit issuer do
    exerciseCmd result2.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-CONSOLIDATION-1" "SSEC-001-CONSOLIDATED" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Apr 15) 0 0 0) 50000.0
        , CT.OcfCreateStockConsolidation StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_1"
        date = DT.time (DA.date 2025 Apr 15) 0 0 0
        security_ids = ["SSEC-001A", "SSEC-001B"]
        resulting_security_id = "SSEC-001-CONSOLIDATED"
        comments = []
        reason_text = Some "Holder requested single certificate"]
      edits = []
      deletes = []
  pure ()

testStockConsolidation_DuplicateSecurityIdsRejected = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  result <- createStockIssuance issuer capTableCid "SSEC-DUP-CONSOLIDATE" 100.0
  submitMustFail issuer do
    exerciseCmd result.updatedCapTableCid CT.UpdateCapTable with
      creates = [CT.OcfCreateStockConsolidation StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_DUP"
        date = DT.time (DA.date 2025 Apr 15) 0 0 0
        security_ids = ["SSEC-DUP-CONSOLIDATE", "SSEC-DUP-CONSOLIDATE"]
        resulting_security_id = "SSEC-DUP-CONSOLIDATED"
        comments = []
        reason_text = Some "Duplicate source security IDs are not schema-valid"]
      edits = []
      deletes = []
  pure ()

-- Test 2: Consolidation of multiple securities with comments
testStockConsolidation_MultipleSecurities = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  r1 <- createStockIssuance issuer capTableCid "SSEC-002A" 10000.0
  r2 <- createStockIssuance issuer r1.updatedCapTableCid "SSEC-002B" 15000.0
  r3 <- createStockIssuance issuer r2.updatedCapTableCid "SSEC-002C" 20000.0
  r4 <- createStockIssuance issuer r3.updatedCapTableCid "SSEC-002D" 5000.0
  _ <- submit issuer do
    exerciseCmd r4.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-CONSOLIDATION-2" "SSEC-002-CONSOLIDATED" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Jun 30) 0 0 0) 50000.0
        , CT.OcfCreateStockConsolidation StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_2"
        date = DT.time (DA.date 2025 Jun 30) 0 0 0
        security_ids = ["SSEC-002A", "SSEC-002B", "SSEC-002C", "SSEC-002D"]
        resulting_security_id = "SSEC-002-CONSOLIDATED"
        comments = ["Consolidation of four separate stock positions.", "Total: 50,000 shares of Common Stock."]
        reason_text = Some "Administrative cleanup per annual cap table maintenance"]
      edits = []
      deletes = []
  pure ()

-- Test 3: Consolidation without reason text
testStockConsolidation_MinimalFields = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addPrerequisites issuer cap_table
  r1 <- createStockIssuance issuer capTableCid "SSEC-003A" 30000.0
  r2 <- createStockIssuance issuer r1.updatedCapTableCid "SSEC-003B" 70000.0
  _ <- submit issuer do
    exerciseCmd r2.updatedCapTableCid CT.UpdateCapTable with
      creates = [stockSuccessorIssuance "STOCK-ISS-CONSOLIDATION-3" "SSEC-003-CONSOLIDATED" "SH-1" "SC_COMMON" (DT.time (DA.date 2025 Aug 01) 0 0 0) 100000.0
        , CT.OcfCreateStockConsolidation StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_3"
        date = DT.time (DA.date 2025 Aug 01) 0 0 0
        security_ids = ["SSEC-003A", "SSEC-003B"]
        resulting_security_id = "SSEC-003-CONSOLIDATED"
        comments = []
        reason_text = None]
      edits = []
      deletes = []
  pure ()
