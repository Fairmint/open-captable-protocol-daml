module OpenCapTable.TestStockConsolidation where

import Fairmint.OpenCapTable.OCF.StockIssuance
import Fairmint.OpenCapTable.OCF.StockConsolidation
import qualified Fairmint.OpenCapTable.OCF.StockConsolidation as SCO
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      context = ctx
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 10000000.0)
        comments = []

-- Create stock issuances to consolidate
createStockIssuance issuer capTableCid securityId quantity =
  submit issuer do
    exerciseCmd capTableCid CT.AddStockIssuance with
      issuance_data = StockIssuanceOcfData with
        id = "TX_STOCK_ISS_" <> securityId
        date = DT.time (DA.date 2022 Jan 01) 0 0 0
        security_id = securityId
        custom_id = "CS-" <> securityId
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "COMMON"
        share_price = OcfMonetary with amount = 0.0001, currency = "USD"
        quantity = quantity
        cost_basis = None
        stock_legend_ids = []
        issuance_type = None
        share_numbers_issued = []
        vesting_terms_id = None
        vestings = []
        stock_plan_id = None
        comments = []

-- Test 1: Basic consolidation of two securities
-- Holder requests single certificate for two separate holdings
testStockConsolidation_TwoSecurities = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockIssuance issuer capTableCid "SSEC-001A" 25000.0
  _ <- createStockIssuance issuer capTableCid "SSEC-001B" 25000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockConsolidation with
      consolidation_data = StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_1"
        date = DT.time (DA.date 2025 Apr 15) 0 0 0
        security_ids = ["SSEC-001A", "SSEC-001B"]
        resulting_security_id = "SSEC-001-CONSOLIDATED"
        comments = []
        reason_text = Some "Holder requested single certificate"
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()

-- Test 2: Consolidation of multiple securities with comments
testStockConsolidation_MultipleSecurities = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockIssuance issuer capTableCid "SSEC-002A" 10000.0
  _ <- createStockIssuance issuer capTableCid "SSEC-002B" 15000.0
  _ <- createStockIssuance issuer capTableCid "SSEC-002C" 20000.0
  _ <- createStockIssuance issuer capTableCid "SSEC-002D" 5000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockConsolidation with
      consolidation_data = StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_2"
        date = DT.time (DA.date 2025 Jun 30) 0 0 0
        security_ids = ["SSEC-002A", "SSEC-002B", "SSEC-002C", "SSEC-002D"]
        resulting_security_id = "SSEC-002-CONSOLIDATED"
        comments = ["Consolidation of four separate stock positions.", "Total: 50,000 shares of Common Stock."]
        reason_text = Some "Administrative cleanup per annual cap table maintenance"
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()

-- Test 3: Consolidation without reason text
testStockConsolidation_MinimalFields = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  let capTableCid = cap_table
  _ <- createStockIssuance issuer capTableCid "SSEC-003A" 30000.0
  _ <- createStockIssuance issuer capTableCid "SSEC-003B" 70000.0
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddStockConsolidation with
      consolidation_data = StockConsolidationOcfData with
        id = "TX_STOCK_CONSOLIDATION_3"
        date = DT.time (DA.date 2025 Aug 01) 0 0 0
        security_ids = ["SSEC-003A", "SSEC-003B"]
        resulting_security_id = "SSEC-003-CONSOLIDATED"
        comments = []
        reason_text = None
  -- Delete via CapTable if needed (archiving individual contracts not supported)
  pure ()
  pure ()
