testStockSecurityBalance_SplitAdjustedBalanceAllowsReduction = script do
  TestOcp{issuer, cap_table} <- setupTestOcp
  (capTableReady, stockClassId, stakeholderId) <- setupForStockIssuance issuer cap_table
  let securityId = "SEC_STOCK_BAL_SPLIT"
  let issuance = (defaultStockIssuance "TX_STOCK_BAL_SPLIT" securityId stakeholderId stockClassId) with quantity = 100.0

  _ <- submit issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateStockIssuance issuance
        , CT.OcfCreateStockClassSplit (stockClassSplitOn "TX_SPLIT_2_FOR_1" stockClassId 2.0 1.0 jan02)
        , CT.OcfCreateStockRepurchase (stockRepurchase "TX_REPURCHASE_AFTER_SPLIT" securityId 150.0 jan03)
        ]
      edits = []
      deletes = []
  pure ()

