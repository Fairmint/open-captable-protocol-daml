        , CT.OcfCreateStockCancellation (stockCancellationOn "TX_CANCEL_60" securityId 60.0 jan02)
        , CT.OcfCreateStockRepurchase (stockRepurchase "TX_REPURCHASE_50" securityId 50.0 jan03)
        ]
      edits = []
      deletes = []

