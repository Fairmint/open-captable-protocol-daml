module OpenCapTable.TestDocument where
import Fairmint.OpenCapTable.Document
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import Daml.Script
import DA.Date
import DA.Time

createIssuerForDocument issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISS_FOR_DOC"
        legal_name = "DocCo"
        formation_date = time (DA.Date.date 2010 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []

createDocument issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateDocument with
      document_data = DocumentOcfData with
        id = "DOC_1"
        path = Some "/docs/acme/charter.pdf"
        uri = None
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = []
        comments = []

-- Optionals Some
createDocumentSome issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateDocument with
      document_data = DocumentOcfData with
        id = "DOC_2"
        path = None
        uri = Some "https://cdn.example.com/docs/acme/charter.pdf"
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = [ OcfObjectReference with object_type = OcfObjIssuer, object_id = "ISS_FOR_DOC" ]
        comments = ["External link"]

testCreateAndArchiveDocument = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- createIssuerForDocument issuer system_operator ctx
  docCid <- createDocument issuer issuerCid
  submit issuer do
    exerciseCmd docCid Fairmint.OpenCapTable.Document.ArchiveByIssuer
  pure ()

testCreateAndArchiveDocumentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- createIssuerForDocument issuer system_operator ctx
  docCid <- createDocument issuer issuerCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd docCid Archive
  pure ()

testCreateAndArchiveDocument_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- createIssuerForDocument issuer system_operator ctx
  docCid <- createDocumentSome issuer issuerCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd docCid Archive
  pure ()
