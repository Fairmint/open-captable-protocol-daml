module OpenCapTable.TestDocument where
import Fairmint.OpenCapTable.OCF.Document
import qualified Fairmint.OpenCapTable.CapTable as CT
import OpenCapTable.Setup
import Daml.Script

testCreateDocument = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add document to CapTable
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.AddDocument with
      document_data = DocumentOcfData with
        id = "DOC_1"
        path = Some "/docs/acme/charter.pdf"
        uri = None
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = []
        comments = []
  pure ()

testCreateAndDeleteDocument = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add document to CapTable
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.AddDocument with
      document_data = DocumentOcfData with
        id = "DOC_1"
        path = Some "/docs/acme/charter.pdf"
        uri = None
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = []
        comments = []
  -- Delete document via CapTable
  _ <- submit issuer do
    exerciseCmd capTableCid CT.DeleteDocument with
      id = "DOC_1"
  pure ()

testCreateDocumentWithOptionalsSome = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add document with optional fields populated
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.AddDocument with
      document_data = DocumentOcfData with
        id = "DOC_2"
        path = None
        uri = Some "https://cdn.example.com/docs/acme/charter.pdf"
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = [ OcfObjectReference with object_type = OcfObjIssuer, object_id = "ISS_FOR_DOC" ]
        comments = ["External link"]
  pure ()

testEditDocument = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  -- Add document
  capTableCid <- submit issuer do
    exerciseCmd cap_table CT.AddDocument with
      document_data = DocumentOcfData with
        id = "DOC_EDIT"
        path = Some "/docs/original.pdf"
        uri = None
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = []
        comments = []
  -- Edit document
  _ <- submit issuer do
    exerciseCmd capTableCid CT.EditDocument with
      id = "DOC_EDIT"
      new_document_data = DocumentOcfData with
        id = "DOC_EDIT"
        path = Some "/docs/updated.pdf"
        uri = None
        md5 = "fedcba9876543210fedcba9876543210"
        related_objects = []
        comments = ["Updated version"]
  pure ()
