module OpenCapTable.TestEquityCompensationAcceptance where

import Fairmint.OpenCapTable.OCF.EquityCompensationIssuance
import Fairmint.OpenCapTable.OCF.EquityCompensationAcceptance
import qualified Fairmint.OpenCapTable.OCF.EquityCompensationAcceptance as EA
import qualified Fairmint.OpenCapTable.CapTable as CT
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import OpenCapTable.Setup
import OpenCapTable.TestHelpers (addDefaultStakeholder)
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

createEquityCompensationIssuance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationIssuance with
      issuance_data = EquityCompensationIssuanceOcfData with
        id = "TX_EC_ISS_1"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "SEC-OPTION-1"
        custom_id = "OPT-001"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = Some "Services rendered"
        security_law_exemptions = []
        stock_plan_id = Some "SP_2024"
        stock_class_id = Some "SC_COMMON"
        compensation_type = OcfCompensationTypeOptionISO
        quantity = 10000.0
        exercise_price = Some (OcfMonetary with amount = 0.50, currency = "USD")
        base_price = None
        vesting_terms_id = None
        vestings = []
        expiration_date = None
        termination_exercise_windows = []
        early_exercisable = None
        comments = []

createEquityCompensationAcceptance issuer capTableCid =
  submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationAcceptance with
      acceptance_data = EquityCompensationAcceptanceOcfData with
        id = "TX_EC_ACCEPT_1"
        date = DT.time (DA.date 2024 Feb 02) 0 0 0
        security_id = "SEC-OPTION-1"
        comments = []

testEquityCompensationAcceptance_CreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  capTableCid <- createEquityCompensationIssuance issuer capTableCid
  cid <- createEquityCompensationAcceptance issuer capTableCid

  pure ()

testEquityCompensationAcceptance_CreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  capTableCid <- createEquityCompensationIssuance issuer capTableCid
  cid <- createEquityCompensationAcceptance issuer capTableCid

  pure ()

-- Test with comments (non-empty array)
testEquityCompensationAcceptance_WithComments = script do
  TestOcp{system_operator, issuer, ctx, cap_table} <- setupTestOcp
  capTableCid <- addDefaultStakeholder issuer cap_table
  capTableCid <- createEquityCompensationIssuance issuer capTableCid
  cid <- submit issuer do
    exerciseCmd capTableCid CT.AddEquityCompensationAcceptance with
      acceptance_data = EquityCompensationAcceptanceOcfData with
        id = "TX_EC_ACCEPT_2"
        date = DT.time (DA.date 2024 Feb 03) 0 0 0
        security_id = "SEC-OPTION-1"
        comments = ["Employee signed option agreement", "Grant notice acknowledged"]

  pure ()
