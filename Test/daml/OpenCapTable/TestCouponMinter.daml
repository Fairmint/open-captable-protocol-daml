-- | Test CouponMinter is consuming but returns new contract ID for chaining
testMintCoupons_ConsumingWithChaining = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 1000000.0
      lastMint = None

  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- First mint - use the new contract ID returned
  result1 <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "first-mint"

  -- Wait for TPS enforcement (1 coupon / 1000000 TPS = 1 microsecond)
  passTime (seconds 1)

  -- Second mint - use the new contract ID from first result
  result2 <- submit (actAs operator <> readAs dso) do
    exerciseCmd result1.couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 2
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "second-mint"

  -- Total markers: 1 + 2 = 3
  assertMsg "First call should produce 1 marker" (length result1.markerCids == 1)
  assertMsg "Second call should produce 2 markers" (length result2.markerCids == 2)

  markers <- query @Amulet.FeaturedAppActivityMarker dso
  assertMsg "Expected 3 total marker contracts on ledger" (length markers == 3)
  pure ()

-- | Test MintCoupons with multiple beneficiaries creates marker per beneficiary per iteration
testMintCoupons_MultipleBeneficiaries = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 1000000.0
      lastMint = None

  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- Exercise MintCoupons with 2 beneficiaries and count = 2
  result <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 2
      beneficiaries = [AppRewardBeneficiary alice 0.5, AppRewardBeneficiary bob 0.5]
      metadata = None

  -- Verify: count=2 * 2 beneficiaries = 4 markers
  assertMsg "Expected 4 markers for count=2 with 2 beneficiaries" (length result.markerCids == 4)

  markers <- query @Amulet.FeaturedAppActivityMarker dso
  assertMsg "Expected 4 marker contracts on ledger" (length markers == 4)
  pure ()

-- | Test TPS enforcement - first call should succeed (no previous mint)
testMintCoupons_TpsFirstCallSucceeds = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 5.0
      lastMint = None

  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- First call should succeed (no previous mint to compare against)
  result <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  assertMsg "Expected 1 marker" (length result.markerCids == 1)
  pure ()

-- | Test TPS enforcement - second call too soon should fail
testMintCoupons_TpsExceededFails = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 5.0
      lastMint = None

  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- First call - mints 10 coupons with 5 TPS limit
  -- Required wait for next call = 10 / 5 = 2 seconds
  result1 <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 10
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  -- Second call immediately (same timestamp) - should fail because not enough time passed
  submitMustFail (actAs operator <> readAs dso) do
    exerciseCmd result1.couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

-- | Test TPS enforcement - call after sufficient time passes should succeed
testMintCoupons_TpsAfterWaitSucceeds = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 5.0
      lastMint = None

  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- First call - mints 5 coupons with 5 TPS limit
  -- Required wait for next call = 5 / 5 = 1 second
  result1 <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 5
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  -- Advance time by 2 seconds (more than required 1 second)
  passTime (seconds 2)

  -- Second call should succeed after waiting
  result2 <- submit (actAs operator <> readAs dso) do
    exerciseCmd result1.couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  assertMsg "Second call should produce 1 marker" (length result2.markerCids == 1)

  markers <- query @Amulet.FeaturedAppActivityMarker dso
  assertMsg "Expected 6 total markers on ledger" (length markers == 6)
  pure ()

-- | Test CouponMinter creation - zero maxTps should fail
testCouponMinter_ZeroTpsFails = script do
  operator <- allocateParty "Operator"

  -- Creating with maxTps = 0 should fail (ensure clause)
  submitMustFail operator do
    createCmd CouponMinter with
      operator
      maxTps = 0.0
      lastMint = None

-- | Test CouponMinter creation - negative maxTps should fail
testCouponMinter_NegativeTpsFails = script do
  operator <- allocateParty "Operator"

  -- Creating with negative maxTps should fail (ensure clause)
  submitMustFail operator do
    createCmd CouponMinter with
      operator
      maxTps = -5.0
      lastMint = None

-- | Test SetMaxTps - zero maxTps should fail
testSetMaxTps_ZeroValueFails = script do
  operator <- allocateParty "Operator"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 5.0
      lastMint = None

  -- SetMaxTps with 0 should fail (ensure clause on recreated contract)
  submitMustFail operator do
    exerciseCmd couponMinterCid SetMaxTps with newMaxTps = 0.0

-- | Test SetMaxTps - negative maxTps should fail
testSetMaxTps_NegativeValueFails = script do
  operator <- allocateParty "Operator"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 5.0
      lastMint = None

  -- SetMaxTps with negative value should fail (ensure clause on recreated contract)
  submitMustFail operator do
    exerciseCmd couponMinterCid SetMaxTps with newMaxTps = -5.0

-- | Test SetMaxTps - operator can change TPS anytime
testSetMaxTps_OperatorCanChangeTps = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"

  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 5.0
      lastMint = None

  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- First mint
  result1 <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 10
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  -- Second call immediately should fail (TPS enforced)
  submitMustFail (actAs operator <> readAs dso) do
    exerciseCmd result1.couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  -- Change TPS to higher value to allow faster minting
  couponMinterCid2 <- submit operator do
    exerciseCmd result1.couponMinterCid SetMaxTps with newMaxTps = 1000.0

  -- Wait for TPS enforcement (10 coupons / 1000 TPS = 0.01 seconds)
  passTime (seconds 1)

  -- Now second call should succeed after waiting
  result2 <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid2 MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

  assertMsg "Should produce 1 marker" (length result2.markerCids == 1)
  pure ()
