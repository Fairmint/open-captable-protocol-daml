      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = -1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

-- | Test CouponMinter is nonconsuming (can be used multiple times)
testMintCoupons_Nonconsuming = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  
  couponMinterCid <- submit operator do
    createCmd CouponMinter with operator
  
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator
  
  -- Exercise MintCoupons twice to verify nonconsuming behavior
  result1 <- submitMulti [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "first-mint"
  
  -- Second call should succeed (nonconsuming)
  result2 <- submitMulti [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 2
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "second-mint"
  
  -- Total markers: 1 + 2 = 3
  assertMsg "First call should produce 1 marker" (length result1.markerCids == 1)
  assertMsg "Second call should produce 2 markers" (length result2.markerCids == 2)
  
  markers <- query @Amulet.FeaturedAppActivityMarker dso
  assertMsg "Expected 3 total marker contracts on ledger" (length markers == 3)
  pure ()

-- | Test MintCoupons with multiple beneficiaries creates marker per beneficiary per iteration
testMintCoupons_MultipleBeneficiaries = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  
  couponMinterCid <- submit operator do
    createCmd CouponMinter with operator
  
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator
  
  -- Exercise MintCoupons with 2 beneficiaries and count = 2
  result <- submitMulti [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 2
      beneficiaries = [AppRewardBeneficiary alice 0.5, AppRewardBeneficiary bob 0.5]
      metadata = None
  
  -- Verify: count=2 * 2 beneficiaries = 4 markers
  assertMsg "Expected 4 markers for count=2 with 2 beneficiaries" (length result.markerCids == 4)
  
  markers <- query @Amulet.FeaturedAppActivityMarker dso
  assertMsg "Expected 4 marker contracts on ledger" (length markers == 4)
  pure ()
