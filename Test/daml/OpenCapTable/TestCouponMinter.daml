module OpenCapTable.TestCouponMinter where

import Daml.Script
import DA.Time (seconds)
import Fairmint.CouponMinter
import Splice.Amulet qualified as Amulet
import Splice.Api.FeaturedAppRightV1 qualified as Featured
import Splice.Api.FeaturedAppRightV1 (AppRewardBeneficiary(..))

-- | Test FeaturedAppRight template that creates real FeaturedAppActivityMarker contracts.
-- This allows us to verify that MintCoupons produces the correct number of markers.
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with ..
      featuredAppRight_CreateActivityMarkerImpl _self arg = do
        -- Create actual FeaturedAppActivityMarker contracts for each beneficiary
        cids <- forA arg.beneficiaries $ \b ->
          create Amulet.FeaturedAppActivityMarker with
            dso = dso
            provider = provider
            beneficiary = b.beneficiary
            weight = b.weight
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult $ map toInterfaceContractId cids)

-- | Test MintCoupons with count = 1, verify one marker per beneficiary is created
testMintCoupons_ValidCount1 = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"

  -- Create CouponMinter (high TPS to not block tests)
  couponMinterCid <- submit operator do
    createCmd CouponMinter with
      operator
      maxTps = 1000000.0
      lastMint = None

  -- Create test FeaturedAppRight (DSO creates it since they're signatory)
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator

  -- Exercise MintCoupons with count = 1
  result <- submit (actAs operator <> readAs dso) do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "test-contract-id-123"

  -- Verify: count=1 * 1 beneficiary = 1 marker
  assertMsg "Expected 1 marker for count=1 with 1 beneficiary" (length result.markerCids == 1)

  -- Verify the marker was actually created on the ledger
  markers <- query @Amulet.FeaturedAppActivityMarker dso
  assertMsg "Expected 1 marker contract on ledger" (length markers == 1)
  pure ()

-- | Test MintCoupons with count = 3, verify correct total markers
