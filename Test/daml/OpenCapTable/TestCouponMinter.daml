-- | Test MintCoupons rejects count = 0
testMintCoupons_RejectsCount0 = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  
  -- Create CouponMinter
  couponMinterCid <- submit operator do
    createCmd CouponMinter with operator
  
  -- Create test FeaturedAppRight
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator
  
  -- Exercise MintCoupons with count = 0 (should fail)
  submitMultiMustFail [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 0
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

-- | Test MintCoupons rejects negative count
testMintCoupons_RejectsNegativeCount = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  
  -- Create CouponMinter
  couponMinterCid <- submit operator do
    createCmd CouponMinter with operator
  
  -- Create test FeaturedAppRight
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator
  
  -- Exercise MintCoupons with count = -1 (should fail)
  submitMultiMustFail [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = -1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = None

-- | Test CouponMinter is nonconsuming (can be used multiple times)
testMintCoupons_Nonconsuming = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  
  -- Create CouponMinter
  couponMinterCid <- submit operator do
    createCmd CouponMinter with operator
  
  -- Create test FeaturedAppRight
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator
  
  -- Exercise MintCoupons twice to verify nonconsuming behavior
  _ <- submitMulti [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "first-mint"
  
  -- Second call should succeed (nonconsuming)
  _ <- submitMulti [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 2
      beneficiaries = [AppRewardBeneficiary operator 1.0]
      metadata = Some "second-mint"
  
  pure ()

-- | Test MintCoupons with multiple beneficiaries
testMintCoupons_MultipleBeneficiaries = script do
  operator <- allocateParty "Operator"
  dso <- allocateParty "DSO"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  
  -- Create CouponMinter
  couponMinterCid <- submit operator do
    createCmd CouponMinter with operator
  
  -- Create test FeaturedAppRight
  featuredAppRightCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = operator
  
  -- Exercise MintCoupons with multiple beneficiaries
  result <- submitMulti [operator] [dso] do
    exerciseCmd couponMinterCid MintCoupons with
      featuredAppRight = toInterfaceContractId featuredAppRightCid
      count = 1
      beneficiaries = [AppRewardBeneficiary alice 0.5, AppRewardBeneficiary bob 0.5]
      metadata = None
  
  -- Verify result (test mock returns empty list per implementation)
  assertMsg "Expected empty marker list from test mock" (result.markerCids == [])
  pure ()
