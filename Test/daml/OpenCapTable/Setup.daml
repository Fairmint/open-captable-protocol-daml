module OpenCapTable.Setup where

import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.CapTable
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.Types
import Splice.Api.FeaturedAppRightV1 as Featured
import Daml.Script
import DA.Date
import DA.Time

-- A minimal FeaturedAppRight instance the tests can use
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
    issuer : Party
    alice : Party
    bob : Party
    charlie : Party
    rando : Party
  where
    signatory dso
    observer provider, issuer, alice, bob, charlie, rando
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with dso, provider
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- Exercise FeaturedAppRightChoice to improve coverage
exerciseFeaturedAppRightChoice : Script ()
exerciseFeaturedAppRightChoice = script do
  sysOp <- allocateParty "SystemOperator"
  aliceP <- allocateParty "Alice"
  testRightCid <- submit sysOp do
    createCmd TestFeaturedAppRight with
      dso = sysOp
      provider = sysOp
      issuer = sysOp
      alice = aliceP
      bob = sysOp
      charlie = sysOp
      rando = sysOp
  let rightIfaceCid : ContractId Featured.FeaturedAppRight = toInterfaceContractId testRightCid
  _ <- submit sysOp do
    exerciseCmd rightIfaceCid Featured.FeaturedAppRight_CreateActivityMarker with
      beneficiaries = [ Featured.AppRewardBeneficiary with beneficiary = aliceP, weight = 1.0 ]
  _ <- submit sysOp do
    exerciseCmd testRightCid Archive
  pure ()

data TestUsers = TestUsers{ tu_system_operator: Party, tu_issuer: Party, tu_alice: Party, tu_bob: Party, tu_charlie: Party, tu_rando: Party }

setupUsers = script do
  sysOp <- allocateParty "SystemOperator"
  issuerP <- allocateParty "Issuer"
  aliceP <- allocateParty "Alice"
  bobP <- allocateParty "Bob"
  charlieP <- allocateParty "Charlie"
  randoP <- allocateParty "Rando"
  return TestUsers{ tu_system_operator = sysOp, tu_issuer = issuerP, tu_alice = aliceP, tu_bob = bobP, tu_charlie = charlieP, tu_rando = randoP }

-- Main test setup: returns CapTable, parties, and Context
data TestOcp = TestOcp
  { system_operator: Party
  , issuer: Party
  , ctx: Context
  , alice: Party
  , cap_table: ContractId CapTable
  }

setupTestOcp : Script TestOcp
setupTestOcp = script do
  TestUsers{tu_system_operator = system_operator, tu_issuer = issuer, tu_alice = alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid

  -- Create IssuerAuthorization then exercise to create CapTable
  authCid <- submit system_operator do
    createCmd IssuerAuthorization with context = ctx

  capTableCid <- submit issuer do
    exerciseCmd authCid CreateCapTable with
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = time (DA.Date.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

  return TestOcp
    { system_operator = system_operator
    , issuer = issuer
    , ctx = ctx
    , alice = alice
    , cap_table = capTableCid
    }

-- Legacy helper for backward compatibility during migration
createIssuer sysOp issuerP = script do
  testRightCid <- submit sysOp do
    createCmd TestFeaturedAppRight with
      dso = sysOp
      provider = sysOp
      issuer = issuerP
      alice = sysOp
      bob = sysOp
      charlie = sysOp
      rando = sysOp
  let context = Context with
        issuer = issuerP
        system_operator = sysOp
        featured_app_right = toInterfaceContractId testRightCid

  -- Create IssuerAuthorization then exercise to create CapTable
  authCid <- submit sysOp do
    createCmd IssuerAuthorization with context = context

  capTableCid <- submit issuerP do
    exerciseCmd authCid CreateCapTable with
      issuer_data = IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = time (DA.Date.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

  return capTableCid
