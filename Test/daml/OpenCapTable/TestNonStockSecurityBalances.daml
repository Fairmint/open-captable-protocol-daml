  let transferResult = (warrantIssuance "TX_W_TRANSFER_50_RESULT_ISSUANCE" "TX_W_TRANSFER_50_RESULT" defaultStakeholderId 50.0) with date = jan03

  submitMustFail issuer do
    exerciseCmd capTableReady CT.UpdateCapTable with
      creates =
        [ CT.OcfCreateWarrantIssuance (warrantIssuance "TX_W_BAL_CUMULATIVE" securityId defaultStakeholderId 100.0)
        , CT.OcfCreateWarrantExercise (warrantExercise "TX_W_EXERCISE_60" securityId (Some 60.0) jan02)
        , CT.OcfCreateWarrantIssuance transferResult
        , CT.OcfCreateWarrantTransfer (warrantTransfer "TX_W_TRANSFER_50" securityId 50.0 jan03)
        ]
      edits = []
      deletes = []

