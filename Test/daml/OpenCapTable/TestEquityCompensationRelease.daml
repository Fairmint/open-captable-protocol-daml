module OpenCapTable.TestEquityCompensationRelease where

import Fairmint.OpenCapTable.OCF.EquityCompensationRelease
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import Fairmint.OpenCapTable.Types (OcfMonetary(..))
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script


-- Test: Create and archive RSU release/settlement
testCreateAndArchiveEquityCompensationRelease = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "ExampleCo Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []
  -- RSU vesting and release
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationRelease with
      release_data = EquityCompensationReleaseOcfData with
        id = "TX_EC_RELEASE_1"
        date = DT.time (DA.date 2024 Apr 01) 0 0 0
        security_id = "SEC_RSU_001"
        settlement_date = DT.time (DA.date 2024 Apr 03) 0 0 0
        release_price = OcfMonetary with amount = 45.50; currency = "USD"
        quantity = 5000.0
        resulting_security_ids = ["SEC_STOCK_101"]
        consideration_text = Some "RSU cliff vest - 25% of total grant"
        comments = ["First anniversary cliff vest for Employee A"]
  submit issuer do
    exerciseCmd cid ArchiveByIssuer
  pure ()


-- Test: Create and archive with Archive choice (quarterly RSU vest)
testCreateAndArchiveEquityCompensationReleaseQuarterly = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_2"
        legal_name = "TechStart Corp."
        formation_date = DT.time (DA.date 2018 Jun 1) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  -- Quarterly RSU vest with tax withholding
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationRelease with
      release_data = EquityCompensationReleaseOcfData with
        id = "TX_EC_RELEASE_2"
        date = DT.time (DA.date 2024 Jul 01) 0 0 0
        security_id = "SEC_RSU_002"
        settlement_date = DT.time (DA.date 2024 Jul 05) 0 0 0
        release_price = OcfMonetary with amount = 52.00; currency = "USD"
        quantity = 1250.0
        resulting_security_ids = ["SEC_STOCK_102", "SEC_STOCK_103"]
        consideration_text = None
        comments = ["Q3 2024 quarterly vest", "Net settlement after tax withholding"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
