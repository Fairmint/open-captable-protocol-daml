  parties <- allocateNftCoreParties "Reject"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
