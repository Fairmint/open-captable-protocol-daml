module OpenCapTable.TestNftRegistry where

import DA.Map qualified as Map
import DA.Optional qualified as Optional
import DA.TextMap qualified as TextMap
import Daml.Script

import Fairmint.OpenCapTableNft.Metadata (canonicalNftIdText, standardMetadataKey)
import Fairmint.OpenCapTableNft.Nft qualified as Nft
import Fairmint.OpenCapTableNft.NftAsset qualified as NftAsset
import Fairmint.OpenCapTableNft.NftRegistry qualified as NftRegistry
import Fairmint.OpenCapTableNft.ReceiveAuthorization qualified as ReceiveAuthorization
import Fairmint.OpenCapTableNft.Types
import OpenCapTable.TestNftCoreHelpers

-- Conformance-style coverage for the generic NFT-native core only.
-- These tests intentionally avoid any Fairmint adapter surface or Splice token interfaces.

testNftCoreCanonicalNftIdIsStableAndDelimiterSafe = script do
  let canonical_nft_id = defaultRegistration.nft_id
  let delimiter_collision_left =
        registrationWithIds "REGISTRY" "COLL|SECTION" "TOKEN"
  let delimiter_collision_right =
        registrationWithIds "REGISTRY|COLL" "SECTION" "TOKEN"

  assertMsg "canonical NFT id text must be stable for the same logical id" $
    canonicalNftIdText canonical_nft_id == canonicalNftIdText canonical_nft_id
  assertMsg "canonical NFT id encoding must distinguish delimiter collisions" $
    canonicalNftIdText delimiter_collision_left.nft_id
      /= canonicalNftIdText delimiter_collision_right.nft_id

testNftCoreDirectAssetCreateRequiresRegistryAuthorityAndOperator = script do
  parties <- allocateNftCoreParties "DirectAssetCreate"

  submitMustFail parties.registry_authority do
    createCmd NftAsset.NftAsset with
      registry_authority = parties.registry_authority
      operator = parties.operator
      holder = parties.alice
      registration = defaultRegistration

  submitMustFail parties.operator do
    createCmd NftAsset.NftAsset with
      registry_authority = parties.registry_authority
      operator = parties.operator
      holder = parties.alice
      registration = defaultRegistration

testNftCoreMintRequiresRegistryAuthorityAndOperator = script do
  parties <- allocateNftCoreParties "MintAuthorization"
  registry_cid <- createRegistry parties.registry_authority parties.operator None

  submitMustFail parties.registry_authority do
    exerciseCmd registry_cid
      (NftRegistry.Mint with
        holder = parties.alice
        registration = defaultRegistration
      )

  submitMustFail parties.operator do
    exerciseCmd registry_cid
      (NftRegistry.Mint with
        holder = parties.alice
        registration = defaultRegistration
      )

  assertRegistryIsEmpty parties.registry_authority registry_cid

testNftCoreMintRejectsDuplicateCanonicalId = script do
  parties <- allocateNftCoreParties "DuplicateMint"
  registry_cid <- createRegistry parties.registry_authority parties.operator None

  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice

  submitMustFail (actAs [parties.registry_authority, parties.operator]) do
    exerciseCmd minted_registry_cid
      (NftRegistry.Mint with
        holder = parties.bob
        registration = defaultRegistration
      )

  assertRegistryTracksNft parties.registry_authority minted_registry_cid defaultRegistration
  assertActiveNftView
    parties.registry_authority
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
  assertRegistryEntryCount parties.registry_authority minted_registry_cid 1
  assertRegistryCollectionCount parties.registry_authority minted_registry_cid 1

testNftCoreMintRejectsOutsideCollectionScope = script do
  parties <- allocateNftCoreParties "ScopedMintReject"
  registry_cid <- createRegistry parties.registry_authority parties.operator (Some defaultCollection)
  let out_of_scope_registration =
        registrationWithPayload
          otherCollection
          alternateTokenId
          defaultMetadata
          None

  submitMustFail (actAs [parties.registry_authority, parties.operator]) do
    exerciseCmd registry_cid
      (NftRegistry.Mint with
        holder = parties.alice
        registration = out_of_scope_registration
      )

  assertRegistryIsEmpty parties.registry_authority registry_cid

testNftCoreRegistryCreationRejectsMismatchedCollectionScopeRegistry = script do
  parties <- allocateNftCoreParties "ScopedRegistryMismatch"
  let mismatched_scope =
        CollectionIdentity with
          registry_id = "NFT-REGISTRY-OTHER"
          collection_id = defaultCollection.collection_id

  submitMustFail (actAs [parties.registry_authority, parties.operator]) do
    createCmd NftRegistry.NftRegistry with
      registry_authority = parties.registry_authority
      operator = parties.operator
      registry = defaultRegistry
      collection_scope = Some mismatched_scope
      collection_registries = Map.empty

testNftCoreOfferTransferRequiresRegistryAuthorityOperatorAndCurrentHolderAuthorization = script do
  setTime baseTime
  parties <- allocateNftCoreParties "OfferAuthorization"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  submitMustFail parties.alice do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with transfer_offer, receive_authorization_cid = None)

  submitMustFail parties.registry_authority do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with transfer_offer, receive_authorization_cid = None)

  submitMustFail parties.operator do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with transfer_offer, receive_authorization_cid = None)

  submitMustFail (actAs [parties.registry_authority, parties.operator]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with transfer_offer, receive_authorization_cid = None)

  assertActiveNftView
    parties.registry_authority
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration

testNftCorePendingTransferConsumesPriorActiveRepresentation = script do
  setTime baseTime
  parties <- allocateNftCoreParties "PendingRepresentation"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
      None

  assertNoNftView parties.registry_authority nft_cid
  assertPendingNftView
    parties.registry_authority
    pending_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
    transfer_offer
  assertRegistryTracksNft parties.registry_authority minted_registry_cid defaultRegistration
  assertRegistryEntryCount parties.registry_authority minted_registry_cid 1

testNftCoreAcceptTransfersWholeAssetWithoutChangingPayload = script do
  setTime baseTime
  parties <- allocateNftCoreParties "AcceptWholeAsset"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
      None
  accepted_cid <-
    acceptPendingTransfer
      parties.registry_authority
      parties.operator
      parties.bob
      pending_cid

  assertNoNftView parties.registry_authority pending_cid
  assertActiveNftView
    parties.registry_authority
    accepted_cid
    parties.registry_authority
    parties.operator
    parties.bob
    defaultRegistration
  assertRegistryTracksNft parties.registry_authority minted_registry_cid defaultRegistration
  assertRegistryEntryCount parties.registry_authority minted_registry_cid 1

  Some accepted_view <- queryInterfaceContractId @Nft.CantonNft parties.registry_authority accepted_cid
  assertMsg "whole-asset transfer must preserve the NFT registration exactly" $
    accepted_view.nft_id == defaultRegistration.nft_id
      && accepted_view.metadata == defaultRegistration.metadata
      && accepted_view.confidentiality_ref == defaultRegistration.confidentiality_ref

testNftCoreAcceptRequiresRegistryAuthorityOperatorAndDesignatedReceiverAuthorization = script do
  setTime baseTime
  parties <- allocateNftCoreParties "AcceptAuthorization"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
      None

  submitMustFail parties.bob do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Accept

  submitMustFail parties.registry_authority do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Accept

  submitMustFail parties.operator do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Accept

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.alice]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Accept

  assertPendingNftView
    parties.registry_authority
    pending_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
    transfer_offer

testNftCoreRejectRestoresSenderOwnership = script do
