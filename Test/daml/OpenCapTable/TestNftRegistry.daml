testNftCoreStandingReceiveAuthorizationRejectsWrongReceiverAndRevokedAuth = script do
  setTime baseTime
  parties <- allocateNftCoreParties "StandingAuthControllerValidation"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  wrong_receiver_auth_cid <-
    createStandingReceiveAuthorization
      parties.registry_authority
      parties.operator
      parties.charlie
      (Some defaultCollection)
      (Some afterFirstTransferExpiry)
  revocable_auth_cid <-
    createStandingReceiveAuthorization
      parties.registry_authority
      parties.operator
      parties.bob
      (Some defaultCollection)
      (Some afterFirstTransferExpiry)
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.alice]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with
        transfer_offer
        receive_authorization_cid = Some wrong_receiver_auth_cid
      )

  submit parties.bob do
    exerciseCmd revocable_auth_cid ReceiveAuthorization.Revoke

  assertStandingReceiveAuthorizationHiddenFrom parties.registry_authority revocable_auth_cid
  assertStandingReceiveAuthorizationHiddenFrom parties.operator revocable_auth_cid
  assertStandingReceiveAuthorizationHiddenFrom parties.bob revocable_auth_cid

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.alice]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with
        transfer_offer
        receive_authorization_cid = Some revocable_auth_cid
      )

  assertActiveNftView
    parties.registry_authority
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration

testNftCoreMetadataAndConfidentialityHookRoundTrip = script do
  parties <- allocateNftCoreParties "Metadata"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  let reserved_public_registration =
        registrationWithPayload
          defaultCollection
          defaultTokenId
          reservedAwareMetadata
          (Some (ConfidentialityRef with reference = "vault://confidentiality/sensitive"))
  let no_confidentiality_registration =
        registrationWithPayload
          defaultCollection
          alternateTokenId
          reservedAwareMetadata
          None

  NftRegistry.MintResult{registry_cid = after_first_registry_cid, nft_cid = first_nft_cid} <-
    mintRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
      reserved_public_registration
  NftRegistry.MintResult{registry_cid = after_second_registry_cid, nft_cid = second_nft_cid} <-
    mintRegistration
      parties.registry_authority
      parties.operator
      after_first_registry_cid
      parties.bob
      no_confidentiality_registration

  assertActiveNftView
    parties.registry_authority
    first_nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    reserved_public_registration
  assertActiveNftView
    parties.registry_authority
    second_nft_cid
    parties.registry_authority
    parties.operator
    parties.bob
    no_confidentiality_registration
  assertRegistryTracksNft
    parties.registry_authority
    after_second_registry_cid
    reserved_public_registration
  assertRegistryTracksNft
    parties.registry_authority
    after_second_registry_cid
    no_confidentiality_registration
  assertRegistryEntryCount parties.registry_authority after_second_registry_cid 2
  assertRegistryCollectionCount parties.registry_authority after_second_registry_cid 1

  Some first_view <- queryInterfaceContractId @Nft.CantonNft parties.registry_authority first_nft_cid
  assertMsg "reserved-looking public metadata keys must round-trip unchanged" $
    first_view.metadata.public_metadata == reservedAwareMetadata.public_metadata
  assertMsg "confidentiality hook must round-trip when present" $
    first_view.confidentiality_ref
      == Some (ConfidentialityRef with reference = "vault://confidentiality/sensitive")

  Some second_view <- queryInterfaceContractId @Nft.CantonNft parties.registry_authority second_nft_cid
  assertMsg "confidentiality hook may be intentionally absent" $
    Optional.isNone second_view.confidentiality_ref

testNftCoreRegistryShardsUniquenessLedgerByCollection = script do
  parties <- allocateNftCoreParties "CollectionLedgerShards"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  let other_collection_registration =
        registrationWithPayload
          otherCollection
          alternateTokenId
          defaultMetadata
          None

  NftRegistry.MintResult{registry_cid = after_first_registry_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  NftRegistry.MintResult{registry_cid = after_second_registry_cid} <-
    mintRegistration
      parties.registry_authority
      parties.operator
      after_first_registry_cid
      parties.bob
      other_collection_registration

  assertRegistryTracksNft parties.registry_authority after_second_registry_cid defaultRegistration
  assertRegistryTracksNft
    parties.registry_authority
    after_second_registry_cid
    other_collection_registration
  assertRegistryEntryCount parties.registry_authority after_second_registry_cid 2
  assertRegistryCollectionCount parties.registry_authority after_second_registry_cid 2

testNftCoreReservedNamespaceRejectedOutsideStandardMetadata = script do
  parties <- allocateNftCoreParties "ReservedNamespace"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  let invalid_metadata =
        reservedAwareMetadata with
          public_metadata =
            TextMap.fromList
              [ (standardMetadataKey "name", MetadataText with text = "bad-public-name")
              ]
  let invalid_registration =
        registrationWithPayload
          defaultCollection
          defaultTokenId
          invalid_metadata
          None

  submitMustFail (actAs [parties.registry_authority, parties.operator]) do
    exerciseCmd registry_cid
      (NftRegistry.Mint with
        holder = parties.alice
        registration = invalid_registration
      )

  assertRegistryIsEmpty parties.registry_authority registry_cid

testNftCoreVisibilityBoundariesMatchStakeholders = script do
  setTime baseTime
  parties <- allocateNftCoreParties "Visibility"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  auth_cid <-
    createStandingReceiveAuthorization
      parties.registry_authority
      parties.operator
      parties.bob
      (Some defaultCollection)
      (Some afterFirstTransferExpiry)
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  assertActiveNftView
    parties.registry_authority
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
  assertActiveNftView
    parties.operator
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
  assertActiveNftView
    parties.alice
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
  assertNoNftView parties.bob nft_cid
  assertNoNftView parties.charlie nft_cid
  assertRegistryTracksNft parties.registry_authority minted_registry_cid defaultRegistration
  assertRegistryHiddenFrom parties.alice minted_registry_cid
  assertRegistryHiddenFrom parties.bob minted_registry_cid
  assertRegistryHiddenFrom parties.charlie minted_registry_cid

  assertStandingReceiveAuthorizationVisibleTo parties.registry_authority auth_cid
  assertStandingReceiveAuthorizationVisibleTo parties.operator auth_cid
  assertStandingReceiveAuthorizationVisibleTo parties.bob auth_cid
  assertStandingReceiveAuthorizationHiddenFrom parties.alice auth_cid
  assertStandingReceiveAuthorizationHiddenFrom parties.charlie auth_cid

  pending_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
      None

  assertPendingNftView
    parties.registry_authority
    pending_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
    transfer_offer
  assertPendingNftView
    parties.operator
    pending_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
    transfer_offer
  assertPendingNftView
    parties.alice
    pending_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
    transfer_offer
  assertPendingNftView
    parties.bob
    pending_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration
    transfer_offer
  assertNoNftView parties.charlie pending_cid
