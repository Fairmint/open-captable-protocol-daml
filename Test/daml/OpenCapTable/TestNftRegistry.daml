module OpenCapTable.TestNftRegistry where

import DA.TextMap qualified as TextMap
import DA.Optional qualified as Optional
import Daml.Script

import Fairmint.OpenCapTableNft.Metadata (canonicalNftIdText, standardMetadataKey)
import Fairmint.OpenCapTableNft.Nft qualified as Nft
import Fairmint.OpenCapTableNft.NftAsset qualified as NftAsset
import Fairmint.OpenCapTableNft.NftRegistry qualified as NftRegistry
import Fairmint.OpenCapTableNft.Types
import OpenCapTable.TestNftCoreHelpers

-- Conformance-style coverage for the generic NFT-native core only.
-- These tests intentionally avoid any Fairmint adapter surface or Splice token interfaces.

testNftCoreCanonicalNftIdIsStableAndDelimiterSafe = script do
  let canonical_nft_id = defaultRegistration.nft_id
  let delimiter_collision_left =
        registrationWithIds "REGISTRY" "COLL|SECTION" "TOKEN"
  let delimiter_collision_right =
        registrationWithIds "REGISTRY|COLL" "SECTION" "TOKEN"

  assertMsg "canonical NFT id text must be stable for the same logical id" $
    canonicalNftIdText canonical_nft_id == canonicalNftIdText canonical_nft_id
  assertMsg "canonical NFT id encoding must distinguish delimiter collisions" $
    canonicalNftIdText delimiter_collision_left.nft_id
      /= canonicalNftIdText delimiter_collision_right.nft_id

testNftCoreMintRejectsDuplicateCanonicalId = script do
  parties <- allocateNftCoreParties "DuplicateMint"
  registry_cid <- createRegistry parties.registry_admin None

  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration parties.registry_admin registry_cid parties.alice

  submitMustFail parties.registry_admin do
    exerciseCmd minted_registry_cid
      (NftRegistry.Mint with
        holder = parties.bob
        registration = defaultRegistration
      )

  assertRegistryTracksNft parties.registry_admin minted_registry_cid defaultRegistration
  assertActiveNftView
    parties.registry_admin
    nft_cid
    parties.registry_admin
    parties.alice
    defaultRegistration
  assertRegistryEntryCount parties.registry_admin minted_registry_cid 1

testNftCorePendingTransferConsumesPriorActiveRepresentation = script do
  setTime baseTime
  parties <- allocateNftCoreParties "PendingRepresentation"
  registry_cid <- createRegistry parties.registry_admin None
  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration parties.registry_admin registry_cid parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer parties.registry_admin parties.alice nft_cid transfer_offer None

  assertNoNftView parties.registry_admin nft_cid
  assertPendingNftView
    parties.registry_admin
    pending_cid
    parties.registry_admin
    parties.alice
    defaultRegistration
    transfer_offer
  assertRegistryTracksNft parties.registry_admin minted_registry_cid defaultRegistration
  assertRegistryEntryCount parties.registry_admin minted_registry_cid 1

testNftCoreAcceptTransfersWholeAssetWithoutChangingPayload = script do
  setTime baseTime
  parties <- allocateNftCoreParties "AcceptWholeAsset"
  registry_cid <- createRegistry parties.registry_admin None
  NftRegistry.MintResult{registry_cid = minted_registry_cid, nft_cid} <-
    mintDefaultRegistration parties.registry_admin registry_cid parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer parties.registry_admin parties.alice nft_cid transfer_offer None
  accepted_cid <- acceptPendingTransfer parties.registry_admin parties.bob pending_cid

  assertNoNftView parties.registry_admin pending_cid
  assertActiveNftView
    parties.registry_admin
    accepted_cid
    parties.registry_admin
    parties.bob
    defaultRegistration
  assertRegistryTracksNft parties.registry_admin minted_registry_cid defaultRegistration
  assertRegistryEntryCount parties.registry_admin minted_registry_cid 1

  Some accepted_view <- queryInterfaceContractId @Nft.CantonNft parties.registry_admin accepted_cid
  assertMsg "whole-asset transfer must preserve the NFT registration exactly" $
    accepted_view.nft_id == defaultRegistration.nft_id
      && accepted_view.metadata == defaultRegistration.metadata
      && accepted_view.confidentiality_ref == defaultRegistration.confidentiality_ref

testNftCoreRejectRestoresSenderOwnership = script do
  setTime baseTime
  parties <- allocateNftCoreParties "Reject"
  registry_cid <- createRegistry parties.registry_admin None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration parties.registry_admin registry_cid parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer parties.registry_admin parties.alice nft_cid transfer_offer None
  rejected_cid <- rejectPendingTransfer parties.registry_admin parties.bob pending_cid

  assertNoNftView parties.registry_admin pending_cid
  assertActiveNftView
    parties.registry_admin
    rejected_cid
    parties.registry_admin
    parties.alice
    defaultRegistration

