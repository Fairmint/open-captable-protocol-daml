  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
