testNftCoreExpiryBlocksResolutionUntilExpiredThenRestoresSender = script do
  setTime baseTime
  parties <- allocateNftCoreParties "Expire"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  pending_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
      None

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.bob]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      (NftAsset.Expire with actor = parties.bob)

  setTime afterFirstTransferExpiry

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.bob]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Accept

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.bob]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Reject

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.alice]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      NftAsset.Withdraw

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.charlie]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftTransferOffer pending_cid)
      (NftAsset.Expire with actor = parties.charlie)

  expired_cid <-
    expirePendingTransfer
      parties.registry_authority
      parties.operator
      parties.bob
      pending_cid

  assertNoNftView parties.registry_authority pending_cid
  assertActiveNftView
    parties.registry_authority
    expired_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration

testNftCoreStandingReceiveAuthorizationCompletesTransferImmediately = script do
  setTime baseTime
  parties <- allocateNftCoreParties "StandingAuth"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  auth_cid <-
    createStandingReceiveAuthorization
      parties.registry_authority
      parties.operator
      parties.bob
      (Some defaultCollection)
      (Some afterFirstTransferExpiry)
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  transferred_cid <-
    offerTransfer
      parties.registry_authority
      parties.operator
      parties.alice
      nft_cid
      transfer_offer
      (Some auth_cid)

  assertNoNftView parties.registry_authority nft_cid
  assertActiveNftView
    parties.registry_authority
    transferred_cid
    parties.registry_authority
    parties.operator
    parties.bob
    defaultRegistration
  assertStandingReceiveAuthorizationVisibleTo parties.registry_authority auth_cid
  assertStandingReceiveAuthorizationVisibleTo parties.operator auth_cid
  assertStandingReceiveAuthorizationVisibleTo parties.bob auth_cid

testNftCoreStandingReceiveAuthorizationRejectsExpiredOrMismatchedScope = script do
  setTime baseTime
  parties <- allocateNftCoreParties "StandingAuthValidation"
  registry_cid <- createRegistry parties.registry_authority parties.operator None
  NftRegistry.MintResult{nft_cid} <-
    mintDefaultRegistration
      parties.registry_authority
      parties.operator
      registry_cid
      parties.alice
  mismatched_auth_cid <-
    createStandingReceiveAuthorization
      parties.registry_authority
      parties.operator
      parties.bob
      (Some otherCollection)
      (Some afterFirstTransferExpiry)
  expired_auth_cid <-
    createStandingReceiveAuthorization
      parties.registry_authority
      parties.operator
      parties.bob
      (Some defaultCollection)
      (Some baseTime)
  let transfer_offer =
        TransferOfferTerms with
          receiver = parties.bob
          expires_at = firstTransferExpiry

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.alice]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with
        transfer_offer
        receive_authorization_cid = Some mismatched_auth_cid
      )

  submitMustFail (actAs [parties.registry_authority, parties.operator, parties.alice]) do
    exerciseCmd
      (fromInterfaceContractId @NftAsset.NftAsset nft_cid)
      (NftAsset.OfferTransfer with
        transfer_offer
        receive_authorization_cid = Some expired_auth_cid
      )

  assertActiveNftView
    parties.registry_authority
    nft_cid
    parties.registry_authority
    parties.operator
    parties.alice
    defaultRegistration

