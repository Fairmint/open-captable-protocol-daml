module OpenCapTable.TestStockClassSplit where

import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.StockClassSplit
import qualified Fairmint.OpenCapTable.StockClassSplit as SCS
import Fairmint.OpenCapTable.Types (OcfRatio(..), OcfStockClassType(..), OcfStockClassConversionRight(..), OcfConversionMechanism(..), OcfConversionTrigger(..), OcfConversionTriggerType(..), OcfAnyConversionRight(..))
import qualified Fairmint.OpenCapTable.Issuer as Iss
import OpenCapTable.Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [system_operator, issuer] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.IssuerOcfData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = DT.time (DA.date 2020 Jan 15) 12 0 0
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 10000000.0)
        comments = []

-- Create a stock class to split
createStockClass issuer issuerCid stockClassId =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClass with
      stock_class_data = StockClassOcfData with
        id = stockClassId
        name = "Common Stock"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS"
        initial_shares_authorized = 10000000.0
        board_approval_date = None
        stockholder_approval_date = None
        votes_per_share = 1.0
        par_value = None
        price_per_share = None
        seniority = 1.0
        conversion_rights = []
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        comments = []

-- Test 1: Standard 2-for-1 stock split
testStockClassSplit_TwoForOne = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createStockClass issuer issuerCid "COMMON"
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClassSplit with
      split_data = StockClassSplitOcfData with
        id = "TX_STOCK_CLASS_SPLIT_1"
        date = DT.time (DA.date 2025 Jul 01) 0 0 0
        stock_class_id = "COMMON"
        split_ratio = OcfRatio with numerator = 2.0, denominator = 1.0
        comments = []
  submit issuer do
    exerciseCmd cid SCS.ArchiveByIssuer
  pure ()

-- Test 2: 10-for-1 stock split with comments
testStockClassSplit_TenForOne = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createStockClass issuer issuerCid "COMMON"
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClassSplit with
      split_data = StockClassSplitOcfData with
        id = "TX_STOCK_CLASS_SPLIT_2"
        date = DT.time (DA.date 2025 Dec 15) 0 0 0
        stock_class_id = "COMMON"
        split_ratio = OcfRatio with numerator = 10.0, denominator = 1.0
        comments = ["Pre-IPO stock split to reduce per-share price.", "Board resolution dated 2025-12-01."]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Test 3: Reverse stock split (1-for-10)
testStockClassSplit_ReverseOneForTen = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createStockClass issuer issuerCid "COMMON"
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClassSplit with
      split_data = StockClassSplitOcfData with
        id = "TX_STOCK_CLASS_SPLIT_REVERSE"
        date = DT.time (DA.date 2025 Sep 01) 0 0 0
        stock_class_id = "COMMON"
        split_ratio = OcfRatio with numerator = 1.0, denominator = 10.0
        comments = ["Reverse split to maintain NASDAQ minimum share price requirement."]
  submit issuer do
    exerciseCmd cid SCS.ArchiveByIssuer
  pure ()
