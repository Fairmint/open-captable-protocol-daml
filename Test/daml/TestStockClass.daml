module TestStockClass where
import Fairmint.OpenCapTable.StockClass
import HelpersTriggers (ocfTriggerElectiveAtWill)
import Fairmint.OpenCapTable.Types (OcfStockClassConversionRight(..), OcfRatio(..), OcfMonetary(..), OcfConversionMechanism(..), OcfStockClassType(..))
import Setup
import Daml.Script
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT

createStockClass issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = OcfStockClassData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []

testCreateAndArchiveStockClass = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  scid <- createStockClass issuer system_operator ctx
  submit issuer do
    exerciseCmd scid Fairmint.OpenCapTable.StockClass.ArchiveByIssuer
  pure ()

testCreateAndArchiveStockClassBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  scid <- createStockClass issuer system_operator ctx
  submitMulti [issuer, system_operator] [] do
    exerciseCmd scid Archive
  pure ()

-- Optionals Some variant with one conversion right
testCreateStockClass_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  let convRight = OcfStockClassConversionRight with
        type_ = "STOCK_CLASS_CONVERSION_RIGHT"
        conversion_mechanism = OcfConversionMechanismRatioConversion
        conversion_trigger = ocfTriggerElectiveAtWill
        converts_to_stock_class_id = "SC_COMMON"
        ratio = Some (OcfRatio with numerator = 1.0, denominator = 1.0)
        percent_of_capitalization = None
        conversion_price = None
        reference_share_price = None
        reference_valuation_price_per_share = None
        discount_rate = None
        valuation_cap = None
        floor_price_per_share = None
        ceiling_price_per_share = None
        custom_description = None
        expires_at = None
  scid <- submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = OcfStockClassData with
        id = "SC_PREFERRED"
        name = "Preferred"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "PS-"
        initial_shares_authorized = 2_000_000.0
        votes_per_share = 1.0
        seniority = 2.0
        board_approval_date = Some (DT.time (DA.date 2024 Jan 1) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 15) 0 0 0)
        par_value = Some (OcfMonetary with amount = 0.0001, currency = "USD")
        price_per_share = Some (OcfMonetary with amount = 1.0, currency = "USD")
        liquidation_preference_multiple = Some 1.0
        participation_cap_multiple = None
        conversion_rights = [ convRight ]
        comments = ["Preferred terms"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd scid Archive
  pure ()
