module TestEquityCompensationExercise where
import Fairmint.OpenCapTable.EquityCompensationExercise
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

mkIssuer issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = Some (DT.time (DA.date 2020 Jan 15) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []

createEquityCompensationExercise issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateEquityCompensationExercise with
      exercise_data = OcfEquityCompensationExerciseData with
        id = "TX_EC_EX_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-1"
        quantity = 10.0
        consideration_text = None
        resulting_security_ids = ["SEC-RES-1"]
        comments = []

testCreateAndArchiveEquityCompensationExercise = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- createEquityCompensationExercise issuer issuerCid
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.EquityCompensationExercise.ArchiveByIssuer
  pure ()

testCreateAndArchiveEquityCompensationExerciseBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  cid <- createEquityCompensationExercise issuer issuerCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


