module TestEquityCompensationExercise where
import Fairmint.OpenCapTable.EquityCompensationExercise
import Fairmint.OpenCapTable.Types
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveEquityCompensationExercise = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create Equity Compensation Exercise
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd EquityCompensationExercise with
      context = ctx
      exercise_data = OcfEquityCompensationExerciseData with
        ocf_id = "TX_EC_EX_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-1"
        quantity = 10.0
        consideration_text = None
        resulting_security_ids = ["SEC-RES-1"]
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.EquityCompensationExercise.ArchiveByIssuer
  pure ()


