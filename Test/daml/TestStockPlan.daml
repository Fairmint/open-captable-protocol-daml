module TestStockPlan where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockClass()
import Fairmint.OpenCapTable.StockPlan()
import Fairmint.OpenCapTable.Types
import DA.Date
import DA.Time

happyCase = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  _ <- submit issuer $ exerciseCmd issuerCid CreateStockPlan with
    stock_classes = [stockClassCid]
    plan_data = OcfStockPlanData with
      plan_name = "2025 Equity Incentive Plan"
      board_approval_date = Some (time (DA.Date.date 2025 Jan 1) 0 0 0)
      stockholder_approval_date = None
      initial_shares_reserved = 1_000_000.0
      default_cancellation_behavior = Some OcfPlanCancelReturnToPool
      comments = None
  pure ()

invalidNoClasses = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  submitMustFail issuer $ exerciseCmd issuerCid CreateStockPlan with
    stock_classes = []
    plan_data = OcfStockPlanData with
      plan_name = "Bad Plan"
      board_approval_date = None
      stockholder_approval_date = None
      initial_shares_reserved = 100.0
      default_cancellation_behavior = None
      comments = None
  pure ()
