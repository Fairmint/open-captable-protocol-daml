  TestUsers{system_operator, issuer, rando} <- setupUsers
  stockClassCid <- createStockClass system_operator issuer
  -- Try to update stock class data as non-issuer party
  newStockClassData <- pure $ OcfStockClassData with
    class_type = OcfStockClassTypeCommon
    name = "Unauthorized Update"
    default_id_prefix = "UNAuth-"
    initial_shares_authorized = 15000.0
    board_approval_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
    stockholder_approval_date = Some (time (DA.Date.date 2020 Jan 20) 12 0 0)
