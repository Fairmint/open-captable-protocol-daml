module TestUpdateStockClassData where
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.Types
import Daml.Script
import DA.Optional
import DA.Date
import DA.Time
-- Helper function to create a stock class for testing
createStockClass system_operator issuer = script do
  issuerCid <- createIssuer system_operator issuer

  let stockClassData = OcfStockClassData with
        class_type = OcfStockClassTypeCommon
        name = "Common Stock"
        default_id_prefix = "CS-"
        initial_shares_authorized = 10000.0
        board_approval_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
        stockholder_approval_date = Some (time (DA.Date.date 2020 Jan 20) 12 0 0)
        votes_per_share = 1.0
        par_value = Some (OcfMonetary with amount = 0.001, currency = "USD")
        price_per_share = Some (OcfMonetary with amount = 1.00, currency = "USD")
        seniority = 1.0
        liquidation_preference_multiple = Some 1.0
        participation_cap_multiple = Some 2.0
        conversion_rights = []
        comments = None
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = stockClassData
  pure stockClassCid
-- Happy Case --
happyCase = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  stockClassCid <- createStockClass system_operator issuer
  -- Update stock class data with new information
  newStockClassData <- pure $ OcfStockClassData with
    class_type = OcfStockClassTypeCommon
    name = "Updated Common Stock"
    default_id_prefix = "UCS-"
    initial_shares_authorized = 20000.0
    board_approval_date = Some (time (DA.Date.date 2020 Feb 1) 12 0 0)
    stockholder_approval_date = Some (time (DA.Date.date 2020 Feb 5) 12 0 0)
    votes_per_share = 2.0
    par_value = Some (OcfMonetary with amount = 0.01, currency = "USD")
    price_per_share = Some (OcfMonetary with amount = 2.00, currency = "USD")
    seniority = 2.0
    liquidation_preference_multiple = Some 1.5
    participation_cap_multiple = Some 3.0
    conversion_rights = []
    comments = None
  updatedStockClassCid <- submit issuer $ exerciseCmd stockClassCid UpdateStockClassData with
    new_stock_class_data = newStockClassData
  -- Verify the update was successful
  updatedContract <- queryContractId issuer updatedStockClassCid
  assertMsg "Updated stock class contract not found" (isSome updatedContract)
  -- Verify old contract is archived
  oldContract <- queryContractId issuer stockClassCid
  assertMsg "Old stock class contract should be archived" (isNone oldContract)
  pure()
-- Validation Tests --
invalidName = script do
  TestUsers{system_operator, issuer} <- setupUsers
  stockClassCid <- createStockClass system_operator issuer
  -- Try to update with invalid (empty) name
  invalidStockClassData <- pure $ OcfStockClassData with
    class_type = OcfStockClassTypeCommon
    name = ""  -- Empty name should fail validation
    default_id_prefix = "CS-"
    initial_shares_authorized = 10000.0
    board_approval_date = Some (time (DA.Date.date 2020 Jan 15) 12 0 0)
    stockholder_approval_date = Some (time (DA.Date.date 2020 Jan 20) 12 0 0)
    votes_per_share = 1.0
    par_value = Some (OcfMonetary with amount = 0.001, currency = "USD")
    price_per_share = Some (OcfMonetary with amount = 1.00, currency = "USD")
    seniority = 1.0
    liquidation_preference_multiple = Some 1.0
    participation_cap_multiple = Some 2.0
    conversion_rights = []
    comments = None
  submitMustFail issuer $ exerciseCmd stockClassCid UpdateStockClassData with
    new_stock_class_data = invalidStockClassData
