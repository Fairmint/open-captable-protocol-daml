-- Test updating after shares have been issued --
updateAfterSharesIssued = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  stockClassCid <- createStockClass system_operator issuer
  -- Issue some shares
  let transfer = TransferOperation with
        quantity = 1000.0
        recipient = alice
  stockPositionCid <- submit issuer $ exerciseCmd stockClassCid IssueStock with
    transfer = transfer
  -- Find the updated stock class contract (the original was archived)
  [(updatedStockClassCid, _)] <- query @StockClass issuer
  -- Now update the stock class data - should work and preserve issued shares count
  newStockClassData <- pure $ OcfStockClassData with
    class_type = OcfStockClassTypeCommon
    name = "Updated After Issuance"
    default_id_prefix = "UAI-"
    initial_shares_authorized = 50000.0
    board_approval_date = Some (time (DA.Date.date 2020 Mar 1) 12 0 0)
    stockholder_approval_date = Some (time (DA.Date.date 2020 Mar 5) 12 0 0)
    votes_per_share = 1.0
    par_value = Some (OcfMonetary with amount = 0.001, currency = "USD")
    price_per_share = Some (OcfMonetary with amount = 1.00, currency = "USD")
    seniority = 1.0
    liquidation_preference_multiple = Some 1.0
    participation_cap_multiple = Some 2.0
    conversion_rights = []
    comments = None
  finalStockClassCid <- submit issuer $ exerciseCmd updatedStockClassCid UpdateStockClassData with
    new_stock_class_data = newStockClassData
  -- Verify the update was successful and issued shares were preserved
  Some finalContract <- queryContractId issuer finalStockClassCid
  assertMsg "Issued shares should be preserved" (finalContract.issued_shares == 1000.0)
  pure()
