module TestOcpFactory where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.IssuerAuthorization
import Setup
import Daml.Script

testAuthorizeAndWithdraw = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  factoryCid <- submit system_operator do
    createCmd OcpFactory with
      system_operator = system_operator
      featured_app_right = toInterfaceContractId rightCid
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  -- Withdraw authorization
  _ <- submit system_operator do
    exerciseCmd authCid WithdrawAuthorization
  pure ()
