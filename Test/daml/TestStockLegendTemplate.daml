module TestStockLegendTemplate where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockLegendTemplate()
import Fairmint.OpenCapTable.Types

happyCase = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  _ <- submit issuer $ exerciseCmd issuerCid CreateStockLegendTemplate with
    template_data = OcfStockLegendTemplateData with
      name = "Standard Legend"
      text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
      comments = None
  pure ()

invalidEmpty = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  submitMustFail issuer $ exerciseCmd issuerCid CreateStockLegendTemplate with
    template_data = OcfStockLegendTemplateData with
      name = ""
      text = ""
      comments = None
  pure ()
