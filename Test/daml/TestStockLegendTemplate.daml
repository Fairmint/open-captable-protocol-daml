module TestStockLegendTemplate where
import Fairmint.OpenCapTable.StockLegendTemplate
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script

testCreateAndArchiveStockLegendTemplate = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  _cid <- submitMulti [issuer, system_operator] [] do
    createCmd StockLegendTemplate with
      context = ctx
      template_data = OcfStockLegendTemplateData with
        ocf_id = "LEG_STD"
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = []
  pure ()
