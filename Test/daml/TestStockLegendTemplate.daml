module TestStockLegendTemplate where
import Fairmint.OpenCapTable.StockLegendTemplate
import Setup
import Daml.Script

createStockLegendTemplate issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd StockLegendTemplate with
      context = ctx
      template_data = OcfStockLegendTemplateData with
        id = "LEG_STD"
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = []

-- Primary test: normal flow archives via ArchiveByIssuer
testCreateAndArchiveByIssuer = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  cid <- createStockLegendTemplate issuer system_operator ctx
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.StockLegendTemplate.ArchiveByIssuer
  pure ()

-- Secondary test: explicitly exercise built-in Archive via submitMulti (for coverage)
testCreateAndArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  cid <- createStockLegendTemplate issuer system_operator ctx
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()

-- Optionals Some
testStockLegendTemplate_OptionalsSome = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd StockLegendTemplate with
      context = ctx
      template_data = OcfStockLegendTemplateData with
        id = "LEG_EXT"
        name = "Extended Legend"
        text = "EXTENDED LEGEND TEXT"
        comments = ["Longer legend text"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()
