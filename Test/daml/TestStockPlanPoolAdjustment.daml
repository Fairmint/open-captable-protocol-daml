module TestStockPlanPoolAdjustment where
import Fairmint.OpenCapTable.StockPlan
import Fairmint.OpenCapTable.StockPlanPoolAdjustment
import Fairmint.OpenCapTable.Types
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveStockPlanPoolAdjustment = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create Issuer to use creation choices
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = Some (DT.time (DA.date 2020 Jan 15) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []
  -- Create a stock plan to reference
  _planCid <- submitMulti [issuer, system_operator] [] do
    createCmd StockPlan with
      context = ctx
      plan_data = OcfStockPlanData with
        id = "PLAN_1"
        plan_name = "2024 Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1000.0
        default_cancellation_behavior = None
        stock_class_ids = ["SC_COMMON"]
        comments = []
  -- Create Stock Plan Pool Adjustment
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockPlanPoolAdjustment with
      adjustment_data = OcfStockPlanPoolAdjustmentData with
        id = "TX_STOCK_PLAN_POOL_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        stock_plan_id = "PLAN_1"
        board_approval_date = None
        stockholder_approval_date = None
        shares_reserved = 1500.0
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.StockPlanPoolAdjustment.ArchiveByIssuer
  pure ()


