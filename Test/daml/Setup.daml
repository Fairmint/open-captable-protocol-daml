module Setup where

import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.OcfObjects
import Daml.Script
import DA.Date

data TestUsers = TestUsers{ system_operator: Party, issuer: Party, alice: Party, bob: Party, charlie: Party, rando: Party }

setupUsers = script do
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  charlie <- allocateParty "Charlie"
  rando <- allocateParty "Rando"

  return TestUsers{ system_operator, issuer, alice, bob, charlie, rando }

createIssuer system_operator issuer = script do
  submitMulti [system_operator, issuer] [] $ createCmd Issuer with
    system_operator = system_operator
    issuer = issuer
    issuer_data = OcfIssuerData with
      legal_name = "TestIssuer Inc."
      formation_date = date 2020 Jan 15
      country_of_formation = "US"
      dba = None
      country_subdivision_of_formation = None
      tax_ids = []
      email = None
      phone = None
      address = None
      initial_shares_authorized = 1000