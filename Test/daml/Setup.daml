module Setup where
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import Splice.Api.FeaturedAppRightV1 as Featured
import Daml.Script
import DA.Date
import DA.Time
-- A minimal FeaturedAppRight instance the tests can use
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
    issuer : Party
    alice : Party
    bob : Party
    charlie : Party
    rando : Party
  where
    signatory dso
    observer provider, issuer, alice, bob, charlie, rando
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with dso, provider
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        -- no-op; return empty markers
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])
-- Exercise FeaturedAppRight choice to improve coverage
exerciseFeaturedAppRightChoice : Script ()
exerciseFeaturedAppRightChoice = script do
  system_operator <- allocateParty "SystemOperator"
  alice <- allocateParty "Alice"
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = system_operator
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  -- Controller is provider (system_operator)
  let rightIfaceCid : ContractId Featured.FeaturedAppRight = toInterfaceContractId testRightCid
  _ <- submit system_operator do
    exerciseCmd rightIfaceCid Featured.FeaturedAppRight_CreateActivityMarker with
      beneficiaries = [ Featured.AppRewardBeneficiary with beneficiary = alice, weight = 1.0 ]
  -- Exercise internal template choice (Archive)
  _ <- submit system_operator do
    exerciseCmd testRightCid Archive
  pure ()

data TestUsers = TestUsers{ system_operator: Party, issuer: Party, alice: Party, bob: Party, charlie: Party, rando: Party }
setupUsers = script do
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  charlie <- allocateParty "Charlie"
  rando <- allocateParty "Rando"
  return TestUsers{ system_operator, issuer, alice, bob, charlie, rando }

createIssuer system_operator issuer = script do
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = system_operator  -- Use system_operator as placeholder for unused parties
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  submitMulti [system_operator, issuer] [] $ createCmd Issuer with
    system_operator = system_operator
    issuer = issuer
    featured_app_right = toInterfaceContractId testRightCid
    issuer_data = OcfIssuerData with
      legal_name = "TestIssuer Inc."
      formation_date = time (DA.Date.date 2020 Jan 15) 12 0 0
      country_of_formation = "US"
      dba = None
      country_subdivision_of_formation = None
      country_subdivision_name_of_formation = None
      tax_ids = Some []
      email = None
      phone = None
      address = None
      initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
      comments = None
