module TestStockClassAuthorizedSharesAdjustment where
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.StockClassAuthorizedSharesAdjustment
import Fairmint.OpenCapTable.Types
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveStockClassAuthorizedSharesAdjustment = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create Issuer to use creation choices
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        ocf_id = "ISSUER_1"
        legal_name = "TestIssuer Inc."
        formation_date = Some (DT.time (DA.date 2020 Jan 15) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000.0)
        comments = []
  -- Create a stock class to reference
  _scid <- submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = OcfStockClassData with
        ocf_id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []
  -- Create Stock Class Authorized Shares Adjustment
  cid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateStockClassAuthorizedSharesAdjustment with
      adjustment_data = OcfStockClassAuthorizedSharesAdjustmentData with
        ocf_id = "TX_SC_AUTH_SHARES_ADJ_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        stock_class_id = "SC_COMMON"
        new_shares_authorized = 2_000_000.0
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.StockClassAuthorizedSharesAdjustment.ArchiveByIssuer
  pure ()


