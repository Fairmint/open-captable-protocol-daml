module TestStockTransactions where
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.Types
import Daml.Script
import DA.Date
import DA.Time

-- Happy path: transfer from Bob to Alice
transferHappy = script do
  TestUsers{system_operator, issuer, alice, bob} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 10000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  bobPosCid <- submit issuer $ exerciseCmd stockClassCid IssueStock with
    transfer = TransferOperation with recipient = bob; quantity = 2_000_000.0
  propCid <- submit bob $ exerciseCmd bobPosCid ProposeTransfer with
    transfer = TransferOperation with recipient = alice; quantity = 500_000.0
  _alicePos <- submit issuer $ exerciseCmd propCid AcceptTransfer with
    date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
  pure ()

-- Failure: cannot transfer more than owned
transferTooMuch = script do
  TestUsers{system_operator, issuer, alice, bob} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 10000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  bobPosCid <- submit issuer $ exerciseCmd stockClassCid IssueStock with
    transfer = TransferOperation with recipient = bob; quantity = 100.0
  submitMustFail bob $ exerciseCmd bobPosCid ProposeTransfer with
    transfer = TransferOperation with recipient = alice; quantity = 200.0
  pure ()

-- Repurchase happy path
repurchaseHappy = script do
  TestUsers{system_operator, issuer, bob} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  bobPosCid <- submit issuer $ exerciseCmd stockClassCid IssueStock with
    transfer = TransferOperation with recipient = bob; quantity = 300.0
  -- Fetch position to get latest stock class cid after issuance
  Some bobPos <- queryContractId bob bobPosCid
  submit issuer $ exerciseCmd bobPos.stock_class RepurchaseStock with
    position = bobPosCid
    quantity = 100.0
    date = DA.Time.time (DA.Date.date 2025 Jan 2) 0 0 0
  pure ()

