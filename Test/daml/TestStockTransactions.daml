-- Negative: split exceeding authorized should fail
splitExceedsAuthorized = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 1000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  alicePos <- submit issuer $ exerciseCmd stockClassCid IssueStock with
    transfer = TransferOperation with recipient = alice; quantity = 600.0
  Some alicePosData <- queryContractId alice alicePos
  -- 600 * 2.0 = 1200 > 1000 authorized -> should fail
  submitMustFail issuer $ exerciseCmd alicePosData.stock_class SplitStockClass with
    split_ratio = 2.0
    positions = [alicePos]
    date = DA.Time.time (DA.Date.date 2025 Jan 9) 0 0 0
  pure ()

-- Transfer retraction
transferRetraction = script do
  TestUsers{system_operator, issuer, alice, bob} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = OcfInitialSharesNumeric 10000000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  bobPosCid <- submit issuer $ exerciseCmd stockClassCid IssueStock with
    transfer = TransferOperation with recipient = bob; quantity = 1_000.0
  propCid <- submit bob $ exerciseCmd bobPosCid ProposeTransfer with
    transfer = TransferOperation with recipient = alice; quantity = 100.0
  submitMulti [bob, issuer, system_operator] [] $ exerciseCmd propCid RetractTransfer with
    date = DA.Time.time (DA.Date.date 2025 Jan 4) 0 0 0
  pure ()
