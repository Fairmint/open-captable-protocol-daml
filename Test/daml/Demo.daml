module Demo where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.StockPlan
import Fairmint.OpenCapTable.StockLegendTemplate
import Fairmint.OpenCapTable.VestingTerms
import Fairmint.OpenCapTable.Stakeholder
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script
import DA.Date
import DA.Time
-- The goal as described by Thibauld (adapted for simplified implementation):
-- 1. Authorize and create the issuer "Acme Inc" with 15M authorized issuer shares
-- 2. Create a stockclass "Common" with 12M authorized shares
-- 3. Create 2 stakeholders: "Alice" and "Bob"
-- 4. Create a stock legend template
-- 5. Create vesting terms and a stock plan

testDemo = script do
  -- Pre-req: create parties
  TestUsers{system_operator, issuer, alice, bob, rando} <- setupUsers
  -- Create test featured app right
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = bob
      charlie = rando  -- Use rando as charlie since charlie is not used in this test
      rando = rando
  -- Pre-req: deploy OcpFactory (this is not strictly required ATM)
  openCapTableFactoryCid <- submit system_operator do
    createCmd OcpFactory
      with
        system_operator = system_operator
        featured_app_right = toInterfaceContractId testRightCid
  -- 1.1: System operator authorizes issuer
  issuerAuthorizationCid <- submit system_operator do
    exerciseCmd openCapTableFactoryCid AuthorizeIssuer
      with
        issuer = issuer
  -- 1.2: Issuer creates issuer contract
  issuerCid <- submit issuer do
    exerciseCmd issuerAuthorizationCid CreateIssuer
      with
        issuer_data = OcfIssuerData with
          legal_name = "Acme Inc"
          formation_date = Some (time (DA.Date.date 2010 Jun 1) 12 0 0)
          country_of_formation = "US"
          dba = None
          country_subdivision_of_formation = None
          country_subdivision_name_of_formation = None
          tax_ids = Some []
          email = None
          phone = None
          address = None
          initial_shares_authorized = Some (OcfInitialSharesNumeric 15_000_000.0)
          comments = None
  -- 2.1: Issuer creates stockclass "Common" with 12M authorized shares
  _commonStockClassCid <- submit issuer do
    exerciseCmd issuerCid CreateStockClass
      with
        -- OCF StockClass data
        stock_class_data = OcfStockClassData with
          name = "Common"
          class_type = OcfStockClassTypeCommon
          default_id_prefix = "CS-"
          initial_shares_authorized = 12_000_000.0
          votes_per_share = 1.0
          seniority = 1.0

          -- Optional fields
          board_approval_date = None
          stockholder_approval_date = None
          par_value = None
          price_per_share = None
          liquidation_preference_multiple = None
          participation_cap_multiple = None
          conversion_rights = []
          comments = None

  -- 3.1: Create stakeholders for Alice and Bob
  _ <- submit issuer do
    exerciseCmd issuerCid CreateStakeholder with
      stakeholder_data = OcfStakeholderData with
        name = "Alice"
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = None
  _ <- submit issuer do
    exerciseCmd issuerCid CreateStakeholder with
      stakeholder_data = OcfStakeholderData with
        name = "Bob"
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationships = []
        current_status = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = None

  -- 4.1: Create a stock legend template
  _ <- submit issuer do
    exerciseCmd issuerCid CreateStockLegendTemplate with
      template_data = OcfStockLegendTemplateData with
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = None

  -- 5.1: Create vesting terms (single start condition)
  let vtCond = OcfVestingCondition with
        id_ = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  vestingTermsCid <- submit issuer do
    exerciseCmd issuerCid CreateVestingTerms with
      vesting_terms_data = OcfVestingTermsData with
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = None

  -- 5.2: Create a stock plan
  _planCid <- submit issuer do
    exerciseCmd issuerCid CreateStockPlan with
      stock_classes = []
      plan_data = OcfStockPlanData with
        plan_name = "2025 Equity Incentive Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1_000_000.0
        default_cancellation_behavior = None
        comments = None
  pure ()
