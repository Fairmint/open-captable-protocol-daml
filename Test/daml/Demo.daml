module Demo where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.StockPlan
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script
import DA.Date
import DA.Time
-- The goal as described by Thibauld:
-- 1. We create the issuer "Acme Inc" with 15M authorized shares
-- 2. We create a stockclass "Common" (for common shares) with 10M authorized shares (of this class)
-- 3. We create 2 stakeholders: "John Bob" and "Jim Alice"
-- 4. We issue 10M common shares to Bob
-- 5. Bob transfers 2M common shares to Alice
testDemo = script do
  -- Pre-req: create parties (more can be added anytime)
  TestUsers{system_operator, issuer, alice, bob, rando} <- setupUsers
  -- Create test featured app right
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = bob
      charlie = rando  -- Use rando as charlie since charlie is not used in this test
      rando = rando
  -- Pre-req: deploy OcpFactory (this is not strictly required ATM)
  openCapTableFactoryCid <- submit system_operator do
    createCmd OcpFactory
      with
        system_operator = system_operator
        featured_app_right = toInterfaceContractId testRightCid
  -- 1.1: System operator authorizes issuer
  issuerAuthorizationCid <- submit system_operator do
    exerciseCmd openCapTableFactoryCid AuthorizeIssuer
      with
        issuer = issuer
  -- 1.2: Issuer creates issuer contract
  issuerCid <- submit issuer do
    exerciseCmd issuerAuthorizationCid CreateIssuer
      with
        issuer_data = OcfIssuerData with
          legal_name = "Acme Inc"
          formation_date = Some (time (DA.Date.date 2010 Jun 1) 12 0 0)
          country_of_formation = "US"
          dba = None
          country_subdivision_of_formation = None
          tax_ids = Some []
          email = None
          phone = None
          address = None
          initial_shares_authorized = Some 15_000_000.0
          comments = None
  -- 2.1: Issuer creates stockclass "Common" with 12M authorized shares
  commonStockClassCid <- submit issuer do
    exerciseCmd issuerCid CreateStockClass
      with
        -- OCF StockClass data
        stock_class_data = OcfStockClassData with
          name = "Common"
          class_type = OcfStockClassTypeCommon
          default_id_prefix = "CS-"
          initial_shares_authorized = OcfInitialSharesNumeric 12_000_000.0
          votes_per_share = 1.0
          seniority = 1.0

          -- Optional fields
          board_approval_date = None
          stockholder_approval_date = None
          par_value = None
          price_per_share = None
          liquidation_preference_multiple = None
          participation_cap_multiple = None
          conversion_rights = []
          comments = None

  -- 4.1: Issuer issues 10M common shares to Bob
  bobStockPositionCid <- submit issuer do
    exerciseCmd commonStockClassCid IssueStock
      with
        transfer = TransferOperation with
          recipient = bob
          quantity = 10_000_000.0
  -- Fetch latest StockClass cid after issuance (previous version replaced)
  [(latestStockClassCid, _)] <- query @StockClass issuer
  -- 5.1: Bob proposes 2M common share transfer to Alice
  transferProposalCid <- submit bob do
    exerciseCmd bobStockPositionCid ProposeTransfer
      with
        transfer = TransferOperation with
          recipient = alice
          quantity = 2_000_000.0
  -- 5.2: Issuer executes the transfer (accept) and Alice receives shares
  aliceStockPositionCid <- submit issuer do
    exerciseCmd transferProposalCid AcceptTransfer with
      date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
  pure()

  -- 6.1: Create stakeholders for Alice and Bob
  _ <- submit issuer do
    exerciseCmd issuerCid CreateStakeholder with
      stakeholder = alice
      stakeholder_data = OcfStakeholderData with
        name = "Alice"
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationship = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = None
  _ <- submit issuer do
    exerciseCmd issuerCid CreateStakeholder with
      stakeholder = bob
      stakeholder_data = OcfStakeholderData with
        name = "Bob"
        stakeholder_type = OcfStakeholderTypeIndividual
        issuer_assigned_id = None
        current_relationship = None
        primary_contact = None
        contact_info = None
        addresses = []
        tax_ids = []
        comments = None

  -- 7.1: Create a stock legend template
  _ <- submit issuer do
    exerciseCmd issuerCid CreateStockLegendTemplate with
      template_data = OcfStockLegendTemplateData with
        name = "Standard Legend"
        text = "THIS SECURITY HAS NOT BEEN REGISTERED..."
        comments = None

  -- 8.1: Create vesting terms (single start condition)
  let vtCond = OcfVestingCondition with
        id_ = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  vestingTermsCid <- submit issuer do
    exerciseCmd issuerCid CreateVestingTerms with
      vesting_terms_data = OcfVestingTermsData with
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = None

  -- 9.1: Create stock plan and issue a plan security to Alice
  planCid <- submit issuer do
    exerciseCmd issuerCid CreateStockPlan with
      stock_classes = [latestStockClassCid]
      plan_data = OcfStockPlanData with
        plan_name = "2025 Equity Incentive Plan"
        board_approval_date = None
        stockholder_approval_date = None
        initial_shares_reserved = 1_000_000.0
        default_cancellation_behavior = None
        comments = None
  grantCid <- submit issuer do
    exerciseCmd planCid IssuePlanSecurity with
      stakeholder = alice
      issuance_data = OcfEquityCompensationIssuanceData with
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 10_000.0
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        base_price = None
        early_exercisable = Some False
        vestings = None
        expiration_date = None
        termination_exercise_windows = []
        comments = None
      stock_class = latestStockClassCid
      vesting_terms = Some vestingTermsCid

  -- 9.2: Exercise a portion of the grant
  _ <- submit issuer do
    exerciseCmd grantCid ExerciseGrant with
      stock_class = latestStockClassCid
      quantity = 1_000.0
      date = DA.Time.time (DA.Date.date 2025 Jan 10) 0 0 0

  -- Refresh latest stock class after issuance from grant
  [(latestStockClassCid, _)] <- query @StockClass issuer

  -- 10.1: Create a valuation for the stock class
  _ <- submit issuer do
    exerciseCmd issuerCid CreateValuation with
      stock_class = latestStockClassCid
      valuation_data = OcfValuationData with
        provider = Some "Acme Advisory"
        board_approval_date = None
        stockholder_approval_date = None
        comments = None
        price_per_share = OcfMonetary with amount = 1.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
        valuation_type = OcfValuationType409A

  -- 11.1: Issue a convertible to Alice and convert part into common stock
  cCid <- submit issuer do
    exerciseCmd issuerCid IssueConvertible with
      stakeholder = alice
      issuance_data = OcfConvertibleIssuanceData with
        investment_amount = OcfMonetary with amount = 100_000.0; currency = "USD"
        convertible_type = OcfConvertibleNote
        conversion_triggers = [OcfConversionTriggerOptional]
        seniority = 1
        pro_rata = None
        comments = None
  _ <- submit issuer do
    exerciseCmd cCid Convert with
      stock_class = latestStockClassCid
      quantity = 100.0
      date = DA.Time.time (DA.Date.date 2025 Jan 12) 0 0 0

  -- Refresh latest stock class after convertible conversion
  [(latestStockClassCid, _)] <- query @StockClass issuer

  -- 12.1: Issue a warrant to Bob and exercise part into common stock
  wCid <- submit issuer do
    exerciseCmd issuerCid IssueWarrant with
      stakeholder = bob
      stock_class = latestStockClassCid
      issuance_data = OcfWarrantIssuanceData with
        quantity = 1_000.0
        exercise_price = OcfMonetary with amount = 1.0; currency = "USD"
        purchase_price = OcfMonetary with amount = 0.0; currency = "USD"
        exercise_triggers = [OcfConversionTriggerOptional]
        warrant_expiration_date = None
        vesting_terms_id = None
        comments = None
  _ <- submit issuer do
    exerciseCmd wCid ExerciseWarrant with
      quantity = 100.0
      date = DA.Time.time (DA.Date.date 2025 Jan 11) 0 0 0
  pure ()
