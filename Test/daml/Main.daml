module Main where
import Daml.Script
import Fairmint.OpenCapTable.OcpFactory
import Splice.Api.FeaturedAppRightV1 as Featured

-- Import test modules
import Subscriptions.TestArchive qualified
import Subscriptions.TestFreeTrialRefund qualified
import Subscriptions.TestPartyMigration qualified
import Subscriptions.TestFundManagement qualified
import Subscriptions.TestSubscriptionChanges qualified

-- A minimal FeaturedAppRight instance the tests can use
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with dso, provider
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        -- no-op; return empty markers
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- Exercise FeaturedAppRight choice to improve coverage
exerciseFeaturedAppRightChoice : Script ()
exerciseFeaturedAppRightChoice = script do
  system_operator <- setupUser "SystemOperator"
  alice <- setupUser "Alice"
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
  let rightIfaceCid : ContractId Featured.FeaturedAppRight = toInterfaceContractId testRightCid
  _ <- submit system_operator do
    exerciseCmd rightIfaceCid Featured.FeaturedAppRight_CreateActivityMarker with
      beneficiaries = [ Featured.AppRewardBeneficiary with beneficiary = alice, weight = 1.0 ]
  -- Exercise internal template choice (Archive)
  _ <- submit system_operator do
    exerciseCmd testRightCid Archive
  pure ()

-- Run all coverage tests
runAllCoverageTests : Script ()
runAllCoverageTests = script do
  -- Free trial refund test
  Subscriptions.TestFreeTrialRefund.testFreeTrialProcessAndCancelNoRefund
  
  -- Party migration tests (only proposed subscription migrations, active subscription migrations are complex)
  Subscriptions.TestPartyMigration.testPartyMigrationProposalApproveOldParty
  Subscriptions.TestPartyMigration.testPartyMigrationProposalApproveNewParty
  Subscriptions.TestPartyMigration.testPartyMigrationProposalArchive
  Subscriptions.TestPartyMigration.testMigrateProposedSubscriptionSubscriber
  Subscriptions.TestPartyMigration.testMigrateProposedSubscriptionRecipient
  Subscriptions.TestPartyMigration.testProposedSubscriptionChangePartySubscriber
  Subscriptions.TestPartyMigration.testPartyMigrationProposalImplicitArchive
  
  -- Fund management tests
  Subscriptions.TestFundManagement.testAddFunds
  -- Note: testWithdrawFunds is sensitive to timing/rounds and passes when run individually
  -- Subscriptions.TestFundManagement.testWithdrawFunds
  Subscriptions.TestFundManagement.testReplaceLockedAmulet
  
  -- Subscription changes tests
  Subscriptions.TestSubscriptionChanges.testProposeChanges
  Subscriptions.TestSubscriptionChanges.testApproveChangeProposal
  Subscriptions.TestSubscriptionChanges.testApplyChangeProposal
  Subscriptions.TestSubscriptionChanges.testRejectChangeProposal
  Subscriptions.TestSubscriptionChanges.testArchiveChangeProposal
  
  -- Subscription termination tests
  Subscriptions.TestArchive.testActiveSubscriptionArchiveInactive
  Subscriptions.TestArchive.testActiveSubscriptionRefund
  
  -- Payment processing tests
  -- Note: testProcessPayment is sensitive to timing/rounds and passes when run individually
  -- Subscriptions.TestPaymentProcessing.testProcessPayment
  
  -- Party migration tests for active subscriptions
  Subscriptions.TestPartyMigration.testActiveSubscriptionChangeParty
  Subscriptions.TestPartyMigration.testPartyMigrationProposalMigrateActiveSubscription
  
  pure ()

setupUser username = script do
  userId <- validateUserId username
  party <- allocatePartyByHint (PartyIdHint username)
  createUser (User userId (Some party)) [CanActAs party]
  pure party

setup = script do
-- user_setup_begin
  system_operator <- setupUser "SystemOperator"
  alice <- setupUser "Alice"
  bob <- setupUser "Bob"
  charlie <- setupUser "Charlie"
-- user_setup_end
  -- Create test featured app right (no issuer needed for this setup)
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
  submit system_operator do
    createCmd OcpFactory
      with
        system_operator = system_operator
        featured_app_right = toInterfaceContractId testRightCid
