module Main where

import Daml.Script
import Fairmint.OpenCapTable.OcpFactory
import Splice.Api.FeaturedAppRightV1 as Featured

-- A minimal FeaturedAppRight instance the tests can use
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider

    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with dso, provider
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        -- no-op; return empty markers
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

setupUser username = script do
  userId <- validateUserId username
  party <- allocatePartyByHint (PartyIdHint username)
  createUser (User userId (Some party)) [CanActAs party]
  pure party

setup = script do
-- user_setup_begin
  system_operator <- setupUser "SystemOperator"
  alice <- setupUser "Alice"
  bob <- setupUser "Bob"
  charlie <- setupUser "Charlie"
-- user_setup_end

  -- Create test featured app right (no issuer needed for this setup)
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with 
      dso = system_operator
      provider = system_operator

  submit system_operator do
    createCmd OcpFactory
      with
        system_operator = system_operator
        featured_app_right = toInterfaceContractId testRightCid
