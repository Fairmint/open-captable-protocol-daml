module TestDocument where
import Fairmint.OpenCapTable.Document
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script

testCreateAndArchiveDocument = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  _cid <- submitMulti [issuer, system_operator] [] do
    createCmd Document with
      context = ctx
      document_data = OcfDocument with
        path = Some "/docs/acme/charter.pdf"
        uri = None
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = None
        comments = None
  pure ()
