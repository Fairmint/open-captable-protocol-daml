module TestDocument where
import Fairmint.OpenCapTable.Document
import qualified Fairmint.OpenCapTable.Issuer as Iss
import Setup
import Daml.Script

testCreateAndArchiveDocument = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISS_FOR_DOC"
        legal_name = "DocCo"
        formation_date = None
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  docCid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateDocument with
      document_data = OcfDocument with
        id = "DOC_1"
        path = Some "/docs/acme/charter.pdf"
        uri = None
        md5 = "0123456789abcdef0123456789abcdef"
        related_objects = []
        comments = []
  submit issuer do
    exerciseCmd docCid Fairmint.OpenCapTable.Document.ArchiveByIssuer
  pure ()

testCreateAndArchiveDocumentBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISS_FOR_DOC2"
        legal_name = "DocCo2"
        formation_date = None
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = None
        comments = []
  docCid <- submit issuer do
    exerciseCmd issuerCid Iss.CreateDocument with
      document_data = OcfDocument with
        id = "DOC_2"
        path = Some "/docs/acme/charter2.pdf"
        uri = None
        md5 = "fedcba9876543210fedcba9876543210"
        related_objects = []
        comments = []
  submitMulti [issuer, system_operator] [] do
    exerciseCmd docCid Archive
  pure ()
