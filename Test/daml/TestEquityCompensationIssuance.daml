module TestEquityCompensationIssuance where
import Fairmint.OpenCapTable.EquityCompensationIssuance
import Fairmint.OpenCapTable.Types
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveEquityCompensationIssuance = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create Equity Compensation Issuance (NSO requires exercise_price)
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd EquityCompensationIssuance with
      context = ctx
      issuance_data = OcfEquityCompensationIssuanceTxData with
        ocf_id = "TX_EC_ISS_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "EC-1"
        custom_id = "EC-CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_plan_id = Some "PLAN_1"
        stock_class_id = Some "SC_COMMON"
        compensation_type = OcfCompensationTypeOptionNSO
        quantity = 100.0
        exercise_price = Some (OcfMonetary with amount = 1.0, currency = "USD")
        base_price = None
        early_exercisable = Some False
        vesting_terms_id = None
        vestings = []
        expiration_date = None
        termination_exercise_windows = []
        comments = []
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.EquityCompensationIssuance.ArchiveByIssuer
  pure ()


