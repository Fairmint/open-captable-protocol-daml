module TestIssuer where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Setup
import Daml.Script
import DA.Date
import DA.Time

createFactory system_operator featured_app_right =
  submit system_operator do
    createCmd OcpFactory with
      system_operator = system_operator
      featured_app_right = featured_app_right

createIssuerViaAuth issuer authCid =
  submit issuer do
    exerciseCmd authCid CreateIssuer with
      issuer_data = OcfIssuerData with
        id = "ISSUER_2"
        legal_name = "Acme Inc"
        formation_date = Some (time (DA.Date.date 2010 Jun 1) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = []

testCreateAndArchiveIssuer = script do
  -- Keep factory-based flow here to validate that path as well
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  factoryCid <- createFactory system_operator (getField @"featured_app_right" ctx)
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  issuerCid <- createIssuerViaAuth issuer authCid
  submit issuer do
    exerciseCmd issuerCid Fairmint.OpenCapTable.Issuer.ArchiveByIssuer
  pure ()

testCreateAndArchiveIssuerBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  factoryCid <- createFactory system_operator (getField @"featured_app_right" ctx)
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  issuerCid <- createIssuerViaAuth issuer authCid
  submitMulti [issuer, system_operator] [] do
    exerciseCmd issuerCid Archive
  pure ()
