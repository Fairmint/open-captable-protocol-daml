module TestIssuer where
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Setup
import Daml.Script
import DA.Date
import DA.Time

testCreateAndArchiveIssuer = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  -- Create FeaturedAppRight for context
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  -- Create factory and authorize issuer
  factoryCid <- submit system_operator do
    createCmd OcpFactory with
      system_operator = system_operator
      featured_app_right = toInterfaceContractId testRightCid
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  -- Create issuer
  _issuerCid <- submit issuer do
    exerciseCmd authCid CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Acme Inc"
        formation_date = Some (time (DA.Date.date 2010 Jun 1) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (OcfInitialSharesNumeric 1000.0)
        comments = None
  pure ()
