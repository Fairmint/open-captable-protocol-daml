module TestIssuerCreateStockClass where
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.Types
import Daml.Script
import DA.Optional
-- Happy Case --
happyCase = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  
  -- Create a common stock class
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass
    with
      stock_class_data = OcfStockClassData with
        name = "Common Stock"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = OcfInitialSharesNumeric 1000.0
        votes_per_share = 1.0
        seniority = 0.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = None
  -- Verify stock class was created with zero issued shares
  stockClassContract <- queryContractId system_operator stockClassCid
  assertMsg "StockClass contract not found" (isSome stockClassContract)
  
  let Some stockClass = stockClassContract
  assertMsg "Initial issued shares should be zero" (stockClass.issued_shares == 0.0)
  assertMsg "Stock class name should match" (stockClass.stock_class_data.name == "Common Stock")
  pure()
-- Test over-issuance protection --
cannotOverIssueShares = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  
  -- Create a stock class with limited authorized shares
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass
    with
      stock_class_data = OcfStockClassData with
        name = "Limited Stock"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "LS-"
        initial_shares_authorized = OcfInitialSharesNumeric 100.0  -- Only 100 shares authorized
        votes_per_share = 1.0
        seniority = 0.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = None
  -- Try to issue more shares than authorized - should fail
  submitMustFail issuer $ exerciseCmd stockClassCid IssueStock
    with
      transfer = TransferOperation with
        recipient = alice
        quantity = 150.0  -- More than the 100.0 authorized
  pure()
-- Test valid stock issuance --
canIssueWithinAuthorizedShares = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  
  -- Create a stock class
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass
    with
      stock_class_data = OcfStockClassData with
        name = "Valid Stock"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "VS-"
        initial_shares_authorized = OcfInitialSharesNumeric 1000.0
        votes_per_share = 1.0
        seniority = 0.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = None
  -- Issue valid amount of shares
  stockPositionCid <- submit issuer $ exerciseCmd stockClassCid IssueStock
    with
      transfer = TransferOperation with
        recipient = alice
        quantity = 50.0
  -- Verify stock position was created correctly
  stockPositionContract <- queryContractId alice stockPositionCid
  assertMsg "StockPosition contract not found" (isSome stockPositionContract)
  
  let Some stockPosition = stockPositionContract
  assertMsg "Stock position quantity should match" (stockPosition.quantity == 50.0)
  assertMsg "Stock position owner should be Alice" (stockPosition.owner == alice)
  assertMsg "Stock class ID should be set" (stockPosition.stock_class_id == "Valid Stock")
  pure()
-- Test conversion rights validation --
invalidConversionRightFails = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  
  -- Try to create stock class with invalid conversion right (negative rate)
  submitMustFail issuer $ exerciseCmd issuerCid CreateStockClass
    with
      stock_class_data = OcfStockClassData with
        name = "Invalid Conversion Stock"
        class_type = OcfStockClassTypePreferred
        default_id_prefix = "ICS-"
        initial_shares_authorized = OcfInitialSharesNumeric 1000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = 
          [ OcfStockClassConversionRight with
              type_ = "STOCK_CLASS_CONVERSION_RIGHT"
              conversion_mechanism = OcfConversionMechanismRatioConversion
              conversion_trigger = OcfConversionTriggerOptional
              converts_to_stock_class_id = "CommonStock"
              conversion_rate = Some (-1.0)  -- Invalid negative rate
              conversion_price = None
              expires_at = None
          ]
        comments = None
  pure()
