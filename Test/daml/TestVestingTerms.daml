module TestVestingTerms where
import Fairmint.OpenCapTable.VestingTerms
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script


testCreateAndArchiveVestingTerms = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  let vtCond = OcfVestingCondition with
        id_ = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  _vtCid <- submitMulti [issuer, system_operator] [] do
    createCmd VestingTerms with
      context = ctx
      vesting_terms_data = OcfVestingTermsData with
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = None
  pure ()
