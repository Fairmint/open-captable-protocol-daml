module TestVestingTerms where
import Fairmint.OpenCapTable.VestingTerms
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script


testCreateAndArchiveVestingTerms = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  let vtCond = OcfVestingCondition with
        id_ = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  vtCid <- submitMulti [issuer, system_operator] [] do
    createCmd VestingTerms with
      context = ctx
      vesting_terms_data = OcfVestingTermsData with
        id = "VT_1"
        name = "Standard 1k at start"
        description = "All at start"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = []
  -- Archive created VestingTerms via issuer
  submit issuer do
    exerciseCmd vtCid Fairmint.OpenCapTable.VestingTerms.ArchiveByIssuer
  pure ()

-- Secondary test: archive built-in Archive via submitMulti
testCreateAndArchiveVestingTermsBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  let vtCond = OcfVestingCondition with
        id_ = "start"
        description = Some "All at start"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  vtCid <- submitMulti [issuer, system_operator] [] do
    createCmd VestingTerms with
      context = ctx
      vesting_terms_data = OcfVestingTermsData with
        id = "VT_2"
        name = "Standard 1k at start 2"
        description = "All at start 2"
        allocation_type = OcfAllocationCumulativeRounding
        vesting_conditions = [vtCond]
        comments = []
  submitMulti [issuer, system_operator] [] do
    exerciseCmd vtCid Archive
  pure ()
