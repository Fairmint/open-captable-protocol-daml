module TestVestingTerms where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.VestingTerms()
import Fairmint.OpenCapTable.Types
import DA.Date()
import DA.Time()

happyCase = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  let vc1 = OcfVestingCondition with
        id_ = "start"
        description = Some "Start condition"
        portion = None
        quantity = Some 1000.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  _ <- submit issuer $ exerciseCmd issuerCid CreateVestingTerms with
    vesting_terms_data = OcfVestingTermsData with
      name = "Standard 1k at start"
      description = "All at start"
      allocation_type = OcfAllocationCumulativeRounding
      vesting_conditions = [vc1]
      comments = None
  pure ()

invalidBothPortionAndQuantity = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  let vc1 = OcfVestingCondition with
        id_ = "bad"
        description = None
        portion = Some (OcfVestingConditionPortion with numerator = 1.0, denominator = 4.0, remainder = False)
        quantity = Some 100.0
        trigger = OcfVestingStartTrigger
        next_condition_ids = []
  submitMustFail issuer $ exerciseCmd issuerCid CreateVestingTerms with
    vesting_terms_data = OcfVestingTermsData with
      name = "Bad"
      description = "invalid"
      allocation_type = OcfAllocationCumulativeRounding
      vesting_conditions = [vc1]
      comments = None
  pure ()
