module Shared.TestUtils where
import Daml.Script
import DA.Time
import qualified DA.Set as Set
import DA.List (head, sortOn)
import Splice.Amulet qualified as Amulet
import Splice.AmuletRules
import Splice.Schedule
import Splice.AmuletConfig
import Splice.Issuance
import Splice.Fees
import Splice.DecentralizedSynchronizer
import Splice.Round (OpenMiningRound)

-- | A set of disclosures with the parties that own the disclosed contracts
-- In Script tests, we track the parties to use them with readAs in submit
data Disclosures' = Disclosures'
  { disclosures : [Disclosure]
  , readAsParties : [Party]  -- Parties that own the disclosed contracts
  }

instance Monoid Disclosures' where
  mempty = Disclosures' [] []

instance Semigroup Disclosures' where
  (Disclosures' ds1 ps1) <> (Disclosures' ds2 ps2) =
    Disclosures' (ds1 <> ds2) (ps1 <> ps2)

-- | Retrieve a disclosed contract by its contract-id from a specific party's ACS.
-- Uses the built-in queryDisclosure function from Daml.Script
-- Tracks the party for later use with readAs in submit
queryDisclosure' : forall t. Template t => Party -> ContractId t -> Script Disclosures'
queryDisclosure' p cid = do
  optDisc <- queryDisclosure @t p cid
  case optDisc of
    None -> error $ "Disclosure not found for: " <> show cid
    Some d -> pure $ Disclosures' [d] [p]

-- | Helper to deduplicate a list
dedup : Eq a => [a] -> [a]
dedup [] = []
dedup (x::xs) = x :: dedup (filter (/= x) xs)

-- | Version of submitWithDisclosures for Daml Script tests
-- In Daml Script, submitWithDisclosures needs readAs to provide visibility
-- This is different from production where disclosures work through the JSON API
submitWithDisclosures' : Party -> Disclosures' -> Commands a -> Script a
submitWithDisclosures' actingParty (Disclosures' _ds readAsParties') cmds = do
  -- Deduplicate and filter out the acting party
  let readAsFiltered = dedup $ filter (/= actingParty) readAsParties'
  if null readAsFiltered
    then submit actingParty cmds
    else submit (actAs actingParty <> readAs readAsFiltered) cmds

-- | Version of submitWithDisclosuresMustFail for Daml Script tests
submitWithDisclosuresMustFail' : Party -> Disclosures' -> Commands a -> Script ()
submitWithDisclosuresMustFail' actingParty (Disclosures' _ds readAsParties') cmds = do
  let readAsFiltered = dedup $ filter (/= actingParty) readAsParties'
  if null readAsFiltered
    then submitMustFail actingParty cmds
    else submitMustFail (actAs actingParty <> readAs readAsFiltered) cmds
-- Minimal AmuletConfig for tests
defaultTestAmuletConfig : AmuletConfig USD
defaultTestAmuletConfig = AmuletConfig with
  transferConfig = TransferConfig with
    createFee = FixedFee 0.01
    holdingFee = RatePerRound 0.0000001  -- Very low holding fee for long-lived amulets in tests
    transferFee = SteppedRate with initialRate = 0.0; steps = [(1.0, 0.0)]
    lockHolderFee = FixedFee 0.01
    extraFeaturedAppRewardAmount = 0.0
    maxNumInputs = 10  -- Allow multiple inputs for fund management operations
    maxNumOutputs = 10  -- Allow multiple outputs for transfers
    maxNumLockHolders = 2
  issuanceCurve = Schedule with
    initialValue = IssuanceConfig with
      amuletToIssuePerYear = 1000.0
      validatorRewardPercentage = 0.0
      appRewardPercentage = 0.0
      validatorRewardCap = 0.0
      featuredAppRewardCap = 0.0
      unfeaturedAppRewardCap = 0.0
      optValidatorFaucetCap = None
      optDevelopmentFundPercentage = None
    futureValues = []
  decentralizedSynchronizer = AmuletDecentralizedSynchronizerConfig with
    requiredSynchronizers = Set.fromList ["sync"]
    activeSynchronizer = "sync"
    fees = SynchronizerFeesConfig with
      baseRateTrafficLimits = BaseRateTrafficLimits with burstAmount = 1; burstWindow = minutes 1
      extraTrafficPrice = 0.0
      readVsWriteScalingFactor = 1
      minTopupAmount = 1
  tickDuration = minutes 1
  packageConfig = PackageConfig with
    amulet = "0"
    amuletNameService = "0"
    dsoGovernance = "0"
    validatorLifecycle = "0"
    wallet = "0"
    walletPayments = "0"
  transferPreapprovalFee = None
  featuredAppActivityMarkerAmount = None
  optDevelopmentFundManager = None
-- Setup AmuletRules with default configuration
setupAmuletRules : Party -> Script (ContractId AmuletRules)
setupAmuletRules dso = do
  amuletRulesCid <- submit dso do
    createCmd AmuletRules with
      dso = dso
      configSchedule = Schedule with
        initialValue = defaultTestAmuletConfig
        futureValues = []
      isDevNet = True
  _ <- submit dso do
    exerciseCmd amuletRulesCid AmuletRules_Bootstrap_Rounds with
      amuletPrice = 0.05
      round0Duration = days 36500  -- 100 years for testing
      initialRound = None
  pure amuletRulesCid
-- Get the latest (highest number) open mining round
getFirstOpenRound : Party -> Script (ContractId OpenMiningRound)
getFirstOpenRound dso = do
  openRounds <- query @OpenMiningRound dso
  case openRounds of
    [] -> abort "No open mining rounds found"
    rounds -> do
      -- Sort by round number descending and take the highest
      let sortedRounds = sortOn (\(_, r) -> negate r.round.number) rounds
      let (openRoundCid, _) = head sortedRounds
      pure openRoundCid

-- Get the AmuletRules contract
getAmuletRules : Party -> Script (ContractId AmuletRules)
getAmuletRules dso = do
  rules <- query @AmuletRules dso
  case rules of
    [] -> abort "No AmuletRules found"
    rulesContracts -> do
      let (rulesCid, _) = head rulesContracts
      pure rulesCid

-- Test environment with DSO, AmuletRules, and OpenMiningRound
data TestEnv = TestEnv
  with
    dso : Party
    amuletRulesCid : ContractId AmuletRules
    openRoundCid : ContractId OpenMiningRound
  deriving (Eq, Show)

-- Setup complete test environment
setupTestEnv : Script TestEnv
setupTestEnv = do
  dso <- allocateParty "dso"
  amuletRulesCid <- setupAmuletRules dso
  openRoundCid <- getFirstOpenRound dso
  pure TestEnv with ..

-- Tap funds for a party using specific DSO, rules, and round
-- Usage: amuletCid <- tap dso amuletRulesCid openRoundCid alice 420
tap : Party -> ContractId AmuletRules -> ContractId OpenMiningRound -> Party -> Decimal -> Script (ContractId Amulet.Amulet)
tap dso amuletRulesCid openRoundCid receiver amount = do
  result <- submit (actAs [dso, receiver]) do
    exerciseCmd amuletRulesCid AmuletRules_DevNet_Tap with
      receiver = receiver
      amount = amount
      openRound = openRoundCid
  
  pure result.amuletSum.amulet
-- Tap funds for a party using a specific DSO
-- Usage: dso <- allocateParty "dso"; alice <- allocateParty "alice"; amuletCid <- tapWithDso dso alice 420
tapWithDso : Party -> Party -> Decimal -> Script (ContractId Amulet.Amulet)
tapWithDso dso receiver amount = do
  amuletRulesCid <- setupAmuletRules dso
  openRoundCid <- getFirstOpenRound dso
  
  result <- submit (actAs [dso, receiver]) do
    exerciseCmd amuletRulesCid AmuletRules_DevNet_Tap with
      receiver = receiver
      amount = amount
      openRound = openRoundCid
  
  pure result.amuletSum.amulet