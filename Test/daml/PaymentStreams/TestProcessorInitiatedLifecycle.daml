-- | Test Payer rejecting after recipient approved (processor already approved as initiator)
testRecipientRejectAfterPayerAccepted : Script ()
testRecipientRejectAfterPayerAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorPaymentStreamProposal processor alice bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Recipient approves
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = bob
  
  -- Payer rejects (note: Payers cannot approve, but they can reject/withdraw)
  submit alice do
    exerciseCmd recipientApprovedCid Proposed.ProposedPaymentStream_Withdraw with actor = alice; description = None
  
  proposal <- queryContractId alice recipientApprovedCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test Payer rejecting after recipient accepted
testPayerRejectAfterRecipientAccepted : Script ()
testPayerRejectAfterRecipientAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorPaymentStreamProposal processor alice bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = bob
  
  submit alice do
    exerciseCmd recipientApprovedCid Proposed.ProposedPaymentStream_Withdraw with actor = alice; description = None
  
  proposal <- queryContractId alice recipientApprovedCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

