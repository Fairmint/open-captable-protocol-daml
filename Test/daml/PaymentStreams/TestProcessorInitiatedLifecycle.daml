-- | Test processor withdrawing after recipient accepted (processor is already approved as initiator)
testProcessorWithdrawAfterPayerAccepted : Script ()
testProcessorWithdrawAfterPayerAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorPaymentStreamProposal processor alice bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Recipient approves (processor already approved as initiator)
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = bob
  
  submit processor do
    exerciseCmd recipientApprovedCid Proposed.ProposedPaymentStream_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor recipientApprovedCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test processor withdrawing after recipient accepted (but before Payer accepts)
testProcessorWithdrawAfterRecipientAccepted : Script ()
testProcessorWithdrawAfterRecipientAccepted = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createProcessorPaymentStreamProposal processor alice bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  recipientApprovedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = bob
  
  submit processor do
    exerciseCmd recipientApprovedCid Proposed.ProposedPaymentStream_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor recipientApprovedCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test recipient withdrawing their acceptance (processor already approved as initiator)
