module PaymentStreams.TestPaymentStreamChanges where

import Daml.Script
import DA.Time (days, addRelTime)
import CantonPayments.PaymentStream.ActivePaymentStream
import CantonPayments.PaymentStream.Types.PaymentStreamChanges (PaymentStreamChanges(..))
import CantonPayments.PaymentStream.Types.PaymentStreamAmount (PaymentStreamAmount(..))
import CantonPayments.PaymentStream.Types.PaymentStreamTime (PaymentStreamExpiration(..))
import PaymentStreams.TestUtils

-- | Test ActivePaymentStream_ProposeChanges
-- Tests proposing changes to an active paymentStream
testProposeChanges : Script ()
testProposeChanges = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)

  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso

  -- Propose changes to the paymentStream
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd paymentStreamCid ActivePaymentStream_ProposeChanges with
      actor = alice
      paymentStreamChanges = PaymentStreamChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"

  Some changeProposal <- queryContractId alice changeProposalCid
  assertMsg "Change proposal should exist" True

  pure ()

-- | Test PaymentStreamChangeProposal_Approve
-- Tests approving a paymentStream change proposal
testApproveChangeProposal : Script ()
testApproveChangeProposal = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)

  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso

  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd paymentStreamCid ActivePaymentStream_ProposeChanges with
      actor = alice
      paymentStreamChanges = PaymentStreamChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"

  -- Bob approves the changes
  approvedCid <- submit bob do
    exerciseCmd changeProposalCid PaymentStreamChangeProposal_Approve with
      actor = bob

  Some approvedProposal <- queryContractId bob approvedCid
  assertMsg "Approval should be recorded" True

  pure ()

-- | Test PaymentStreamChangeProposal_Apply
-- Tests applying approved changes to an active paymentStream
testApplyChangeProposal : Script ()
testApplyChangeProposal = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)

  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso

  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd paymentStreamCid ActivePaymentStream_ProposeChanges with
      actor = alice
      paymentStreamChanges = PaymentStreamChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"

  -- Bob and processor approve the changes
  approvedCid1 <- submit bob do
    exerciseCmd changeProposalCid PaymentStreamChangeProposal_Approve with
      actor = bob

  approvedCid2 <- submit processor do
    exerciseCmd approvedCid1 PaymentStreamChangeProposal_Approve with
      actor = processor

  -- Apply the changes
  updatedPaymentStreamCid <- submit alice do
    exerciseCmd approvedCid2 PaymentStreamChangeProposal_Apply with
      actor = alice
      activePaymentStreamCid = paymentStreamCid

  Some updatedPaymentStream <- queryContractId alice updatedPaymentStreamCid
  assertMsg "Payment per day should be updated" (updatedPaymentStream.paymentStream.recipientPaymentPerDay == AmuletAmount 2.0)

  pure ()

-- | Test PaymentStreamChangeProposal_Reject
-- Tests rejecting a paymentStream change proposal
testRejectChangeProposal : Script ()
testRejectChangeProposal = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)

  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso

  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd paymentStreamCid ActivePaymentStream_ProposeChanges with
      actor = alice
      paymentStreamChanges = PaymentStreamChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"

  -- Bob rejects the changes
  submit bob do
    exerciseCmd changeProposalCid PaymentStreamChangeProposal_Reject with
      actor = bob
      description = Some "I don't agree with this change"

  changeProposal <- queryContractId bob changeProposalCid
  assertMsg "Change proposal should be archived" (changeProposal == None)

  pure ()

-- | Test archiving PaymentStreamChangeProposal using implicit Archive choice
testArchiveChangeProposal : Script ()
testArchiveChangeProposal = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)

  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso

  -- Propose changes
  now <- getTime
  let newExpiresAt = addRelTime now (days 730)
  changeProposalCid <- submit alice do
    exerciseCmd paymentStreamCid ActivePaymentStream_ProposeChanges with
      actor = alice
      paymentStreamChanges = PaymentStreamChanges with
        processedAndPaidUntilAdjustment = None
        provider = None
        recipientPaymentPerDay = Some (AmuletAmount 2.0)
        processorPaymentPerDay = None
        paymentsEndAt = Some (Some (PreciseTime newExpiresAt))
        freeTrialExpiration = None
        appRewardBeneficiaries = None
        observers = None
        prepayWindow = None
        metadata = None
        description = None
      description = Some "Increasing payment amount"

  -- Archive using implicit Archive choice (requires all signatories)
  submit (actAs [alice, bob, processor]) do
    exerciseCmd changeProposalCid Archive

  changeProposal <- queryContractId alice changeProposalCid
  assertMsg "Change proposal should be archived" (changeProposal == None)

  pure ()
