module PaymentStreams.TestUtils where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Api.FeaturedAppRightV1 (AppRewardBeneficiary(..))
import Splice.Api.FeaturedAppRightV1 qualified as Featured
import Splice.AmuletRules qualified
import Splice.Round qualified
import CantonPayments.PaymentStream.PaymentStreamFactory qualified as Factory
import CantonPayments.PaymentStream.ProposedPaymentStream qualified as Proposed
import CantonPayments.PaymentStream.ActivePaymentStream qualified as Active
import CantonPayments.PaymentStream.Types.PaymentStreamProposal (PaymentStreamProposal(..))
import CantonPayments.PaymentStream.Types.PaymentStreamTime (PaymentStreamExpiration(..))
import CantonPayments.PaymentStream.Types.ProcessorContext (ProcessorContext(..))
import CantonPayments.PaymentStream.Types.PaymentStreamAmount (PaymentStreamAmount(..))
import CantonPayments.PaymentStream.Types.PaymentContext (PaymentContext(..))
import CantonPayments.PaymentStream.Types.LockFundsInput (LockFundsInput(..))
import Shared.TestUtils (setupTestEnv, TestEnv(..), tapWithDso, getAmuletRules)

-- | Test-only FeaturedAppRight template for testing paymentStream updates
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with ..
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- | Helper to create a PaymentStreamFactory
createPaymentStreamFactory : Party -> Party -> Script (ContractId Factory.PaymentStreamFactory)
createPaymentStreamFactory processor dso = do
  submit processor do
    createCmd Factory.PaymentStreamFactory with
      processorContext = ProcessorContext with ..

-- | Helper to create a paymentStream proposal (processor-initiated, for Payer)
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
-- NOTE: Payers cannot create proposals - only processor or recipient can initiate
createPayerPaymentStreamProposal : Party -> Party -> Party -> PaymentStreamProposal -> Script (ContractId Proposed.ProposedPaymentStream)
createPayerPaymentStreamProposal processor payer dso proposal = do
  result <- submit processor do
    createAndExerciseCmd
      (Factory.PaymentStreamFactory with processorContext = ProcessorContext with ..)
      (Factory.PaymentStreamFactory_CreatePaymentStreamProposal with actor = processor; paymentStreamProposal = proposal; Factory.lockFundsInput = None)
  case result of
    Left proposedCid -> pure proposedCid
    Right _ -> error "Expected ProposedPaymentStream but got ActivePaymentStream"

-- | Helper to create a recipient-initiated paymentStream proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createRecipientPaymentStreamProposal : Party -> Party -> Party -> PaymentStreamProposal -> Script (ContractId Proposed.ProposedPaymentStream)
createRecipientPaymentStreamProposal processor recipient dso proposal = do
  result <- submit (actAs [recipient, processor]) do
    createAndExerciseCmd
      (Factory.PaymentStreamFactory with processorContext = ProcessorContext with ..)
      (Factory.PaymentStreamFactory_CreatePaymentStreamProposal with actor = recipient; paymentStreamProposal = proposal; Factory.lockFundsInput = None)
  case result of
    Left proposedCid -> pure proposedCid
    Right _ -> error "Expected ProposedPaymentStream but got ActivePaymentStream"

-- | Helper to create a processor-initiated paymentStream proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction
createProcessorPaymentStreamProposal : Party -> Party -> Party -> Party -> PaymentStreamProposal -> Script (ContractId Proposed.ProposedPaymentStream)
createProcessorPaymentStreamProposal processor payer recipient dso proposal = do
  result <- submit processor do
    createAndExerciseCmd
      (Factory.PaymentStreamFactory with processorContext = ProcessorContext with ..)
      (Factory.PaymentStreamFactory_CreatePaymentStreamProposal with actor = processor; paymentStreamProposal = proposal; Factory.lockFundsInput = None)
  case result of
    Left proposedCid -> pure proposedCid
    Right _ -> error "Expected ProposedPaymentStream but got ActivePaymentStream"

-- | Helper to create default paymentStream proposal for testing
defaultPaymentStreamProposal : Party -> Party -> Time -> PaymentStreamProposal
defaultPaymentStreamProposal payer recipient expiresAt = PaymentStreamProposal with
  payer = payer
  recipient = recipient
  provider = payer  -- Use payer as default provider
  appRewardBeneficiaries = [AppRewardBeneficiary payer 1.0]  -- Default to payer as sole beneficiary
  freeTrialExpiration = None
  recipientPaymentPerDay = AmuletAmount 1.0
  processorPaymentPerDay = Some (AmuletAmount 0.2)
  prepayWindow = days 0
  paymentsEndAt = Some (PreciseTime expiresAt)
  description = Some "Test paymentStream"
  metadata = None
  observers = []

-- | Helper to get expiration time for testing (days from now)
getExpirationTime : Int -> Script Time
getExpirationTime numDays = do
  now <- getTime
  pure (addRelTime now (days numDays))

-- | Standard test parties setup with test environment
data TestParties = TestParties with
    alice : Party
    bob : Party
    processor : Party
    dso : Party
    amuletRulesCid : ContractId Splice.AmuletRules.AmuletRules
    openRoundCid : ContractId Splice.Round.OpenMiningRound

-- | Allocate standard test parties
allocateTestParties : Script TestParties
allocateTestParties = do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  TestEnv{..} <- setupTestEnv
  pure TestParties with ..

-- | Helper to fully approve a proposal and return the ActivePaymentStream
-- Handles the approval flow including escrow locking
-- NOTE: Assumes processor may already be approved (if they initiated the proposal)
approveProposalFully : ContractId Proposed.ProposedPaymentStream -> Party -> Party -> Party -> Party -> Script (ContractId Active.ActivePaymentStream)
approveProposalFully proposalCid processor recipient payer dso = do
  -- Check if processor is already approved
  Some proposal <- queryContractId processor proposalCid
  let processorAlreadyApproved = proposal.approvals.processorApproved
  
  -- Processor approves if not already approved
  proposedCid1 <- if processorAlreadyApproved
    then pure proposalCid
    else submit processor do
      exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
        actor = processor
  
  -- Recipient approves next
  proposedCid2 <- submit recipient do
    exerciseCmd proposedCid1 Proposed.ProposedPaymentStream_Approve with 
      actor = recipient
  
  -- Create amulet for locking
  amuletCid <- tapWithDso dso payer 100.0
  
  -- Get payment context
  openRounds <- query @Splice.Round.OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Payer starts the paymentStream with funds
  -- Use readAs [dso] to provide visibility to DSO contracts
  (activeCid, _) <- submit (actAs payer <> readAs dso) do
    exerciseCmd proposedCid2 Proposed.ProposedPaymentStream_StartPaymentStream with 
      lockFundsInput = LockFundsInput with
        amuletInputs = [amuletCid]
        amountToLock = 50.0
        paymentContext = PaymentContext with
          amuletRulesCid = amuletRulesCid
          openMiningRoundCid = openRoundCid
          featuredAppRight = None
  
  pure activeCid


