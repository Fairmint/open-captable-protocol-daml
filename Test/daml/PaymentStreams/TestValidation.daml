module PaymentStreams.TestValidation where

import Daml.Script
import DA.Time (days)
import CantonPayments.PaymentStream.PaymentStreamFactory
import CantonPayments.PaymentStream.Types.PaymentStreamProposal (PaymentStreamProposal(..))
import CantonPayments.PaymentStream.Types.PaymentStreamTime (PaymentStreamExpiration(..))
import CantonPayments.PaymentStream.Types.ProcessorContext (ProcessorContext(..))
import CantonPayments.PaymentStream.Types.PaymentStreamAmount (PaymentStreamAmount(..))
import PaymentStreams.TestUtils

-- | Test validation: negative amount not allowed
testNegativeAmountNotAllowed : Script ()
testNegativeAmountNotAllowed = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  submitMustFail (actAs [alice, processor]) do
    createAndExerciseCmd
      (PaymentStreamFactory with processorContext = ProcessorContext processor dso)
      (PaymentStreamFactory_CreatePaymentStreamProposal with
        actor = alice
        paymentStreamProposal = PaymentStreamProposal with
          payer = alice
          recipient = bob
          provider = alice
          appRewardBeneficiaries = []
          freeTrialExpiration = None
          recipientPaymentPerDay = AmuletAmount (-5.0)
          processorPaymentPerDay = Some (AmuletAmount 1.0)
          prepayWindow = days 0
          paymentsEndAt = Some (PreciseTime expiresAt)
          description = Some "Service"
          metadata = None
          observers = []
        lockFundsInput = None)

  pure ()

-- | Test validation: negative fee not allowed
testNegativeFeeNotAllowed : Script ()
testNegativeFeeNotAllowed = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  submitMustFail (actAs [alice, processor]) do
