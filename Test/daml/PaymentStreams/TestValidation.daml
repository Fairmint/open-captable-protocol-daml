-- | Test validation: zero fee is allowed
testZeroFeeAllowed : Script ()
testZeroFeeAllowed = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  let proposal = (defaultPaymentStreamProposal alice bob expiresAt) with
        processorPaymentPerDay = Some (AmuletAmount 0.0)

  proposalCid <- createPayerPaymentStreamProposal processor alice dso proposal

  Some proposedSub <- queryContractId alice proposalCid
  assertMsg "Fee should be 0.0" (proposedSub.paymentStreamProposal.processorPaymentPerDay == Some (AmuletAmount 0.0))

  pure ()

-- | Test validation: Payer and recipient must be different
testPayerRecipientMustBeDifferent : Script ()
testPayerRecipientMustBeDifferent = script do
  TestParties{..} <- allocateTestParties

  expiresAt <- getExpirationTime 365
  submitMustFail (actAs [alice, processor]) do
    createAndExerciseCmd
      (PaymentStreamFactory with processorContext = ProcessorContext processor dso)
      (PaymentStreamFactory_CreatePaymentStreamProposal with
        actor = alice
        paymentStreamProposal = PaymentStreamProposal with
          payer = alice
          recipient = alice  -- Same as Payer
          provider = alice
          appRewardBeneficiaries = []
          freeTrialExpiration = None
          recipientPaymentPerDay = AmuletAmount 5.0
          processorPaymentPerDay = Some (AmuletAmount 1.0)
          prepayWindow = days 0
          paymentsEndAt = Some (PreciseTime expiresAt)
          description = Some "Service"
          metadata = None
          observers = []
        lockFundsInput = None)

  pure ()
