module PaymentStreams.TestProcessorInitiatedPaymentStreams where

import Daml.Script
import CantonPayments.PaymentStream.ProposedPaymentStream qualified as Proposed
import PaymentStreams.TestUtils

-- | Test ProcessorPaymentStreamProposal Archive
testProcessorPaymentStreamProposalArchive : Script ()
testProcessorPaymentStreamProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = defaultPaymentStreamProposal alice bob expiresAt
  proposalCid <- createProcessorPaymentStreamProposal processor alice bob dso proposal
  
  submitMulti [processor] [alice, bob] do
    archiveCmd proposalCid
  
  pure ()

-- | Test OnePartyApprovedProcessorPaymentStreamProposal Archive
-- Processor creates proposal (auto-approved), recipient approves, then archive
testOnePartyApprovedProcessorPaymentStreamProposalArchive : Script ()
testOnePartyApprovedProcessorPaymentStreamProposalArchive = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  let proposal = defaultPaymentStreamProposal alice bob expiresAt
  proposalCid <- createProcessorPaymentStreamProposal processor alice bob dso proposal
  
  -- Recipient approves (processor is already approved as initiator)
  approvedCid <- submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = bob
  
  submitMulti [processor, bob] [alice] do
    archiveCmd approvedCid
  
  pure ()
