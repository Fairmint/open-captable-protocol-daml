module PaymentStreams.TestPayerInitiatedLifecycle where

import Daml.Script
import DA.Optional (isNone)
import CantonPayments.PaymentStream.ProposedPaymentStream qualified as Proposed
import CantonPayments.PaymentStream.Types.PaymentStreamAmount (PaymentStreamAmount(..))
import PaymentStreams.TestUtils

-- | Test the full happy path: factory → proposal → approval → acceptance
testFactoryProposalAcceptance : Script ()
testFactoryProposalAcceptance = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Use helper to fully approve with proper escrow handling
  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso
  
  Some paymentStream <- queryContractId alice paymentStreamCid
  assertMsg "Payer should be alice" (paymentStream.paymentStream.payer == alice)
  assertMsg "Recipient should be bob" (paymentStream.paymentStream.recipient == bob)
  assertMsg "Processor should match" (paymentStream.processorContext.processor == processor)
  assertMsg "Amount per day should be 1.0" (paymentStream.paymentStream.recipientPaymentPerDay == AmuletAmount 1.0)
  assertMsg "Fee amount per day should be 0.2" (paymentStream.paymentStream.processorPaymentPerDay == Some (AmuletAmount 0.2))
  
  pure ()

-- | Test proposal rejection by recipient (before processor approval)
testProposalRejectionByRecipient : Script ()
testProposalRejectionByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = bob; description = None
  
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test proposal rejection by processor
testProposalRejectionByProcessor : Script ()
testProposalRejectionByProcessor = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  submit processor do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = processor; description = None
  
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test Payer withdrawing proposal (before processor approval)
testProposalWithdrawByPayer : Script ()
testProposalWithdrawByPayer = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  submit alice do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = alice; description = None
  
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test processor withdrawing after proposal creation (processor is auto-approved as initiator)
testProcessorApprovedProposalProcessorWithdraw : Script ()
testProcessorApprovedProposalProcessorWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Processor is already approved as the initiator, can withdraw directly
  submit processor do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = processor; description = None
  
  pure ()

-- | Test recipient rejecting after processor proposes (processor is auto-approved as initiator)
testProcessorApprovedProposalRecipientReject : Script ()
testProcessorApprovedProposalRecipientReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Processor is already approved as the initiator, recipient can reject directly
  submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = bob; description = None
  
  pure ()

-- | Test Payer withdrawing after processor proposes (processor is auto-approved as initiator)
testProcessorApprovedProposalPayerWithdraw : Script ()
testProcessorApprovedProposalPayerWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Processor is already approved as the initiator, Payer can withdraw directly
  submit alice do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = alice; description = None
  
  pure ()

