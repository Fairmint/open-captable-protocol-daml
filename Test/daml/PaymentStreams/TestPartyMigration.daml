module PaymentStreams.TestPartyMigration where

import Daml.Script
import CantonPayments.PaymentStream.ProposedPaymentStream
import CantonPayments.PaymentStream.ActivePaymentStream
import CantonPayments.PaymentStream.PartyMigrationProposal
import CantonPayments.PaymentStream.Types.PartyRole (PartyRole(..))
import CantonPayments.PaymentStream.Types.PaymentContext (PaymentContext(..))
import PaymentStreams.TestUtils

-- | Test PartyMigrationProposal_Approve by old party
testPartyMigrationProposalApproveOldParty : Script ()
testPartyMigrationProposalApproveOldParty = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  -- Create migration proposal (initiated by new party)
  proposalCid <- submitMulti [newPayer] [alice] do
    createCmd PartyMigrationProposal with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      oldPartyApproved = False
      newPartyApproved = True
  
  -- Old party approves
  approvedCid <- submit alice do
    exerciseCmd proposalCid PartyMigrationProposal_Approve with
      actor = alice
  
  pure ()

-- | Test PartyMigrationProposal_Approve by new party
testPartyMigrationProposalApproveNewParty : Script ()
testPartyMigrationProposalApproveNewParty = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  -- Create migration proposal (initiated by old party)
  proposalCid <- submitMulti [alice] [newPayer] do
    createCmd PartyMigrationProposal with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      oldPartyApproved = True
      newPartyApproved = False
  
  -- New party approves
  approvedCid <- submit newPayer do
    exerciseCmd proposalCid PartyMigrationProposal_Approve with
      actor = newPayer
  
  pure ()

-- | Test PartyMigrationProposal_Archive
testPartyMigrationProposalArchive : Script ()
testPartyMigrationProposalArchive = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  -- Create migration proposal
  proposalCid <- submitMulti [alice] [newPayer] do
    createCmd PartyMigrationProposal with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      oldPartyApproved = True
      newPartyApproved = False
  
  -- Old party withdraws
  submit alice do
    exerciseCmd proposalCid PartyMigrationProposal_Archive with
      actor = alice
      description = Some "Changed my mind"
  
  pure ()

-- NOTE: Active paymentStream migration tests removed due to complexity with locked amulet visibility
-- These need to be rewritten to properly handle amulet escrow, visibility, and stakeholder requirements

-- | Test PartyMigrationProposal_MigrateProposedPaymentStream for Payer
testMigrateProposedPaymentStreamPayer : Script ()
testMigrateProposedPaymentStreamPayer = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  -- Create proposed paymentStream
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [alice, newPayer] [] do
    createCmd PartyMigrationProposal with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration
  newProposalCid <- submit alice do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateProposedPaymentStream with
      actor = alice
      proposedPaymentStreamCid = proposalCid
  
  pure ()

-- | Test PartyMigrationProposal_MigrateProposedPaymentStream for recipient
testMigrateProposedPaymentStreamRecipient : Script ()
testMigrateProposedPaymentStreamRecipient = script do
  TestParties{..} <- allocateTestParties
  newRecipient <- allocateParty "NewBob"
  
  -- Create proposed paymentStream
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [bob, newRecipient] [] do
    createCmd PartyMigrationProposal with
      partyType = Recipient
      oldParty = bob
      newParty = newRecipient
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration
  newProposalCid <- submit bob do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateProposedPaymentStream with
      actor = bob
      proposedPaymentStreamCid = proposalCid
  
  pure ()

-- | Test ProposedPaymentStream_ChangeParty for Payer (via migration proposal)
testProposedPaymentStreamChangePartyPayer : Script ()
testProposedPaymentStreamChangePartyPayer = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  -- Create proposed paymentStream
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Directly exercise ChangeParty choice (requires both old and new party authorization)
  newProposalCid <- submitMulti [alice, newPayer] [] do
    exerciseCmd proposalCid ProposedPaymentStream_ChangeParty with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
  
  pure ()

-- | Test ActivePaymentStream_ChangeParty for Payer
-- Tests directly changing a party in an active paymentStream
testActivePaymentStreamChangeParty : Script ()
testActivePaymentStreamChangeParty = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Change Payer from alice to newPayer (Payer change doesn't require PaymentContext but we need to provide it)
  let changePartyPaymentContext = PaymentContext with
        amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
  newPaymentStreamCid <- submitMulti [alice, newPayer] [dso] do
    exerciseCmd paymentStreamCid ActivePaymentStream_ChangeParty with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      ..
  
  Some updatedPaymentStream <- queryContractId newPayer newPaymentStreamCid
  assertMsg "Payer should be newPayer" (updatedPaymentStream.paymentStream.payer == newPayer)
  
  pure ()

-- | Test PartyMigrationProposal_MigrateActivePaymentStream
-- Tests migrating an active paymentStream through a migration proposal
testPartyMigrationProposalMigrateActivePaymentStream : Script ()
testPartyMigrationProposalMigrateActivePaymentStream = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Create fully approved migration proposal
  migrationCid <- submitMulti [alice, newPayer] [] do
    createCmd PartyMigrationProposal with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Apply migration to active paymentStream
  let changePartyPaymentContext = PaymentContext with
        amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
  newPaymentStreamCid <- submitMulti [alice] [dso] do
    exerciseCmd migrationCid PartyMigrationProposal_MigrateActivePaymentStream with
      actor = alice
      activePaymentStreamCid = paymentStreamCid
      ..
  
  Some updatedPaymentStream <- queryContractId newPayer newPaymentStreamCid
  assertMsg "Payer should be newPayer" (updatedPaymentStream.paymentStream.payer == newPayer)
  
  pure ()

-- | Test archiving PartyMigrationProposal using implicit Archive choice
-- This exercises the implicit Archive that all templates have
testPartyMigrationProposalImplicitArchive : Script ()
testPartyMigrationProposalImplicitArchive = script do
  TestParties{..} <- allocateTestParties
  newPayer <- allocateParty "NewAlice"
  
  -- Create fully approved migration proposal (both parties are signatories)
  proposalCid <- submitMulti [alice, newPayer] [] do
    createCmd PartyMigrationProposal with
      partyType = Payer
      oldParty = alice
      newParty = newPayer
      oldPartyApproved = True
      newPartyApproved = True
  
  -- Archive using implicit Archive choice (requires both signatories)
  submitMulti [alice, newPayer] [] do
    exerciseCmd proposalCid Archive
  
  pure ()

