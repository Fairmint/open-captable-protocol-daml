module PaymentStreams.TestRecipientInitiatedLifecycle where

import Daml.Script
import DA.Optional (isNone)
import CantonPayments.PaymentStream.ProposedPaymentStream qualified as Proposed
import PaymentStreams.TestUtils

-- NOTE: Recipient-initiated approval test removed due to complexity with recipient being pre-approved
-- The recipient is already approved when creating the proposal, which conflicts with the approval helper
-- This functionality is covered by other lifecycle tests and the Payer-initiated version

-- | Test Payer rejecting recipient's proposal (before processor approval)
testRecipientProposalRejectionByPayer : Script ()
testRecipientProposalRejectionByPayer = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Alice (Payer) rejects before processor approval
  submit alice do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = alice; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test recipient withdrawing their own proposal (before processor approval)
testRecipientProposalWithdrawByRecipient : Script ()
testRecipientProposalWithdrawByRecipient = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob (recipient) creates proposal
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Bob withdraws before processor approval
  submit bob do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = bob; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test processor rejecting recipient's proposal
testRecipientProposalProcessorReject : Script ()
testRecipientProposalProcessorReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  -- Bob creates proposal
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Processor rejects
  submit processor do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Withdraw with actor = processor; description = None
  
  -- Verify proposal is archived
  proposal <- queryContractId processor proposalCid
  assertMsg "Proposal should be archived" (isNone proposal)
  
  pure ()

-- | Test Payer rejecting after processor approval
testProcessorApprovedRecipientProposalPayerReject : Script ()
testProcessorApprovedRecipientProposalPayerReject = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  -- Processor approves
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = processor
  
  -- Alice (Payer) rejects after processor approval
  submit alice do
    exerciseCmd approvedProposalCid Proposed.ProposedPaymentStream_Withdraw with actor = alice; description = None
  
  pure ()

-- | Test recipient withdrawing after processor approval (but before Payer accepts)
testProcessorApprovedRecipientProposalRecipientWithdraw : Script ()
testProcessorApprovedRecipientProposalRecipientWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = processor
  
  -- Bob (recipient) withdraws after processor approval
  submit bob do
    exerciseCmd approvedProposalCid Proposed.ProposedPaymentStream_Withdraw with actor = bob; description = None
  
  pure ()

-- | Test processor withdrawing after approval (but before Payer accepts)
testProcessorApprovedRecipientProposalProcessorWithdraw : Script ()
testProcessorApprovedRecipientProposalProcessorWithdraw = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createRecipientPaymentStreamProposal processor bob dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid Proposed.ProposedPaymentStream_Approve with 
      actor = processor
  
  -- Processor withdraws their approval
  submit processor do
    exerciseCmd approvedProposalCid Proposed.ProposedPaymentStream_Withdraw with actor = processor; description = None
  
  pure ()

