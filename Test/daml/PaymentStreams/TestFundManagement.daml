module PaymentStreams.TestFundManagement where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round qualified
import CantonPayments.PaymentStream.ActivePaymentStream
import CantonPayments.PaymentStream.Types.PaymentContext (PaymentContext(..))
import CantonPayments.PaymentStream.Types.LockFundsInput (LockFundsInput(..))
import Shared.TestUtils (tapWithDso, getAmuletRules)
import PaymentStreams.TestUtils

-- | Test ActivePaymentStream_AddFunds
-- Tests adding funds to an active paymentStream's escrow
-- This choice requires multi-party authorization (actor, Payer, recipient, processor)
testAddFunds : Script ()
testAddFunds = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get the paymentStream to check initial state
  Some paymentStream <- queryContractId alice paymentStreamCid
  assertMsg "PaymentStream should have locked amulet" True
  
  -- Create amulets to add to the paymentStream
  newAmulet <- tapWithDso dso alice 50.0
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @Splice.Round.OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Exercise AddFunds choice with multi-party authorization
  -- Use readAs [dso] to provide visibility to DSO contracts (AmuletRules, OpenMiningRound)
  (newPaymentStreamCid, changeAmulet) <- submitMulti [alice, bob, processor] [dso] do
    exerciseCmd paymentStreamCid ActivePaymentStream_AddFunds with
      actor = alice  -- Alice is providing the funds
      lockFundsInput = LockFundsInput with
        amuletInputs = [newAmulet]
        amountToLock = 90.0  -- Lock 90 total (50 existing + 50 new - fees)
        paymentContext = PaymentContext with
          amuletRulesCid
          openMiningRoundCid = openRoundCid
          featuredAppRight = None
      description = Some "Adding more funds"
  
  -- Verify the paymentStream was updated
  Some updatedPaymentStream <- queryContractId alice newPaymentStreamCid
  assertMsg "PaymentStream should have updated locked amulet" True
  
  pure ()

-- | Test ActivePaymentStream_WithdrawFunds
-- Tests withdrawing excess funds from an active paymentStream's escrow
-- This choice requires the Payer to exercise it, and the DSO contracts are accessed via divulgence
testWithdrawFunds : Script ()
testWithdrawFunds = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @Splice.Round.OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Exercise WithdrawFunds choice
  -- Use readAs [dso] to provide visibility to DSO contracts (AmuletRules, OpenMiningRound)
  (newPaymentStreamCid, withdrawnAmuletCid) <- submitMulti [alice] [dso] do
    exerciseCmd paymentStreamCid ActivePaymentStream_WithdrawFunds with
      amountToKeepLocked = 20.0  -- Keep 20 locked, withdraw ~30 minus fees (ensures change > fees)
      paymentContext = PaymentContext with
        amuletRulesCid
        openMiningRoundCid = openRoundCid
        featuredAppRight = None
  
  -- Verify the paymentStream was updated and amulet was withdrawn
  Some updatedPaymentStream <- queryContractId alice newPaymentStreamCid
  Some withdrawnAmulet <- queryContractId alice withdrawnAmuletCid
  assertMsg "PaymentStream should have updated locked amulet" True
  assertMsg "Withdrawn amulet should exist" True
  
  pure ()

-- | Test ActivePaymentStream_ReplaceLockedAmulet
-- Tests replacing an expired locked amulet (recovery mechanism)
-- This choice requires the Payer to exercise it, and the DSO contracts are accessed via divulgence
testReplaceLockedAmulet : Script ()
testReplaceLockedAmulet = script do
  TestParties{..} <- allocateTestParties
  
  expiresAt <- getExpirationTime 365
  proposalCid <- createPayerPaymentStreamProposal processor alice dso (defaultPaymentStreamProposal alice bob expiresAt)
  
  paymentStreamCid <- approveProposalFully proposalCid processor bob alice dso
  
  -- Wait long enough for the lock to expire (locks expire after 365 days)
  now <- getTime
  setTime (addRelTime now (days 366))
  
  -- Create new amulets to replace the locked ones
  newAmulet1 <- tapWithDso dso alice 30.0
  
  -- Get payment context
  amuletRulesCid <- getAmuletRules dso
  openRounds <- query @Splice.Round.OpenMiningRound dso
  now2 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now2) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds
  
  -- Exercise ReplaceLockedAmulet choice
  -- Use readAs [dso] to provide visibility to DSO contracts (AmuletRules, OpenMiningRound)
  (newPaymentStreamCid, changeAmulet) <- submitMulti [alice] [dso] do
    exerciseCmd paymentStreamCid ActivePaymentStream_AddFunds with
      actor = alice
      lockFundsInput = LockFundsInput with
        amuletInputs = [newAmulet1]
        amountToLock = 30.0
        paymentContext = PaymentContext with
          amuletRulesCid
          openMiningRoundCid = openRoundCid
          featuredAppRight = None
      description = Some "Replace expired lock"
  
  -- Verify the paymentStream was updated
  Some updatedPaymentStream <- queryContractId alice newPaymentStreamCid
  assertMsg "PaymentStream should have new locked amulet" True
  
  pure ()

