module TestStockIssuance where
import Fairmint.OpenCapTable.StockIssuance
import Fairmint.OpenCapTable.StockClass
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script
import Fairmint.OpenCapTable.Types

createStockClass issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = OcfStockClassData with
        id = "SC_COMMON"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []

createStockIssuance issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd StockIssuance with
      context = ctx
      issuance_data = OcfStockIssuanceData with
        id = "TX_STOCK_ISSUANCE_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-1"
        custom_id = "CERT-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON"
        stock_plan_id = None
        share_numbers_issued = []
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = 100.0
        vesting_terms_id = None
        vestings = []
        cost_basis = None
        stock_legend_ids = ["L1"]
        issuance_type = None
        comments = []

testCreateAndArchiveStockIssuance = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  -- Create a stock class to reference
  _ <- createStockClass issuer system_operator ctx
  -- Create Stock Issuance
  cid <- createStockIssuance issuer system_operator ctx
  -- Archive created StockIssuance via issuer
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.StockIssuance.ArchiveByIssuer
  pure ()

testCreateAndArchiveStockIssuanceBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  _ <- createStockClass issuer system_operator ctx
  cid <- createStockIssuance issuer system_operator ctx
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


-- Additional coverage: all Optional fields = Some and arrays non-empty
testStockIssuance_OptionalsSome_ArraysNonEmpty = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  _ <- createStockClass issuer system_operator ctx
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd StockIssuance with
      context = ctx
      issuance_data = OcfStockIssuanceData with
        id = "TX_STOCK_ISS_SOME"
        date = DT.time (DA.date 2024 Feb 01) 0 0 0
        security_id = "SEC-3"
        custom_id = "CERT-3"
        stakeholder_id = "SH-3"
        board_approval_date = Some (DT.time (DA.date 2024 Jan 15) 0 0 0)
        stockholder_approval_date = Some (DT.time (DA.date 2024 Jan 16) 0 0 0)
        consideration_text = Some "Cash consideration"
        security_law_exemptions = [ OcfSecurityExemption with description = "Rule 506(b)", jurisdiction = "US-CA" ]
        stock_class_id = "SC_COMMON"
        stock_plan_id = Some "PLAN_1"
        share_numbers_issued = [ OcfShareNumberRange with starting_share_number = 1.0, ending_share_number = 10.0 ]
        share_price = OcfMonetary with amount = 2.5, currency = "USD"
        quantity = 10.0
        vesting_terms_id = Some "VT_1"
        vestings = [ OcfVesting with date = DT.time (DA.date 2024 Mar 01) 0 0 0, amount = 5.0 ]
        cost_basis = Some (OcfMonetary with amount = 25.0, currency = "USD")
        stock_legend_ids = ["L1", "L2"]
        issuance_type = Some OcfStockIssuanceRSA
        comments = ["Initial issuance"]
  submitMulti [issuer, system_operator] [] do
    exerciseCmd cid Archive
  pure ()


