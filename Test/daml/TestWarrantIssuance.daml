module TestWarrantIssuance where
import Fairmint.OpenCapTable.WarrantIssuance
import Fairmint.OpenCapTable.Types
import Fairmint.OpenCapTable.StockClass (OcfConversionTrigger(..))
import Setup
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT
import Daml.Script

testCreateAndArchiveWarrantIssuance = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId rightCid
  -- Create Warrant Issuance
  cid <- submitMulti [issuer, system_operator] [] do
    createCmd WarrantIssuance with
      context = ctx
      issuance_data = OcfWarrantIssuanceData with
        ocf_id = "TX_WARRANT_ISSUANCE_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "WSEC-1"
        custom_id = "W-1"
        stakeholder_id = "SH-1"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        quantity = 100.0
        exercise_price = OcfMonetary with amount = 1.0, currency = "USD"
        purchase_price = OcfMonetary with amount = 0.0, currency = "USD"
        exercise_triggers = [ OcfTriggerElectiveAtWill ]
        warrant_expiration_date = None
        vesting_terms_id = None
        vestings = []
        comments = []
  -- Archive
  submit issuer do
    exerciseCmd cid Fairmint.OpenCapTable.WarrantIssuance.ArchiveByIssuer
  pure ()


