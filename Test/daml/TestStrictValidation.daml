module TestStrictValidation where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.Types
import DA.Date
import Splice.Api.FeaturedAppRightV1 as Featured

-- Helper function to create a new authorization for each test
createAuthorization system_operator issuer factoryCid = script do
  authCid <- submit system_operator do
    exerciseCmd factoryCid AuthorizeIssuer with issuer = issuer
  pure authCid

-- Comprehensive test to demonstrate strict validation
testStrictValidation = script do
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  
  -- Create test featured app right
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with 
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = system_operator  -- Use system_operator as placeholder for unused parties
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  
  -- Create factory
  factoryCid <- submit system_operator do
    createCmd OcpFactory with 
      system_operator = system_operator
      featured_app_right = toInterfaceContractId testRightCid
  
  -- Test 1: Invalid country code (empty)
  authCid1 <- createAuthorization system_operator issuer factoryCid
  submitMustFail issuer do
    exerciseCmd authCid1 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = ""  -- Invalid: empty string
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- Test 2: Invalid country code (1 character)
  authCid2 <- createAuthorization system_operator issuer factoryCid
  submitMustFail issuer do
    exerciseCmd authCid2 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "U"  -- Invalid: only 1 character
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- Test 3: Invalid country code (3 characters)
  authCid3 <- createAuthorization system_operator issuer factoryCid
  submitMustFail issuer do
    exerciseCmd authCid3 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "USA"  -- Invalid: 3 characters instead of 2
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- Test 4: Invalid country subdivision (empty)
  authCid4 <- createAuthorization system_operator issuer factoryCid
  submitMustFail issuer do
    exerciseCmd authCid4 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = Some ""  -- Invalid: empty string
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- Test 5: Invalid tax ID (empty fields)
  authCid5 <- createAuthorization system_operator issuer factoryCid
  submitMustFail issuer do
    exerciseCmd authCid5 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some [OcfTaxID with tax_id_type = ""; tax_id = "123456789"]  -- Invalid: empty tax_id_type
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- Test 6: Invalid address (missing required fields)
  authCid6 <- createAuthorization system_operator issuer factoryCid
  submitMustFail issuer do
    exerciseCmd authCid6 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = Some (OcfAddress with
          line1 = ""  -- Invalid: empty line1
          line2 = None
          city = "San Francisco"
          state = "CA"
          postal_code = "94105"
          country = "US")
        initial_shares_authorized = Some 1000.0
  
  -- Test 7: Success with valid data (US)
  authCid7 <- createAuthorization system_operator issuer factoryCid
  issuerCid1 <- submit issuer do
    exerciseCmd authCid7 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = Some "CA"
        tax_ids = Some [OcfTaxID with tax_id_type = "EIN"; tax_id = "12-3456789"]
        email = Some "test@example.com"
        phone = Some "+1 (555) 123-4567"
        address = Some (OcfAddress with
          line1 = "123 Main St"
          line2 = Some "Suite 100"
          city = "San Francisco"
          state = "CA"
          postal_code = "94105"
          country = "US")
        initial_shares_authorized = Some 1000.0
  
  -- Test 8: Success with valid data (Canada)
  authCid8 <- createAuthorization system_operator issuer factoryCid
  issuerCid2 <- submit issuer do
    exerciseCmd authCid8 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc Canada"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "CA"
        dba = None
        country_subdivision_of_formation = Some "ON"
        tax_ids = Some [OcfTaxID with tax_id_type = "BN"; tax_id = "123456789RC0001"]
        email = Some "test@example.ca"
        phone = Some "+1 (416) 555-1234"
        address = Some (OcfAddress with
          line1 = "456 Bay St"
          line2 = None
          city = "Toronto"
          state = "ON"
          postal_code = "M5H 2Y2"
          country = "CA")
        initial_shares_authorized = Some 1000.0
  
  -- Test 9: Success with valid data (UK)
  authCid9 <- createAuthorization system_operator issuer factoryCid
  issuerCid3 <- submit issuer do
    exerciseCmd authCid9 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc UK"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "GB"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some [OcfTaxID with tax_id_type = "VAT"; tax_id = "GB123456789"]
        email = Some "test@example.co.uk"
        phone = Some "+44 20 7946 0958"
        address = Some (OcfAddress with
          line1 = "10 Downing St"
          line2 = None
          city = "London"
          state = "England"
          postal_code = "SW1A 2AA"
          country = "GB")
        initial_shares_authorized = Some 1000.0
  
  -- Test 10: Success with valid data (less common country code)
  authCid10 <- createAuthorization system_operator issuer factoryCid
  issuerCid4 <- submit issuer do
    exerciseCmd authCid10 CreateIssuer with
      issuer_data = OcfIssuerData with
        legal_name = "Test Inc Generic"
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "AQ"  -- Valid: Antarctica (less common but valid ISO code)
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  pure () 