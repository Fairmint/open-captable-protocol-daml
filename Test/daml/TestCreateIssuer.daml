module TestCreateIssuer where

import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.Types
import Daml.Script
import DA.Optional
import DA.Date

-- Happy Case --

happyCase = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  -- System operator can read
  issuerContract <- queryContractId system_operator issuerCid
  assertMsg "Issuer contract not found" (isSome issuerContract)

  -- Issuer can read
  issuerContract <- queryContractId issuer issuerCid
  assertMsg "Issuer contract not found" (isSome issuerContract)

  -- Rando cannot read
  issuerContract <- queryContractId rando issuerCid
  assertMsg "Rando should not see issuer contract" (isNone issuerContract)

  pure()

-- Ensures --

nameCannotBeEmpty = script do
  TestUsers{system_operator, issuer, rando} <- setupUsers

  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with 
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = system_operator  -- Use system_operator as placeholder for unused parties
      bob = system_operator
      charlie = system_operator
      rando = rando

  submitMultiMustFail [system_operator, issuer] [] $ createCmd Issuer with
    system_operator = system_operator
    issuer = issuer
    featured_app_right = toInterfaceContractId testRightCid
    issuer_data = OcfIssuerData with
      legal_name = ""
      formation_date = Some (date 2020 Jan 15)
      country_of_formation = "US"
      dba = None
      country_subdivision_of_formation = None
      tax_ids = Some []
      email = None
      phone = None
      address = None
      initial_shares_authorized = Some 1000.0

-- Archiving --

issuerCannotArchive = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  submitMustFail issuer $ archiveCmd issuerCid

systemOperatorCannotArchive = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  submitMustFail system_operator $ archiveCmd issuerCid

issuerAndSystemOperatorCanArchive = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer

  submitMulti [system_operator, issuer] [] $ archiveCmd issuerCid
