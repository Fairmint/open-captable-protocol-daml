module TestSpliceIntegration where

import Daml.Script
import Fairmint.OpenCapTable.AdminService
import Fairmint.OpenCapTable.Issuer
import Splice.Amulet qualified as Amulet
import Splice.Types
import Splice.Expiry

-- Simple test script to demonstrate basic Splice amulet integration with OpenCapTable
testSpliceIntegration = script do
  -- Setup parties
  fairmint <- allocateParty "Fairmint"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  dsoParty <- allocateParty "DSO" -- Decentralized Synchronizer Operator
  
  -- Create the Fairmint admin service
  submit fairmint do
    createCmd FairmintAdminService with
      fairmint = fairmint
  
  -- Create an issuer
  submitMulti [fairmint, issuer] [] do
    createCmd Issuer with
      fairmint = fairmint
      issuer = issuer
      name = "TestIssuer"
      authorizedShares = 1000
      issuedShares = 0
  
  -- Create a simple amulet for Alice
  amulet <- submit dsoParty do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = alice
      amount = ExpiringAmount with
        initialAmount = 100.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001
  
  logInfo "Created amulet for Alice with amount: 100.0"
  logInfo "Amulet integration with OpenCapTable is now available"
  
  -- Show that we can access the amulet data
  amuletData <- fetch amulet
  logInfo ("Amulet owner: " <> show amuletData.owner)
  logInfo ("Amulet amount: " <> show amuletData.amount.initialAmount)
  
  return ()

-- Test script to show how amulets could be used for payment in OpenCapTable
testAmuletPayment = script do
  -- Setup parties
  fairmint <- allocateParty "Fairmint"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  dsoParty <- allocateParty "DSO"
  
  -- Create basic setup
  submit fairmint do
    createCmd FairmintAdminService with
      fairmint = fairmint
  
  submitMulti [fairmint, issuer] [] do
    createCmd Issuer with
      fairmint = fairmint
      issuer = issuer
      name = "TestIssuer"
      authorizedShares = 1000
      issuedShares = 0
  
  -- Give Alice some amulets
  aliceAmulet <- submit dsoParty do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = alice
      amount = ExpiringAmount with
        initialAmount = 50.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001
  
  -- Give Bob some amulets
  bobAmulet <- submit dsoParty do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = bob
      amount = ExpiringAmount with
        initialAmount = 25.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001
  
  logInfo "Created amulets for Alice (50.0) and Bob (25.0)"
  logInfo "These amulets could be used for payment in OpenCapTable operations"
  logInfo "For example, they could pay for transaction fees or premium features"
  
  return () 