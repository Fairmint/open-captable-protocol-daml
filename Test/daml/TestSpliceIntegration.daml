module TestSpliceIntegration where

import Daml.Script
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.OcfObjects
import Splice.Amulet qualified as Amulet
import Splice.Types
import Splice.Fees
import DA.Date

-- Simple test script to demonstrate basic Splice amulet integration with OpenCapTable
testSpliceIntegration = script do
  -- Setup parties
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  dsoParty <- allocateParty "DSO" -- Decentralized Synchronizer Operator
  
  -- Create the OpenCapTable factory
  submit system_operator do
    createCmd OcpFactory with ..
  
  -- Create an issuer
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      system_operator = system_operator
      issuer = issuer
      issuer_data = OcfIssuerData with
        legal_name = "TestIssuer Inc."
        formation_date = date 2020 Jan 15
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = 1000
  
  -- Create a simple amulet for Alice
  amulet <- submitMulti [dsoParty, alice] [] do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = alice
      amount = ExpiringAmount with
        initialAmount = 100.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001
  
  pure ()
  
  -- Show that we can access the amulet data
  pure ()
  
  return ()

-- Test script to show how amulets could be used for payment in OpenCapTable
testAmuletPayment = script do
  -- Setup parties
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  dsoParty <- allocateParty "DSO"
  
  -- Create basic setup
  submit system_operator do
    createCmd OcpFactory with ..
  
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      system_operator = system_operator
      issuer = issuer
      issuer_data = OcfIssuerData with
        legal_name = "TestIssuer Inc."
        formation_date = date 2020 Jan 15
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = 1000
  
    -- Give Alice some amulets
  aliceAmulet <- submitMulti [dsoParty, alice] [] do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = alice
      amount = ExpiringAmount with
        initialAmount = 50.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001

  -- Give Bob some amulets
  bobAmulet <- submitMulti [dsoParty, bob] [] do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = bob
      amount = ExpiringAmount with
        initialAmount = 25.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001
  
  pure ()
  
  return () 