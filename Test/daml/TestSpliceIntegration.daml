module TestSpliceIntegration where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.OcpFactory
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.IssuerAuthorization
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.Types
import Splice.Amulet qualified as Amulet
import Splice.Types
import Splice.Fees
import DA.Date
import Splice.Api.FeaturedAppRightV1 as Featured

-- Simple test script to demonstrate basic Splice amulet integration with OpenCapTable
testSpliceIntegration = script do
  -- Setup parties
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  dsoParty <- allocateParty "DSO" -- Decentralized Synchronizer Operator
  
  -- Create test featured app right
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with 
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator  -- Use system_operator as placeholder for unused parties
      charlie = system_operator
      rando = system_operator
  
  -- Create the OpenCapTable factory
  submit system_operator do
    createCmd OcpFactory with 
      system_operator = system_operator
      featured_app_right = toInterfaceContractId testRightCid
  
  -- Create an issuer
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      system_operator = system_operator
      issuer = issuer
      featured_app_right = toInterfaceContractId testRightCid
      issuer_data = OcfIssuerData with
        legal_name = "TestIssuer Inc."
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
  -- Create a simple amulet for Alice
  amulet <- submitMulti [dsoParty, alice] [] do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = alice
      amount = ExpiringAmount with
        initialAmount = 100.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001
  
  pure ()
  
  -- Show that we can access the amulet data
  pure ()
  
  return ()

-- Test script to show how amulets could be used for payment in OpenCapTable
testAmuletPayment = script do
  -- Setup parties
  system_operator <- allocateParty "SystemOperator"
  issuer <- allocateParty "Issuer"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  dsoParty <- allocateParty "DSO"
  
  -- Create test featured app right
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with 
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = bob
      charlie = system_operator  -- Use system_operator as placeholder for unused parties
      rando = system_operator
  
  -- Create basic setup
  submit system_operator do
    createCmd OcpFactory with 
      system_operator = system_operator
      featured_app_right = toInterfaceContractId testRightCid
  
  submitMulti [system_operator, issuer] [] do
    createCmd Issuer with
      system_operator = system_operator
      issuer = issuer
      featured_app_right = toInterfaceContractId testRightCid
      issuer_data = OcfIssuerData with
        legal_name = "TestIssuer Inc."
        formation_date = Some (date 2020 Jan 15)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        tax_ids = Some []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some 1000.0
  
    -- Give Alice some amulets
  aliceAmulet <- submitMulti [dsoParty, alice] [] do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = alice
      amount = ExpiringAmount with
        initialAmount = 50.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001

  -- Give Bob some amulets
  bobAmulet <- submitMulti [dsoParty, bob] [] do
    createCmd Amulet.Amulet with
      dso = dsoParty
      owner = bob
      amount = ExpiringAmount with
        initialAmount = 25.0
        createdAt = Round 1
        ratePerRound = RatePerRound 0.001

  pure () 