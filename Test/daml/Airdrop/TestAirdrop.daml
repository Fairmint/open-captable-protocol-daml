module Airdrop.TestAirdrop where

import Daml.Script
import DA.List (head)
import Splice.Round (OpenMiningRound)
import CantonPayments.Airdrop.Airdrop (Airdrop(..), AirdropConfig(..), RecipientTransferSpec(..), Airdrop_Join(..), Airdrop_AddObservers(..), Airdrop_Execute(..))
import Shared.TestUtils (setupTestEnv, TestEnv(..), tapWithDso, getAmuletRules)

data TestParties = TestParties
  with
    alice : Party
    bob : Party
    charlie : Party
    dso : Party

allocateTestParties : Script TestParties
allocateTestParties = do
  TestEnv{..} <- setupTestEnv
  alice <- allocatePartyOn "Alice" (ParticipantName "participant0")
  bob <- allocatePartyOn "Bob" (ParticipantName "participant0")
  charlie <- allocatePartyOn "Charlie" (ParticipantName "participant0")
  pure TestParties with
    ..

-- | Test airdrop with observers joining
testAirdropWithJoin : Script ()
testAirdropWithJoin = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso

  -- Alice creates an airdrop
  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob, charlie]

  -- Bob joins (becomes signatory)
  submit bob do
    exerciseCmd airdropCid Airdrop_Join with
      actor = bob

  -- Query to verify
  airdropContracts <- query @Airdrop alice
  assertMsg "Should have one airdrop" (length airdropContracts == 1)
  let (_, airdrop) = head airdropContracts
  assertMsg "Bob should be in joined parties" (bob `elem` airdrop.joinedParties)

  pure ()

-- | Test airdrop execution
testAirdropExecution : Script ()
testAirdropExecution = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso


  -- Alice creates airdrop
  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob, charlie]

  -- Bob joins
  submit bob do
    exerciseCmd airdropCid Airdrop_Join with actor = bob

  -- Query for updated contract
  airdropContracts <- query @Airdrop alice
  let (airdropCid, _) = head airdropContracts

  -- Charlie joins
  submit charlie do
    exerciseCmd airdropCid Airdrop_Join with actor = charlie

  -- Query for updated contract
  airdropContracts <- query @Airdrop alice
  let (airdropCid, _) = head airdropContracts

  -- Alice gets amulets
  amuletCid <- tapWithDso dso alice 300.0

  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds

  -- Execute airdrop with transfer specs
  submit (actAs alice <> readAs dso) do
    exerciseCmd airdropCid Airdrop_Execute with
      transferSpecs =
        [ RecipientTransferSpec with
            recipient = bob
            numberOfTransfers = 2
            appRewardBeneficiaries = []  -- Sender gets 100% of rewards
        , RecipientTransferSpec with
            recipient = charlie
            numberOfTransfers = 1
            appRewardBeneficiaries = []  -- Sender gets 100% of rewards
        ]
      initialAmuletInputs = [amuletCid]
      openMiningRoundCid = openRoundCid
      amountPerTransfer = 50.0
      amuletRules = None

  pure ()

-- | Test duplicate join fails
testDuplicateJoinFails : Script ()
testDuplicateJoinFails = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso


  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob]

  -- Bob joins
  submit bob do
    exerciseCmd airdropCid Airdrop_Join with actor = bob

  -- Get the new contract
  airdropContracts <- query @Airdrop bob
  let (airdropCid2, _) = head airdropContracts

  -- Bob tries to join again - should fail
  submitMustFail bob do
    exerciseCmd airdropCid2 Airdrop_Join with actor = bob

  pure ()

-- | Test non-observer cannot join
testNonObserverCannotJoin : Script ()
testNonObserverCannotJoin = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso


  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob]

  -- Charlie is not an observer, should fail to join
  submitMustFail charlie do
    exerciseCmd airdropCid Airdrop_Join with actor = charlie

  pure ()

-- | Test adding observers
testAddObservers : Script ()
testAddObservers = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso


  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob]

  -- Bob adds Charlie as observer (anyone who can see the contract can add observers)
  submit bob do
    exerciseCmd airdropCid Airdrop_AddObservers with
      actor = bob
      newObservers = [charlie]

  -- Verify charlie is now an observer
  airdropContracts <- query @Airdrop alice
  assertMsg "Should have one airdrop" (length airdropContracts == 1)
  let (_, airdrop) = head airdropContracts
  assertMsg "Charlie should be an observer" (charlie `elem` airdrop.observers)

  pure ()

-- | Test airdrop fails with zero amount
testAirdropFailsWithZeroAmount : Script ()
testAirdropFailsWithZeroAmount = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso


  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob]

  amuletCid <- tapWithDso dso alice 100.0
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds

  -- Try to execute with zero amount - should fail
  submitMustFail (actAs alice <> readAs dso) do
    exerciseCmd airdropCid Airdrop_Execute with
      transferSpecs =
        [ RecipientTransferSpec with
            recipient = bob
            numberOfTransfers = 1
            appRewardBeneficiaries = []
        ]
      initialAmuletInputs = [amuletCid]
      openMiningRoundCid = openRoundCid
      amountPerTransfer = 0.0
      amuletRules = None

  pure ()

-- | Test airdrop fails when sender is observer
testAirdropFailsSenderAsObserver : Script ()
testAirdropFailsSenderAsObserver = script do
  TestParties{..} <- allocateTestParties

  amuletRulesCid <- getAmuletRules dso


  submitMustFail alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [alice, bob]

  pure ()

-- | Test bulk airdrop with multiple recipients
testBulkAirdropMultipleRecipients : Script ()
testBulkAirdropMultipleRecipients = script do
  TestParties{..} <- allocateTestParties

  recipient1 <- allocatePartyOn "Recipient1" (ParticipantName "participant0")
  recipient2 <- allocatePartyOn "Recipient2" (ParticipantName "participant0")

  amuletRulesCid <- getAmuletRules dso


  airdropCid <- submit alice do
    createCmd Airdrop with
      config = AirdropConfig with
        sender = alice
        featuredAppRight = None
        amuletRulesCid = amuletRulesCid
        dso = dso
      joinedParties = []
      observers = [bob, charlie, recipient1, recipient2]

  -- Recipients join
  submit bob do
    exerciseCmd airdropCid Airdrop_Join with actor = bob
  airdropContracts <- query @Airdrop alice
  let (airdropCid, _) = head airdropContracts

  submit charlie do
    exerciseCmd airdropCid Airdrop_Join with actor = charlie
  airdropContracts <- query @Airdrop alice
  let (airdropCid, _) = head airdropContracts

  submit recipient1 do
    exerciseCmd airdropCid Airdrop_Join with actor = recipient1
  airdropContracts <- query @Airdrop alice
  let (airdropCid, _) = head airdropContracts

  submit recipient2 do
    exerciseCmd airdropCid Airdrop_Join with actor = recipient2
  airdropContracts <- query @Airdrop alice
  let (airdropCid, _) = head airdropContracts

  -- Alice executes bulk airdrop
  amuletCid <- tapWithDso dso alice 600.0

  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds

  -- Execute airdrop
  submit (actAs alice <> readAs dso) do
    exerciseCmd airdropCid Airdrop_Execute with
      transferSpecs =
        [ RecipientTransferSpec with
            recipient = bob
            numberOfTransfers = 1
            appRewardBeneficiaries = []
        , RecipientTransferSpec with
            recipient = charlie
            numberOfTransfers = 1
            appRewardBeneficiaries = []
        , RecipientTransferSpec with
            recipient = recipient1
            numberOfTransfers = 2
            appRewardBeneficiaries = []
        , RecipientTransferSpec with
            recipient = recipient2
            numberOfTransfers = 3
            appRewardBeneficiaries = []
        ]
      initialAmuletInputs = [amuletCid]
      openMiningRoundCid = openRoundCid
      amountPerTransfer = 50.0
      amuletRules = None

  pure ()
