module Airdrop.TestPersonalAirdrop where

import Daml.Script
import DA.List (head)
import qualified Splice.Amulet as Amulet
import Splice.Round (OpenMiningRound)
import Splice.Api.FeaturedAppRightV1 (AppRewardBeneficiary(..))
import CantonPayments.Airdrop.PersonalAirdrop (PersonalAirdrop(..), PersonalAirdrop_ExecuteTransfer(..))
import Shared.TestUtils (tapWithDso, getAmuletRules)

-- | Test PersonalAirdrop_ExecuteTransfer with amuletRulesCidOverride = None (default behavior)
testPersonalAirdropExecuteTransferWithNone : Script ()
testPersonalAirdropExecuteTransferWithNone = script do
  dso <- allocatePartyOn "dso" (ParticipantName "participant0")
  sender <- allocatePartyOn "Sender" (ParticipantName "participant0")
  recipient <- allocatePartyOn "Recipient" (ParticipantName "participant0")

  -- Use sender as provider for simplicity (sender is authorized)
  let provider = sender

  -- Get amulets (this sets up AmuletRules and OpenMiningRound)
  amuletCid <- tapWithDso dso sender 100.0

  -- Get the amuletRulesCid from the same DSO
  amuletRulesCid <- getAmuletRules dso

  -- Query for current open rounds
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds

  -- Create FeaturedAppRight for the provider
  featuredAppRightCid <- submit dso do
    createCmd Amulet.FeaturedAppRight with
      dso
      provider

  -- Create PersonalAirdrop contract (both sender and recipient are signatories)
  personalAirdropCid <- submit (actAs sender <> actAs recipient) do
    createCmd PersonalAirdrop with
      dso
      sender
      provider
      featuredAppRight = featuredAppRightCid
      amuletRulesCid
      appRewardBeneficiaries =
        [ AppRewardBeneficiary with beneficiary = provider; weight = 1.0 ]
      recipient

  -- Execute transfer with amuletRulesCidOverride = None (uses stored amuletRulesCid)
  submit (actAs sender <> readAs dso) do
    exerciseCmd personalAirdropCid PersonalAirdrop_ExecuteTransfer with
      amuletInputs = [amuletCid]
      openMiningRoundCid = openRoundCid
      amount = 10.0
      numberOfTransfers = 1
      optMergeAmuletInputs = None
      amuletRulesCidOverride = None

  pure ()

-- | Test PersonalAirdrop_ExecuteTransfer with amuletRulesCidOverride = Some (override behavior)
testPersonalAirdropExecuteTransferWithOverride : Script ()
testPersonalAirdropExecuteTransferWithOverride = script do
  dso <- allocatePartyOn "dso" (ParticipantName "participant0")
  sender <- allocatePartyOn "Sender" (ParticipantName "participant0")
  recipient <- allocatePartyOn "Recipient" (ParticipantName "participant0")

  -- Use sender as provider for simplicity (sender is authorized)
  let provider = sender

  -- Get amulets (this sets up AmuletRules and OpenMiningRound)
  amuletCid <- tapWithDso dso sender 100.0

  -- Get the amuletRulesCid from the same DSO
  amuletRulesCid <- getAmuletRules dso

  -- Query for current open rounds
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds

  -- Create FeaturedAppRight for the provider
  featuredAppRightCid <- submit dso do
    createCmd Amulet.FeaturedAppRight with
      dso
      provider

  -- Create PersonalAirdrop contract with the amuletRulesCid
  personalAirdropCid <- submit (actAs sender <> actAs recipient) do
    createCmd PersonalAirdrop with
      dso
      sender
      provider
      featuredAppRight = featuredAppRightCid
      amuletRulesCid
      appRewardBeneficiaries =
        [ AppRewardBeneficiary with beneficiary = provider; weight = 1.0 ]
      recipient

  -- Execute transfer with amuletRulesCidOverride = Some (uses override instead of stored)
  -- Get the same amuletRulesCid to use as override (demonstrates the override works)
  submit (actAs sender <> readAs dso) do
    exerciseCmd personalAirdropCid PersonalAirdrop_ExecuteTransfer with
      amuletInputs = [amuletCid]
      openMiningRoundCid = openRoundCid
      amount = 10.0
      numberOfTransfers = 1
      optMergeAmuletInputs = None
      amuletRulesCidOverride = Some amuletRulesCid

  pure ()

-- | Test PersonalAirdrop_ExecuteTransfer with multiple transfers and None override
testPersonalAirdropMultipleTransfersWithNone : Script ()
testPersonalAirdropMultipleTransfersWithNone = script do
  dso <- allocatePartyOn "dso" (ParticipantName "participant0")
  sender <- allocatePartyOn "Sender" (ParticipantName "participant0")
  recipient <- allocatePartyOn "Recipient" (ParticipantName "participant0")

  -- Use sender as provider for simplicity (sender is authorized)
  let provider = sender

  -- Get amulets (this sets up AmuletRules and OpenMiningRound)
  amuletCid <- tapWithDso dso sender 100.0

  -- Get the amuletRulesCid from the same DSO
  amuletRulesCid <- getAmuletRules dso

  -- Query for current open rounds
  openRounds <- query @OpenMiningRound dso
  now <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, _) = head currentOpenRounds

  -- Create FeaturedAppRight for the provider
  featuredAppRightCid <- submit dso do
    createCmd Amulet.FeaturedAppRight with
      dso
      provider

  -- Create PersonalAirdrop contract
  personalAirdropCid <- submit (actAs sender <> actAs recipient) do
    createCmd PersonalAirdrop with
      dso
      sender
      provider
      featuredAppRight = featuredAppRightCid
      amuletRulesCid
      appRewardBeneficiaries =
        [ AppRewardBeneficiary with beneficiary = provider; weight = 1.0 ]
      recipient

  -- Execute multiple transfers with amuletRulesCidOverride = None
  submit (actAs sender <> readAs dso) do
    exerciseCmd personalAirdropCid PersonalAirdrop_ExecuteTransfer with
      amuletInputs = [amuletCid]
      openMiningRoundCid = openRoundCid
      amount = 10.0
      numberOfTransfers = 3
      optMergeAmuletInputs = None
      amuletRulesCidOverride = None

  pure ()
