module Airdrop.SimpleAirdropTest where

import DA.Assert
import DA.Foldable (minimum, maximum)
import Daml.Script

-- | Test: Validate RecipientSpec structure and calculations
test_RecipientSpecCalculations : Script ()
test_RecipientSpecCalculations = script do
  -- Test transfer count calculations
  let numberOfTransfers1 = 3
  let numberOfTransfers2 = 5
  let numberOfTransfers3 = 2

  let totalTransfers = numberOfTransfers1 + numberOfTransfers2 + numberOfTransfers3
  totalTransfers === 10

  -- Verify all are positive
  all (\n -> n > 0) [numberOfTransfers1, numberOfTransfers2, numberOfTransfers3] === True

-- | Test: Validate total transfer calculations across multiple recipients
test_MultipleRecipientsCalculations : Script ()
test_MultipleRecipientsCalculations = script do
  -- Test calculating total transfers across multiple recipients
  let transferCounts = [5, 3, 1, 2, 4]

  -- Verify total number of transfers
  let totalTransfers = sum transferCounts
  totalTransfers === 15

  -- Verify all counts are positive
  all (\count -> count > 0) transferCounts === True

  -- Verify minimum and maximum
  let minTransfers = minimum transferCounts
  let maxTransfers = maximum transferCounts
  minTransfers === 1
  maxTransfers === 5

-- | Run all tests
test_All : Script ()
test_All = script do
  test_RecipientSpecCalculations
  test_MultipleRecipientsCalculations
  pure ()
