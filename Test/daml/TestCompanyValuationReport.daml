module TestCompanyValuationReport where

import Daml.Script
import DA.Time
import qualified DA.Set as Set

import Fairmint.OpenCapTable.CompanyValuationReport
import Fairmint.OpenCapTable.OcpFactory

-- Create a report, add observers (with duplicates), update valuation, and confirm current timestamp
happyPath : Script ()
happyPath = script do
  system_operator <- allocateParty "SystemOperator"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  -- Create initial report
  t0 <- getTime
  factoryCid <- submit system_operator do
    createCmd OcpFactory with system_operator
  reportCid <- submit system_operator do
    exerciseCmd factoryCid CreateCompanyValuationReport with
      company_id = "co-1"
      company_valuation = 100
      observers = []

  -- Add observers with duplicates; expect dedup
  reportCid1 <- submit system_operator do
    exerciseCmd reportCid AddObservers with added = [alice, bob, alice]

  report1Opt <- queryContractId system_operator reportCid1
  case report1Opt of
    None -> abort "Report not found after AddObservers"
    Some report1 -> assert (Set.fromList report1.observers == Set.fromList [alice, bob])

  -- Advance time, update valuation
  passTime (minutes 10)
  t1 <- getTime
  reportCid2 <- submit system_operator do
    exerciseCmd reportCid1 SetCompanyValuation with new_company_valuation = 200

  report2Opt <- queryContractId system_operator reportCid2
  case report2Opt of
    None -> abort "Report not found after SetCompanyValuation"
    Some report2 -> do
      assert (report2.company_valuation == 200)
      assert (report2.last_update_at == t1)
      assert (Set.fromList report2.observers == Set.fromList [alice, bob])

  -- Advance time and confirm current without changing valuation
  passTime (minutes 10)
  t2 <- getTime
  reportCid3 <- submit system_operator do
    exerciseCmd reportCid2 ConfirmCurrent

  report3Opt <- queryContractId system_operator reportCid3
  case report3Opt of
    None -> abort "Report not found after ConfirmCurrent"
    Some report3 -> do
      assert (report3.company_valuation == 200)
      assert (report3.last_update_at == t2)
      assert (Set.fromList report3.observers == Set.fromList [alice, bob])

-- Only the system operator can exercise choices; and negative valuations are rejected by ensure
accessControlAndValidation : Script ()
accessControlAndValidation = script do
  system_operator <- allocateParty "SystemOperator"
  alice <- allocateParty "Alice"

  t0 <- getTime
  factoryCid <- submit system_operator do
    createCmd OcpFactory with system_operator
  reportCid <- submit system_operator do
    exerciseCmd factoryCid CreateCompanyValuationReport with
      company_id = "co-2"
      company_valuation = 50
      observers = []

  -- Non-operator cannot add observers
  submitMustFail alice do
    exerciseCmd reportCid AddObservers with added = [alice]

  -- Negative valuation update must fail (template ensure enforces non-negative)
  submitMustFail system_operator do
    exerciseCmd reportCid SetCompanyValuation with new_company_valuation = -1

  pure () 

-- AddObservers with an empty list should revert
addObserversEmptyList : Script ()
addObserversEmptyList = script do
  system_operator <- allocateParty "SystemOperator"
  alice <- allocateParty "Alice"

  t0 <- getTime
  factoryCid <- submit system_operator do
    createCmd OcpFactory with system_operator
  reportCid <- submit system_operator do
    exerciseCmd factoryCid CreateCompanyValuationReport with
      company_id = "co-empty-observers"
      company_valuation = 0
      observers = [alice]

  submitMustFail system_operator do
    exerciseCmd reportCid AddObservers with added = []

-- Very large valuation numbers (boundary of Int64)
largeValuationNumbers : Script ()
largeValuationNumbers = script do
  system_operator <- allocateParty "SystemOperator"

  let big : Int = 9223372036854775807 -- 2^63 - 1

  t0 <- getTime
  factoryCid <- submit system_operator do
    createCmd OcpFactory with system_operator
  reportCid <- submit system_operator do
    exerciseCmd factoryCid CreateCompanyValuationReport with
      company_id = "co-big"
      company_valuation = big
      observers = []

  passTime (minutes 1)
  t1 <- getTime
  reportCid' <- submit system_operator do
    -- Set again to the same big value to ensure it's accepted in updates too
    exerciseCmd reportCid SetCompanyValuation with new_company_valuation = big

  reportOpt <- queryContractId system_operator reportCid'
  case reportOpt of
    None -> abort "Report not found after setting big valuation"
    Some report -> do
      assert (report.company_valuation == big)
      assert (report.last_update_at == t1)

-- company_id edge cases: empty should fail; special characters should be accepted
companyIdEdgeCases : Script ()
companyIdEdgeCases = script do
  system_operator <- allocateParty "SystemOperator"

  t0 <- getTime
  -- Empty company_id should fail due to ensure
  factoryCid <- submit system_operator do
    createCmd OcpFactory with system_operator
  submitMustFail system_operator do
    exerciseCmd factoryCid CreateCompanyValuationReport with
      company_id = ""
      company_valuation = 1
      observers = []

  let specialId = "co-!@#$%^&*()_+=/\\:;,.?<>[]{}|~"
  t1 <- getTime
  factoryCid2 <- submit system_operator do
    createCmd OcpFactory with system_operator
  specialCid <- submit system_operator do
    exerciseCmd factoryCid2 CreateCompanyValuationReport with
      company_id = specialId
      company_valuation = 2
      observers = []

  specialOpt <- queryContractId system_operator specialCid
  case specialOpt of
    None -> abort "Special company_id report not found"
    Some report -> assert (report.company_id == specialId) 