module TestReports where
import Fairmint.OpenCapTableReports.ReportsFactory
import Fairmint.OpenCapTableReports.CompanyValuationReport
import Setup
import Daml.Script
import DA.Date
import DA.Time

-- Create a company valuation report via factory
testCreateCompanyValuationReport = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  factoryCid <- submit system_operator do
    createCmd ReportsFactory with
      system_operator = system_operator
      featured_app_right = toInterfaceContractId rightCid
  _reportCid <- submit system_operator do
    exerciseCmd factoryCid CreateCompanyValuationReport with
      company_id = "acme"
      company_valuation = Some 123.45
      observers = [issuer, alice]
  pure ()

-- Exercise CompanyValuationReport choices
testCompanyValuationReportChoices = script do
  TestUsers{system_operator, issuer, alice, bob} <- setupUsers
  rightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = bob
      charlie = system_operator
      rando = system_operator
  reportCid <- submit system_operator do
    createCmd CompanyValuationReport with
      company_id = "acme"
      company_valuation = None
      last_update_at = DA.Time.time (DA.Date.date 2024 Jan 1) 0 0 0
      system_operator = system_operator
      featured_app_right = toInterfaceContractId rightCid
      observers = [issuer]
  -- AddObservers with a truly new observer returns a new contract id
  reportCid2 <- submit system_operator do
    exerciseCmd reportCid AddObservers with added = [alice]
  -- SetCompanyValuation on the latest contract
  _ <- submit system_operator do
    exerciseCmd reportCid2 SetCompanyValuation with new_company_valuation = Some 999.99
  pure ()
