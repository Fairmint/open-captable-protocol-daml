-- Test processing a subscription payment
testProcessPayment : Script ()
testProcessPayment = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create subscription
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with
      amountPerDay = AmuletAmount 1.0
      featuredAppRight = None
    processorPayment = PaymentConfig with
      amountPerDay = AmuletAmount 0.2
      featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Monthly service"
  
  -- Processor approves
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  -- Bob accepts to create active subscription
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Alice creates amulet for payment (before advancing time so mining rounds exist)
  -- This also sets up AmuletRules and OpenMiningRounds
  amuletCid <- tapWithDso dso alice 100.0
  
  -- Get payment context - query for rounds that are actually open at current time
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, openRound) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Wait for the processing period to elapse
  now2 <- getTime
  setTime (addRelTime now2 (days 31))
  
  -- Get disclosures for contracts the processor needs
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Process payment with explicit contract disclosures
  result <- submitWithDisclosures processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        amuletPrice = openRound.amuletPrice
  
  -- Verify the subscription was updated
  Some updatedSubscription <- queryContractId alice result.subscriptionCid
  assertMsg "Subscription should be updated" (updatedSubscription.paidUntil > now)
  
  pure ()

-- Test processing payment fails before period elapses
testProcessPaymentFailsBeforePeriodElapses : Script ()
testProcessPaymentFailsBeforePeriodElapses = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create subscription
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with
      amountPerDay = AmuletAmount 5.0
      featuredAppRight = None
    processorPayment = PaymentConfig with
      amountPerDay = AmuletAmount 1.0
      featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Service"
  
  -- Processor approves
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  -- Bob accepts
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Create amulet for payment
  amuletCid <- tapWithDso dso alice 50.0
  
  -- Get payment context - query for rounds that are actually open at current time
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, openRound) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Get disclosures for contracts the processor needs
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Try to process payment immediately (should fail - period hasn't elapsed)
  submitWithDisclosuresMustFail processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        amuletPrice = openRound.amuletPrice
  
  pure ()

-- Test processing payment fails after expiration
testProcessPaymentFailsAfterExpiration : Script ()
testProcessPaymentFailsAfterExpiration = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create subscription with short expiration
  now <- getTime
  let expiresAt = addRelTime now (days 60)  -- Expires in 60 days
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with
      amountPerDay = AmuletAmount 5.0
      featuredAppRight = None
    processorPayment = PaymentConfig with
      amountPerDay = AmuletAmount 1.0
      featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Service"
  
  -- Processor approves
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  -- Bob accepts
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Create amulet for payment before advancing time
  amuletCid <- tapWithDso dso alice 50.0
  
  -- Get payment context - query for rounds that are actually open at current time
  openRounds <- query @OpenMiningRound dso
  now3 <- getTime
  let currentOpenRounds = filter (\(_, r) -> r.opensAt <= now3) openRounds
  assertMsg "Need at least one open round" (not (null currentOpenRounds))
  let (openRoundCid, openRound) = head currentOpenRounds
  amuletRulesCid <- getAmuletRules dso
  
  -- Wait past expiration
  now2 <- getTime
  setTime (addRelTime now2 (days 61))
  
  -- Get disclosures for contracts the processor needs
  Some amuletDisclosure <- queryDisclosure alice amuletCid
  Some amuletRulesDisclosure <- queryDisclosure dso amuletRulesCid
  Some openRoundDisclosure <- queryDisclosure dso openRoundCid
  
  -- Try to process payment after expiration (should fail)
  submitWithDisclosuresMustFail processor [amuletDisclosure, amuletRulesDisclosure, openRoundDisclosure] do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      processingPeriod = days 30
      paymentCtx = PaymentContext with
        amuletInputs = [amuletCid]
        amuletRulesCid = amuletRulesCid
        openMiningRoundCid = openRoundCid
        amuletPrice = openRound.amuletPrice
  
  pure ()

-- Test recipient can update their own FeaturedAppRight
testRecipientUpdatesFeaturedAppRight : Script ()
testRecipientUpdatesFeaturedAppRight = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create subscription
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with
      amountPerDay = AmuletAmount 1.0
      featuredAppRight = None
    processorPayment = PaymentConfig with
      amountPerDay = AmuletAmount 0.2
      featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Test subscription"
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Create FeaturedAppRight for Bob
  bobFarCid <- submit dso do
    createCmd TestFeaturedAppRight with
      dso = dso
      provider = bob
  
  -- Bob updates their own FeaturedAppRight
  updatedSubscriptionCid <- submit bob do
    exerciseCmd subscriptionCid Subscription_UpdateRecipientFeaturedAppRight with
      newFeaturedAppRight = Some (coerceContractId bobFarCid)
  
  -- Verify update
  Some updatedSub <- queryContractId bob updatedSubscriptionCid
  assertMsg "Recipient FeaturedAppRight should be updated" 
    (updatedSub.config.recipientPayment.featuredAppRight == Some (coerceContractId bobFarCid))
  
  -- Bob removes their FeaturedAppRight
  finalSubscriptionCid <- submit bob do
    exerciseCmd updatedSubscriptionCid Subscription_UpdateRecipientFeaturedAppRight with
      newFeaturedAppRight = None
  
  -- Verify removal
  Some finalSub <- queryContractId bob finalSubscriptionCid
  assertMsg "Recipient FeaturedAppRight should be None" 
    (finalSub.config.recipientPayment.featuredAppRight == None)
  
  pure ()

