-- Test validation: subscriber and recipient must be different
testSubscriberRecipientMustBeDifferent : Script ()
testSubscriberRecipientMustBeDifferent = script do
  alice <- allocateParty "Alice"
  processor <- allocateParty "Processor"
  
  factoryCid <- createSubscriptionFactory processor
  
  -- Try to create proposal where subscriber == recipient
  submitMustFail alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = alice  -- Same as subscriber
        amountPerRound = 5.0
        feeAmountPerRound = 1.0
        reason = Some "Service"
  
  pure ()
