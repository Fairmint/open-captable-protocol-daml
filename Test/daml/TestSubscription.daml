-- Test validation: cannot process old rounds
testCannotProcessOldRounds : Script ()
testCannotProcessOldRounds = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  -- Create and propose with locked amulet
  lockedAmuletCid <- createLockedAmulet alice 100.0
  
  proposalCid <- submit alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = "Service subscription"
      amountPerRound = 5.0
      lockedAmulet = lockedAmuletCid
  
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept
  
  -- Process up to round 5
  result <- submit bob do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      currentRound = 5
      subscriptionId = "sub-002"
  
  -- Try to process round 3 (before last processed) - should fail
  submitMustFail bob do
    exerciseCmd result.subscriptionCid Subscription_ProcessPayment with
      currentRound = 3
      subscriptionId = "sub-002"
  
  pure ()

-- Test validation: empty reason not allowed
testEmptyReasonNotAllowed : Script ()
testEmptyReasonNotAllowed = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  lockedAmuletCid <- createLockedAmulet alice 50.0
  
  -- Try to create proposal with empty reason
  submitMustFail alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = ""
      amountPerRound = 5.0
      lockedAmulet = lockedAmuletCid
  
  pure ()

-- Test validation: negative amount not allowed
testNegativeAmountNotAllowed : Script ()
testNegativeAmountNotAllowed = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  lockedAmuletCid <- createLockedAmulet alice 50.0
  
