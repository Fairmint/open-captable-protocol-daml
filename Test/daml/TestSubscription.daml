module TestSubscription where

import Daml.Script
import DA.Time (days, addRelTime)
import DA.List (head)
import Splice.Round (OpenMiningRound)
import Splice.Api.FeaturedAppRightV1 qualified as Featured
import Fairmint.Subscriptions.Subscription
import Fairmint.Subscriptions.SubscriptionProposal
import Fairmint.Subscriptions.ProcessorApprovedSubscriptionProposal
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionConfig(..), ProcessorContext(..), SubscriptionAmount(..), PaymentConfig(..))
import TestUtils (tapWithDso, sharedDso, getAmuletRules)

-- | Test-only FeaturedAppRight template for testing subscription updates
template TestFeaturedAppRight
  with
    dso : Party
    provider : Party
  where
    signatory dso
    observer provider
    interface instance Featured.FeaturedAppRight for TestFeaturedAppRight where
      view = Featured.FeaturedAppRightView with dso, provider
      featuredAppRight_CreateActivityMarkerImpl _ arg = do
        pure (Featured.FeaturedAppRight_CreateActivityMarkerResult [])

-- Helper to create a SubscriptionFactory
createSubscriptionFactory : Party -> Script (ContractId SubscriptionFactory)
createSubscriptionFactory processor = do
  dso <- sharedDso
  submit processor do
    createCmd SubscriptionFactory with
      context = ProcessorContext with
        processor = processor
        dso = dso

-- Helper to create a subscription proposal
-- Uses createAndExerciseCmd to create factory and proposal in one transaction, avoiding divulgence issues
createProposal : Party -> Party -> Party -> SubscriptionConfig -> Script (ContractId SubscriptionProposal)
createProposal processor subscriber dso config = do
  submitMulti [subscriber, processor] [] do
    createAndExerciseCmd
      (SubscriptionFactory with
        context = ProcessorContext with
          processor = processor
          dso = dso)
      (SubscriptionFactory_CreateProposal with
        config = config)

-- Test the factory/proposal/approval/acceptance flow
testFactoryProposalAcceptance : Script ()
testFactoryProposalAcceptance = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Alice creates subscription proposal via factory
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with
      amountPerDay = AmuletAmount 1.0
      featuredAppRight = None
    processorPayment = PaymentConfig with
      amountPerDay = AmuletAmount 0.2
      featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Monthly service fee"
  
  -- Processor approves the proposal
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  -- Bob (recipient) accepts the approved proposal
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Verify subscription was created
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
  assertMsg "Processor should match" (subscription.context.processor == processor)
  assertMsg "Amount per day should be 1.0" (subscription.config.recipientPayment.amountPerDay == AmuletAmount 1.0)
  assertMsg "Fee amount per day should be 0.2" (subscription.config.processorPayment.amountPerDay == AmuletAmount 0.2)
  
  pure ()

-- Test proposal rejection by recipient
testProposalRejectionByRecipient : Script ()
testProposalRejectionByRecipient = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Alice proposes subscription via factory
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with
      amountPerDay = AmuletAmount 5.0
      featuredAppRight = None
    processorPayment = PaymentConfig with
      amountPerDay = AmuletAmount 1.0
      featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Service subscription"
  
  -- Bob (recipient) rejects
  submit bob do
    exerciseCmd proposalCid SubscriptionProposal_RecipientReject
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

