-- Test validation: zero fee is allowed
testZeroFeeAllowed : Script ()
testZeroFeeAllowed = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  
  factoryCid <- createSubscriptionFactory processor
  
  -- Create proposal with zero fee (should succeed)
  proposalCid <- submit alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = 5.0
        feeAmountPerRound = 0.0
        reason = Some "Service"
  
  -- Verify proposal was created
  Some proposal <- queryContractId alice proposalCid
  assertMsg "Fee should be 0.0" (proposal.config.feeAmountPerRound == 0.0)
  
  pure ()

