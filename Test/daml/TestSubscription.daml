module TestSubscription where

import Daml.Script
import DA.Date (datetime, Month(..))
import Fairmint.Subscriptions.Subscription
import Fairmint.Subscriptions.SubscriptionProposal
import Fairmint.Subscriptions.SubscriptionFactory
import Fairmint.Subscriptions.SubscriptionConfig (SubscriptionConfig(..), ProcessorContext(..))
import Splice.AmuletRules (TransferContext(..), AmuletRules)
import TestUtils (tap, sharedDso, getFirstOpenRound, getAmuletRules)
import qualified DA.Map as Map

-- Helper to create a SubscriptionFactory
createSubscriptionFactory : Party -> Script (ContractId SubscriptionFactory)
createSubscriptionFactory processor = do
  dso <- sharedDso
  submit processor do
    createCmd SubscriptionFactory with
      context = ProcessorContext with
        processor = processor
        dso = dso

-- Test the factory/proposal/acceptance flow
testFactoryProposalAcceptance : Script ()
testFactoryProposalAcceptance = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create factory
  factoryCid <- createSubscriptionFactory processor
  
  -- Alice creates subscription proposal via factory (no amulet yet)
  proposalCid <- submit alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = 10.0
        feeAmountPerRound = 2.0
        reason = Some "Monthly service fee"
  
  -- Alice creates an amulet for payment
  amuletCid <- tap alice 100.0
  
  -- Get necessary context for locking the amulet
  openRoundCid <- getFirstOpenRound dso
  amuletRulesCid <- getAmuletRules dso
  let transferContext = TransferContext with
        openMiningRound = openRoundCid
        featuredAppRight = None
        issuingMiningRounds = Map.empty
        validatorRights = Map.empty
  
  -- Bob accepts the proposal, providing the amulet and locking 100.0
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept with
      inputAmulets = [amuletCid]
      amountToLock = 100.0
      amuletRulesCid = amuletRulesCid
      openMiningRoundCid = openRoundCid
      transferContext = transferContext
  
  -- Verify subscription was created with locked amulet
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.config.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.config.recipient == bob)
  assertMsg "Processor should match" (subscription.processor == processor)
  assertMsg "Should have locked amulet" (subscription.lockedAmulet /= None)
  assertMsg "Amount per round should be 10.0" (subscription.config.amountPerRound == 10.0)
  assertMsg "Fee amount per round should be 2.0" (subscription.config.feeAmountPerRound == 2.0)
  
  pure ()

-- Test proposal rejection
testProposalRejection : Script ()
testProposalRejection = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  
  -- Create factory
  factoryCid <- createSubscriptionFactory processor
  
  -- Alice proposes subscription via factory
  proposalCid <- submit alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = 5.0
        feeAmountPerRound = 1.0
        reason = Some "Service subscription"
  
  -- Bob rejects
  submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Reject
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- Test subscriber canceling proposal
testProposalCancelBySubscriber : Script ()
testProposalCancelBySubscriber = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  
  -- Create factory
  factoryCid <- createSubscriptionFactory processor
  
  -- Alice proposes subscription via factory
  proposalCid <- submit alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = 5.0
        feeAmountPerRound = 1.0
        reason = Some "Service subscription"
  
  -- Alice cancels before Bob accepts
  submit alice do
    exerciseCmd proposalCid SubscriptionProposal_Cancel
  
  -- Verify proposal is archived
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  pure ()

-- Test cancellation by subscriber
testCancelBySubscriber : Script ()
testCancelBySubscriber = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create factory
  factoryCid <- createSubscriptionFactory processor
  
  -- Alice proposes via factory
  proposalCid <- submit alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = 5.0
        feeAmountPerRound = 1.0
        reason = Some "Service subscription"
  
  -- Alice creates amulet and Bob accepts with locking
  amuletCid <- tap alice 50.0
  openRoundCid <- getFirstOpenRound dso
  amuletRulesCid <- getAmuletRules dso
  let transferContext = TransferContext with
        openMiningRound = openRoundCid
        featuredAppRight = None
        issuingMiningRounds = Map.empty
        validatorRights = Map.empty
  
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept with
      amuletCid = amuletCid
      amuletRulesCid = amuletRulesCid
      openMiningRoundCid = openRoundCid
      transferContext = transferContext
  
  -- Alice cancels
  returnedLockedAmulet <- submit alice do
    exerciseCmd subscriptionCid Subscription_CancelBySubscriber
  
  -- Verify subscription was archived
  subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  -- Verify we got back the locked amulet
  assertMsg "Should return locked amulet" (returnedLockedAmulet /= None)
  
  pure ()

-- Test cancellation by recipient
testCancelByRecipient : Script ()
testCancelByRecipient = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  -- Create factory
  factoryCid <- createSubscriptionFactory processor
  
  -- Alice proposes via factory
  proposalCid <- submit alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = 5.0
        feeAmountPerRound = 1.0
        reason = Some "Service subscription"
  
  -- Alice creates amulet and Bob accepts
  amuletCid <- tap alice 50.0
  
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept with
      amuletCid = amuletCid
  
  -- Bob cancels
  returnedAmulet <- submit bob do
    exerciseCmd subscriptionCid Subscription_CancelByRecipient
  
  -- Verify subscription was archived
  subscription <- queryContractId bob subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  -- Verify we got back the amulet
  assertMsg "Should return amulet" (returnedAmulet /= None)
  
  pure ()

-- Test validation: negative amount not allowed
testNegativeAmountNotAllowed : Script ()
testNegativeAmountNotAllowed = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  
  factoryCid <- createSubscriptionFactory processor
  
  -- Try to create proposal with negative amount
  submitMustFail alice do
    exerciseCmd factoryCid SubscriptionFactory_CreateProposal with
      config = SubscriptionConfig with
        subscriber = alice
        recipient = bob
        amountPerRound = -5.0
        feeAmountPerRound = 1.0
        reason = Some "Service"
  
  pure ()

