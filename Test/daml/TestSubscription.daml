-- Test Subscription_DecreaseExpiration
testDecreaseExpiration : Script ()
testDecreaseExpiration = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with amountPerDay = AmuletAmount 1.0, featuredAppRight = None
    processorPayment = PaymentConfig with amountPerDay = AmuletAmount 0.2, featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = None
    reason = Some "Test"
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Recipient decreases expiration
  let newExpiresAt = addRelTime now (days 180)
  updatedCid <- submit bob do
    exerciseCmd subscriptionCid Subscription_DecreaseExpiration with
      newExpiresAt = newExpiresAt
      exercisingParty = bob
  
  Some updated <- queryContractId alice updatedCid
  assertMsg "Expiration should be decreased" (updated.config.expiresAt == newExpiresAt)
  
  pure ()

-- Test Subscription_ProcessFreeTrial
testProcessFreeTrial : Script ()
testProcessFreeTrial = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  processor <- allocateParty "Processor"
  dso <- sharedDso
  
  now <- getTime
  let expiresAt = addRelTime now (days 365)
  let freeTrialEndsAt = addRelTime now (days 30)
  proposalCid <- createProposal processor alice dso SubscriptionConfig with
    subscriber = alice
    recipient = bob
    recipientPayment = PaymentConfig with amountPerDay = AmuletAmount 1.0, featuredAppRight = None
    processorPayment = PaymentConfig with amountPerDay = AmuletAmount 0.2, featuredAppRight = None
    prepayWindow = days 0
    expiresAt = expiresAt
    freeTrialEndsAt = Some freeTrialEndsAt
    reason = Some "Test"
  
  approvedProposalCid <- submit processor do
    exerciseCmd proposalCid SubscriptionProposal_ProcessorApprove
  
  subscriptionCid <- submit bob do
    exerciseCmd approvedProposalCid ProcessorApprovedSubscriptionProposal_RecipientAccept
  
  -- Wait 10 days then process free trial
  setTime (addRelTime now (days 10))
  
  result <- submit processor do
    exerciseCmd subscriptionCid Subscription_ProcessFreeTrial with
      processingPeriod = days 7
  
  Some updated <- queryContractId alice result.subscriptionCid
  assertMsg "paidUntil should advance" (updated.paidUntil > now)
  
  pure ()

