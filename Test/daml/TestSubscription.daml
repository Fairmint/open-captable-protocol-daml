module TestSubscription where

import Daml.Script
import DA.Date (datetime, Month(..))
import Splice.Subscriptions.Subscription
import Splice.Amulet qualified as Amulet
import Splice.Expiry (TimeLock(..))
import TestUtils (tap, sharedDso)

-- Helper to create a LockedAmulet for testing
createLockedAmulet : Party -> Decimal -> Script (ContractId Amulet.LockedAmulet)
createLockedAmulet owner amount = do
  dso <- sharedDso
  amuletCid <- tap owner amount
  Some amulet <- queryContractId owner amuletCid
  
  -- Create LockedAmulet (signed by both dso and owner)
  submitMulti [dso, owner] [] do
    createCmd Amulet.LockedAmulet with
      amulet = amulet
      lock = TimeLock with
        holders = [owner]
        expiresAt = datetime 2099 Dec 31 23 59 59
        optContext = Some "Subscription collateral"

-- Test the proposal/acceptance flow with locked funds
testProposalAcceptance : Script ()
testProposalAcceptance = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  -- Alice locks funds first
  lockedAmuletCid <- createLockedAmulet alice 100.0
  
  -- Alice proposes subscription with locked funds (no DSO signature needed)
  proposalCid <- submit alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = "Monthly service fee"
      amountPerRound = 10.0
      lockedAmulet = lockedAmuletCid
  
  -- Bob accepts the proposal (no DSO signature needed)
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept
  
  -- Verify subscription was created with locked funds
  Some subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscriber should be alice" (subscription.subscriber == alice)
  assertMsg "Recipient should be bob" (subscription.recipient == bob)
  assertMsg "Provider should match" (subscription.provider == provider)
  assertMsg "Should have locked amulet" (subscription.lockedAmulet == Some lockedAmuletCid)
  
  pure ()

-- Test proposal rejection returns locked funds
testProposalRejection : Script ()
testProposalRejection = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  -- Alice locks funds
  lockedAmuletCid <- createLockedAmulet alice 50.0
  
  -- Alice proposes subscription
  proposalCid <- submit alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = "Service subscription"
      amountPerRound = 5.0
      lockedAmulet = lockedAmuletCid
  
  -- Bob rejects (no DSO signature needed)
  returnedLockedAmuletCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Reject
  
  -- Verify proposal is archived
  proposal <- queryContractId bob proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  -- Verify we got back the locked amulet
  assertMsg "Should return locked amulet" (returnedLockedAmuletCid == lockedAmuletCid)
  
  pure ()

-- Test subscriber canceling proposal gets funds back
testProposalCancelBySubscriber : Script ()
testProposalCancelBySubscriber = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  -- Alice locks funds
  lockedAmuletCid <- createLockedAmulet alice 50.0
  
  -- Alice proposes subscription
  proposalCid <- submit alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = "Service subscription"
      amountPerRound = 5.0
      lockedAmulet = lockedAmuletCid
  
  -- Alice cancels before Bob accepts (no DSO signature needed)
  returnedLockedAmuletCid <- submit alice do
    exerciseCmd proposalCid SubscriptionProposal_Cancel
  
  -- Verify proposal is archived
  proposal <- queryContractId alice proposalCid
  assertMsg "Proposal should be archived" (proposal == None)
  
  -- Verify we got back the locked amulet
  assertMsg "Should return locked amulet" (returnedLockedAmuletCid == lockedAmuletCid)
  
  pure ()

-- Test processing payments with ActivityMarkerRequest pattern
testProcessPayment : Script ()
testProcessPayment = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  -- Alice locks funds
  lockedAmuletCid <- createLockedAmulet alice 100.0
  
  -- Alice proposes with locked amulet
  proposalCid <- submit alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = "Service subscription"
      amountPerRound = 5.0
      lockedAmulet = lockedAmuletCid
  
  -- Bob accepts
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept
  
  -- Bob processes payment for round 1 (no DSO signature needed)
  result1 <- submit bob do
    exerciseCmd subscriptionCid Subscription_ProcessPayment with
      currentRound = 1
      subscriptionId = "sub-001"
  
  -- Verify round was processed and marker request created
  Some subscription <- queryContractId bob result1.subscriptionCid
  assertMsg "Last processed round should be 1" (subscription.lastProcessedRound == 1)
  
  -- Verify marker request was created
  Some markerRequest <- queryContractId dso result1.activityMarkerRequest
  assertMsg "Should have request for 1 round" (markerRequest.roundsProcessed == 1)
  assertMsg "Provider should match" (markerRequest.provider == provider)
  assertMsg "Recipient should match" (markerRequest.recipient == bob)
  
  -- DSO processes the request to create markers
  markers <- submit dso do
    exerciseCmd result1.activityMarkerRequest SubscriptionActivityMarkerRequest_Process
  
  assertMsg "Should have 1 pair of activity markers" (length markers == 1)
  
  -- Bob processes payment for rounds 2-5 (catch up)
  result2 <- submit bob do
    exerciseCmd result1.subscriptionCid Subscription_ProcessPayment with
      currentRound = 5
      subscriptionId = "sub-001"
  
  -- Verify rounds were processed
  Some subscription <- queryContractId bob result2.subscriptionCid
  assertMsg "Last processed round should be 5" (subscription.lastProcessedRound == 5)
  
  -- Verify new marker request
  Some markerRequest2 <- queryContractId dso result2.activityMarkerRequest
  assertMsg "Should have request for 4 rounds" (markerRequest2.roundsProcessed == 4)
  
  pure ()

-- Test cancellation by subscriber
testCancelBySubscriber : Script ()
testCancelBySubscriber = script do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  provider <- allocateParty "Provider"
  dso <- sharedDso
  
  -- Alice locks funds and proposes
  lockedAmuletCid <- createLockedAmulet alice 50.0
  
  proposalCid <- submit alice do
    createCmd SubscriptionProposal with
      subscriber = alice
      recipient = bob
      provider = provider
      dso = dso
      reason = "Service subscription"
      amountPerRound = 5.0
      lockedAmulet = lockedAmuletCid
  
  subscriptionCid <- submit bob do
    exerciseCmd proposalCid SubscriptionProposal_Accept
  
  -- Alice cancels (no DSO signature needed)
  returnedAmulet <- submit alice do
    exerciseCmd subscriptionCid Subscription_CancelBySubscriber
  
  -- Verify subscription was archived
  subscription <- queryContractId alice subscriptionCid
  assertMsg "Subscription should be archived" (subscription == None)
  
  -- Verify we got back the locked amulet
  assertMsg "Should return locked amulet" (returnedAmulet == Some lockedAmuletCid)
  
  pure ()

