module TestOwnershipProof where

import Daml.Script
import qualified DA.Date as DA
import DA.Date (Month(..))
import qualified DA.Time as DT

import Setup
import Fairmint.OpenCapTable.Types
import Fairmint.OpenCapTable.Issuer as Iss
import Fairmint.OpenCapTable.StockClass
import Fairmint.OpenCapTable.StockIssuance
import Fairmint.OpenCapTable.StockCancellation
import Fairmint.OpenCapTableProof.OwnershipProof

mkIssuer issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd Iss.Issuer with
      context = ctx
      issuer_data = Iss.OcfIssuerData with
        id = "ISSUER_OWNERSHIP"
        legal_name = "ProofTest Inc."
        formation_date = Some (DT.time (DA.date 2020 Jan 15) 12 0 0)
        country_of_formation = "US"
        dba = None
        country_subdivision_of_formation = None
        country_subdivision_name_of_formation = None
        tax_ids = []
        email = None
        phone = None
        address = None
        initial_shares_authorized = Some (Iss.OcfInitialSharesNumeric 1000000.0)
        comments = []

createStockClass issuer system_operator ctx =
  submitMulti [issuer, system_operator] [] do
    createCmd StockClass with
      context = ctx
      stock_class_data = OcfStockClassData with
        id = "SC_COMMON_OWN"
        name = "Common"
        class_type = OcfStockClassTypeCommon
        default_id_prefix = "CS-"
        initial_shares_authorized = 1_000_000.0
        votes_per_share = 1.0
        seniority = 1.0
        board_approval_date = None
        stockholder_approval_date = None
        par_value = None
        price_per_share = None
        liquidation_preference_multiple = None
        participation_cap_multiple = None
        conversion_rights = []
        comments = []

createIssuance issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateStockIssuance with
      issuance_data = OcfStockIssuanceData with
        id = "TX_STOCK_ISS_PROOF_1"
        date = DT.time (DA.date 2024 Jan 01) 0 0 0
        security_id = "SEC-PROOF-1"
        custom_id = "CERT-PROOF-1"
        stakeholder_id = "SH-PROOF"
        board_approval_date = None
        stockholder_approval_date = None
        consideration_text = None
        security_law_exemptions = []
        stock_class_id = "SC_COMMON_OWN"
        stock_plan_id = None
        share_numbers_issued = []
        share_price = OcfMonetary with amount = 1.0, currency = "USD"
        quantity = 100.0
        vesting_terms_id = None
        vestings = []
        cost_basis = None
        stock_legend_ids = ["L1"]
        issuance_type = None
        comments = []

createCancellation issuer issuerCid =
  submit issuer do
    exerciseCmd issuerCid Iss.CreateStockCancellation with
      cancellation_data = OcfStockCancellationTxData with
        id = "TX_STOCK_CANCEL_PROOF_1"
        date = DT.time (DA.date 2024 Jan 15) 0 0 0
        security_id = "SEC-PROOF-1"
        quantity = 40.0
        balance_security_id = None
        reason_text = "Forfeit"
        comments = []

testOwnershipProof_Verify_Succeeds = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createStockClass issuer system_operator ctx
  issCid <- createIssuance issuer issuerCid
  canCid <- createCancellation issuer issuerCid
  now <- getTime
  proofCid <- submit system_operator do
    createCmd OwnershipProof with
      context = ctx
      stakeholder_id = "SH-PROOF"
      expected_total = 60.0
      stock_issuances = [issCid]
      stock_cancellations = [canCid]
      created_at = now
      observers = [issuer]
  submit system_operator do
    exerciseCmd proofCid Verify
  pure ()

testOwnershipProof_Verify_FailsOnMismatch = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createStockClass issuer system_operator ctx
  issCid <- createIssuance issuer issuerCid
  canCid <- createCancellation issuer issuerCid
  now2 <- getTime
  proofCid <- submit system_operator do
    createCmd OwnershipProof with
      context = ctx
      stakeholder_id = "SH-PROOF"
      expected_total = 70.0
      stock_issuances = [issCid]
      stock_cancellations = [canCid]
      created_at = now2
      observers = [issuer]
  submitMustFail system_operator do
    exerciseCmd proofCid Verify
  pure ()

-- Exercise AddObservers to add a new observer and ensure it updates
testOwnershipProof_AddObservers = script do
  TestOcp{system_operator, issuer, ctx, alice} <- setupTestOcp
  issuerCid <- mkIssuer issuer system_operator ctx
  _ <- createStockClass issuer system_operator ctx
  issCid <- createIssuance issuer issuerCid
  canCid <- createCancellation issuer issuerCid
  now <- getTime
  proofCid <- submit system_operator do
    createCmd OwnershipProof with
      context = ctx
      stakeholder_id = "SH-PROOF"
      expected_total = 60.0
      stock_issuances = [issCid]
      stock_cancellations = [canCid]
      created_at = now
      observers = [issuer]
  -- Add a new observer and ensure a new contract is created
  newProofCid <- submit system_operator do
    exerciseCmd proofCid (AddObservers with added = [alice])
  -- Verify choice still works on the new proof
  submit system_operator do
    exerciseCmd newProofCid Verify
  -- Archive the new proof to cover Archive
  submit system_operator do
    exerciseCmd newProofCid Archive
  pure ()


