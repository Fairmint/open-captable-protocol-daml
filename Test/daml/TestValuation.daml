module TestValuation where

import Daml.Script
import Setup
import Fairmint.OpenCapTable.Issuer
import Fairmint.OpenCapTable.StockClass()
import Fairmint.OpenCapTable.Valuation()
import Fairmint.OpenCapTable.Types
import DA.Date
import DA.Time

happyCase = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = 1000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  valuationCid <- submit issuer $ exerciseCmd issuerCid CreateValuation with
    stock_class = stockClassCid
    valuation_data = OcfValuationData with
      provider = Some "Acme Advisory"
      board_approval_date = None
      stockholder_approval_date = None
      comments = None
      price_per_share = OcfMonetary with amount = 1.00, currency = "USD"
      effective_date = time (DA.Date.date 2025 Jan 1) 0 0 0
      valuation_type = OcfValuationType409A
  Some v <- queryContractId issuer valuationCid
  assert (validateOcfValuationData v.valuation_data)
  pure ()

invalidPrice = script do
  TestUsers{system_operator, issuer} <- setupUsers
  issuerCid <- createIssuer system_operator issuer
  stockClassCid <- submit issuer $ exerciseCmd issuerCid CreateStockClass with
    stock_class_data = OcfStockClassData with
      name = "Common"
      class_type = OcfStockClassTypeCommon
      default_id_prefix = "CS-"
      initial_shares_authorized = 1000.0
      votes_per_share = 1.0
      seniority = 0.0
      board_approval_date = None
      stockholder_approval_date = None
      par_value = None
      price_per_share = None
      liquidation_preference_multiple = None
      participation_cap_multiple = None
      conversion_rights = []
      comments = None
  submitMustFail issuer $ exerciseCmd issuerCid CreateValuation with
    stock_class = stockClassCid
    valuation_data = OcfValuationData with
      provider = None
      board_approval_date = None
      stockholder_approval_date = None
      comments = None
      price_per_share = OcfMonetary with amount = -1.00, currency = "USD" -- invalid
      effective_date = time (DA.Date.date 2025 Jan 1) 0 0 0
      valuation_type = OcfValuationType409A
  pure ()
