module TestValuation where
import Fairmint.OpenCapTable.Valuation
import Fairmint.OpenCapTable.Types
import Setup
import Daml.Script
import DA.Date
import DA.Time

testCreateValuation = script do
  TestUsers{system_operator, issuer, alice} <- setupUsers
  -- Create a FeaturedAppRight to satisfy Context.featured_app_right
  testRightCid <- submit system_operator do
    createCmd TestFeaturedAppRight with
      dso = system_operator
      provider = system_operator
      issuer = issuer
      alice = alice
      bob = system_operator
      charlie = system_operator
      rando = system_operator
  let ctx = Context with
        issuer = issuer
        system_operator = system_operator
        featured_app_right = toInterfaceContractId testRightCid
  _ <- submitMulti [issuer, system_operator] [] do
    createCmd Valuation with
      context = ctx
      valuation_data = OcfValuationData with
        ocf_id = "VAL_409A_2025"
        provider = Some "Acme Advisory"
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
        price_per_share = OcfMonetary with amount = 1.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"
  pure ()
