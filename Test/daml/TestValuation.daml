module TestValuation where
import Fairmint.OpenCapTable.Valuation
import Setup
import Daml.Script
import DA.Date
import DA.Time

testCreateValuation = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  _ <- submitMulti [issuer, system_operator] [] do
    createCmd Valuation with
      context = ctx
      valuation_data = OcfValuationData with
        id = "VAL_409A_2025"
        provider = Some "Acme Advisory"
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
        price_per_share = OcfMonetary with amount = 1.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2025 Jan 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"
  do
    cids <- query @Valuation issuer
    case cids of
      (cid, _) :: _ -> submit issuer do
        exerciseCmd cid Fairmint.OpenCapTable.Valuation.ArchiveByIssuer
      _ -> pure ()
  pure ()

testCreateValuationArchiveBuiltIn = script do
  TestOcp{system_operator, issuer, ctx} <- setupTestOcp
  _ <- submitMulti [issuer, system_operator] [] do
    createCmd Valuation with
      context = ctx
      valuation_data = OcfValuationData with
        id = "VAL_409A_2026"
        provider = Some "Acme Advisory 2"
        board_approval_date = None
        stockholder_approval_date = None
        comments = []
        price_per_share = OcfMonetary with amount = 2.00, currency = "USD"
        effective_date = DA.Time.time (DA.Date.date 2026 Jan 1) 0 0 0
        valuation_type = OcfValuationType409A
        stock_class_id = "SC_COMMON"
  do
    cids <- query @Valuation issuer
    case cids of
      (cid, _) :: _ -> submitMulti [issuer, system_operator] [] do
        exerciseCmd cid Archive
      _ -> pure ()
  pure ()
