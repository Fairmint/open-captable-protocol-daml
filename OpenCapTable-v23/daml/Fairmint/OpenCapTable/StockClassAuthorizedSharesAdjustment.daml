module Fairmint.OpenCapTable.StockClassAuthorizedSharesAdjustment where

import Fairmint.OpenCapTable.Types (Context, OcfNumeric)


-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/objects/transactions/adjustment/StockClassAuthorizedSharesAdjustment.schema.json
-- Object describing an event to change the number of authorized shares of a stock class
data OcfStockClassAuthorizedSharesAdjustmentData = OcfStockClassAuthorizedSharesAdjustmentData
  with
    id: Text
    -- From primitives Transaction
    date: Time
    -- From StockClassTransaction
    stock_class_id: Text
    -- Specific fields
    new_shares_authorized: OcfNumeric
    board_approval_date: Optional Time
    stockholder_approval_date: Optional Time
    comments: [Text]
  deriving (Eq, Show)

validateOcfStockClassAuthorizedSharesAdjustmentDataTx : OcfStockClassAuthorizedSharesAdjustmentData -> Bool
validateOcfStockClassAuthorizedSharesAdjustmentDataTx d =
  d.id /= "" &&
  d.stock_class_id /= "" &&
  d.new_shares_authorized >= (0.0)

template StockClassAuthorizedSharesAdjustment
  with
    context: Context
    adjustment_data: OcfStockClassAuthorizedSharesAdjustmentData
  where
    signatory context.issuer, context.system_operator

    ensure
      validateOcfStockClassAuthorizedSharesAdjustmentDataTx adjustment_data

    -- Allow issuer to archive without system_operator involvement
    choice ArchiveByIssuer : ()
      controller context.issuer
      do
        pure ()


