module Fairmint.OpenCapTable.IssuerAuthorizedSharesAdjustment where

import Fairmint.OpenCapTable.Types (Context, OcfNumeric)


-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/objects/transactions/adjustment/IssuerAuthorizedSharesAdjustment.schema.json
-- Object describing an event to change the number of authorized shares at the issuer level
data OcfIssuerAuthorizedSharesAdjustmentData = OcfIssuerAuthorizedSharesAdjustmentData
  with
    ocf_id: Text
    -- From primitives Transaction
    date: Time
    -- From IssuerTransaction
    issuer_id: Text
    -- Specific fields
    new_shares_authorized: OcfNumeric
    board_approval_date: Optional Time
    stockholder_approval_date: Optional Time
    comments: [Text]
  deriving (Eq, Show)

validateOcfIssuerAuthorizedSharesAdjustmentDataTx : OcfIssuerAuthorizedSharesAdjustmentData -> Bool
validateOcfIssuerAuthorizedSharesAdjustmentDataTx d =
  d.ocf_id /= "" &&
  d.issuer_id /= "" &&
  d.new_shares_authorized >= (0.0)

template IssuerAuthorizedSharesAdjustment
  with
    context: Context
    adjustment_data: OcfIssuerAuthorizedSharesAdjustmentData
  where
    signatory context.issuer, context.system_operator

    ensure
      validateOcfIssuerAuthorizedSharesAdjustmentDataTx adjustment_data

    -- Allow issuer to archive without system_operator involvement
    choice ArchiveByIssuer : ()
      controller context.issuer
      do
        pure ()


