module Fairmint.OpenCapTable.OCF.StockClassConversionRatioAdjustment where

import Fairmint.OpenCapTable.Types.Core (Context)
import Fairmint.OpenCapTable.Types.Validation (validateNonEmptyStringsArray)
import Fairmint.OpenCapTable.Types.Conversion (OcfRatioConversionMechanism, validateOcfRatioConversionMechanism)


template StockClassConversionRatioAdjustment
  with
    context: Context
    adjustment_data: StockClassConversionRatioAdjustmentOcfData
  where
    signatory context.issuer, context.system_operator

    ensure
      validateStockClassConversionRatioAdjustmentOcfData adjustment_data



-- Object - Stock Class Conversion Ratio Adjustment Transaction
-- Object describing a conversion ratio adjustment due to anti-dilution repricing
-- OCF: https://raw.githubusercontent.com/Open-Cap-Table-Coalition/Open-Cap-Format-OCF/main/schema/objects/transactions/adjustment/StockClassConversionRatioAdjustment.schema.json
data StockClassConversionRatioAdjustmentOcfData = StockClassConversionRatioAdjustmentOcfData
  with
    -- Identifier for the object
    id: Text

    -- Required fields (alphabetical)
    ---------------------------------

    -- Date on which the transaction occurred
    date: Time
    -- New conversion ratio mechanism after adjustment
    new_ratio_conversion_mechanism: OcfRatioConversionMechanism
    -- Identifier for the stock class being adjusted
    stock_class_id: Text

    -- Arrays (alphabetical)
    ---------------------------------

    -- Unstructured text comments related to and stored for the object
    comments: [Text]
  deriving (Eq, Show)

validateStockClassConversionRatioAdjustmentOcfData : StockClassConversionRatioAdjustmentOcfData -> Bool
validateStockClassConversionRatioAdjustmentOcfData d =
  d.id /= "" &&
  d.stock_class_id /= "" &&
  validateOcfRatioConversionMechanism d.new_ratio_conversion_mechanism &&
  validateNonEmptyStringsArray d.comments
