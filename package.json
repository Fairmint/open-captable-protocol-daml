{
  "name": "@fairmint/open-captable-protocol-daml-js",
  "version": "0.0.2",
  "description": "Open CapTable Protocol DAML smart contracts with generated JavaScript bindings",
  "main": "generated/js/OpenCapTable-v01-0.0.1/lib/index.js",
  "types": "generated/js/OpenCapTable-v01-0.0.1/lib/index.d.ts",
  "files": [
    "generated/js/OpenCapTable-v01-0.0.1/lib/**/*",
    "generated/js/OpenCapTable-v01-0.0.1/package.json",
    "generated/js/OpenCapTable-v01-0.0.1/tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "daml build --all",
    "clean": "daml clean --all",
    "codegen": "cd OpenCapTable-v01 && daml codegen js",
    "test": "cd Test && daml test",
    "upload-dar": "ts-node scripts/upload-dar.ts",
    "publish": "yarn codegen && npm publish",
    "publish:manifest": "yarn codegen && npm pack --dry-run --json --ignore-scripts > /tmp/npm-pack.json 2>/dev/null && jq -r '.[0].files[].path' /tmp/npm-pack.json | sort | tsx scripts/collapse-manifest.ts > generated/npm-manifest.txt"
  },
  "dependencies": {
    "@fairmint/canton-node-sdk": "^0.0.63"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@daml/ledger": "3.3.0-snapshot.20250528.13806.0.v3cd439fb",
    "@daml/types": "3.3.0-snapshot.20250528.13806.0.v3cd439fb"
  },
  "keywords": [
    "daml",
    "opencaptable",
    "blockchain",
    "smart-contracts",
    "fairmint"
  ],
  "author": "Fairmint",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fairmint/open-captable-protocol-daml.git"
  }
}
