-- StakeholderRelationshipType
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/enums/StakeholderRelationshipType.schema.json
data OcfStakeholderRelationshipType =
  OcfRelEmployee | OcfRelAdvisor | OcfRelInvestor | OcfRelFounder | OcfRelBoardMember | OcfRelOfficer | OcfRelOther
  deriving (Eq, Show)

-- StakeholderType already defined earlier

-- ObjectReference validator moved to Document module

-- Percentage type (0..1 inclusive)
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/Percentage.schema.json
type OcfPercentage = Decimal

validateOcfPercentage : OcfPercentage -> Bool
validateOcfPercentage p = p >= (0.0) && p <= 1.0

-- Numeric type (fixed-point string in schema; represented as Decimal here)
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/Numeric.schema.json
type OcfNumeric = Decimal

-- SecurityExemption type
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/SecurityExemption.schema.json
data OcfSecurityExemption = OcfSecurityExemption
  with
    description: Text
    jurisdiction: Text
  deriving (Eq, Show)

validateOcfSecurityExemption : OcfSecurityExemption -> Bool
validateOcfSecurityExemption e = e.description /= "" && e.jurisdiction /= ""

-- ShareNumberRange type
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/ShareNumberRange.schema.json
data OcfShareNumberRange = OcfShareNumberRange
  with
    starting_share_number: OcfNumeric
    ending_share_number: OcfNumeric
  deriving (Eq, Show)

validateOcfShareNumberRange : OcfShareNumberRange -> Bool
validateOcfShareNumberRange r = r.starting_share_number > (0.0) && r.ending_share_number >= r.starting_share_number

-- StockParent type
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/StockParent.schema.json
data OcfStockParent = OcfStockParent
  with
    parent_object_type: OcfParentSecurityType
    parent_object_id: Text
  deriving (Eq, Show)

validateOcfStockParent : OcfStockParent -> Bool
validateOcfStockParent p = p.parent_object_id /= ""

-- CapitalizationDefinition type
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/CapitalizationDefinition.schema.json
data OcfCapitalizationDefinition = OcfCapitalizationDefinition
  with
    include_stock_class_ids: [Text]
    include_stock_plans_ids: [Text]
    include_security_ids: [Text]
    exclude_security_ids: [Text]
  deriving (Eq, Show)

validateOcfCapitalizationDefinition : OcfCapitalizationDefinition -> Bool
validateOcfCapitalizationDefinition _ = True

-- CapitalizationDefinitionRules type
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/CapitalizationDefinitionRules.schema.json
data OcfCapitalizationDefinitionRules = OcfCapitalizationDefinitionRules
  with
    include_outstanding_shares: Bool
    include_outstanding_options: Bool
    include_outstanding_unissued_options: Bool
    include_this_security: Bool
    include_other_converting_securities: Bool
    include_option_pool_topup_for_promised_options: Bool
    include_additional_option_pool_topup: Bool
    include_new_money: Bool
  deriving (Eq, Show)

validateOcfCapitalizationDefinitionRules : OcfCapitalizationDefinitionRules -> Bool
validateOcfCapitalizationDefinitionRules _ = True

-- MD5 type
-- OCF: https://schema.opencaptablecoalition.com/v/1.2.0/types/Md5.schema.json
type OcfMd5 = Text

validateOcfMd5 : OcfMd5 -> Bool
validateOcfMd5 md5 =
  let n = Text.length md5 in
  -- Check for correct length and valid hex characters using Text.all
  n == 32 && Text.all (\c -> (c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) md5
